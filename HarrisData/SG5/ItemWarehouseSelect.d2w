%FUNCTION(dtw_sql) ItemWarehouse_Select_Current_Status (IN  CHAR(64)    profileHandle,
				                             CHAR(2)     dataBaseID,
                                                            CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="currentstatus"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"
      %if (PDBRelease == "Y")
          @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMQUAL", V_IMQUAL)
      %endif
      %if ((PDBRelease == "Y" && V_IMQUAL != "Y") || PDBRelease != "Y")
          @dtw_assign(includeOnHandRecv, "Y")
      %else
          @dtw_assign(includeOnHandRecv, "")
      %endif

      %ROW{
          @Get_Qty_Avail(profileHandle, dataBaseID, itemNumber, warehouseNumber, qtyAvailable)
          @Format_Nbr(qtyAvailable, F_qtyAvailable, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_IWOHQT, F_IWOHQT, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_IWQTRS, F_IWQTRS, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_IWOHRC, F_IWOHRC, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_IWDSQO, F_IWDSQO, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_IWRESQ, F_IWRESQ, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_IWQOPK, F_IWQOPK, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_IWQHSR, F_IWQHSR, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_IWQTYB, F_IWQTYB, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_IWQOO, F_IWQOO, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_IWQTRS, F_IWQTRS, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_IWQLIT, F_IWQLIT, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_IWQUNS, F_IWQUNS, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_IWQSYT, F_IWQSYT, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_IWQRYT, F_IWQRYT, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
          @Format_Date(V_IWLRDT, "D", F_IWLRDT)
          @Format_Date(V_IWENDT, "D", F_IWENDT)
          @Format_Date(V_IWLIDT, "D", F_IWLIDT)
          @Format_Date(V_IWDLCY, "D", F_IWDLCY)
          @Format_Date(V_IWLPDT, "D", F_IWLPDT)
          @Format_Date(V_IWLPCH, "D", F_IWLPCH)
          @Format_Date(V_IWDTLS, "D", F_IWDTLS)
          @Format_Date(V_IWLUDT, "D", F_IWLUDT)

          <table $(contentTable)>
              <tr valign=top>
                  <td>
                      <fieldset class="legendBody">
                          <legend class="legendTitle">Quantities</legend>
                          <table $(contentTable)>
                              <tr valign="top">
                                  <td>
                                      <table $(contentTable)>
                                          <tr>
                                              <td class="dsphdr">On Hand</td>
                                              <td class="dspcode">&nbsp;</td>
                                              <td class="dspqty">$(F_IWOHQT)</td>
                                          </tr>
                                          %if (includeOnHandRecv == "Y")
                                              <tr>
                                                  <td class="dsphdr">On Hand Receiving</td>
                                                  <td class="dspcode">+</td>
                                                  <td class="dspqty">$(F_IWOHRC)</td>
                                              </tr>
                                          %endif
                                          %if (V_CIOOIA == "Y")
                                              <tr>
                                                  <td class="dsphdr">On Order</td>
                                                  <td class="dspcode">+</td>
                                                  <td class="dspqty">$(F_IWQOO)</td>
                                              </tr>
                                              <tr>
                                                  <td class="dsphdr">Drop Shipped</td>
                                                  <td class="dspcode">+</td>
                                                  <td class="dspqty">$(F_IWDSQO)</td>
                                              </tr>
                                          %endif
                                          <tr>
                                              <td class="dsphdr">Held In Stock</td>
                                              <td class="dspcode">-</td>
                                              <td class="dspqty">$(F_IWQHSR)</td>
                                          </tr>
                                          <tr>
                                              <td class="dsphdr">Reserved</td>
                                              <td class="dspcode">-</td>
                                              <td class="dspqty">$(F_IWRESQ)</td>
                                          </tr>
                                          <tr>
                                              <td class="dsphdr">Available</td>
                                              <td class="dspcode">&nbsp;</td>
                                              <td class="dsptotal">$(F_qtyAvailable)</td>
                                          </tr>
                                      </table>
                                  </td>
                                  <td>&nbsp;</td>
                                  <td>
                                      <table $(contentTable)>
                                          <tr>
                                              <td class="dsphdr">In Transit</td>
                                              <td class="dspqty">$(F_IWQTRS)</td>
                                          </tr>

                                          %if (includeOnHandRecv != "Y")
                                              <tr>
                                                  <td class="dsphdr">On Hand Receiving</td>
                                                  <td class="dspqty">$(F_IWOHRC)</td>
                                              </tr>
                                          %endif

                                          %if (V_CIOOIA != "Y")
                                              <tr>
                                                  <td class="dsphdr">On Order</td>
                                                  <td class="dspqty">$(F_IWQOO)</td>
                                              </tr>
                                              <tr>
                                                  <td class="dsphdr">Drop Shipped</td>
                                                  <td class="dspqty">$(F_IWDSQO)</td>
                                              </tr>
                                          %endif

                                          <tr>
                                              <td class="dsphdr">On Backorder</td>
                                              <td class="dspqty">$(F_IWQTYB)</td>
                                          </tr>

                                          <tr>
                                              <td class="dsphdr">On Pick Tickets</td>
                                              <td class="dspqty">$(F_IWQOPK)</td>
                                          </tr>

                                          <tr>
                                              <td class="dsphdr">On Order Unscheduled</td>
                                              <td class="dspqty">$(F_IWQUNS)</td>
                                          </tr>
                                          <tr>
                                              <td class="dsphdr">Last Physical</td>
                                              <td class="dspqty">$(F_IWQLIT)</td>
                                          </tr>
                                          <tr>
                                              <td class="dsphdr">YTD Billed</td>
                                              <td class="dspqty">$(F_IWQSYT)</td>
                                          </tr>
                                          <tr>
                                              <td class="dsphdr">YTD Received</td>
                                              <td class="dspqty">$(F_IWQRYT)</td>
                                          </tr>
                                      </table>
                                  </td>
                              </tr>
                          </table>
                      </fieldset>
                  </td>
                  <td>
                      <fieldset class="legendBody">
                          <legend class="legendTitle">Dates</legend>
                          <table $(contentTable)>
                              <tr>
                                  <td class="dsphdr">Last Received</td>
                                  <td class="dspnmbr">$(F_IWLRDT)</td>
                              </tr>
                              <tr>
                                  <td class="dsphdr">Last Physical</td>
                                  <td class="dspnmbr">$(F_IWLIDT)</td>
                              </tr>
                              <tr>
                                  <td class="dsphdr">Last Purchased</td>
                                  <td class="dspnmbr">$(F_IWLPDT)</td>
                              </tr>
                              <tr>
                                  <td class="dsphdr"> Last Sold</td>
                                  <td class="dspnmbr">$(F_IWDTLS)</td>
                              </tr>
                              <tr>
                                  <td class="dsphdr">Last Cycle Count</td>
                                  <td class="dspnmbr">$(F_IWDLCY)</td>
                              </tr>
                              <tr>
                                  <td class="dsphdr">Last Price Change</td>
                                  <td class="dspnmbr">$(F_IWLPCH)</td>
                              </tr>
                              <tr>
                                  <td class="dsphdr">Last Maintained</td>
                                  <td class="dspnmbr">$(F_IWLUDT)</td>
                              </tr>
                              <tr>
                                  <td class="dsphdr">Date Established</td>
                                  <td class="dspnmbr">$(F_IWENDT)</td>
                              </tr>
                          </table>
                      </fieldset>
                  </td>
              </tr>
          </table>
      %}
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) ItemWarehouse_Select_Inventory (IN  CHAR(64)    profileHandle,
                                                       CHAR(2)     dataBaseID,
                                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="inventory"></a>
      @dtw_assign(moreURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=429&amp;fKey1=ISITEM&amp;fVal1=@dtw_rurlescseq(itemNumber)&amp;fKey2=ISWHS&amp;fVal2=@dtw_rurlescseq(warehouseNumber)&amp;tag=QSEARCH")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @OrderBy_Sort("ISSTKR", sortVar)
                  @dtw_assign(columnHdr, "Stock Location")
                  %if (sortVar == "sort")
                     <th class="colhdr$(sortVar)" colspan="3" $(helpCursor)><span title="$(orderByDisplay)">$(columnHdr)</span></th>
                  %else
                     <th class="colhdr" colspan="3">$(columnHdr)</th>
                  %endif

                  @Format_Column_Header("ISRATE", "Priority")

                  %if (lotControlled=="Y")
                      @Format_Column_Header("ISLOT", "Lot Number")
                  %endif

                  @Format_Column_Header("ISDTRC", "Date<br>Received")
                  @Format_Column_Header("ISQOH", "Quantity<br>On Hand")
                  @Format_Column_Header("ISQRES", "Quantity<br>Reserved")
                  @Format_Column_Header("ISQHSR", "Quantity<br>Held<br>In Stock")
                  @Format_Column_Header("ISAVQT", "Quantity<br>Available")
              </tr>

          %endif

          @dtw_assign(T_ISQOH, "0")
          @dtw_assign(T_ISQRES, "0")
          @dtw_assign(T_ISQHSR, "0")
          @dtw_assign(T_ISAVQT, "0")

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Date(V_ISDTRC, "D", F_ISDTRC)
              @Format_Nbr(V_ISQOH, F_ISQOH, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(V_ISQRES, F_ISQRES, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(V_ISQHSR, F_ISQHSR, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr($(V_ISAVQT), F_ISAVQT, $(qtyNbrDec), $(qtyEditCode), "", "", "")

              @dtw_add(T_ISQOH, V_ISQOH, "15", T_ISQOH)
              @dtw_add(T_ISQRES, V_ISQRES, "15", T_ISQRES)
              @dtw_add(T_ISQHSR, V_ISQHSR, "15", T_ISQHSR)
              @dtw_add(T_ISAVQT, V_ISAVQT, "15", T_ISAVQT)
              <tr class="$(rowClass)">
                  <td class="colalph">$(V_ISSTKR)</td>
                  <td class="colalph">$(V_ISAILE)</td>
                  <td class="colalph">$(V_ISSLOC)</td>
                  <td class="colnmbr">$(V_ISRATE)</td>
                  %if (lotControlled=="Y")
                      @dtw_assign(lotCnt, "0")
                      %if (V_ISLOT != "")
                          @RtvFldDesc("LTITEM='$(itemNumber)' and LTWH=$(warehouseNumber) and LTLT#='$(V_ISLOT)'", "HDLOT", "char(count(*))", lotCnt)
                      %endif
                      <td class="colnmbr">
                          %if (lotCnt > "0")
                              <a onClick="saveCurrentURL();" href="$(homeURL)$(cGIPath)LotSelect.d2w/REPORT$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;warehouseNumber=@dtw_rurlescseq(warehouseNumber)&amp;lotNumber=@dtw_rurlescseq(V_ISLOT)" title="View Lot">$(V_ISLOT)</a>
                          %else
                              $(V_ISLOT)
                          %endif
                      </td>
                  %endif
                  <td class="colnmbr">$(F_ISDTRC)</td>
                  <td class="colnmbr">$(F_ISQOH)</td>
                  <td class="colnmbr">$(F_ISQRES)</td>
                  <td class="colnmbr">$(F_ISQHSR)</td>
                  <td class="colnmbr">$(F_ISAVQT)</td>
              </tr>
	   %}
          %if (sql_Record_Count>"1")
              %INCLUDE "SetRowClass.icl"
              @Format_Nbr(T_ISQOH, F_ISQOH, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr(T_ISQRES, F_ISQRES, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr(T_ISQHSR, F_ISQHSR, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr(T_ISAVQT, F_ISAVQT, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              <tr>
                  %if (lotControlled=="Y")
                      @dtw_assign(columnSpan, "6")
                  %else
                      @dtw_assign(columnSpan, "5")
                  %endif
                  <td class="colnmbr" colspan="$(columnSpan)">Total:</td>
                  <td class="coltotal">$(F_ISQOH)</td>
                  <td class="coltotal">$(F_ISQRES)</td>
                  <td class="coltotal">$(F_ISQHSR)</td>
                  <td class="coltotal">$(F_ISAVQT)</td>
              </tr>
          %endif
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) ItemWarehouse_Select_Transaction_History (IN  CHAR(64)    profileHandle,
                                                                 CHAR(2)     dataBaseID,
                                                                 CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="inventory"></a>
      @dtw_assign(moreURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=180&amp;fKey1=DTITEM&amp;fVal1=@dtw_rurlescseq(itemNumber)&amp;fKey2=DTWHS&amp;fVal2=@dtw_rurlescseq(warehouseNumber)&amp;tag=QSEARCH")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("DTTRDT", "Trans<br>Date")
                  @Format_Column_Header("DTIVTT", "Trans<br>Type")
                  @Format_Column_Header("DTEXPA", "Extended<br>Price")
                  @Format_Column_Header("DTEXCA", "Extended<br>Cost")
                  @Format_Column_Header("DTQTY",  "Trans<br>Quantity")
                  @Format_Column_Header("DTDOC#", "Document<br>Number")
                  @Format_Column_Header("DTMORD", "Mfg<br>Order")
              </tr>

          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Date(V_DTTRDT, "D", F_DTTRDT)
              @RtvFldDesc("TTTYPE='$(V_DTIVTT)'", "HDTTYP", "TTDESC", transTypeDesc)
              @Format_Nbr(V_DTQTY, F_DTQTY, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(V_DTEXPA, F_DTEXPA, $(prcNbrDec), $(prcEditCode), "Y", "", "")
              @Format_Nbr(V_DTEXCA, F_DTEXCA, $(cstNbrDec), $(cstEditCode), "Y", "", "")
              @RtvFldDesc("OHPLT=$(V_DTPLT) and OHORD='$(V_DTMORD)'", "HDMOHM", "char(count(*))", mfgOrderCnt)
              
              <tr class="$(rowClass)">
                  <td class="coldate">$(F_DTTRDT)</td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)TransactionHistoryInquiry.d2w/DISPLAY$(genericVarBase)&amp;viewOption=E&amp;itemNumber=@dtw_rurlescseq(V_DTITEM)&amp;itemDescription=@dtw_rurlescseq(V_IMIMDS)&amp;origTransSequence=@dtw_rurlescseq(V_DTOSEQ)&amp;transSequence=@dtw_rurlescseq(V_DTDSEQ)" onclick="$(inquiryWinVar)" title="Transaction Quickview - ($(V_DTIVTT)) $(transTypeDesc)">$(V_DTIVTT)</a></td>
                  <td class="colnmbr">$(F_DTEXPA)</td>
                  <td class="colnmbr">$(F_DTEXCA)</td>
                  %if (V_HDPDRL > "0")
                      @dtw_assign(whsPlant, "&amp;plantNumber=@dtw_rurlescseq(V_DTPLT)")
                  %else
                      @dtw_assign(whsPlant, "&amp;warehouseNumber=@dtw_rurlescseq(V_DTWHS)")
                  %endif  
                  <td class="colnmbr"><a href="$(homeURL)$(cGIPath)ItemTransactionHistory.d2w/Edit_Plant$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(V_DTITEM)&amp;itemDescription=@dtw_rurlescseq(V_IMIMDS)$(whsPlant)" title="Item Transaction History - $(F_DTQTY)">$(F_DTQTY)</a></td>
                  <td class="colnmbr">
	                  %if (V_DTDOC# > "0" && V_H_TBL == "OEORHH" && V_H_SEQ > "0")
	                      <a onClick="saveCurrentURL();" href="$(homeURL)$(cGIPath)SelectOrderHistory.d2w/REPORT$(d2wVarBase)&amp;orderNumber=@dtw_rurlescseq(V_DTDOC#)&amp;orderSequence=@dtw_rurlescseq(V_H_SEQ)&amp;customerNumber@dtw_rurlescseq(V_DTSTCS)" title="View Order History - $(V_DTDOC#)">$(V_DTDOC#)</a>
	                  %elif (V_DTDOC# > "0" && V_H_TBL == "POPOMS" && V_H_SEQ > "0")
	                      <a href="$(homeURL)$(phpPath)SelectPO.php$(altVarBase)&amp;vendorNumber=@dtw_rurlescseq(V_DTVEND)&amp;purchaseOrderNumber=@dtw_rurlescseq(V_DTDOC#)" title="View Purchase Order - $(V_DTDOC#)">$(V_DTDOC#)</a>
	                  %elif (V_DTDOC# > "0" && V_H_TBL == "POPOHH" && V_H_SEQ > "0" && V_DTIVTT != "RS")
	                      <a href="$(homeURL)$(phpPath)SelectPO.php$(altVarBase)&amp;vendorNumber=@dtw_rurlescseq(V_DTVEND)&amp;purchaseOrderNumber=@dtw_rurlescseq(V_DTDOC#)&amp;orderSequence=@dtw_rurlescseq(V_H_SEQ)" title="View Purchase Order History - $(V_DTDOC#)">$(V_DTDOC#)</a>
	                  %else
	                      $(V_DTDOC#)
	                  %endif
                  </td>  
                  <td class="colalph">
                      %if ($(mfgOrderCnt) > "0")
                          <a href="$(homeURL)$(cGIPath)SelectMfgOrder.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq($(V_DTPLT))&amp;mfgOrder=@dtw_rurlescseq($(V_DTMORD))" onclick="$(inquiryWinVar)" title="View Mfg Order - $(V_DTMORD)">$(V_DTMORD)</a>
                      %else
                          $(V_DTMORD)
                      %endif
                  </td>
              </tr>
	   %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) ItemWarehouse_Select_Open_Orders (IN  CHAR(64)    profileHandle,
				                          CHAR(2)     dataBaseID,
                                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="vendoropenorders"></a>
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>

          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("POVEND", "Vendor")
                  @Format_Column_Header("xxx", "Vendor Name")
                  @Format_Column_Header("PDVDSN", "Vendor Item")
                  @Format_Column_Header("POBUYR", "Buyer")
                  @Format_Column_Header("POTYPE", "Order<br>Type")
                  @Format_Column_Header("PDPO", "Purchase<br>Order")
                  @Format_Column_Header("PDPOL#", "Line")
                  @Format_Column_Header("PDPORL", "Rel")
                  @Format_Column_Header("PDRORD", "Reference")
                  @Format_Column_Header("PDRQDT", "Required<br>Date")
                  @Format_Column_Header("xxx", "Quantity<br>Ordered")
                  @Format_Column_Header("PDQHRT", "Quantity<br>Held In Receiving")
                  @Format_Column_Header("xxx", "Quantity<br>Received To Date")
                  @Format_Column_Header("PDDSCC", "Cost")
                  @Format_Column_Header("xxx", "Extended<br>Cost")
              </tr>
          %endif
   			
          %ROW{
              %INCLUDE "SetRowClass.icl"
              @RtvFldDesc("VMVEND=$(V_POVEND)", "HDVEND", "VMVNA1", vendorName)
              %if (V_PDPORL == "0")
                  @Format_Nbr("@dtw_rdivide(@dtw_rmultiply(V_PDQTOR, V_PDDSCC), V_PDPCPB)", extendedPrice, "2", $(amtEditCode), "Y", "", "")
                  @Format_Nbr(V_PDDSCC, F_PDDSCC, $(prcNbrDec), $(amtEditCode), "", "", "")
              %endif
              @Format_Nbr("@dtw_rdivide(V_PDQTOR, V_PDPCPB)", qtyOrdered, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(V_PDQHRT, F_PDQHRT, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr("@dtw_rdivide(@dtw_radd(V_PDQRST, @dtw_radd(V_PDQRRT, V_PDQRFT)), V_PDPCPB)", qtyRecv, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(V_PDDSCC, F_PDDSCC, $(prcNbrDec), $(amtEditCode), "", "", "")
              @Format_Date(V_PDRQDT, "D", F_PDRQDT)
              @RtvFldDesc("OTAPID='PO' and OTOTCD='$(V_POTYPE)'", "HDOTYP", "OTDESC", orderTypeDesc)

              <tr class="$(rowClass)">
                  <td class="colnmbr"><a href="$(homeURL)$(phpPath)VendorDashboard.php$(altVarBase)&amp;vendorNumber=$(V_POVEND)&amp;fromItem=@dtw_rurlescseq($(itemNumber))" title="View Vendor Dashboard">$(V_POVEND)</a></td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)VendorSelect.d2w/REPORT$(genericVarBase)&amp;vendorNumber=@dtw_rurlescseq(V_POVEND)&amp;vendorName=@dtw_rurlescseq(vendorName)" title="View Vendor">$(vendorName)</a></td>
                  <td class="colalph">$(V_PDVDSN)</td>
                  <td class="colalph"><a href="$(homeURL)$(phpPath)BuyerSelect.php$(altVarBase)&amp;buyer=@dtw_rurlescseq(V_POBUYR)" title="View Buyer">$(V_BMBNA1)</a></td>
                  <td class="colcode" $(helpCursor)><span title="$(orderTypeDesc)">$(V_POTYPE)</span></td>
                  <td class="colnmbr"><a href="$(homeURL)$(phpPath)SelectPO.php$(altVarBase)&amp;vendorNumber=@dtw_rurlescseq(V_POVEND)&amp;vendorName=@dtw_rurlescseq(vendorName)&amp;purchaseOrderNumber=@dtw_rurlescseq(V_PDPO)" title="View Purchase Order">$(V_PDPO)</a></td>
                  <td class="colnmbr">$(V_PDPOL#)</td>
                  <td class="colnmbr">$(V_PDPORL)</td>
                  <td class="colalph">$(V_PDRORD)</td>
                  <td class="coldate">$(F_PDRQDT)</td>
                  <td class="colnmbr">$(qtyOrdered)</td>
                  <td class="colcode">$(F_PDQHRT)</td>
                  <td class="colnmbr">$(qtyRecv)</td>
                  %if (V_PDPORL == "0")
                      <td class="colnmbr">$(F_PDDSCC)</td>
                      <td class="colnmbr">$(extendedPrice)</td>
                  %else
                      <td class="colcode">&nbsp;</td>
                      <td class="colcode">&nbsp;</td>
                  %endif
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) ItemWarehouse_Select_Order_History (IN  CHAR(64)    profileHandle,
				                            CHAR(2)     dataBaseID,
                                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="vendororderhistory"></a>
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>

          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("PHVEND", "Vendor")
                  @Format_Column_Header("xxx", "Vendor Name")
                  @Format_Column_Header("PIVDSN", "Vendor Item")
                  @Format_Column_Header("PHBUYR", "Buyer")
                  @Format_Column_Header("PHTYPE", "Order<br>Type")
                  @Format_Column_Header("PIPO", "Purchase<br>Order")
                  @Format_Column_Header("PHSEQ#", "Seq")
                  @Format_Column_Header("PIPOL#", "Line")
                  @Format_Column_Header("PIPORL", "Rel")
                  @Format_Column_Header("PIPORF", "Reference")
                  @Format_Column_Header("PHLRDT", "Date Last<br>Received")
                  @Format_Column_Header("xxx", "Quantity<br>Ordered")
                  @Format_Column_Header("PIBUOM", "U/M")
                  @Format_Column_Header("xxx", "Quantity<br>Received<br>To Date")
                  @Format_Column_Header("PIDSCC", "Cost")
                  @Format_Column_Header("xxx", "Extended<br>Cost")
              </tr>
          %endif
   			
          %ROW{
              %INCLUDE "SetRowClass.icl"
              @RtvFldDesc("VMVEND=$(V_PHVEND)", "HDVEND", "VMVNA1", vendorName)
              @RtvFldDesc("OTAPID='PO' and OTOTCD='$(V_PHTYPE)'", "HDOTYP", "OTDESC", orderTypeDesc)
              @RtvFldDesc("UMUOM='$(V_PIBUOM)'", "HDUOM", "UMUMLD", uomDesc)
              @Format_Nbr("@dtw_rdivide(@dtw_rmultiply(V_PITRQT, V_PIDSCC), V_PIPCPB)", extendedPrice, "2", $(amtEditCode), "Y", "", "")
              @Format_Nbr(V_PIDSCC, F_PIDSCC, $(prcNbrDec), $(amtEditCode), "", "", "")
              @Format_Nbr("@dtw_rdivide(V_PIQTOR, V_PIPCPB)", qtyOrdered, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr("@dtw_rdivide(V_PITRQT, V_PIPCPB)", qtyRecv, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Date(V_PHLRDT, "D", F_PHLRDT)

              <tr class="$(rowClass)">
                  <td class="colnmbr"><a href="$(homeURL)$(phpPath)VendorDashboard.php$(altVarBase)&amp;vendorNumber=$(V_PHVEND)&amp;fromItem=@dtw_rurlescseq($(itemNumber))" title="View Vendor Dashboard">$(V_PHVEND)</a></td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)VendorSelect.d2w/REPORT$(genericVarBase)&amp;vendorNumber=@dtw_rurlescseq(V_PHVEND)&amp;vendorName=@dtw_rurlescseq(vendorName)" title="View Vendor">$(vendorName)</a></td>
                  <td class="colalph">$(V_PIVDSN)</td>
                  <td class="colalph"><a href="$(homeURL)$(phpPath)BuyerSelect.php$(altVarBase)&amp;buyer=@dtw_rurlescseq(V_PHBUYR)" title="View Buyer">$(V_BMBNA1)</a></td>
                  <td class="colcode" $(helpCursor)><span title="$(orderTypeDesc)">$(V_PHTYPE)</span></td>
                  <td class="colnmbr"><a href="$(homeURL)$(phpPath)SelectPO.php$(altVarBase)&amp;tabID=RECEIPTS&amp;vendorNumber=@dtw_rurlescseq(V_PHVEND)&amp;vendorName=@dtw_rurlescseq(vendorName)&amp;purchaseOrderNumber=@dtw_rurlescseq(V_PIPO)&amp;orderSequence=@dtw_rurlescseq(V_PHSEQ#)" title="View Purchase Order">$(V_PIPO)</a></td>
                  <td class="colnmbr">$(V_PHSEQ#)</td>
                  <td class="colnmbr">$(V_PIPOL#)</td>
                  <td class="colnmbr">$(V_PIPORL)</td>
                  <td class="colalph">$(V_PHPORF)</td>
                  <td class="coldate">$(F_PHLRDT)</td>
                  <td class="colnmbr">$(qtyOrdered)</td>
                  <td class="colcode" $(helpCursor)><span title="$(uomDesc)">$(V_PIBUOM)</span></td>
                  <td class="colnmbr">$(qtyRecv)</td>
                  <td class="colnmbr">$(F_PIDSCC)</td>
                  <td class="colnmbr">$(extendedPrice)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) ItemWarehouse_Select_Customer_Open_Orders (IN CHAR(64)    profileHandle,
				                                  CHAR(2)     dataBaseID,
                                                                 CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="customeropenorders"></a>
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("OESHTO", "Customer<br>Number")
                  @Format_Column_Header("xxx", "Customer Name")
                  @Format_Column_Header("OEORTY", "Order<br>Type")
                  @Format_Column_Header("ODORD#", "Order<br>Number")
                  @Format_Column_Header("ODOLN#", "Line")
                  @Format_Column_Header("ODBRL#", "Rel")
                  @Format_Column_Header("ODRQDT", "Required<br>Date")
                  @Format_Column_Header("ODQORD", "Quantity<br>Ordered")
                  @Format_Column_Header("ODQOPK", "Quantity<br>On Pick")
                  @Format_Column_Header("ODQSTD", "Quantity<br>Shipped")
                  @Format_Column_Header("ODQOBO", "Quantity<br>Backordered")

                  %if (PDBRelease == "Y")
                      @Format_Column_Header("ODMORD", "Mfg Order")
                  %endif
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  @Format_Date(V_ODRQDT, "D", F_ODRQDT)
                  @Format_Nbr(V_ODQORD, F_ODQORD, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                  @Format_Nbr(V_ODQOPK, F_ODQOPK, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                  @Format_Nbr(V_ODQSTD, F_ODQSTD, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                  @Format_Nbr(V_ODQOBO, F_ODQOBO, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")

                  @dtw_assign(customerNumber, V_OESHTO)
                  @RtvFldDesc("CMCUST=$(customerNumber)", "HDCUST", "CMCNA1", customerName)
                  @RtvFldDesc("OTAPID='OE' and OTOTCD='$(V_OEORTY)'", "HDOTYP", "OTDESC", orderTypeDesc)

                  <td class="colnmbr"><a href="$(homeURL)$(cGIPath)CustomerInquiry.d2w/DISPLAY$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)" onclick="$(inquiryWinVar)" title="Customer Quickview">$(customerNumber)</a></td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)CustomerSelect.d2w/REPORT$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)" title="View Customer">$(customerName)</a></td>
                  <td class="colcode" $(helpCursor)><span title="$(orderTypeDesc)">$(V_OEORTY)</span></td>
                  <td class="colnmbr"><a onClick="saveCurrentURL();" href="$(homeURL)$(cGIPath)SelectOrder.d2w/REPORT$(d2wVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;orderNumber=@dtw_rurlescseq(V_ODORD#)" title="View Order Detail">$(V_ODORD#)</a></td>
                  <td class="colnmbr">$(V_ODORL#)</td>
                  <td class="colnmbr">$(V_ODBLN#)</td>
                  <td class="coldate">$(F_ODRQDT)</td>
                  <td class="colnmbr">$(F_ODQORD)</td>
                  <td class="colnmbr">$(F_ODQOPK)</td>
                  <td class="colnmbr">$(F_ODQSTD)</td>
                  <td class="colnmbr">$(F_ODQOBO)</td>
                  %if (PDBRelease == "Y")
                      %if (V_ODMORD != "")
                          @RtvFldDesc("OHPLT=$(V_ODPLT) and OHORD='$(V_ODMORD)'", "HDMOHM", "CHAR(COUNT(OHORD))", mfgOrderCnt)
                      %else
                          @dtw_assign(mfgOrderCnt, "0")
                      %endif
                      %if (mfgOrderCnt > "0")
                          <td class="colalph"><a href="$(homeURL)$(cGIPath)SelectMfgOrder.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq($(V_ODPLT))&amp;mfgOrder=@dtw_rurlescseq($(V_ODMORD))" onclick="$(inquiryWinVar)" title="View Mfg Order">$(V_ODMORD)</a></td>
                      %else
                          <td class="colalph">$(V_ODMORD)</td>
                      %endif
                  %endif
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) ItemWarehouse_Select_Customer_Order_History (IN CHAR(64)    profileHandle,
				                                    CHAR(2)     dataBaseID,
                                                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="customerorderhistory"></a>
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("OESHTO", "Customer<br>Number")
                  @Format_Column_Header("xxx", "Customer Name")
                  @Format_Column_Header("HHORTY", "Order<br>Type")
                  @Format_Column_Header("DHORD#", "Order<br>Number")
                  @Format_Column_Header("DHORL#", "Line")
                  @Format_Column_Header("DHBLN#", "Rel")
                  @Format_Column_Header("DHRQDT", "Required<br>Date")
                  @Format_Column_Header("DHQORD", "Quantity<br>Ordered")
                  @Format_Column_Header("DHQSTD", "Quantity<br>Shipped")
                  @Format_Column_Header("DHSLPR", "Price")
                  @Format_Column_Header("xxx", "Extended<br>Price")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Date(V_DHRQDT, "D", F_DHRQDT)
              %if (V_DHBLKT != "Y")
                  %if (V_DHSEQ# == "0")
                      @Format_Nbr("@dtw_rdivide(@dtw_rmultiply(V_DHQSTD, V_DHSLPR), V_DHORUF)", extendedPrice, "2", $(amtEditCode), "Y", "", "")
                  %else
                      @Format_Nbr("@dtw_rdivide(@dtw_rmultiply(V_DHQSTC, V_DHSLPR), V_DHORUF)", extendedPrice, "2", $(amtEditCode), "Y", "", "")
                  %endif
              %endif
              @Format_Nbr(V_DHQORD, F_DHQORD, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr(V_DHQSTD, F_DHQSTD, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr(V_DHQSTC, F_DHQSTC, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr(V_DHSLPR, F_DHSLPR, $(prcNbrDec), $(amtEditCode), "", "", "")
              @dtw_assign(customerNumber, V_HHSHTO)
              @RtvFldDesc("CMCUST=$(customerNumber)", "HDCUST", "CMCNA1", customerName)
              @RtvFldDesc("SMSLSM=$(V_HHSLSM)", "HDSLSM", "SMSNA1", salesmanName)
              @RtvFldDesc("OTAPID='OE' and OTOTCD='$(V_HHORTY)'", "HDOTYP", "OTDESC", orderTypeDesc)

              <tr class="$(rowClass)">
                  <td class="colnmbr"><a href="$(homeURL)$(cGIPath)CustomerInquiry.d2w/DISPLAY$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)" onclick="$(inquiryWinVar)" title="Customer Quickview">$(customerNumber)</a></td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)CustomerSelect.d2w/REPORT$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)" title="View Customer">$(customerName)</a></td>
                  <td class="colcode" $(helpCursor)><span title="$(orderTypeDesc)">$(V_HHORTY)</span></td>
                  <td class="colnmbr"><a onClick="saveCurrentURL();" href="$(homeURL)$(cGIPath)SelectOrderHistory.d2w/REPORT$(d2wVarBase)&amp;orderNumber=@dtw_rurlescseq(V_DHORD#)&amp;orderSequence=@dtw_rurlescseq(V_DHSEQ#)&amp;noMenu=@dtw_rurlescseq(noMenu)" title="View Shipment Summary">$(V_DHORD#)</a></td>
                  <td class="colcode">$(V_DHORL#)</td>
                  <td class="colcode">$(V_DHBLN#)</td>
                  <td class="coldate">$(F_DHRQDT)</td>
                  <td class="colnmbr">$(F_DHQORD)</td>
                  %if (orderSequence == "000")
                      <td class="colnmbr">$(F_DHQSTD)</td>
                  %else
                      <td class="colnmbr">$(F_DHQSTC)</td>
                  %endif
                  %if (V_DHBLKT != "Y")
                      <td class="colnmbr">$(F_DHSLPR)</td>
                      <td class="colnmbr">$(extendedPrice)</td>
                  %endif
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) ItemWarehouse_Select_Plants (IN  CHAR(64)    profileHandle,
