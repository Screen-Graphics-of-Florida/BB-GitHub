%FUNCTION(dtw_sql) ItemWarehouse_Select_Top_Customers (IN CHAR(64)    profileHandle,
				                           CHAR(2)     dataBaseID,
                                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (quicklinkRef == "ytdtopcustomers" )
          <a name="ytdtopcustomers"></a>
      %else
          <a name="lastyeartopcustomers"></a>
      %endif
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

          %if (sql_Record_Count == "0")
              <table $(contentTable)>
                  %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              @Format_Nbr(salesTotal, F_salesTotal, "2", $(amtEditCode), "", "$", "")
              <div class="page">
                   Total Sales: $(F_salesTotal)
              </div>

              <table $(contentTable)>
                  <tr>
                      @Format_Column_Header("DHSHTO", "Customer<br>Number")
                      @Format_Column_Header("xxx", "Customer Name")
                      @Format_Column_Header("SALES", "Sales")
                      @Format_Column_Header("xxx", "Percent<br>of Total")
                      @Format_Column_Header("QTYSHIPPED", "Quantity")
                  </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              %if (salesTotal > "0")
                  @dtw_multiply(V_SALES, "100", percentOfTotal)
                  @dtw_divide(percentOfTotal, salesTotal, percentOfTotal)
                  @Format_Nbr($(percentOfTotal), F_percentOfTotal, "2", $(pctEditCode), "Y", "", "%")
              %else
                  @dtw_assign(F_percentOfTotal, "")
              %endif
              @Format_Nbr(V_QTYSHIPPED, F_QTYSHIPPED, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr($(V_SALES), F_SALES, "2", $(amtEditCode), "", "", "")
              @dtw_assign(customerNumber, V_DHSHTO)
              @RtvFldDesc("CMCUST=$(customerNumber)", "HDCUST", "CMCNA1", customerName)

              <tr class="$(rowClass)">
                  %if (customerName>"")
                      <td class="colnmbr"><a href="$(homeURL)$(cGIPath)CustomerInquiry.d2w/DISPLAY$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)" onclick="$(inquiryWinVar)" title="Customer Quickview">$(customerNumber)</a></td>
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)CustomerSelect.d2w/REPORT$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)" title="View Customer">$(customerName)</a></td>
                  %else
                      <td class="colnmbr">$(customerNumber)</td>
                      <td class="colalph">$(customerName)</td>
                  %endif
                  <td class="colnmbr">$(F_SALES)</td>
                  <td class="colnmbr">$(F_percentOfTotal)</td>
                  <td class="colnmbr">$(F_QTYSHIPPED)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

