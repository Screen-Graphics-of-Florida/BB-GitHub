*********************************************************************
%}

%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "InventoryControl$(dataBaseID).icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "QuickLink.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Item/Warehouse Select"
  d2wName                 = "ItemWarehouseSelect.d2w"
  attachFolder            = "ItemWarehouse"
  d2wVarBase              = "$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;warehouseNumber=@dtw_rurlescseq(warehouseNumber)"
  currentURL              = "$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)"
  programName             = "HHDIWU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  rowIndexNext            = "1"
  totalPages              = "0"	
  warehouseName           = ""
  itemDescription         = ""
  salesTotal              = ""
  purchasesTotal          = ""
  PDBRelease              = ""
  lotControlled           = ""
  quickLinkByUser         = "Y"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
   @dtw_replace(workURL, "@@itemNumber", "@dtw_rurlescseq(itemNumber)", "1", "a", workURL)
   @dtw_replace(workURL, "@@warehouseNumber", "@dtw_rurlescseq(warehouseNumber)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @ItemWarehouseUserView(profileHandle, dataBaseID, userPass, warehouseNumber, itemNumber)
  %if (userPass == "Y")
      @ItemUserView(profileHandle, dataBaseID, userPass, itemNumber)
  %endif
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "AJAXRequest.icl"
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
                  %INCLUDE "SaveCurrentURL.icl"
                  function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                           @dtw_assign(pageID, "ITEMWAREHOUSESELECT")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">

%{ PDBRelease %}
                          %if (V_HDPDRL>"0")		
                              @dtw_assign(PDBRelease, "Y")
                          %endif

%{ lotControlled %}
                          @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMLOT", V_IMLOT)
                          %if (V_IMLOT != "N")		
                              @dtw_assign(lotControlled, "Y")
                          %endif

%{ stockLocatorActive %}
                          @RtvFldDesc("WHWHS=$(warehouseNumber)", "HDWHSM", "WHSTKL", stockLocatorActive)

%{ QuickLink Table %}     %INCLUDE "QuickLinkTable.icl"

                          %if (CILTUS != "Y" && stockLocatorActive != "Y" )
                              @Remove_Quick_Link("inventory")
                          %endif

                          %if (PDBRelease != "Y")
                              @Remove_Quick_Link("plants")
                          %endif

                          %if (lotControlled !="Y")
                              @Remove_Quick_Link("lottracking")
                          %endif

%{ QuickLink By User %}   %INCLUDE "QuickLinkByUser.icl"

%{ ItemWarehouse Heading %}
                          @dtw_assign(RPT_MAX_ROWS, "99")
                          @dtw_assign(dspMaxRows, "10")
                          @dtw_assign(uv_Sql, "")  %{ No user view security. %}
                          @dtw_assign(wildCardSearch, "")  %{ No wildCardSearch %}
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " HDIWHS inner join HDIMST on IMITEM=IWITEM ", fileSQL)
                          @dtw_concat(selectSQL, "IWWHS=$(warehouseNumber) and IWITEM='$(itemNumber)' ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          %INCLUDE "stmtSQLEnd.icl"
                          @ItemWarehouse_Select_Header(profileHandle, dataBaseID, stmtSQL)

%{ Quicklink Begin %}     %INCLUDE "QuickLinkBegLoop.icl"

    %{ Demographics %}
                              %if (quicklinkRef == "demographics")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDIWHS ", fileSQL)
                                  @dtw_concat(selectSQL, "IWWHS=$(warehouseNumber) and IWITEM='$(itemNumber)' ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @ItemWarehouse_Select_Demographics(profileHandle, dataBaseID, stmtSQL)

    %{ Cost %}
                              %elif (quicklinkRef == "cost")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDIWHS ", fileSQL)
                                  @dtw_concat(selectSQL, "IWWHS=$(warehouseNumber) and IWITEM='$(itemNumber)' ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @ItemWarehouse_Select_Cost(profileHandle, dataBaseID, stmtSQL)

    %{ Physical Inventory %}
                              %elif (quicklinkRef == "physicalinventory")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDIWHS ", fileSQL)
                                  @dtw_concat(selectSQL, "IWWHS=$(warehouseNumber) and IWITEM='$(itemNumber)' ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @ItemWarehouse_Select_PhyInventory(profileHandle, dataBaseID, stmtSQL)

    %{ User Defined %}
                              %elif (quicklinkRef == "userdefined")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDIWHS ", fileSQL)
                                  @dtw_concat(selectSQL, "IWWHS=$(warehouseNumber) and IWITEM='$(itemNumber)' ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @ItemWarehouse_Select_UserDefined(profileHandle, dataBaseID, stmtSQL)

    %{ Inventory %}
                              %elif (quicklinkRef == "inventory")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select HDITSL.*, ISQOH-(ISQRES+ISQHSR) as ISAVQT ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDITSL ", fileSQL)
                                  @dtw_concat(selectSQL, "ISITEM='$(itemNumber)' and ISWHS=$(warehouseNumber) ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %if (orderBy == "")
                                      @DTW_ASSIGN(orderBy, "ISSTKR,ISAILE,ISSLOC")
                                      @DTW_ASSIGN(orderByDisplay, "Stock Location")
                                  %endif
                                  @dtw_assign(orderBy, "ISSTKR,ISAILE,ISSLOC")
                                  @dtw_assign(orderByDisplay, "Stock Location")
                                  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @ItemWarehouse_Select_Inventory(profileHandle, dataBaseID, stmtSQL)

    %{ Transaction History %}
                              %elif (quicklinkRef == "transactionhistory")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDDTRN25 ", fileSQL)
                                  @dtw_concat(selectSQL, "DTITEM='$(itemNumber)' and DTWHS=$(warehouseNumber) ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  @dtw_assign(orderBy, "DTTRDT desc")
                                  @dtw_assign(orderByDisplay, "Transaction Date")
                                  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @ItemWarehouse_Select_Transaction_History(profileHandle, dataBaseID, stmtSQL)

    %{ Open Orders (VendorSelect.d2w) %}
                              %elif (quicklinkRef == "vendoropenorders")
                                  %INCLUDE "QuickLinkClear.icl"
                                  @dtw_assign(uv_WarehouseName, "POWHS")
                                  @dtw_assign(uv_VendorName, "POVEND")
                                  @dtw_assign(uv_BuyerName, "POBUYR")
                                  %INCLUDE "userview.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "SELECT POVEND, POBUYR, PDVDSN, PDPO, PDPOL#, PDRORD, PDRQDT, ", stmtSQL)
                                  @dtw_concat(stmtSQL, " PDQTOR, PDQHRT, PDQRFT, PDQRRT, PDQRST, PDQRVT, ", stmtSQL)
                                  @dtw_concat(stmtSQL, " PDBUOM, PDDSCC, PDPLT, PDPORL, PDPCPB, POTYPE, coalesce(BMBNA1,' ') as BMBNA1 ", stmtSQL)
                                  @dtw_concat(fileSQL, " POPOMS inner join POPOMD on POPO=PDPO ", fileSQL)
                                  @dtw_concat(fileSQL, "        left join HDBUYR on POBUYR=BMBUYR ", fileSQL)
                                  @dtw_concat(selectSQL, "PDOVWH=$(warehouseNumber) and PDITEM='$(itemNumber)' and PDSTAT='O'", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  @dtw_assign(orderBy, "PDRQDT, PDPO")
                                  @dtw_assign(orderByDisplay, "Required Date, Purchase Order")
                                  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @ItemWarehouse_Select_Open_Orders(profileHandle, dataBaseID, stmtSQL)


    %{ Order History (SelectPurchaseOrderHistory.d2w) %}
                              %elif (quicklinkRef == "vendororderhistory")
                                  %INCLUDE "QuickLinkClear.icl"
                                  @dtw_assign(uv_WarehouseName, "PHWHS")
                                  @dtw_assign(uv_VendorName, "PHVEND")
                                  @dtw_assign(uv_BuyerName, "PHBUYR")
                                  %INCLUDE "userview.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, "SELECT PHVEND, PHSEQ#, PHBUYR, PHSTAT, PHPORF, PHDSHP, PHRQDT, PHTYPE,", stmtSQL)
                                  @dtw_concat(stmtSQL, " PHLRDT, PHSVDS, ", stmtSQL)
                                  @dtw_concat(stmtSQL, " PIRQDT, PITRQT, PIDSCC, PIPCPB, PIPO, PIPOL#, PIPORL, PIQTOR, PIPCPB, PIBUOM, coalesce(BMBNA1,' ') as BMBNA1 ", stmtSQL)
                                  @dtw_concat(fileSQL, " POPOHH inner join POPOHD on PHPO=PIPO and PHSEQ#=PISEQ# ", fileSQL)
                                  @dtw_concat(fileSQL, "        left join HDBUYR on PHBUYR=BMBUYR ", fileSQL)
                                  @dtw_concat(selectSQL, "PIITEM='$(itemNumber)' and PHWHS=$(warehouseNumber) and PISEQ#>0", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  @dtw_assign(orderBy, "PHLRDT Desc, PHPO")
                                  @dtw_assign(orderByDisplay, "Date Of Last Receipt (descending), Purchase Order")
                                  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @ItemWarehouse_Select_Order_History(profileHandle, dataBaseID, stmtSQL)

    %{ Customer Open Orders (CustomerSelect.d2w) %}
                              %elif (quicklinkRef == "customeropenorders")
                                  %INCLUDE "QuickLinkClear.icl"
                                  @dtw_assign(uv_BillingLocationName, "OELOC#")
                                  @dtw_assign(uv_CustomerName, "OESHTO")
                                  @dtw_assign(uv_SalesmanName, "OESLSM")
                                  @dtw_assign(uv_OEOrderTypeName, "OEORTY")
                                  %INCLUDE "userview.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select OESHTO, ODIMDS, ODORD#, ODORL#,", stmtSQL)
                                  @dtw_concat(stmtSQL, " ODBLN#, ODRQDT, ODQORD, ODQOPK, ODQSTD,", stmtSQL)
                                  @dtw_concat(stmtSQL, " ODQOBO, ODPLT, ODMORD, ODQSTC, OEORTY ", stmtSQL)
                                  @dtw_concat(fileSQL, " OEORHD inner join OEORDT on OEORD#=ODORD# ", fileSQL)
                                  @dtw_concat(fileSQL, "        inner join HDCUST on OEBLTO=CMCUST ", fileSQL)
                                  @dtw_concat(selectSQL, "ODITEM='$(itemNumber)' and ODWH=$(warehouseNumber) ", selectSQL)
                                  @dtw_concat(selectSQL, "and OEORST='O' and ODORST='O'and ODBLKT<>'Y' ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  @dtw_assign(orderBy, "ODRQDT, OESHTO, ODORD#, ODBLN#, ODORL# ")
                                  @dtw_assign(orderByDisplay, "Required Date, Customer Number, Order Number, Line, Rel")
                                  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @ItemWarehouse_Select_Customer_Open_Orders(profileHandle, dataBaseID, stmtSQL)

    %{ Customer Order History (SelectOrderHistory.d2w) %}
                              %elif (quicklinkRef == "customerorderhistory")
                                  %INCLUDE "QuickLinkClear.icl"
                                  @dtw_assign(uv_BillingLocationName, "HHLOC#")
                                  @dtw_assign(uv_CustomerName, "HHBLTO")
                                  @dtw_assign(uv_SalesmanName, "HHSLSM")
                                  @dtw_assign(uv_OEOrderTypeName, "HHORTY")
                                  %INCLUDE "userview.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select DHORD#, DHRQDT, DHSEQ#,", stmtSQL)
                                  @dtw_concat(stmtSQL, " HHSHTO, HHSLSM, HHLOC#, HHORTY, ", stmtSQL)
                                  @dtw_concat(stmtSQL, " DHRQDT, DHQSTD, DHQSTC, DHSLPR, DHORUF, DHQORD, DHORD#, DHORL#, DHBLN#", stmtSQL)
                                  @dtw_concat(fileSQL, " OEORHH inner join OEORDH on HHORD#=DHORD# and HHSEQ#=DHSEQ# ", fileSQL)
                                  @dtw_concat(selectSQL, "DHITEM = '$(itemNumber)' and DHWH = $(warehouseNumber) and DHSEQ#>0 ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  @dtw_assign(orderBy, "DHRQDT Desc, HHSHTO, DHORD#, DHORL#, DHBLN# ")
                                  @dtw_assign(orderByDisplay, "Required Date (descending), Customer Number, Order Number, Line, Rel")
                                  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @ItemWarehouse_Select_Customer_Order_History(profileHandle, dataBaseID, stmtSQL)

    %{ Plants %}
                              %elif (quicklinkRef == "plants")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select IPPLT, IPITEM, IPBAC, IPPTYP, IPABCC, IPOHFS, IPCMTO, ", stmtSQL)
                                  @dtw_concat(stmtSQL, " coalesce(PLNAME,' ') as PLNAME, upper(coalesce(PLNAME,' ')) as PLNAMEU, ", stmtSQL)
                                  @dtw_concat(stmtSQL, " coalesce(BMBNA1,' ') as BMBNA1, FLDESC as FLDESC, ", stmtSQL)
                                  @dtw_concat(stmtSQL, " (select coalesce(sum(IWOHQT),0) from HDIWHS inner join HDWSPM on WSTYPE='P' and WSPLWH=IPPLT and WSSORD='S' and WSWH=IWWHS where iwitem='$(itemNumber)') as PLANTOH ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDIPLT ", fileSQL)
                                  @dtw_concat(fileSQL, " left join HDPLNT on PLPLNT=IPPLT ", fileSQL)
                                  @dtw_concat(fileSQL, " left join SYFLAG on FLTYPE='PARTTYPE' and FLVALU=IPPTYP ", fileSQL)
                                  @dtw_concat(fileSQL, " left join HDBUYR on BMBUYR=IPBAC ", fileSQL)
                                  @dtw_concat(selectSQL, "IPITEM = '$(itemNumber)' ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  @dtw_assign(orderBy, "IPOHFS Desc")
                                  @dtw_assign(orderByDisplay, "Floorstock Quantity (descending)")
                                  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @ItemWarehouse_Select_Plants(profileHandle, dataBaseID, stmtSQL)

    %{ Current Status %}
                              %elif (quicklinkRef == "currentstatus")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDIWHS ", fileSQL)
                                  @dtw_concat(selectSQL, "IWITEM='$(itemNumber)' and IWWHS=$(warehouseNumber) ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @ItemWarehouse_Select_Current_Status(profileHandle, dataBaseID, stmtSQL)

    %{ Usage By Period %}
                              %elif (quicklinkRef == "usagebyperiod")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDISLH ", fileSQL)
                                  @dtw_concat(selectSQL, "IHITEM='$(itemNumber)' and IHWHS=$(warehouseNumber) ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %if (orderBy == "")
                                      @dtw_assign(orderBy, "IHPERD Desc")
                                      @dtw_assign(orderByDisplay, "Transaction Period (descending)")
                                  %endif
                                  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @ItemWarehouse_Select_Usage_ByPeriod(profileHandle, dataBaseID, stmtSQL)

    %{ Usage By Year %}
                              %elif (quicklinkRef == "usagebyyear")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select sum(IHDLRS) as S_DLRS, sum(IHQSLD) as S_QSLD, ", stmtSQL)
                                  @dtw_concat(stmtSQL, "        sum(IHQREC) as S_QREC, sum(IHQAMT) as S_QAMT, ", stmtSQL)
                                  @dtw_concat(stmtSQL, "        sum(IHQTRF) as S_QTRF, sum(IHQTYI) as S_QTYI, ", stmtSQL)
                                  @dtw_concat(stmtSQL, "        sum(IHQKTI) as S_QKTI, sum(IHQRTV) as S_QRTV, ", stmtSQL)
                                  @dtw_concat(stmtSQL, "        sum(IHQSCR) as S_QSCR, sum(IHQDSH) as S_QDSH, ", stmtSQL)
                                  @dtw_concat(stmtSQL, "        sum(IHSTOT) as S_STOT, IHCYR ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDISLH ", fileSQL)
                                  @dtw_concat(selectSQL, "IHITEM='$(itemNumber)' and IHWHS=$(warehouseNumber) ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %if (orderBy == "")
                                      @dtw_assign(orderBy, "IHCYR Desc")
                                      @dtw_assign(orderByDisplay, "Transaction Year (descending)")
                                  %endif
                                  @dtw_concat(stmtSQL, " Group By IHCYR ", stmtSQL)
                                  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @ItemWarehouse_Select_Usage_ByYear(profileHandle, dataBaseID, stmtSQL)

    %{ Lot Tracking %}
                              %elif (quicklinkRef == "lottracking")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select LTPLT, LTLT#, LTDTEX, ", stmtSQL)
                                  @dtw_concat(stmtSQL, " LTQOH, (LTQOH - LTQAL - LTQHSR + LTLRCP) as QTYAVAIL ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDLOT ", fileSQL)
                                  @dtw_concat(selectSQL, "LTITEM = '$(itemNumber)' and LTWH=$(warehouseNumber) ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %if (orderBy == "")
                                      @dtw_assign(orderBy, "LTLT#")
                                      @dtw_assign(orderByDisplay, "Lot Number")
                                  %endif
                                  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @ItemWarehouse_Select_Lot_Tracking(profileHandle, dataBaseID, stmtSQL)

    %{ Top Customers %}
                              %elif (quicklinkRef == "lastyeartopcustomers" || quicklinkRef == "ytdtopcustomers")
                                  %INCLUDE "QuickLinkClear.icl"
                                  @dtw_date("S", sysDateYYYYMMDD)
                                  @dtw_substr(sysDateYYYYMMDD,"3","2",sysYearYY)
                                  %if (quicklinkRef == "lastyeartopcustomers")
                                      @dtw_subtract(sysYearYY,"1",yearYY)
                                  %else
                                      @dtw_assign(yearYY, sysYearYY)
                                  %endif
                                  @Build_Date_Range(yearYY, startCMD, endCMD)
                                  @RtvFldDesc("DHSEQ#>0 and DHWH=$(warehouseNumber) and DHITEM='$(itemNumber)' and DHDTLI>=$(startCMD) and DHDTLI<=$(endCMD)", "OEORDH", "char(SUM((DHQSTC*DHSLPR)/DHORUF))", salesTotal)

                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(distinctSQL, "DHSHTO ", distinctSQL)
                                  @dtw_concat(stmtSQL, " Select DHSHTO, SUM((DHQSTC*DHSLPR)/DHORUF) as SALES, ", stmtSQL)
                                  @dtw_concat(stmtSQL, " SUM(DHQSTC) as QTYSHIPPED ", stmtSQL)
                                  @dtw_concat(fileSQL, " OEORDH ", fileSQL)
                                  @dtw_concat(selectSQL, "DHWH=$(warehouseNumber) and DHITEM='$(itemNumber)' and DHSEQ#>0 ", selectSQL)
                                  @dtw_concat(selectSQL, "and (DHDTLI >= $(startCMD) and DHDTLI <= $(endCMD)) ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  @dtw_concat(stmtSQL, " GROUP BY DHSHTO", stmtSQL)
                                  @dtw_assign(orderBy, "SALES Desc")
                                  @dtw_assign(orderByDisplay, "Sales (descending)")
                                  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @ItemWarehouse_Select_Top_Customers(profileHandle, dataBaseID, stmtSQL)

    %{ Top Vendors %}
                              %elif (quicklinkRef == "lastyeartopvendors" || quicklinkRef == "ytdtopvendors")
                                  %INCLUDE "QuickLinkClear.icl"
                                  @dtw_date("S", sysDateYYYYMMDD)
                                  @dtw_substr(sysDateYYYYMMDD,"3","2",sysYearYY)
                                  %if (quicklinkRef == "lastyeartopvendors")
                                      @dtw_subtract(sysYearYY,"1",yearYY)
                                  %else
                                      @dtw_assign(yearYY, sysYearYY)
                                  %endif
                                  @Build_Date_Range(yearYY, startCMD, endCMD)
                                  @RtvFldDesc("PHWHS=$(warehouseNumber) and PIITEM='$(itemNumber)' and PHLRDT>=$(startCMD) and PHLRDT<=$(endCMD)", "POPOHH inner join POPOHD on PHPO=PIPO and PHSEQ#=PISEQ#", "char(SUM((PIDSCC*PITRQT)/PIPCPB))", purchasesTotal)

                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(distinctSQL, "PHVEND ", distinctSQL)
                                  @dtw_concat(stmtSQL, " Select PHVEND, SUM((PIDSCC*PITRQT)/PIPCPB) as PURCHASES, ", stmtSQL)
                                  @dtw_concat(stmtSQL, " SUM(PITRQT) as RECEIVED ", stmtSQL)
                                  @dtw_concat(fileSQL, " POPOHH inner join POPOHD on PHPO=PIPO and PHSEQ#=PISEQ# ", fileSQL)
                                  @dtw_concat(selectSQL, "PHWHS=$(warehouseNumber) and PIITEM='$(itemNumber)' and PHLRDT>=$(startCMD) and PHLRDT<=$(endCMD) ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  @dtw_concat(stmtSQL, " GROUP BY PHVEND", stmtSQL)
                                  @dtw_assign(orderBy, "PURCHASES Desc")
                                  @dtw_assign(orderByDisplay, "Purchases (descending)")
                                  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @ItemWarehouse_Select_Top_Vendors(profileHandle, dataBaseID, stmtSQL)
                              %endif

    %{ Attachments %}         %INCLUDE "AttachmentSQL.icl"

%{ Quicklink End %}       %INCLUDE "QuickLinkEndLoop.icl"

                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) ItemWarehouse_Select_Header (IN CHAR(64)    profileHandle,
			                            CHAR(2)     dataBaseID,
                                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %ROW{
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1> $(page_title) &nbsp; </h1></td>
                  @dtw_assign(attachWarehouseKey, warehouseNumber)
                  %while(@dtw_rlength(attachWarehouseKey) != "3") {@dtw_insert("0", attachWarehouseKey, attachWarehouseKey) %}
                  @dtw_assign(attachVarKey, "$(attachWarehouseKey)$(itemNumber)")
                  @dtw_assign(attachForDesc, "$(warehouseName)/$(V_IMIMDS)")
                  @dtw_assign(attachPrg1, "HDIWHS Where IWWHS=$(warehouseNumber) and IWITEM='$(itemNumber)'")

                  %if (formatToPrint != "Y")
                      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                      <td class="toolbar">
                          %if (V_IMKIT == "K")
                              <a href="$(homeURL)$(phpPath)KitInquiry.php$(altVarBase)&amp;itemNumber=@dtw_rurlescseq($(V_IMITEM))" onclick="$(inquiryWinVar)" title="Kit Quickview">$(kitOptionImageLrg)</a>
                          %endif
                          %INCLUDE "Attachment.icl"
                          %if (sec_01 == "Y")
                              <a href="$(homeURL)$(cGIPath)ItemWarehouseMaintain.d2w/ADD$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;warehouseNumber=@dtw_rurlescseq(warehouseNumber)&amp;fromSel=Y&amp;maintenanceCode=A">$(addImageLrg)</a>
                          %endif
                          %if (sec_01=="Y" && sec_04=="Y")
                              <a href="$(homeURL)$(cGIPath)ItemWarehouseMaintain.d2w/ADD$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;fromItemNumber=@dtw_rurlescseq(itemNumber)&amp;warehouseNumber=@dtw_rurlescseq(warehouseNumber)&amp;fromWarehouse=@dtw_rurlescseq(warehouseNumber)&amp;fKey1=IWITEM&amp;fVal1=@dtw_rurlescseq(itemNumber)&amp;fromSel=Y&amp;maintenanceCode=Z">$(copyImageLrg)</a>
                          %endif
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)ItemWarehouseMaintain.d2w/MAINTAIN$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;fromItemNumber=@dtw_rurlescseq(itemNumber)&amp;warehouseNumber=@dtw_rurlescseq(warehouseNumber)&amp;fromWarehouse=@dtw_rurlescseq(warehouseNumber)&amp;fromSel=Y&amp;maintenanceCode=C">$(changeImageLrg)</a>
                          %endif
                          %if (sec_03 == "Y")
                              @Format_Confirm_Desc($(itemDescription), $(itemNumber), $(warehouseName), $(warehouseNumber), "", "", confirmDesc)
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)ItemWarehouseMaintain.d2w/Edit_Data$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;fromItemNumber=@dtw_rurlescseq(itemNumber)&amp;warehouseNumber=@dtw_rurlescseq(warehouseNumber)&amp;fromWarehouse=@dtw_rurlescseq(warehouseNumber)&amp;fromSel=Y&amp;maintenanceCode=D">$(deleteImageLrg)</a>
                          %endif
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"

          $(hrTagAttr)

          @dtw_assign(itemDescription, V_IMIMDS)   %{Save for future use.%}
          <table $(contentTable)>
              @Format_Header_URL("Warehouse", $(warehouseName), $(warehouseNumber), "$(homeURL)$(cGIPath)WarehouseSelect.d2w/REPORT$(d2wVarBase)&amp;warehouseName=@dtw_rurlescseq(warehouseName)")
              @Format_Header_URL("Item", $(itemDescription), $(itemNumber), "$(homeURL)$(cGIPath)ItemSelect.d2w/REPORT$(d2wVarBase)&amp;itemDescription=@dtw_rurlescseq(itemDescription)")
          </table>

          $(hrTagAttr)	

          %INCLUDE "QuickLinkDisplay.icl"
      %}
  %}
%}

%FUNCTION(dtw_sql) ItemWarehouse_Select_Demographics (IN  CHAR(64)    profileHandle,
				                           CHAR(2)     dataBaseID,
                                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="demographics"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %ROW{
              %if (PDBRelease == "Y")		
                 @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMPTYP", partType)
                 @Format_Code(partType, F_partType)
                 @RtvFldDesc("FLTYPE='PARTTYPE' and FLVALU='$(partType)'", "SYFLAG", "FLDESC", partTypeDesc)
                 <tr><td class="dsphdr">Part Type</td>
                     <td class="dspalph">$(partTypeDesc)</td>
                     <td class="dspalph">$(F_partType)</td>
                 </tr>
              %endif
              	   		
              %if (V_HDINRL>"0")		
                 @RtvYNDesc($(V_IWSTKL), fieldDesc)
                 <tr><td class="dsphdr">Stock Locator Active</td>
                  <td class="dspalph">$(fieldDesc)</td>
                 </tr>
              %endif

              @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMUOMS", stockUOM)
              @RtvFldDesc("UMUOM='$(stockUOM)'", "HDUOM", "UMUMLD", fieldDesc)
              @Format_Code(stockUOM, F_stockUOM)
              <tr><td class="dsphdr">Stocking Unit Of Measure</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_stockUOM)</td>
              </tr>
	
              @RtvFldDesc("UMUOM='$(V_IWUOMP)'", "HDUOM", "UMUMLD", fieldDesc)
              <tr><td class="dsphdr">Pricing U/M</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dsphdr">Pieces Per Stocking U/M</td>
                  <td class="dspnmbr">$(V_IWPCPP)</td>
              </tr>

              @RtvFldDesc("UMUOM='$(V_IWUOMB)'", "HDUOM", "UMUMLD", fieldDesc)
              <tr><td class="dsphdr">Purchasing U/M</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dsphdr">Pieces Per Stocking U/M</td>
                  <td class="dspnmbr">$(V_IWPCPB)</td>
              </tr>

              <tr><td class="dsphdr">Case Pack</td>
                  <td class="dspalph">&nbsp;</td>
                  <td class="dsphdr">Pieces Per Case</td>
                  <td class="dspnmbr">$(V_IWPCPC)</td>
              </tr>

              <tr><td class="dsphdr">List Price</td>
                  <td class="dspnmbr">$(V_IWLIST)</td>
              </tr>

              @RtvYNDesc($(V_IWTXCD), fieldDesc)
              <tr><td class="dsphdr">Taxable</td>
                  <td class="dspalph">$(fieldDesc)</td>
              </tr>

              @RtvFldDesc("PGPGRP='$(V_IWPGRP)'", "HDPRGM", "PGDESC", fieldDesc)
              @Format_Code(V_IWPGRP, F_IWPGRP)
              <tr><td class="dsphdr">Product Group</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_IWPGRP)
              </tr>

              @RtvFldDesc("FTCLAS='$(V_IWFTCL)'", "HDFTCL", "FTLD01", fieldDesc)
              @Format_Code(V_IWFTCL, F_IWFTCL)
              <tr><td class="dsphdr">Freight Class</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_IWFTCL)
              </tr>

              @RtvFldDesc("VMVEND=$(V_IWVEND)", "HDVEND", "VMVNA1", fieldDesc)
              @Format_Code(V_IWVEND, F_IWVEND)
              <tr><td class="dsphdr">Primary Vendor Number</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_IWVEND)</td>
              </tr>

              @RtvFldDesc("BMBUYR=$(V_IWBUYR)", "HDBUYR", "BMBNA1", fieldDesc)
              @Format_Code(V_IWBUYR, F_IWBUYR)
              <tr><td class="dsphdr">Buyer Number</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_IWBUYR)</td>
              </tr>

              <tr><td class="dsphdr">Purchase Lead Time</td>
                  <td class="dspnmbr">$(V_IWPULT)</td>
              </tr>

              <tr><td class="dsphdr">Minimum Quantity On Hand</td>
                  <td class="dspnmbr">$(V_IWMINQ)</td>
              </tr>

              <tr><td class="dsphdr">Maximum Quantity On Hand</td>
                  <td class="dspnmbr">$(V_IWMAXQ)</td>
              </tr>

              @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMKIT", kitItem)
              %if (kitItem == "K" && V_HDTCV != "S")		
                 <tr><td class="dsphdr">Kit Additional Cost</td>
                     <td class="dspnmbr">$(V_IWKITC)</td>
                 </tr>
              %endif

              <tr><td class="dsphdr">Economic Order Quantity</td>
                 <td class="dspnmbr">$(V_IWEOQ)</td>
              </tr>

              <tr><td class="dsphdr">Duty Percent</td>
                  <td class="dspnmbr">@dtw_rformat(@dtw_rMultiply(V_IWDUTY, "100"),"","2")%</td>
              </tr>

              %if (V_HDPORL>"0")
                  @dtw_assign(dspSuggPOFields, "Y")
                  @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMPTYP", partType)
                  %if (PDBRelease == "Y" && (V_HDMPRL>"0" || partType != "P"))
                      @dtw_assign(dspSuggPOFields, "")
                  %endif
              %endif
              %if (dspSuggPOFields == "Y")		
                  <tr><td class="dsphdr">Build To Number Days</td>
                      <td class="dspnmbr">$(V_IWBTND)</td>
                  </tr>

                  @RtvYNDesc($(V_IWSITM), fieldDesc)
                  <tr><td class="dsphdr">Seasonal Item</td>
                      <td class="dspnmbr">$(fieldDesc)</td>
                  </tr>

                  <tr><td class="dsphdr"># Of Periods For Avg Qty Shipped</td>
                      <td class="dspnmbr">$(V_IWNPUS)</td>
                  </tr>

                  @RtvFldDesc("FLTYPE='ROUNDDECML' AND FLVALU='$(V_IWRTOD)'", "SYFLAG", "FLDESC", fieldDesc)
                  @Format_Code(V_IWRTOD, F_IWRTOD)
                  <tr><td class="dsphdr">Round Sug Order Qty To # Decimals</td>
                      <td class="dspnmbr">$(fieldDesc)</td>
                      <td class="dspnmbr">$(F_IWRTOD)</td>
                  </tr>
              %endif
          %}
      </table>
      </fieldset>
  %}
%}

