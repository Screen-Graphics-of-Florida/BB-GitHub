                  <tr>
                      @Format_Column_Header("PHVEND", "Vendor<br>Number")
                      @Format_Column_Header("xxx", "Vendor Name")
                      @Format_Column_Header("PURCHASES", "Purchases")
                      @Format_Column_Header("xxx", "Percent<br>of Total")
                      @Format_Column_Header("RECEIVED", "Quantity")
                  </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              %if (purchasesTotal > "0")
                  @dtw_multiply(V_PURCHASES, "100", percentOfTotal)
                  @dtw_divide(percentOfTotal, purchasesTotal, percentOfTotal)
                  @Format_Nbr($(percentOfTotal), F_percentOfTotal, "2", $(pctEditCode), "Y", "", "%")
              %else
                  @dtw_assign(F_percentOfTotal, "")
              %endif
              @Format_Nbr(V_RECEIVED, F_RECEIVED, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr($(V_PURCHASES), F_PURCHASES, "2", $(amtEditCode), "", "", "")
              @RtvFldDesc("VMVEND=$(V_PHVEND)", "HDVEND", "VMVNA1", vendorName)
              <tr class="$(rowClass)">
                  %if (vendorName>"")
                  	  <td class="colnmbr"><a href="$(homeURL)$(phpPath)VendorDashboard.php$(altVarBase)&amp;vendorNumber=$(V_PHVEND)&amp;fromItem=@dtw_rurlescseq($(itemNumber))" title="View Vendor Dashboard">$(V_PHVEND)</a></td>
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)VendorSelect.d2w/REPORT$(genericVarBase)&amp;vendorNumber=@dtw_rurlescseq(V_PHVEND)&amp;vendorName=@dtw_rurlescseq(vendorName)" title="View Vendor">$(vendorName)</a></td>
                  %else
                      <td class="colnmbr">$(V_PHVEND)</td>
                      <td class="colalph">$(vendorName)</td>
                  %endif
                  <td class="colnmbr">$(F_PURCHASES)</td>
                  <td class="colnmbr">$(F_percentOfTotal)</td>
                  <td class="colnmbr">$(F_RECEIVED)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%INCLUDE "AttachmentSelect.icl"

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @RtvFldDesc("WHWHS=$(warehouseNumber)", "HDWHSM", "WHWHNM", warehouseName)
  @Set_SQL(stmtSQL)
%}