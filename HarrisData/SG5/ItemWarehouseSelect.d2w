                      %else
                          &nbsp;
                      %endif
                  </td>
                  <td class="colcode" $(helpCursor)><span title="$(V_FLDESC)">$(V_IPPTYP)</span></td>
                  <td class="colcode">$(V_IPABCC)</td>
                  <td class="colnmbr">$(F_IPOHFS)</td>
                  <td class="colnmbr">$(F_IPCMTO)</td>
                  <td class="colnmbr">$(F_IPQMRL)</td>
                  <td class="colnmbr">$(F_PLANTOH)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) ItemWarehouse_Select_Usage_ByPeriod (IN CHAR(64)    profileHandle,
				                            CHAR(2)     dataBaseID,
                                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="usagebyperiod"></a>
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMKIT", kitIssued)

              <tr>
                  @Format_Column_Header("IHPERD", "Transaction<br>Period")
                  @Format_Column_Header("IHDLRS", "Sales<br>Amount")
