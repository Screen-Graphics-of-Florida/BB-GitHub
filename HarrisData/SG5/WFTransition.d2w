%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {	
  page_title              = "Transition"
  d2wName                 = "WFTransition.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;wfProcess=@dtw_rurlescseq(wfProcess)&amp;passedWfPoint=@dtw_rurlescseq(passedWfPoint)&amp;passedWfSequence=@dtw_rurlescseq(passedWfSequence)&amp;passedWFFromTo=@dtw_rurlescseq(passedWFFromTo)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HWFTRM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  noMsg                   = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
              function validate(searchForm) {
                  if (editNum(document.Search.srchFromPoint, 4, 3) &&
                      editNum(document.Search.srchToPoint, 4, 3))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "WFTRANSITION")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select WFPRTR.*, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(a.PDDESC,'(Any Previous Detail Point)') as PDDESC_FR, coalesce(a.PDDESCU,' ') as PDDESCU_FR, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(b.PDDESC,'(Any Previous Detail Point)') as PDDESC_TO, coalesce(b.PDDESCU,' ') as PDDESCU_TO, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(CMDESC,' ') as CMDESC, coalesce(CMDESCU,' ') as CMDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " coalesce(VIDESC,' ') as VIDESC, coalesce(VIDESCU,' ') as VIDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " WFPRTR ", fileSQL)
                      @dtw_concat(fileSQL, " left join WFPRDT a on a.PDPROC=TRPROC and a.PDPONT=TRFPNT and a.PDSEQ=TRFSEQ ", fileSQL)
                      @dtw_concat(fileSQL, " left join WFPRDT b on b.PDPROC=TRPROC and b.PDPONT=TRTPNT and b.PDSEQ=TRTSEQ ", fileSQL)
                      @dtw_concat(fileSQL, " left join WFCNDM on CMCOND=TRCOND ", fileSQL)
                      @dtw_concat(fileSQL, " left join WFVLID on VIVPGM=TRVPGM and VIVLID=TRVLID ", fileSQL)
                      @dtw_concat(selectSQL, " TRPROC='$(wfProcess)' ", selectSQL)
                      %if (passedWfPoint != "" && passedWFFromTo == "T")
                          @dtw_concat(selectSQL, " and TRTPNT=$(passedWfPoint) and TRTSEQ=$(passedWfSequence) ", selectSQL)
                      %elif (passedWfPoint != "")
                          @dtw_concat(selectSQL, " and TRFPNT=$(passedWfPoint) and TRFSEQ=$(passedWfSequence) ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64)    profileHandle,
                                   CHAR(2)     dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)WFTransitionMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      <table $(contentTable)>
          @RtvFldDesc("PRPROC='$(wfProcess)'", "WFPRHD", "PRDESC", V_PRDESC)
          @Format_Header_URL("Process", $(V_PRDESC), $(wfProcess), "$(homeURL)$(cGIPath)WFProcessSelect.d2w/REPORT$(d2wVarBase)")

          %if (passedWfPoint != "")
              @RtvFldDesc("PDPROC='$(wfProcess)' and PDPONT=$(passedWfPoint) and PDSEQ=$(passedWfSequence)", "WFPRDT", "PDDESC", V_PDDESC)
              %if (passedWFFromTo == "T")
                  @Format_Header_URL("Detail Point", $(V_PDDESC), "$(passedWfPoint)-$(passedWfSequence) (Transitions coming to this Detail Point)", "$(homeURL)$(cGIPath)WFDetailSelect.d2w/REPORT$(d2wVarBase)")
              %else
                  @Format_Header_URL("Detail Point", $(V_PDDESC), "$(passedWfPoint)-$(passedWfSequence)", "$(homeURL)$(cGIPath)WFDetailSelect.d2w/REPORT$(d2wVarBase)")
              %endif
          %endif
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint == "")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr>
                      <th class="colhdr">Pass/<br>Fail</th>
                      <th class="colhdr">From Detail Point Description</th>
                      <th class="colhdr">From Point</th>
                      <th class="colhdr">To Detail Point Description</th>
                      <th class="colhdr">To Point</th>
                      <th class="colhdr">Condition</th>
                      <th class="colhdr">Validation</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchPassFail" size="1" maxlength="1">
                          <input type="hidden" name="operPassFail" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchFromDesc" size="15" maxlength="50">
                          <input type="hidden" name="operFromDesc" value="LIKE">
                      </td>
                      <td><input type="text" class="inputnmbr" name="srchFromPoint" size="8" maxlength="8">
                          <input type="hidden" name="operFromPoint" value="=">
                      </td>
                      <td><input type="text" class="inputalph" name="srchToDesc" size="15" maxlength="50">
                          <input type="hidden" name="operToDesc" value="LIKE">
                      </td>
                      <td><input type="text" class="inputnmbr" name="srchToPoint" size="8" maxlength="8">
                          <input type="hidden" name="operToPoint" value="=">
                      </td>
                      <td><input type="text" class="inputalph" name="srchCondition" size="15" maxlength="50">
                          <input type="hidden" name="operCondition" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchValidation" size="15" maxlength="50">
                          <input type="hidden" name="operValidation" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchFromDesc.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("PDDESCU_FR", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=FromDesc"  title="Sequence By From Detail Point Description, From Detail Point">From Detail Point Description</a></th>
              @OrderBy_Sort("TRFAIL", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PassFail"    title="Sequence By Pass/Fail, From Detail Point">Pass/<br>Fail</a></th>
              @OrderBy_Sort("TRLEVL", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=AndSplit"  title="Sequence By And Split Level, From Detail Point">And Split</a></th>
              @OrderBy_Sort("TROPT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=OptTransition"    title="Sequence By Optional Transition, From Detail Point">Opt</a></th>
              @OrderBy_Sort("PDDESCU_TO", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ToDesc"  title="Sequence By To Detail Point Description, From Detail Point">To Detail Point Description</a></th>
              @OrderBy_Sort("CMDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Condition"    title="Sequence By Condition, From Detail Point">Condition</a></th>
              @OrderBy_Sort("VIDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Validation"    title="Sequence By Validation, From Detail Point">Validation</a></th>
              @OrderBy_Sort("TRFPNT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=FromPoint"  title="Sequence By From Detail Point">From Detail Point</a></th>
              @OrderBy_Sort("TRTPNT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ToPoint"  title="Sequence By To Detail Point, From Detail Point">To Detail Point</a></th>
              @OrderBy_Sort("TREFDT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=FromDate"  title="Sequence By Effective From Date">Effective From</a></th>
              @OrderBy_Sort("TRETDT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ToDate"  title="Sequence By Effective To Date">Effective To</a></th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          @dtw_assign(Check_TRFPNT, "")
          @dtw_assign(Check_TRFSEQ, "")

          %ROW{
              @RtvFldDesc("FLTYPE='WFPASSFAIL' and FLVALU='$(V_TRFAIL)'", "SYFLAG", "FLDESC", failDesc)
              @RtvFldDesc("FLTYPE='WFOPTTRANS' and FLVALU='$(V_TROPT)'", "SYFLAG", "FLDESC", optDesc)
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;wfTransitionId=@dtw_rurlescseq(V_TRTRID)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;updRecNbr=@dtw_rurlescseq(START_ROW_NUM)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc("$(V_PDDESC_FR) to $(V_PDDESC_TO)", "", "", "", "", "", confirmDesc)

              @Format_Date(V_TREFDT, "D", F_TREFDT)
              @Format_Date(V_TRETDT, "D", F_TRETDT)
              %if (V_TRFPNT!=Check_TRFPNT || V_TRFSEQ!=Check_TRFSEQ)
                  @dtw_assign(F_PDDESC_FR, V_PDDESC_FR)
                  @dtw_assign(Check_TRFPNT, V_TRFPNT)
                  @dtw_assign(Check_TRFSEQ, V_TRFSEQ)
              %else
                  @dtw_assign(F_PDDESC_FR, "")
              %endif

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)WFTransitionMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_01=="Y" && sec_04=="Y")
                              <a href="$(homeURL)$(cGIPath)WFTransitionMaintain.d2w/MAINTAIN$(maintainVar)&amp;fromTransitionId=@dtw_rurlescseq(V_TRTRID)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)WFTransitionMaintain.d2w/EDIT_DATA$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph">$(F_PDDESC_FR)</td>                                      	
                  <td class="colcode" $(helpCursor)><span title="$(failDesc)">$(V_TRFAIL)</span></td>
                  <td class="colnmbr">$(V_TRLEVL)</td>                                      	
                  <td class="colcode" $(helpCursor)><span title="$(optDesc)">$(V_TROPT)</span></td>
                  <td class="colalph">$(V_PDDESC_TO)</td>                                      	
                  <td class="colalph" $(helpCursor)><span title="$(V_TRCOND)">$(V_CMDESC)</span></td>
                  <td class="colalph" $(helpCursor)><span title="$(V_TRVPGM)-$(V_TRVLID)">$(V_VIDESC)</span></td>
                  <td class="colnmbr"><a href="$(homeURL)$(cGIPath)WFDetailSelect.d2w/REPORT$(d2wVarBase)&amp;passedWfPoint=@dtw_rurlescseq(V_TRFPNT)&amp;passedWfSequence=@dtw_rurlescseq(V_TRFSEQ)" title="View Detail Point">$(V_TRFPNT)-$(V_TRFSEQ)</a></td>
                  %if (V_TRTPNT>"0")
                      <td class="colnmbr"><a href="$(homeURL)$(cGIPath)WFDetailSelect.d2w/REPORT$(d2wVarBase)&amp;passedWfPoint=@dtw_rurlescseq(V_TRTPNT)&amp;passedWfSequence=@dtw_rurlescseq(V_TRTSEQ)" title="View Detail Point">$(V_TRTPNT)-$(V_TRTSEQ)</a></td>
                  %else
                      <td class="colnmbr">&nbsp;</td>
                  %endif
                  <td class="colalph">$(F_TREFDT)</td>
                  <td class="colalph">$(F_TRETDT)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select WFPRTR.*, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(a.PDDESC,' ') as PDDESC_FR, coalesce(a.PDDESCU,' ') as PDDESCU_FR, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(b.PDDESC,' ') as PDDESC_TO, coalesce(b.PDDESCU,' ') as PDDESCU_TO, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(CMDESC,' ') as CMDESC, coalesce(CMDESCU,' ') as CMDESCU, ", stmtSQL)
  @dtw_concat(stmtSQL, " coalesce(VIDESC,' ') as VIDESC, coalesce(VIDESCU,' ') as VIDESCU ", stmtSQL)
  @dtw_concat(fileSQL, " WFPRTR ", fileSQL)
  @dtw_concat(fileSQL, " left join WFPRDT a on a.PDPROC=TRPROC and a.PDPONT=TRFPNT and a.PDSEQ=TRFSEQ ", fileSQL)
  @dtw_concat(fileSQL, " left join WFPRDT b on b.PDPROC=TRPROC and b.PDPONT=TRTPNT and b.PDSEQ=TRTSEQ ", fileSQL)
  @dtw_concat(fileSQL, " left join WFCNDM on CMCOND=TRCOND ", fileSQL)
  @dtw_concat(fileSQL, " left join WFVLID on VIVPGM=TRVPGM and VIVLID=TRVLID ", fileSQL)
  @dtw_concat(selectSQL, " TRPROC='$(wfProcess)' ", selectSQL)
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @List_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) List_XMLQuery (IN  CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("WFTransitionList")
          %ROW{
              @XMLIDTag("$(V_TRPROC)-$(V_TRFPNT)-$(V_TRFSEQ)-$(V_TRTRID)", "Transition ID")
                  @XMLTag(V_TRPROC, "Process")
                  @XMLTag(V_TRTRID, "TransitionId")
                  @XMLTag(V_TRFPNT, "FromPoint")
                  @XMLTag(V_TRFSEQ, "FromSequence")
                  @XMLTag(V_TRLEVL, "AndSplitLevel")
                  @XMLTag(V_TRFAIL, "PassFail")
                  @XMLTag(V_TROPT, "OptionalTransition")
                  @XMLTag(V_TRTPNT, "ToPoint")
                  @XMLTag(V_TRTSEQ, "ToSequence")
                  @XMLTag(V_TRCOND, "ConditionId")
                  @XMLTag(V_TRVLID, "ValidationId")
                  @XMLTag(V_TREFDT, "EffectiveFromDate")
                  @XMLTag(V_TRETDT, "EffectiveToDate")
              @XMLEndTag("Transition")
          %}
      @XMLEndTag("WFTransitionList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "PDDESC_FR,TRFPNT,TRFSEQ,TRFAIL,TRLEVL")
          @DTW_ASSIGN(orderByDisplay, "From Detail Point Description, From Detail Point")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %if (updRecNbr > "0")
      @dtw_assign(START_ROW_NUM, updRecNbr)
      @dtw_assign(updRecNbr, "")
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "FromDesc")
      %if (orderBy == "PDDESC_FR,TRFPNT,TRFSEQ,TRFAIL,TRLEVL")
          @DTW_ASSIGN(orderBy, "PDDESC_FR DESC,TRFPNT,TRFSEQ,TRFAIL,TRLEVL")
          @DTW_ASSIGN(orderByDisplay, "From Detail Point Description (descending), From Detail Point")
      %else
          @DTW_ASSIGN(orderBy, "PDDESC_FR,TRFPNT,TRFSEQ,TRFAIL,TRLEVL")
          @DTW_ASSIGN(orderByDisplay, "From Detail Point Description, From Detail Point")
      %endif
  %elif (sequence == "AndSplit")
      %if (orderBy == "TRLEVL,TRFPNT,TRFSEQ,TRFAIL,TRLEVL")
          @DTW_ASSIGN(orderBy, "TRLEVL DESC,TRFPNT,TRFSEQ,TRFAIL,TRLEVL")
          @DTW_ASSIGN(orderByDisplay, "And Split Level (descending), From Detail Point")
      %else
          @DTW_ASSIGN(orderBy, "TRLEVL,TRFPNT,TRFSEQ,TRFAIL,TRLEVL")
          @DTW_ASSIGN(orderByDisplay, "And Split Level, From Detail Point")
      %endif
 %elif (sequence == "PassFail")
      %if (orderBy == "TRFAIL,TRFPNT,TRFSEQ,TRLEVL")
          @DTW_ASSIGN(orderBy, "TRFAIL DESC,TRFPNT,TRFSEQ,TRLEVL")
          @DTW_ASSIGN(orderByDisplay, "Pass/Fail (descending), From Detail Point")
      %else
          @DTW_ASSIGN(orderBy, "TRFAIL,TRFPNT,TRFSEQ,TRLEVL")
          @DTW_ASSIGN(orderByDisplay, "Pass/Fail, From Detail Point")
      %endif
 %elif (sequence == "OptTransition")
      %if (orderBy == "TROPT,TRFPNT,TRFSEQ,TRFAIL,TRLEVL")
          @DTW_ASSIGN(orderBy, "TROPT DESC,TRFPNT,TRFSEQ,TRFAIL,TRLEVL")
          @DTW_ASSIGN(orderByDisplay, "Optional Transition (descending), From Detail Point")
      %else
          @DTW_ASSIGN(orderBy, "TROPT,TRFPNT,TRFSEQ,TRFAIL,TRLEVL")
          @DTW_ASSIGN(orderByDisplay, "Optional Transition, From Detail Point")
      %endif
  %elif (sequence == "ToDesc")
      %if (orderBy == "PDDESC_TO,TRFPNT,TRFSEQ,TRFAIL,TRLEVL")
          @DTW_ASSIGN(orderBy, "PDDESC_TO DESC,TRFPNT,TRFSEQ,TRFAIL,TRLEVL")
          @DTW_ASSIGN(orderByDisplay, "To Detail Point Description (descending), From Detail Point")
      %else
          @DTW_ASSIGN(orderBy, "PDDESC_TO,TRFPNT,TRFSEQ,TRFAIL,TRLEVL")
          @DTW_ASSIGN(orderByDisplay, "To Detail Point Description, From Detail Point")
      %endif
 %elif (sequence == "Condition")
      %if (orderBy == "CMDESCU,TRFPNT,TRFSEQ,TRFAIL,TRLEVL")
          @DTW_ASSIGN(orderBy, "CMDESCU DESC,TRFPNT,TRFSEQ,TRFAIL,TRLEVL")
          @DTW_ASSIGN(orderByDisplay, "Condition (descending), From Detail Point")
      %else
          @DTW_ASSIGN(orderBy, "CMDESCU,TRFPNT,TRFSEQ,TRFAIL,TRLEVL")
          @DTW_ASSIGN(orderByDisplay, "Condition, From Detail Point")
      %endif
 %elif (sequence == "Validation")
      %if (orderBy == "VIDESCU,TRFPNT,TRFSEQ,TRFAIL,TRLEVL")
          @DTW_ASSIGN(orderBy, "VIDESCU DESC,TRFPNT,TRFSEQ,TRFAIL,TRLEVL")
          @DTW_ASSIGN(orderByDisplay, "Validation (descending), From Detail Point")
      %else
          @DTW_ASSIGN(orderBy, "VIDESCU,TRFPNT,TRFSEQ,TRFAIL,TRLEVL")
          @DTW_ASSIGN(orderByDisplay, "Validation, From Detail Point")
      %endif
  %elif (sequence == "FromPoint")
      %if (orderBy == "TRFPNT,TRFSEQ,TRFAIL,TRLEVL")
          @DTW_ASSIGN(orderBy, "TRFPNT DESC,TRFSEQ DESC,TRFAIL,TRLEVL")
          @DTW_ASSIGN(orderByDisplay, "From Detail Point")
      %else
          @DTW_ASSIGN(orderBy, "TRFPNT,TRFSEQ,TRFAIL,TRLEVL")
          @DTW_ASSIGN(orderByDisplay, "From Detail Point")
      %endif
  %elif (sequence == "ToPoint")
      %if (orderBy == "TRTPNT,TRTSEQ,TRFPNT,TRFSEQ,TRFAIL,TRLEVL")
          @DTW_ASSIGN(orderBy, "TRTPNT DESC,TRTSEQ DESC,TRFPNT,TRFSEQ,TRFAIL,TRLEVL")
          @DTW_ASSIGN(orderByDisplay, "To Detail Point (descending), From Detail Point")
      %else
          @DTW_ASSIGN(orderBy, "TRTPNT,TRTSEQ,TRFPNT,TRFSEQ,TRFAIL,TRLEVL")
          @DTW_ASSIGN(orderByDisplay, "To Detail Point, From Detail Point")
      %endif
  %elif (sequence == "FromDate")
      %if (orderBy == "TREFDT,TRFPNT,TRFSEQ,TRFAIL,TRLEVL")
          @DTW_ASSIGN(orderBy, "TREFDT DESC,TRFPNT,TRFSEQ,TRFAIL,TRLEVL")
          @DTW_ASSIGN(orderByDisplay, "Effective From Date (descending), From Detail Point")
      %else
          @DTW_ASSIGN(orderBy, "TREFDT,TRFPNT,TRFSEQ,TRFAIL,TRLEVL")
          @DTW_ASSIGN(orderByDisplay, "Effective From Date, From Detail Point")
      %endif
  %elif (sequence == "ToDate")
      %if (orderBy == "TRETDT,TRFPNT,TRFSEQ,TRFAIL,TRLEVL")
          @DTW_ASSIGN(orderBy, "TRETDT DESC,TRFPNT,TRFSEQ,TRFAIL,TRLEVL")
          @DTW_ASSIGN(orderByDisplay, "Effective To Date (descending), From Detail Point")
      %else
          @DTW_ASSIGN(orderBy, "TRETDT,TRFPNT,TRFSEQ,TRFAIL,TRLEVL")
          @DTW_ASSIGN(orderByDisplay, "Effective To Date, From Detail Point")
      %endif
  %endif
	
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"

  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchAndSplit, 6, 1) &&
                      editNum(document.Search.srchFromPoint, 4, 3) &&
                      editNum(document.Search.srchFromSeq, 4, 3) &&
                      editNum(document.Search.srchToPoint, 4, 3) &&
                      editNum(document.Search.srchToSeq, 4, 3) &&
                      editdate(document.Search.srchFromDate) &&
                      editdate(document.Search.srchToDate))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "WFTRANSITIONSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                              <tr><td class="dsphdr">From Detail Point Description</td>
                                  @dtw_assign(operNbr, "operFromDesc")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchFromDesc" size="15" maxlength="50"></td>
                              </tr>

                              <tr><td class="dsphdr">And Split Level</td>
                                  @dtw_assign(operNbr, "operAndSplit")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchAndSplit" size="8" maxlength="8"></td>
                              </tr>

                              <tr><td class="dsphdr">Pass/Fail</td>
                                  @dtw_assign(operNbr, "operPassFail")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchPassFail" size="1" maxlength="1"></td>
                              </tr>

                              <tr><td class="dsphdr">Optional Transition</td>
                                  @dtw_assign(operNbr, "operOptTransition")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchOptTransition" size="1" maxlength="1"></td>
                              </tr>

                              <tr><td class="dsphdr">To Detail Point Description</td>
                                  @dtw_assign(operNbr, "operToDesc")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchToDesc" size="15" maxlength="50"></td>
                              </tr>

                              <tr><td class="dsphdr">Condition</td>
                                  @dtw_assign(operNbr, "operCondition")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchCondition" size="15" maxlength="50"></td>
                              </tr>

                              <tr><td class="dsphdr">Validation</td>
                                  @dtw_assign(operNbr, "operValidation")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input type="text" name="srchValidation" size="15" maxlength="50"></td>
                              </tr>

                              <tr><td class="dsphdr">From Point</td>
                                  @dtw_assign(operNbr, "operFromPoint")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchFromPoint" size="8" maxlength="8"></td>
                              </tr>

                              <tr><td class="dsphdr">From Sequence</td>
                                  @dtw_assign(operNbr, "operFromSeq")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchFromSeq" size="8" maxlength="8"></td>
                              </tr>

                              <tr><td class="dsphdr">To Point</td>
                                  @dtw_assign(operNbr, "operToPoint")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchToPoint" size="8" maxlength="8"></td>
                              </tr>

                              <tr><td class="dsphdr">To Sequence</td>
                                  @dtw_assign(operNbr, "operToSeq")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchToSeq" size="8" maxlength="8"></td>
                              </tr>

                              <tr><td class="dsphdr">Effective From Date</td>
                                  @dtw_assign(operNbr, "operFromDate")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchFromDate" size="6" maxlength="6">
                                      <a href="javascript:calWindow('srchFromDate');">$(calendarImage)</a></td>
                              </tr>

                              <tr><td class="dsphdr">Effective To Date</td>
                                  @dtw_assign(operNbr, "operToDate")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchToDate" size="6" maxlength="6">
                                      <a href="javascript:calWindow('srchToDate');">$(calendarImage)</a></td>
                              </tr>
                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchFromDesc.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("a.PDDESCU",  "From Detail Point Description", $(srchFromDesc), "U", operFromDesc, "A")
  @Build_WildCard ("TRLEVL",  "And Split Level", $(srchAndSplit), "", operAndSplit, "N")
  @Build_WildCard ("TRFAIL",  "Pass/Fail", $(srchPassFail), "U", operPassFail, "A")
  @Build_WildCard ("TROPT",  "Optional Transition", $(srchOptTransition), "U", operOptTransition, "A")
  @Build_WildCard ("b.PDDESCU",  "To Detail Point Description", $(srchToDesc), "U", operToDesc, "A")
  @Build_WildCard ("coalesce(CMDESCU,' ')",  "Condition", $(srchCondition), "U", operCondition, "A")
  @Build_WildCard ("coalesce(VIDESCU,' ')",  "Validation", $(srchValidation), "U", operValidation, "A")
  @Build_WildCard ("TRFPNT",  "From Point", $(srchFromPoint), "", operFromPoint, "N")
  @Build_WildCard ("TRFSEQ",  "From Sequence", $(srchFromSeq), "", operFromSeq, "N")
  @Build_WildCard ("TRTPNT",  "To Point", $(srchToPoint), "", operToPoint, "N")
  @Build_WildCard ("TRTSEQ",  "To Sequence", $(srchToSeq), "", operToSeq, "N")
  @Build_WildCard ("TREFDT", "Effective From Date", $(srchFromDate), "", operFromDate, "D")
  @Build_WildCard ("TRETDT", "Effective To Date", $(srchToDate), "", operToDate, "D")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}