%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Event Code"
  d2wName                 = "EventCode.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fileName=@dtw_rurlescseq(fileName)&amp;fileDesc=@dtw_rurlescseq(fileDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HSYEVN_E"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@fileName", "@dtw_rurlescseq(fileName)", "1", "a", workURL)
  @dtw_replace(workURL, "@@fileDesc", "@dtw_rurlescseq(fileDesc)", "1", "a", workURL)
%}
%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "EVENTCODE")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select ECEVNT, ECDESC, ECIMG, ECAUTO, ECEXPG, ECRESV, upper(ECDESC) as ECDESCU", stmtSQL)
                      @dtw_concat(fileSQL, " SYEVNT ", fileSQL)
                      @dtw_concat(selectSQL, "ECFILN = '$(fileName)' ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @EventCode_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) EventCode_Query (IN  CHAR(64)    profileHandle,
                                        CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)

      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  <td class="toolbar">
                      <a href="$(homeURL)$(cGIPath)userdefinedfile.d2w/REPORT$(genericVarBase)" title="Return To User-Defined File">$(portalHome)</a>
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)EventCodeMaintain.d2w/REPORT$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      <table $(contentTable)>
          @Format_Header("Table", $(fileDesc), $(fileName))
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Event Code</th>
                      <th class="colhdr">Description</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchEvent" size="10" maxlength="10">
                          <input type="hidden" name="operEvent" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchDesc" size="20" maxlength="20">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchEvent.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("ECEVNT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Code" title="Sequence By Event Code">Event Code</a></th>
              @OrderBy_Sort("ECDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Desc" title="Sequence By Description, Event Code">Description</a></th>
              @OrderBy_Sort("ECAUTO", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Auto" title="Sequence By Auto Generate Event, Event Code">Auto Gen<br>Event</a></th>
              @OrderBy_Sort("ECEXPG", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ExitPgm" title="Sequence By Exit Program, Event Code">Exit<br>Program</a></th>
              @OrderBy_Sort("ECIMG", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Image" title="Sequence By Image, Event Code">Image</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;eventCode=@dtw_rurlescseq(V_ECEVNT)&amp;eventCodeDesc=@dtw_rurlescseq(V_ECDESC)&amp;eventResv=@dtw_rurlescseq(V_ECRESV)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_ECDESC), $(V_ECEVNT), "", "", "", "", confirmDesc)
              @dtw_assign(imageExists, "")
              %if (V_ECIMG != "")
                  @dtw_assign(eventImage, "$(V_ECIMG)")
                  @dtwf_exists(eventImage, imageExists)
              %endif

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)EventCodeMaintain.d2w/REPORT$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_01=="Y" && sec_04=="Y")
                              <a href="$(homeURL)$(cGIPath)EventCodeMaintain.d2w/REPORT$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y" && V_ECRESV != "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)EventCodeMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph">$(V_ECEVNT)</td>
                  <td class="colalph">$(V_ECDESC)</td>
                  <td class="colcode">$(V_ECAUTO)</td>
                  <td class="colcode">$(V_ECEXPG)</td>
                  <td class="colalph">$(V_ECIMG)</td>
                  %if (imageExists == "Y")
                      <td class="colicon"><img src="$(homeURL)$(eventImage)" border="0" alt=""></td>
                  %endif
               </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "ECDESCU,ECEVNT")
          @DTW_ASSIGN(orderByDisplay, "Description, Event Code")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Code")
      %if (orderBy == "ECEVNT")
          @DTW_ASSIGN(orderBy, "ECEVNT DESC")
          @DTW_ASSIGN(orderByDisplay, "Event Code (descending)")
      %else
          @DTW_ASSIGN(orderBy, "ECEVNT")
          @DTW_ASSIGN(orderByDisplay, "Event Code")
      %endif
  %elif (sequence == "Desc")
      %if (orderBy == "ECDESCU,ECEVNT")
          @DTW_ASSIGN(orderBy, "ECDESCU DESC,ECEVNT")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Event Code")
      %else
          @DTW_ASSIGN(orderBy, "ECDESCU,ECEVNT")
          @DTW_ASSIGN(orderByDisplay, "Description, Event Code")
      %endif
  %elif (sequence == "Auto")
      %if (orderBy == "ECAUTO,ECEVNT")
          @DTW_ASSIGN(orderBy, "ECAUTO DESC,ECEVNT")
          @DTW_ASSIGN(orderByDisplay, "Auto Generate Event (descending), Event Code")
      %else
          @DTW_ASSIGN(orderBy, "ECAUTO,ECEVNT")
          @DTW_ASSIGN(orderByDisplay, "Auto Generate Event, Event Code")
      %endif
  %elif (sequence == "ExitPgm")
      %if (orderBy == "ECEXPG,ECEVNT")
          @DTW_ASSIGN(orderBy, "ECEXPG DESC,ECEVNT")
          @DTW_ASSIGN(orderByDisplay, "Exit Program (descending), Event Code")
      %else
          @DTW_ASSIGN(orderBy, "ECEXPG,ECEVNT")
          @DTW_ASSIGN(orderByDisplay, "Exit Program, Event Code")
      %endif
  %elif (sequence == "Image")
      %if (orderBy == "ECIMG,ECEVNT")
          @DTW_ASSIGN(orderBy, "ECIMG DESC,ECEVNT")
          @DTW_ASSIGN(orderByDisplay, "Image (descending), Event Code")
      %else
          @DTW_ASSIGN(orderBy, "ECIMG,ECEVNT")
          @DTW_ASSIGN(orderByDisplay, "Image, Event Code")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
  @Build_WildCard ("ECEVNT", "Event Code", $(srchEvent), "U", operEvent, "A")
  @Build_WildCard ("upper(ECDESC)", "Description", $(srchDesc), "U", operDesc, "A")
  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
