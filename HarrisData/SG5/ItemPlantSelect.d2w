                  <td class="colalph"><a href="$(homeURL)$(cGIPath)ConfigurationHeaderSelect.d2w/REPORT$(d2wVarBase)&amp;configurationType=@dtw_rurlescseq(V_CHCFGT)&amp;configurationID=@dtw_rurlescseq(V_CHCFGI)" title="View Configuration Header">$(V_CHCDSC)</a></td>
                  <td class="colalph">$(V_CHECN)</td>
