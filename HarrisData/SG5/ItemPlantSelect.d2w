%FUNCTION(dtw_sql) ItemPlant_Select_Vendor_Open_Orders (IN  CHAR(64)    profileHandle,
				                                            CHAR(2)     dataBaseID,
                                                            CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="vendoropenorders"></a>
      @dtw_assign(moreURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=186&amp;fKey1=PDITEM&amp;fVal1=@dtw_rurlescseq(itemNumber)&amp;fDsc1=@dtw_rurlescseq(itemDescription)&amp;tag=QSEARCH")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>

          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("POVEND", "Vendor")
                  @Format_Column_Header("xxx", "Vendor Name")
                  @Format_Column_Header("PDVDSN", "Vendor Item")
                  @Format_Column_Header("POBUYR", "Buyer")
                  @Format_Column_Header("POTYPE", "Order<br>Type")
                  @Format_Column_Header("PDOVWH", "Whs")
                  @Format_Column_Header("PDPO", "Purchase<br>Order")
                  @Format_Column_Header("PDPOL#", "Line")
                  @Format_Column_Header("PDPORL", "Rel")
                  @Format_Column_Header("PDRORD", "Reference")
                  @Format_Column_Header("PDRQDT", "Required<br>Date")
                  @Format_Column_Header("xxx", "Quantity<br>Ordered")
                  @Format_Column_Header("PDQHRT", "Quantity<br>Held In Receiving")
                  @Format_Column_Header("xxx", "Quantity<br>Received To Date")
                  @Format_Column_Header("PDDSCC", "Cost")
                  @Format_Column_Header("xxx", "Extended<br>Cost")
              </tr>
          %endif
   			
          %ROW{
              %INCLUDE "SetRowClass.icl"
              @RtvFldDesc("VMVEND=$(V_POVEND)", "HDVEND", "VMVNA1", vendorName)
              %if (V_PDPORL == "0")
                  @Format_Nbr("@dtw_rdivide(@dtw_rmultiply(V_PDQTOR, V_PDDSCC), V_PDPCPB)", extendedPrice, "2", $(amtEditCode), "Y", "", "")
                  @Format_Nbr(V_PDDSCC, F_PDDSCC, $(prcNbrDec), $(amtEditCode), "", "", "")
              %endif
              @Format_Nbr("@dtw_rdivide(V_PDQTOR, V_PDPCPB)", qtyOrdered, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(V_PDQHRT, F_PDQHRT, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr("@dtw_rdivide(@dtw_radd(V_PDQRST, @dtw_radd(V_PDQRRT, V_PDQRFT)), V_PDPCPB)", qtyRecv, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              @Format_Nbr(V_PDDSCC, F_PDDSCC, $(prcNbrDec), $(amtEditCode), "", "", "")
              @Format_Date(V_PDRQDT, "D", F_PDRQDT)
              @RtvFldDesc("OTAPID='PO' and OTOTCD='$(V_POTYPE)'", "HDOTYP", "OTDESC", orderTypeDesc)

              <tr class="$(rowClass)">
                  <td class="colnmbr"><a href="$(homeURL)$(phpPath)VendorDashboard.php$(altVarBase)&amp;vendorNumber=$(V_POVEND)&amp;fromItem=@dtw_rurlescseq($(itemNumber))" title="View Vendor Dashboard">$(V_POVEND)</a></td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)VendorSelect.d2w/REPORT$(genericVarBase)&amp;vendorNumber=@dtw_rurlescseq(V_POVEND)&amp;vendorName=@dtw_rurlescseq(vendorName)" title="View Vendor">$(vendorName)</a></td>
                  <td class="colalph">$(V_PDVDSN)</td>
                  <td class="colalph"><a href="$(homeURL)$(phpPath)BuyerSelect.php$(altVarBase)&amp;buyer=@dtw_rurlescseq(V_POBUYR)" title="View Buyer">$(V_BMBNA1)</a></td>
                  <td class="colcode" $(helpCursor)><span title="$(orderTypeDesc)">$(V_POTYPE)</span></td>
                  <td class="colnmbr"><a href="$(homeURL)$(cGIPath)ItemWarehouseSelect.d2w/REPORT$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq($(itemNumber))&amp;warehouseNumber=@dtw_rurlescseq(V_PDOVWH)" title="View Item/Warehouse"> $(V_PDOVWH)</a></td>
                  <td class="colnmbr"><a href="$(homeURL)$(phpPath)SelectPO.php$(altVarBase)&amp;vendorNumber=@dtw_rurlescseq(V_POVEND)&amp;vendorName=@dtw_rurlescseq(vendorName)&amp;purchaseOrderNumber=@dtw_rurlescseq(V_PDPO)" title="View Purchase Order">$(V_PDPO)</a></td>
                  <td class="colnmbr">$(V_PDPOL#)</td>
                  <td class="colnmbr">$(V_PDPORL)</td>
                  <td class="colalph">$(V_PDRORD)</td>
                  <td class="coldate">$(F_PDRQDT)</td>
                  <td class="colnmbr">$(qtyOrdered)</td>
                  <td class="colcode">$(F_PDQHRT)</td>
                  <td class="colnmbr">$(qtyRecv)</td>
                  %if (V_PDPORL == "0")
                      <td class="colnmbr">$(F_PDDSCC)</td>
                      <td class="colnmbr">$(extendedPrice)</td>
                  %else
                      <td class="colcode">&nbsp;</td>
                      <td class="colcode">&nbsp;</td>
                  %endif
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

