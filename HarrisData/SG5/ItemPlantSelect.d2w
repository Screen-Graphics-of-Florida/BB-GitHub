      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) ItemPlant_Select_ManufacturingOrders (IN  CHAR(64)    profileHandle,
				                              CHAR(2)     dataBaseID,
                                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="manufacturingorders"></a>
      @dtw_assign(moreURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=445&amp;fKey1=OHPLT&amp;fVal1=@dtw_rurlescseq(plantNumber)&amp;fKey2=OHPN&amp;fVal2=@dtw_rurlescseq(itemNumber)&amp;tag=QSEARCH")
      %INCLUDE "QuickLinkTopOfForm.icl"

          %if (sql_Record_Count == "0")
              <table $(contentTable)>
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              @Format_Nbr(totalQuantity, F_totalQuantity, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
              <div class="page">
                   Total Quantity All Mfg Orders: $(F_totalQuantity)
              </div>

              <table $(contentTable)>
                  <tr>
                      @Format_Column_Header("OHORD", "Order<br>Number")
                      @Format_Column_Header("OHCQTY", "Quantity")
                      @Format_Column_Header("OHCSDT", "Start Date")
                      @Format_Column_Header("OHCDDT", "Due Date")
                      @Format_Column_Header("OHOTYP", "Order<br>Type")
                      @Format_Column_Header("OHSTC", "Status")
                      @Format_Column_Header("OHPAPS", "Print<br>Switch")
                      @Format_Column_Header("OHRORD", "Reference Number")
                  </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @RtvFldDesc("IMITEM='$(V_OHPN)'", "HDIMST", "IMIMDS", itemDesc)
              @RtvFldDesc("FLTYPE='MFGORDTYPE' and FLVALU='$(V_OHOTYP)'", "SYFLAG", "FLDESC", orderTypeDesc)
              @RtvFldDesc("FLTYPE='MFGORDSTAT' and FLVALU='$(V_OHSTC)'", "SYFLAG", "FLDESC", statusDesc)
              @RtvFldDesc("FLTYPE='PAPERSW' and FLVALU='$(V_OHPAPS)'", "SYFLAG", "FLDESC", paperSwitchDesc)
              @Format_Nbr($(V_OHCQTY), F_OHCQTY, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Date_ISO(V_OHCSDT, "D", F_OHCSDT)
              @Format_Date_ISO(V_OHCDDT, "D", F_OHCDDT)
	       <tr class="$(rowClass)">
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)SelectMfgOrder.d2w/REPORT$(d2wVarBase)&amp;mfgOrder=@dtw_rurlescseq(V_OHORD)" onclick="$(inquiryWinVar)" title="View Mfg Order">$(V_OHORD)</a></td>
                  <td class="colnmbr">$(F_OHCQTY)</td>
                  <td class="colnmbr">$(F_OHCSDT)</td>
                  <td class="colnmbr">$(F_OHCDDT)</td>
                  <td class="colcode" $(helpCursor)><span title="$(orderTypeDesc)">$(V_OHOTYP)</span></td>
                  <td class="colcode" $(helpCursor)><span title="$(statusDesc)">$(V_OHSTC)</span></td>
                  <td class="colcode" $(helpCursor)><span title="$(paperSwitchDesc)">$(V_OHPAPS)</span></td>
                  <td class="colalph">$(V_OHRORD)</td>
	       </tr>
          %}
      </table>
      </fieldset>
  %}
%}
%FUNCTION(dtw_sql) ItemPlant_Select_Current_Quantities (IN CHAR(64)    profileHandle,
				                            CHAR(2)     dataBaseID,
                                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="currentquantities"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      %ROW{
          @RtvFldDesc("IMITEM='$(itemNumber)'", "HDIMST", "IMQUAL", V_IMQUAL)
          @dtw_assign(edtVar, "")
          @Concat_Field("@@pdrl", V_HDPDRL)
          @Concat_Field("@@item", itemNumber)
          @Concat_Field("@@plt@", plantNumber)
          @dtw_concat(edtVar, "}{", edtVar)
          @Get_Qty_ItemPlt(edtVar)

          @Decat_Negative("@@aval")   @dtw_assign(V_SQAVAL, fieldValue)
          @Decat_Negative("@@ohqt")   @dtw_assign(V_SQOHQT, fieldValue)
          @Decat_Negative("@@ohrc")   @dtw_assign(V_SQOHRC, fieldValue)
          @Decat_Negative("@@qhsr")   @dtw_assign(V_SQQHSR, fieldValue)
          @Decat_Negative("@@qoo@")   @dtw_assign(V_SQQOO,  fieldValue)
          @Decat_Negative("@@qiyt")   @dtw_assign(V_SQQIYT, fieldValue)
          @Decat_Negative("@@qsyt")   @dtw_assign(V_SQQSYT, fieldValue)
          @Decat_Negative("@@quns")   @dtw_assign(V_SQQUNS, fieldValue)
          @Decat_Negative("@@qryt")   @dtw_assign(V_SQQRYT, fieldValue)
          @Decat_Negative("@@qayt")   @dtw_assign(V_SQQAYT, fieldValue)
          @Decat_Negative("@@resq")   @dtw_assign(V_SQRESQ, fieldValue)

          @Format_Nbr(V_SQAVAL, F_SQAVAL, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_SQOHQT, F_SQOHQT, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_SQOHRC, F_SQOHRC, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_SQQHSR, F_SQQHSR, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_SQQOO,  F_SQQOO,  $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_SQQSYT, F_SQQSYT, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_SQQUNS, F_SQQUNS, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_SQQRYT, F_SQQRYT, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_SQQAYT, F_SQQAYT, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_SQRESQ, F_SQRESQ, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_IPFOQ,  F_IPFOQ,  "0", $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_IPMNQ,  F_IPMNQ,  "0", $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_IPMXQ,  F_IPMXQ,  "0", $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_IPMUQ,  F_IPMUQ,  "0", $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_IPSSQ,  F_IPSSQ,  "0", $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_IPOHFS, F_IPOHFS, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_IPCMTO, F_IPCMTO, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_IPQMRL, F_IPQMRL, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_IPFPOQ, F_IPFPOQ, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_IPQMFG, F_IPQMFG, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
          @dtw_add(V_IPYTDU, V_SQQIYT, V_usage)
          @Format_Nbr(V_usage, F_usage, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_IPSCRP, F_IPSCRP, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_IPYTDL, F_IPYTDL, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
          @Format_Nbr(V_IPAAU,  F_IPAAU,  $(qtyNbrDec), $(qtyEditCode), "Y", "", "")

          <table $(contentTable)>
              <tr valign=top>
                  <td>
                      <table $(contentTable)>
                          <tr valign="top">
                              <td>
                                  <table $(contentTable)>
                                      <tr>
                                          <td class="dsphdr">On Hand</td>
                                          <td class="dspcode">&nbsp;</td>
                                          <td class="dspqty">$(F_SQOHQT)</td>
                                      </tr>
                                      %if (V_CIOOIA == "Y")
                                          <tr>
                                              <td class="dsphdr">On Order</td>
                                              <td class="dspcode">+</td>
                                              <td class="dspqty">$(F_SQQOO)</td>
                                          </tr>
                                      %endif
                                      %if (V_IMQUAL != "Y")
                                          <tr>
                                              <td class="dsphdr">On Hand Receiving</td>
                                              <td class="dspcode">+</td>
                                              <td class="dspqty">$(F_SQOHRC)</td>
                                          </tr>
                                      %endif
                                      <tr>
                                          <td class="dsphdr">On Hand Floorstock</td>
                                          <td class="dspcode">+</td>
                                          <td class="dspqty">$(F_IPOHFS)</td>
                                      </tr>
                                      <tr>
                                          <td class="dsphdr">Committed To Mfg</td>
                                          <td class="dspcode">-</td>
                                          <td class="dspqty">$(F_IPCMTO)</td>
                                      </tr>
                                      <tr>
                                          <td class="dsphdr">Held In Stock</td>
                                          <td class="dspcode">-</td>
                                          <td class="dspqty">$(F_SQQHSR)</td>
                                      </tr>
                                      <tr>
                                          <td class="dsphdr">Reserved</td>
                                          <td class="dspcode">-</td>
                                          <td class="dspqty">$(F_SQRESQ)</td>
                                      </tr>
                                      <tr>
                                          <td class="dsphdr">Available</td>
                                          <td class="dspcode">&nbsp;</td>
                                          <td class="dsptotal">$(F_SQAVAL)</td>
                                      </tr>
                                  </table>
                              </td>
                              <td>&nbsp;</td>
                              <td>
                                  <table $(contentTable)>
                                      %if (V_IMQUAL == "Y")
                                          <tr>
                                              <td class="dsphdr">On Hand Receiving</td>
                                              <td class="dspqty">$(F_SQOHRC)</td>
                                          </tr>
                                      %endif
                                      %if (V_CIOOIA != "Y")
                                          <tr>
                                              <td class="dsphdr">On Order</td>
                                              <td class="dspqty">$(F_SQQOO)</td>
                                          </tr>
                                      %endif
                                      <tr>
                                          <td class="dsphdr">On Order Unscheduled</td>
                                          <td class="dspqty">$(F_SQQUNS)</td>
                                      </tr>
                                      <tr>
                                          <td class="dsphdr">Released</td>
                                          <td class="dspqty">$(F_IPQMRL)</td>
                                      </tr>
                                      <tr>
                                          <td class="dsphdr">Firm Planned</td>
                                          <td class="dspqty">$(F_IPFPOQ)</td>
                                      </tr>
                                      <tr>
                                          <td class="dsphdr">Prior Year Usage</td>
                                          <td class="dspqty">$(F_IPYTDL)</td>
                                      </tr>
                                      <tr>
                                          <td class="dsphdr">Anticipated Annual Usage</td>
                                          <td class="dspqty">$(F_IPAAU)</td>
                                      </tr>
                                      <tr>
                                          <td class="dsphdr">Fixed Order</td>
                                          <td class="dspqty">$(F_IPFOQ)</td>
                                      </tr>
                                      <tr>
                                          <td class="dsphdr">Minimum Order</td>
                                          <td class="dspqty">$(F_IPMNQ)</td>
                                      </tr>
                                      <tr>
                                          <td class="dsphdr">Maxmimum Order</td>
                                          <td class="dspqty">$(F_IPMXQ)</td>
                                      </tr>
                                      <tr>
                                          <td class="dsphdr">Multiple Order</td>
                                          <td class="dspqty">$(F_IPMUQ)</td>
                                      </tr>
                                      <tr>
                                          <td class="dsphdr">Safety Stock</td>
                                          <td class="dspqty">$(F_IPSSQ)</td>
                                      </tr>
                                  </table>
                              </td>
                              <td>&nbsp;</td>
                              <td>
                                  <fieldset class="legendBody">
                                  <legend class="legendTitle">Year To Date</legend>
                                      <table $(contentTable)>
                                          <tr>
                                              <td class="dsphdr">Billed</td>
                                              <td class="dspqty">$(F_SQQSYT)</td>
                                          </tr>
                                          <tr>
                                              <td class="dsphdr">Manufactured</td>
                                              <td class="dspqty">$(F_IPQMFG)</td>
                                          </tr>
                                          <tr>
                                              <td class="dsphdr">Received</td>
                                              <td class="dspqty">$(F_SQQRYT)</td>
                                          </tr>
                                          <tr>
                                              <td class="dsphdr">Usage</td>
                                              <td class="dspqty">$(F_usage)</td>
                                          </tr>
                                          <tr>
                                              <td class="dsphdr">Scrapped</td>
                                              <td class="dspqty">$(F_IPSCRP)</td>
                                          </tr>
                                          <tr>
                                              <td class="dsphdr">Adjusted</td>
                                              <td class="dspqty">$(F_SQQAYT)</td>
                                          </tr>
                                      </table>
                                  </fieldset>
                              </td>
                          </tr>
                      </table>
                  </td>
              </tr>
          </table>
      %}
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) ItemPlant_Select_Usage_ByPeriod (IN CHAR(64)    profileHandle,
				                        CHAR(2)     dataBaseID,
                                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{ 

      <a name="usagebyperiod"></a>
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("PHPERD", "Transaction<br>Period")
                  @Format_Column_Header("PHYTDU", "Usage")
                  @Format_Column_Header("PHSCRP", "Scrapped<br>From WIP")
                  @Format_Column_Header("PHYADJ", "Adjustments")
                  @Format_Column_Header("PHYRCV", "Received")
                  @Format_Column_Header("PHYFSS", "Scrapped<br>From Floorstock")
                  @Format_Column_Header("PHQMFG", "Manufactured")
                  @Format_Column_Header("PHREWK", "Reported<br>To Rework")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
	       <tr class="$(rowClass)">
                  @PeriodFromCYP(V_PHPERD)
                  @Format_Nbr($(V_PHYTDU), F_PHYTDU, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                  @Format_Nbr($(V_PHSCRP), F_PHSCRP, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                  @Format_Nbr($(V_PHYADJ), F_PHYADJ, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                  @Format_Nbr($(V_PHYRCV), F_PHYRCV, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                  @Format_Nbr($(V_PHYFSS), F_PHYFSS, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                  @Format_Nbr($(V_PHQMFG), F_PHQMFG, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                  @Format_Nbr($(V_PHREWK), F_PHREWK, $(qtyNbrDec), $(qtyEditCode), "", "", "")

                  <td class="colcode">$(V_PHPERD)</td>
                  <td class="colnmbr">$(F_PHYTDU)</td>
                  <td class="colnmbr">$(F_PHSCRP)</td>
                  <td class="colnmbr">$(F_PHYADJ)</td>
                  <td class="colnmbr">$(F_PHYRCV)</td>
                  <td class="colnmbr">$(F_PHYFSS)</td>
                  <td class="colnmbr">$(F_PHQMFG)</td>
                  <td class="colnmbr">$(F_PHREWK)</td>
	       </tr>
          %}
      </table>
      </fieldset>
  %}
%}

