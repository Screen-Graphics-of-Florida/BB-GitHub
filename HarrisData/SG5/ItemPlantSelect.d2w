%FUNCTION(dtw_sql) ItemPlant_Select_Kanban_Triggers (IN  CHAR(64)    profileHandle,
				                          CHAR(2)     dataBaseID,
                                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="kanbantriggers"></a>
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      @RtvFldDesc("IPPLT=$(plantNumber) AND IPITEM='$(itemNumber)'", "HDIPLT", "IPPTYP", partType)
      @RtvFldDesc("IPPLT=$(plantNumber) AND IPITEM='$(itemNumber)'", "HDIPLT", "IPKBPC", policyCode)
      @RtvFldDesc("IPPLT=$(plantNumber) AND IPITEM='$(itemNumber)'", "HDIPLT", "CHAR(IPCQTY)", numberContainer)
      @RtvFldDesc("IPPLT=$(plantNumber) AND IPITEM='$(itemNumber)'", "HDIPLT", "IPCTID", containerID)
      @RtvFldDesc("IPPLT=$(plantNumber) AND IPITEM='$(itemNumber)'", "HDIPLT", "CHAR(IPCADJ)", containerAdjustment)
      @RtvFldDesc("IPPLT=$(plantNumber) AND IPITEM='$(itemNumber)'", "HDIPLT", "CHAR(IPCQTS)", containerInUse)
      @RtvFldDesc("IPPLT=$(plantNumber) AND IPITEM='$(itemNumber)'", "HDIPLT", "CHAR(IPFOQ)", orderQuantity)
      @RtvFldDesc("IPPLT=$(plantNumber) AND IPITEM='$(itemNumber)'", "HDIPLT", "CHAR(IPODPT)", orderPoint)
      @RtvFldDesc("IPPLT=$(plantNumber) AND IPITEM='$(itemNumber)'", "HDIPLT", "CHAR(IPVEND)", vendorNumber)
      @RtvFldDesc("IPPLT=$(plantNumber) AND IPITEM='$(itemNumber)'", "HDIPLT", "CHAR(IPBAC)", analystNumber)
      @RtvFldDesc("IPPLT=$(plantNumber) AND IPITEM='$(itemNumber)'", "HDIPLT", "IPKBDD", documentDefinition)
      %if (documentDefinition == "")
          @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLKBDD", documentDefinition)
      %endif
      @RtvFldDesc("FLTYPE='PARTTYPE' AND FLVALU='$(partType)'", "SYFLAG", "FLDESC", partTypeDesc)
      @RtvFldDesc("FLTYPE='KANBANPLCY' AND FLVALU='$(policyCode)'", "SYFLAG", "FLDESC", policyDesc)
      @RtvFldDesc("CTCTID='$(containerID)'", "HDCNTM", "CTDESC", containerDesc)
      @RtvFldDesc("VMVEND=$(vendorNumber)", "HDVEND", "VMVNA1", vendorName)
      @RtvFldDesc("BMBUYR=$(analystNumber)", "HDBUYR", "BMBNA1", analystName)
      @RtvFldDesc("FLTYPE='KANBANDOC' AND FLVALU='$(documentDefinition)'", "SYFLAG", "FLDESC", documentDesc)
      %INCLUDE "KanbanMaintain.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("KBTURN", "Kanban<br>Turnaround")
                  @Format_Column_Header("KBSTAT", "Status")
                  @Format_Column_Header("KBDEPT", "Dept")
                  @Format_Column_Header("KBWC",   "Work<br>Center")
                  @Format_Column_Header("KBFWHS", "Whs")
                  @OrderBy_Sort("KBFSTK", sortVar)
                  @dtw_assign(columnHdr, "Stock Location")
                  %if (sortVar == "sort")
                     <th class="colhdr$(sortVar)" colspan="3" $(helpCursor)><span title="$(orderByDisplay)">$(columnHdr)</span></th>
                  %else
                     <th class="colhdr" colspan="3">$(columnHdr)</th>
                  %endif
                  @Format_Column_Header("KBTTRN", "Traveler Turnaround")
                  @Format_Column_Header("KBLLSZ", "Last Order Quantity")
                  @Format_Column_Header("KBVEND", "Vendor Number")
                  @Format_Column_Header("KBVNDT", "Date Vendor Notified")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colnmbr">$(V_KBTURN)</td>
                  @RtvFldDesc("FLTYPE='KANBANSTAT' AND FLVALU='$(V_KBSTAT)'", "SYFLAG", "FLDESC", fieldDesc)
                  <td class="colcode" $(helpCursor)><span title="$(fieldDesc)">$(V_KBSTAT)</span></td>
                  <td class="colalph">$(V_KBDEPT)</td>
                  <td class="colalph">$(V_KBWC)</td>
                  @Format_Nbr($(V_KBFWHS), F_KBFWHS, "0", "Z", "", "", "")
                  <td class="colnmbr">$(F_KBFWHS)</td>
                  <td class="colalph">$(V_KBFSTK)</td>
                  <td class="colalph">$(V_KBFAIL)</td>
                  <td class="colalph">$(V_KBFSLC)</td>
                  @Format_Nbr($(V_KBTTRN), F_KBTTRN, "0", "Z", "", "", "")
                  <td class="colnmbr">$(F_KBTTRN)</td>
                  @Format_Nbr($(V_KBLLSZ), F_KBLLSZ, "0", "Z", "", "", "")
                  <td class="colnmbr">$(F_KBLLSZ)</td>
                  @Format_Nbr($(V_KBVEND), F_KBVEND, "0", "Z", "", "", "")
                  <td class="colnmbr">$(F_KBVEND)</td>
                  @Format_Date(V_KBVNDT, "D", F_KBVNDT)
                  <td class="coldate">$(F_KBVNDT)</td>
              </tr>
	   %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) ItemPlant_Select_Customer_Order_History (IN CHAR(64)    profileHandle,
				                                               CHAR(2)     dataBaseID,
                                                               CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="customerorderhistory"></a>
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("OESHTO", "Customer<br>Number")
                  @Format_Column_Header("xxx", "Customer Name")
                  @Format_Column_Header("HHORTY", "Order<br>Type")
                  @Format_Column_Header("DHORD#", "Order<br>Number")
                  @Format_Column_Header("DHORL#", "Line")
                  @Format_Column_Header("DHBLN#", "Rel")
                  @Format_Column_Header("DHRQDT", "Required<br>Date")
                  @Format_Column_Header("DHQORD", "Quantity<br>Ordered")
                  @Format_Column_Header("DHQSTD", "Quantity<br>Shipped")
                  @Format_Column_Header("DHSLPR", "Price")
                  @Format_Column_Header("xxx", "Extended<br>Price")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Date(V_DHRQDT, "D", F_DHRQDT)
              %if (V_DHBLKT != "Y")
                  %if (V_DHSEQ# == "0")
                      @Format_Nbr("@dtw_rdivide(@dtw_rmultiply(V_DHQSTD, V_DHSLPR), V_DHORUF)", extendedPrice, "2", $(amtEditCode), "Y", "", "")
                  %else
                      @Format_Nbr("@dtw_rdivide(@dtw_rmultiply(V_DHQSTC, V_DHSLPR), V_DHORUF)", extendedPrice, "2", $(amtEditCode), "Y", "", "")
                  %endif
              %endif
              @Format_Nbr(V_DHQORD, F_DHQORD, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr(V_DHQSTD, F_DHQSTD, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr(V_DHQSTC, F_DHQSTC, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr(V_DHSLPR, F_DHSLPR, $(prcNbrDec), $(amtEditCode), "", "", "")

              @dtw_assign(customerNumber, V_HHSHTO)
              @RtvFldDesc("CMCUST=$(customerNumber)", "HDCUST", "CMCNA1", customerName)
              @RtvFldDesc("SMSLSM=$(V_HHSLSM)", "HDSLSM", "SMSNA1", salesmanName)
              @RtvFldDesc("OTAPID='OE' and OTOTCD='$(V_HHORTY)'", "HDOTYP", "OTDESC", orderTypeDesc)

              <tr class="$(rowClass)">
                  <td class="colnmbr"><a href="$(homeURL)$(cGIPath)CustomerInquiry.d2w/DISPLAY$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)" onclick="$(inquiryWinVar)" title="Customer Quickview">$(customerNumber)</a></td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)CustomerSelect.d2w/REPORT$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)" title="View Customer">$(customerName)</a></td>
                  <td class="colcode" $(helpCursor)><span title="$(orderTypeDesc)">$(V_HHORTY)</span></td>
                  <td class="colnmbr"><a onClick="saveCurrentURL();" href="$(homeURL)$(cGIPath)SelectOrderHistory.d2w/REPORT$(d2wVarBase)&amp;orderNumber=@dtw_rurlescseq(V_DHORD#)&amp;orderSequence=@dtw_rurlescseq(V_DHSEQ#)&amp;noMenu=@dtw_rurlescseq(noMenu)" title="View Shipment Summary">$(V_DHORD#)</a></td>
                  <td class="colcode">$(V_DHORL#)</td>
                  <td class="colcode">$(V_DHBLN#)</td>
                  <td class="coldate">$(F_DHRQDT)</td>
                  <td class="colnmbr">$(F_DHQORD)</td>
                  %if (orderSequence == "000")
                      <td class="colnmbr">$(F_DHQSTD)</td>
                  %else
                      <td class="colnmbr">$(F_DHQSTC)</td>
                  %endif
                  %if (V_DHBLKT != "Y")
                      <td class="colnmbr">$(F_DHSLPR)</td>
                      <td class="colnmbr">$(extendedPrice)</td>
                  %endif
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) ItemPlant_Select_Top_Customers (IN CHAR(64)    profileHandle,
				                                      CHAR(2)     dataBaseID,
                                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (quicklinkRef == "ytdtopcustomers" )
          <a name="ytdtopcustomers"></a>
      %else
          <a name="lastyeartopcustomers"></a>
      %endif
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

          %if (sql_Record_Count == "0")
              <table $(contentTable)>
                  %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              @Format_Nbr(salesTotal, F_salesTotal, "2", $(amtEditCode), "", "$", "")
              <div class="page">
                   Total Sales: $(F_salesTotal)
              </div>

              <table $(contentTable)>
                  <tr>
                      @Format_Column_Header("DHSHTO", "Customer<br>Number")
                      @Format_Column_Header("xxx", "Customer Name")
                      @Format_Column_Header("SALES", "Sales")
                      @Format_Column_Header("xxx", "Percent<br>of Total")
                      @Format_Column_Header("QTYSHIPPED", "Quantity")
                  </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              %if (salesTotal > "0")
                  @dtw_multiply(V_SALES, "100", percentOfTotal)
                  @dtw_divide(percentOfTotal, salesTotal, percentOfTotal)
                  @Format_Nbr($(percentOfTotal), F_percentOfTotal, "2", $(pctEditCode), "Y", "", "%")
              %else
                  @dtw_assign(F_percentOfTotal, "")
              %endif
              @Format_Nbr(V_QTYSHIPPED, F_QTYSHIPPED, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr($(V_SALES), F_SALES, "2", $(amtEditCode), "", "", "")
              @dtw_assign(customerNumber, V_DHSHTO)
              @RtvFldDesc("CMCUST=$(customerNumber)", "HDCUST", "CMCNA1", customerName)

              <tr class="$(rowClass)">
                  %if (customerName>"")
                      <td class="colnmbr"><a href="$(homeURL)$(cGIPath)CustomerInquiry.d2w/DISPLAY$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)" onclick="$(inquiryWinVar)" title="Customer Quickview">$(customerNumber)</a></td>
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)CustomerSelect.d2w/REPORT$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)" title="View Customer">$(customerName)</a></td>
                  %else
                      <td class="colnmbr">$(customerNumber)</td>
                      <td class="colalph">$(customerName)</td>
                  %endif
                  <td class="colnmbr">$(F_SALES)</td>
                  <td class="colnmbr">$(F_percentOfTotal)</td>
                  <td class="colnmbr">$(F_QTYSHIPPED)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) ItemPlant_Select_Top_Vendors (IN CHAR(64)    profileHandle,
				                                    CHAR(2)     dataBaseID,
                                                    CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (quicklinkRef == "ytdtopvendors" )
          <a name="ytdtopvendors"></a>
      %else
          <a name="lastyeartopvendors"></a>
      %endif
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

          %if (sql_Record_Count == "0")
              <table $(contentTable)>
                  %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              @Format_Nbr(purchasesTotal, F_purchasesTotal, "2", $(amtEditCode), "", "$", "")
              <div class="page">
                   Total Purchases: $(F_purchasesTotal)
              </div>

              <table $(contentTable)>
                  <tr>
                      @Format_Column_Header("PHVEND", "Vendor<br>Number")
                      @Format_Column_Header("xxx", "Vendor Name")
                      @Format_Column_Header("PURCHASES", "Purchases")
                      @Format_Column_Header("xxx", "Percent<br>of Total")
                      @Format_Column_Header("RECEIVED", "Quantity")
                  </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              %if (purchasesTotal > "0")
                  @dtw_multiply(V_PURCHASES, "100", percentOfTotal)
                  @dtw_divide(percentOfTotal, purchasesTotal, percentOfTotal)
                  @Format_Nbr($(percentOfTotal), F_percentOfTotal, "2", $(pctEditCode), "Y", "", "%")
              %else
                  @dtw_assign(F_percentOfTotal, "")
              %endif
              @Format_Nbr(V_RECEIVED, F_RECEIVED, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr($(V_PURCHASES), F_PURCHASES, "2", $(amtEditCode), "", "", "")
              @RtvFldDesc("VMVEND=$(V_PHVEND)", "HDVEND", "VMVNA1", vendorName)
              <tr class="$(rowClass)">
                  %if (vendorName>"")
                  	  <td class="colnmbr"><a href="$(homeURL)$(phpPath)VendorDashboard.php$(altVarBase)&amp;vendorNumber=$(V_PHVEND)&amp;fromItem=@dtw_rurlescseq($(itemNumber))" title="View Vendor Dashboard">$(V_PHVEND)</a></td>
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)VendorSelect.d2w/REPORT$(genericVarBase)&amp;vendorNumber=@dtw_rurlescseq(V_PHVEND)&amp;vendorName=@dtw_rurlescseq(vendorName)" title="View Vendor">$(vendorName)</a></td>
                  %else
                      <td class="colnmbr">$(V_PHVEND)</td>
                      <td class="colalph">$(vendorName)</td>
                  %endif
                  <td class="colnmbr">$(F_PURCHASES)</td>
                  <td class="colnmbr">$(F_percentOfTotal)</td>
                  <td class="colnmbr">$(F_RECEIVED)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%INCLUDE "AttachmentSelect.icl"

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
  @Set_SQL(stmtSQL)
%}