%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Manufacturing Order Final Tag"
  d2wName                 = "MfgOrderFinalTag.d2w"
  d2wVarBase              = "$(genericVarBase)"
  programName             = ""
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")	
          <script type="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (document.Chg.transDate.value =="")
                     {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.transDate, 6, 0) &&
                      editdate(document.Chg.transDate))
                      return true;
              }
              %INCLUDE "DateEdit.icl"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "KeyboardFunctionsTS.icl"
              %INCLUDE "ShowHideSelCriteria.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      @dtw_concat(stmtSQL, "Select * From HDTRNM Where DCTURN = $(turnaroundNumber)", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @Tag_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
                   <td>
                       <ul class="toolbarTS">
                          <li class="optionTS"><a href="$(homeURL)$(cGIPath)$(d2wName)/NOUPDATE$(d2wVarBase)">&nbsp;<br>Back</a></li>                       
                          <li class="optionTS"><a href="javascript:check(document.Chg)">&nbsp;<br>Accept</a></li>
                      </ul>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Tag_Query (IN CHAR(64)    profileHandle,
                                 CHAR(2)     dataBaseID,
                                 CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)

      <table $(contentTable)>
          <tr><td><h1>$(page_title)</h1></td></tr>
      </table>

      %ROW {
          <table $(contentTable)>
              <colgroup>
                  <col width="20%">
                  <col width="60%">
                  <col width="15%">
              <tr><td class="hdrtitl">Order:</td>
                  <td class="hdrdata">$(V_DCMORD)</td>
              </tr>
              @RtvFldDesc("IMITEM='$(V_DCPITM)'", "HDIMST", "IMIMDS", itemDescription)
              @Format_Code($(V_DCPITM), F_DCPITM)
              <tr><td class="hdrtitl">Item:</td>
                  <td class="hdrdata">$(itemDescription) &nbsp; $(F_DCPITM)</td>
              </tr>
              <tr><td class="hdrtitl">Reference Number:</td>
                  <td class="hdrdata">$(V_DCRORD)</td>
                  <td><a href="javascript:void+0" onClick="showSel('selData')" onBlur="hideSel('selData')">$(smMoreInfoImage)</a></td>
              </tr>
          </table>
          @RtvFldDesc("PLPLNT=$(V_DCPLT)", "HDPLNT", "PLNAME", plantName)
          @Format_Code($(V_DCPLT), F_plantNumber)
          @RtvFldDesc("IMITEM='$(V_DCPITM)'", "HDIMST", "IMUOMS", stockingUOM)
          @RtvFldDesc("UMUOM='$(stockingUOM)'", "HDUOM", "UMUMLD", uomDescription)
          @Format_Code(stockingUOM, F_stockingUOM)

          @dtw_assign(moreInfo, "")
          @Build_More_Info("Plant", plantName, F_plantNumber, moreInfo)
          @Build_More_Info("Stocking UOM", uomDescription, F_stockingUOM, moreInfo)
          @Build_More_Info("Turnaround", turnaroundNumber, "", moreInfo)
          %INCLUDE "MoreInfo.icl"

          $(hrTagAttr)

          %INCLUDE "ErrorDisplay.icl"
			
          <form class="formClass" method="post" name="Chg" onsubmit="return validate(document.Chg)"  action="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
              %INCLUDE "RequiredFieldTS.icl"
              <table $(contentTable)>
                  %if (errFound != "")
                      @dtw_assign(focusField, "")
                      @EdtVarErr(profileHandle, typeValue, edtVar)
                      @ErrVarErr(profileHandle, typeError, errVar)
                      @DecatErr_Field("@@date", "transDate")         @dtw_assign(Err_DATE, fieldValue)

                      @Decat_Field("@@turn")   @dtw_assign(V_DCTURN,  fieldValue)
                      @Decat_Field("@@date")   @dtw_assign(F_DATE,  fieldValue)

                      @dtw_assign(errFound, "")
                  %else
                      @DateTodayCYMD(F_DATE)
                      @DateInputFromCYMD(F_DATE)
                  %endif

                  @dtw_assign(focusField, "transDate")

                  @SetTextOvr(Err_DATE)
                  <tr><td class="dsphdr"><span $(textOvr)>Date</span></td>
                      <td class="input"><input class="input" id="transDate" onfocus="kbActive(this, 'dtpDiv');" name="transDate" type="text" value="$(F_DATE)" size="6" maxlength="6"> $(reqFieldChar)</td>
                      <td><input name="turnaroundNumber" type="hidden" value="$(V_DCTURN)" size="9"></td>
                  </tr>
                  @DspErrMsg(Err_DATE)

              %}	
          </table>
          %INCLUDE "KeyboardTS.icl"

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HSITFT_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}

%HTML(NOUPDATE) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(confMessage, "Confirm No Update")
  @dtw_assign(returnURL, "DataCollection.d2w/REPORT$(genericVarBase)")
  %INCLUDE "ReturnTS.icl"
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"

  @dtw_assign(transDate,    @dtw_rstrip(transDate))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@turn", turnaroundNumber)
  @Concat_Field("@@date", transDate)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, errFound, edtVar, errVar)

  %if (errFound == "")
      @dtw_assign(confMessage, "Confirm Manufacturing Order Final Tag")
      @dtw_assign(returnURL, "DataCollection.d2w/REPORT$(genericVarBase)")
      %INCLUDE "ReturnTS.icl"
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(genericVarBase)&amp;turnaroundNumber=@dtw_rurlescseq(turnaroundNumber)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
