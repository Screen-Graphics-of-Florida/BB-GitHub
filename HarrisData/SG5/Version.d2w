%INCLUDE "$(baseVar)"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {	
  page_title              = "Portal Version"
  d2wName                 = "Version.d2w"
  d2wVarBase              = "$(genericVarBase)"
  DATABASE                = "*LOCAL"
  DTW_PRINT_HEADER        = "NO"
  versionDisplay          = %TABLE
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_DISPLAY () {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      <table $(contentTable)>
                  	   <colgroup>
                  	       <col width="85%">
                  	       <col width="10%">
                          <tr><td><h1>$(page_title)</h1></td>
                              <td class="toolbar">
                                  %INCLUDE "CloseWindow.icl"
                                  @dtw_assign(medIcon, "Y")
                                  %INCLUDE "HelpPage.icl"
                              </td>
                          </tr>
                      </table>
                      $(inquiryhrTagAttr)
                      @dtw_assign(fileName, "$(homePath)version.txt")
                      @dtwf_read(fileName, "DELIMITED", ",", versionDisplay)
                      <table $(contentTable)>
                         <tr><td class="dsphdr">HarrisData Release</td>
                             <td class="dspalph">@dtw_tb_rgetv(versionDisplay, "1", "1")</td>
                         </tr>
                         <tr><td class="dsphdr">HarrisData Refresh</td>
                             <td class="dspalph">@dtw_tb_rgetv(versionDisplay, "1", "2")</td>
                         </tr>
                         <tr><td class="dsphdr">HarrisData Portal</td>
                             <td class="dspalph">@dtw_tb_rgetv(versionDisplay, "1", "3")</td>
                         </tr>
                         <tr><td class="dsphdr">Title</td>
                             <td class="dspalph">$(title)</td>
                         </tr>
                         <tr><td class="dsphdr">Description</td>
                             <td class="dspalph">$(description)</td>
                         </tr>
                         <tr><td class="dsphdr">CGI Path</td>
                             <td class="dspalph">$(cGIPath)</td>
                         </tr>
                         <tr><td class="dsphdr">Home Path</td>
                             <td class="dspalph">$(homePath)</td>
                         </tr>
                         <tr><td class="dsphdr">Image Path</td>
                             <td class="dspalph">$(imagePath)</td>
                         </tr>
                         <tr><td class="dsphdr">Help Path</td>
                             <td class="dspalph">$(helpPath)</td>
                         </tr>
                         <tr><td class="dsphdr">Home URL</td>
                             <td class="dspalph">$(homeURL)</td>
                         </tr>
                         <tr><td class="dsphdr">Program Schema</td>
                             <td class="dspalph">$(pgmLibrary)</td>
                         </tr>
                         <tr><td class="dsphdr">Database ID</td>
                             <td class="dspalph">$(dataBaseID)</td>
                         </tr>
                         <tr><td class="dsphdr">Web Registry Schema</td>
                             <td class="dspalph">$(webRegLibrary)</td>
                         </tr>
                         <tr><td class="dsphdr">Web Registry Path</td>
                             <td class="dspalph">$(webRegPath)</td>
                         </tr>
                         <tr><td class="dsphdr">Web Registry Current Table</td>
                             <td class="dspalph">$(webRegCurFile)</td>
                         </tr>
                      </table>
                      $(inquiryhrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_DISPLAY()
%}