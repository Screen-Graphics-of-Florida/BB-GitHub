%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title 	        = "Pay Code"
  d2wName              = "HRCoFacPayCodeSelect.d2w"
  d2wVarBase           = "$(genericVarBase)$(hrCoFacVarBase)&amp;payCode=@dtw_rurlescseq(payCode)&amp;backHome=@dtw_rurlescseq(backHome)"
  programName          = "HPRPYM"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  RPT_MAX_ROWS         = "99"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  codeTypeY            = "Y"
  codeType4            = "4"
  dspMaxRows           = "$(dspMaxRowsDft)"
  prtMaxRows           = "$(prtMaxRowsDft)"
  rowIndexNext	        = "1"
  totalPages	        = "0"	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "HrCoFacURL.icl"
   @dtw_replace(workURL, "@@payCode", "@dtw_rurlescseq(payCode)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  @HrCoFacUserView(profileHandle, dataBaseID, userPass, prCompany, prFacility)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                           @dtw_assign(pageID, "PAYCODESELECT")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          @dtw_concat(stmtSQL, "Select * From PRCODE ", stmtSQL)
                          @dtw_concat(stmtSQL, " Where C2COMP=$(prCompany) and C2FACL=$(prFacility) ", stmtSQL)
                          @dtw_concat(stmtSQL, " and C2CODE='$(payCode)'", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          @PayCodeSelect_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) PayCodeSelect_Query (IN CHAR(64)    profileHandle,
				            CHAR(2)     dataBaseID,
                                           CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
              <tr><td><h1> $(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      <td class="toolbar">
                          %if ((backHome != "$(d2wName)/report") && (backHome != ""))
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                          %endif
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>

              @RetHrCompNam(profileHandle, dataBaseID, prCompany, prFacility, coFacName)
              <tr><td><h2>$(coFacName)</h2></td></tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"
      $(hrTagAttr)

      %ROW {

          <table $(contentTable)>
              <tr><td class="dsphdr">Pay Code</td>
                  <td class="dspalph">$(V_C2CODE)</td>
              </tr>
              <tr><td class="dsphdr">Description</td>
                  <td class="dspalph">$(V_C2DESC)</td>
              </tr>
              <tr><td class="dsphdr">Report Heading</td>
                  <td class="dspalph">$(V_C2RPHD)</td>
              </tr>
              <tr><td class="dsphdr">Summary Pay Type</td>
                  @RtvFldDesc("SUMCOD='$(V_C2SMTY)'", "PRSUMT", "SUMDSC", sumDesc)
                  <td class="dspalph">$(sumDesc)</td>
              <tr>
                  %if (V_C2HRCD != "")
                      <td class="dsphdr">Hours/Units</td>
                      @dtw_assign(hoursUnits, "")
                      %if (V_C2HRCD == "H")
                          @dtw_assign(hoursUnits, "Hours")
                      %elif (V_C2HRCD == "U")
                          @dtw_assign(hoursUnits, "Units")
                      %endif
                  %endif
                  <td class="dspalph">$(hoursUnits)</td>
              </tr>
              <tr><td class="dsphdr">Apply Shift Premium</td>
                  @RtvYNDesc($(V_C2PREM), syFlagDesc)
                  <td class="dspnmbr">$(syFlagDesc)</td>
              </tr>
              <tr><td class="dsphdr">Take Deductions</td>
                  @RtvYNDesc($(V_C2DED), syFlagDesc)
                  <td class="dspnmbr">$(syFlagDesc)</td>
              </tr>
              <tr><td class="dsphdr">Include In Vac/Sick Accrual</td>
                  @RtvYNDesc($(V_C2ACCR), syFlagDesc)
                  <td class="dspnmbr">$(syFlagDesc)</td>
              </tr>
              <tr><td class="dsphdr">Include In Overtime</td>
                  @RtvYNDesc($(V_C2IOTC), syFlagDesc)
                  <td class="dspnmbr">$(syFlagDesc)</td>
              </tr>
              <tr><td class="dsphdr">Process Distribution Tables</td>
                  @RtvYNDesc($(V_C2WGDS), syFlagDesc)
                  <td class="dspnmbr">$(syFlagDesc)</td>
              </tr>
              <tr><td class="dsphdr">Process Salary Distribution</td>
                  @RtvYNDesc($(V_C2SLDS), syFlagDesc)
                  <td class="dspnmbr">$(syFlagDesc)</td>
              </tr>
              <tr><td class="dsphdr">Processing Sequence</td>
                  <td class="dspnmbr">$(V_C2SEQ)</td>
              </tr>
              <tr><td class="dsphdr">G/L Account</td>
                  @Format_Acct("$(V_C2ACCT)", "$(V_C2SUB)", "Y", F_AcctSub)
                  <td class="dspalph">$(F_AcctSub)</td>
              </tr>
              <tr><td class="dsphdr">Unpaid Hours/Units</td>
                  @RtvYNDesc($(V_C2NOPY), syFlagDesc)
                  <td class="dspnmbr">$(syFlagDesc)</td>
              </tr>
              %if (V_C2RPHR != "")
                  <tr><td class="dsphdr">Worked Hours</td>
                      @RtvYNDesc($(V_C2RPHR), syFlagDesc)
                      <td class="dspnmbr">$(syFlagDesc)</td>
                  </tr>
              %endif
              %if (V_C2ATCD != "")
                  <tr><td class="dsphdr">Attendance Exception</td>
                      @RtvFldDesc("EVTYPE='A' and EVCODE='$(V_C2ATCD)'", "HDEVNT", "EVDESC", attnDesc)
                      <td class="dspalph">$(attnDesc)</td>
                  </tr>
              %endif
              %if (V_C2HRS != ".00")
                  @Format_Nbr($(V_C2HRS), F_C2HRS, "2", $(hrsEditCode), "", "", "")
                  <tr><td class="dsphdr">Hours/Units/Earnings Default</td>
                      <td class="dspnmbr">$(F_C2HRS)</td>
                  </tr>
              %endif
              %if (V_C2DEPT != "")
                  <tr><td class="dsphdr">Department Worked</td>
                      @RtvFldDesc("EADEPT='$(V_C2DEPT)'", "PREXAC", "EANAME", deptName)
                      <td class="dspnmbr">$(deptName)</td>
                  </tr>
              %endif
              %if (V_C2OVRT != ".000")
                  @Format_Nbr($(V_C2OVRT), F_C2OVRT, $(rteNbrDec), $(rteEditCode), "", "", "")
                  <tr><td class="dsphdr">Override Rate</td>
                      <td class="dspnmbr">$(F_C2OVRT)</td>
                  </tr>
              %endif
              %if (V_C2SHFW != "")
                  <tr><td class="dsphdr">Shift Worked</td>
                      <td class="dspnmbr">$(V_C2SHFW)</td>
                  </tr>
              %endif
              %if (V_C2JOB != "")
                  <tr><td class="dsphdr">Job Number</td>
                      <td class="dspnmbr">$(V_C2JOB)</td>
                  </tr>
              %endif
              %if (V_C2STRT != "0")
                  @Format_Date(V_C2STRT, "H", F_C2STRT)
                  <tr><td class="dsphdr">Start Date</td>
                      <td class="dspdate">$(F_C2STRT)</td>
                  </tr>
              %endif
              %if (V_C2END != "0")
                  @Format_Date(V_C2END, "H", F_C2END)
                  <tr><td class="dsphdr">End Date</td>
                      <td class="dspdate">$(F_C2END)</td>
                  </tr>
              %endif
              %if (V_C2MAX1 != ".00")
                  @Format_Nbr($(V_C2MAX1), F_C2MAX1, "2", $(hrsEditCode), "", "", "")
                  <tr><td class="dsphdr">Maximum YTD Hours/Units</td>
                      <td class="dspnmbr">$(F_C2MAX1)</td>
                  </tr>
              %endif
              %if (V_C2MAX2 != ".00")
                  @Format_Nbr($(V_C2MAX2), F_C2MAX2, "2", $(amtEditCode), "", "", "")
                  <tr><td class="dsphdr">Maximum YTD Earnings</td>
                      <td class="dspnmbr">$(F_C2MAX2)</td>
                  </tr>
              %endif
              <tr><td class="dsphdr">Default Row</td>
                  @RtvYNDesc($(V_C2DFLT), syFlagDesc)
                  <td class="dspnmbr">$(syFlagDesc)</td>
              </tr>
              %if ((V_C2XFIT != "0") || (V_C2XFIC != "N") || (V_C2XFUI != "N") || (V_C2XSIT != "0") || (V_C2XSDI != "N") || (V_C2XSUI != "N") || (V_C2XSWC != "N"))
                  <tr><td class="dsphdr">Tax Status:</td>
                      <td class="dspnmbr"> </td>
                  </tr>
                  <tr><td class="dsphdr">Federal Income Tax</td>
                      @RtvFldDesc("FLTYPE='EXEMPTSTS' and FLVALU='$(V_C2XFIT)'", "SYFLAG", "FLDESC", syFlagDesc)
                      <td class="dspnmbr">$(syFlagDesc)</td>
                  </tr>
                  <tr><td class="dsphdr">FICA Tax</td>
                      @RtvFldDesc("FLTYPE='EXEMPTSTS' and FLVALU='$(V_C2XFIC)'", "SYFLAG", "FLDESC", syFlagDesc)
                      <td class="dspnmbr">$(syFlagDesc)</td>
                  </tr>
                  <tr><td class="dsphdr">Federal Unemployment Insurance</td>
                      @RtvFldDesc("FLTYPE='EXEMPTSTS' and FLVALU='$(V_C2XFUI)'", "SYFLAG", "FLDESC", syFlagDesc)
                      <td class="dspnmbr">$(syFlagDesc)</td>
                  </tr>
                  <tr><td class="dsphdr">State Income Tax</td>
                      @RtvFldDesc("FLTYPE='EXEMPTSTS' and FLVALU='$(V_C2XSIT)'", "SYFLAG", "FLDESC", syFlagDesc)
                      <td class="dspnmbr">$(syFlagDesc)</td>
                  </tr>
                  <tr><td class="dsphdr">State Disability Insurance</td>
                      @RtvFldDesc("FLTYPE='EXEMPTSTS' and FLVALU='$(V_C2XSDI)'", "SYFLAG", "FLDESC", syFlagDesc)
                      <td class="dspnmbr">$(syFlagDesc)</td>
                  </tr>
                  <tr><td class="dsphdr">State Unemployment Insurance</td>
                      @RtvFldDesc("FLTYPE='EXEMPTSTS' and FLVALU='$(V_C2XSUI)'", "SYFLAG", "FLDESC", syFlagDesc)
                      <td class="dspnmbr">$(syFlagDesc)</td>
                  </tr>
                  <tr><td class="dsphdr">State Workers' Compensation</td>
                      @RtvFldDesc("FLTYPE='EXEMPTSTS' and FLVALU='$(V_C2XSWC)'", "SYFLAG", "FLDESC", syFlagDesc)
                      <td class="dspnmbr">$(syFlagDesc)</td>
                  </tr>
              %endif
          </table>
      %}	
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}