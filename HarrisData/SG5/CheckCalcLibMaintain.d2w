%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Check Calculator Schema Maintenance"
  d2wName                 = "CheckCalcLibMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)&amp;fromD2w=@dtw_rurlescseq(fromD2w)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;userProfileName=@dtw_rurlescseq(userProfileName)&amp;libraryName=@dtw_rurlescseq(libraryName)&amp;maintenanceCode=D"
  programName             = "HPRCLM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
      %INCLUDE "$(docType)"
      <html>
          <head>
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "CheckEnterChg.icl"
                  %INCLUDE "Menu.js"
                  function validate(chgForm) {
                      if (document.Chg.userProfileName.value =="" ||
                          document.Chg.libraryName.value =="" )
                         {alert("$(reqFieldError)"); return false;}
                         return true;
                  }
                  function confirmDelete() {return confirm("$(delRecordConf)")}
	           %INCLUDE "NumEdit.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>

          <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "CHECKCALCLIBMAINTAIN")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          %if (maintenanceCode == "A")
                              %INCLUDE "AddRecordSQL.icl"
                          %else
                              @dtw_concat(stmtSQL, "SELECT * FROM PRCLIB WHERE CBUSER = '$(userProfileName) ' ", stmtSQL)
                          %endif
                          %INCLUDE "stmtSQLEnd.icl"
                          @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=135")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;warningFlag=@dtw_rurlescseq(warningFlag)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "userProfileName")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@usrp", "userProfileName")          @dtw_assign(Err_CBUSER, fieldValue)
                          @DecatErr_Field("@@lib@", "libraryName")          @dtw_assign(Err_CBLIB,  fieldValue)
                          @DecatErr_Field("@@libd", "libraryDesc")          @dtw_assign(Err_CBLIBD, fieldValue)
                          @DecatErr_Field("@@tstp", "timeStamp")            @dtw_assign(Err_CBTSTP, fieldValue)
                      %endif

                      @Decat_Field("@@usrp")   @dtw_assign(V_CBUSER, fieldValue)
                      @Decat_Field("@@lib@")   @dtw_assign(V_CBLIB,  fieldValue)
                      @Decat_Field("@@libd")   @dtw_assign(V_CBLIBD, fieldValue)

                      @Decat_Field("@@tstp")   @dtw_assign(V_CBTSTP, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "userProfileName")
                      %endif

                      @dtw_assign(errFound, "")

                  %elseif (maintenanceCode == "Z")
                      @dtw_assign(V_CBUSER, "")
                      @dtw_assign(focusField, "userProfileName")
                  %else
                      @dtw_assign(focusField, "libraryName")
                  %endif

                  @SetTextOvr(Err_CBTSTP)
                  <tr><td class="dsphdr"><span $(textOvr)>.</span></td>
                  	  <td><input name="timeStamp" type="hidden" value="$(V_CBTSTP)"></td> 
                  </tr>
                  @DspErrMsg(Err_CBTSTP)
		  
                  @SetTextOvr(Err_CBUSER)
                  <tr><td class="dsphdr"><span $(textOvr)>User Profile</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="userProfileName" type="text" value="$(V_CBUSER)" size="10" maxlength="10"> $(reqFieldChar) <a href="$(homeURL)$(phpPath)UserSearch.php$(altVarBase)&amp;docName=Chg&amp;userFld=userProfileName&amp;descFld=userName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="userName" value="$(fieldDesc)" type="text"></td>
                      %else
                          <td class="inputalph"><input name="userProfileName" type="hidden" value="$(V_CBUSER)" size="10" maxlength="10">$(V_CBUSER)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_CBUSER)

                  @SetTextOvr(Err_CBLIB)
                  <tr><td class="dsphdr"><span $(textOvr)>Schema</span></td>
                      <td class="inputalph"><input name="libraryName" type="text" value="$(V_CBLIB)" size="15" maxlength="10"> $(reqFieldChar)  </td>
                  </tr>
                  @DspErrMsg(Err_CBLIB)
    	
                  @SetTextOvr(Err_CBLIBD)
                  <tr><td class="dsphdr"><span $(textOvr)>Schema Description</span></td>
                      <td class="inputalph"><input name="libraryDesc" type="text" value="$(V_CBLIBD)" size="70" maxlength="50"> </td>
                  </tr>
                  @DspErrMsg(Err_CBLIBD)
              %}	
          </table>

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     warningFlag,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HPRCLM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(userProfileName)
  @dtw_mUPPERCASE(libraryName)

  @dtw_assign(userProfileName,@dtw_rstrip(userProfileName))
  @dtw_assign(libraryName,@dtw_rstrip(libraryName))
  @dtw_assign(libraryDesc,@dtw_rstrip(libraryDesc))

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@usrp", userProfileName)
  @Concat_Field("@@lib@", libraryName)
  @Concat_Field("@@libd", libraryDesc)
  @Concat_Field("@@tstp", timeStamp)

  @dtw_concat(edtVar, "}{", edtVar)



  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, warningFlag, errFound, edtVar, errVar)
  @DecatErr_Field("@@usrp", "userProfileName")          @dtw_assign(Err_CBUSER, fieldValue)
  
  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, "User Profile: ", $(userProfileName), "Schema: ", $(libraryName), "", "", confMessage)
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=135&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %elif ((maintenanceCode == "C" || maintenanceCode == "D") && errFound != "" && fieldValue != "")
      @DecatErr_Field("@@usrp", "userProfileName")
      @Format_ConfMsg_Desc("E", "User Profile: ", $(userProfileName), "Schema: ", $(libraryName), "<br>$(fieldValue)", "", confMessage)
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=135&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;userProfileName=@dtw_rurlescseq(userProfileName)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;warningFlag=@dtw_rurlescseq(warningFlag)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
