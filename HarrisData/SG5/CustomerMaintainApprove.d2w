%INCLUDE "$(baseVar)"
%INCLUDE "ARControl$(dataBaseID).icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Customer Maintain Approve"
  d2wName                 = "CustomerMaintainApprove.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;wfInstance=@dtw_rurlescseq(wfInstance)&amp;wfInstanceDate=@dtw_rurlescseq(wfInstanceDate)&amp;wfWorkItem=@dtw_rurlescseq(wfWorkItem)&amp;wfWorkItemSequence=@dtw_rurlescseq(wfWorkItemSequence)&amp;wfParticipantId=@dtw_rurlescseq(wfParticipantId)&amp;wfProcess=@dtw_rurlescseq(wfProcess)&amp;wfPoint=@dtw_rurlescseq(wfPoint)&amp;wfSequence=@dtw_rurlescseq(wfSequence)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  maintainVar             = ""
  V_ADVAR                 = ""
  Change                  = ""
  E_MNCD                  = ""
  showIconPassWith        = ""
  showIconPassWithout     = ""
  recordCount             = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              function submitForm(action) {document.Chg.action = action; return true;}
              function confirmFail(text) {return confirm("$(wfFailConf)" + "\n" + "\n" + text);}
              %INCLUDE "Menu.js"
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      @RtvFldDesc("ADINST=$(wfInstance) and ADINDT=$(wfInstanceDate)", "WFDTAA", "ADVAR", V_ADVAR)
      @dtw_assign(edtVar, V_ADVAR)
      @Decat_Field("@@cust")   @dtw_assign(E_CMCUST, fieldValue)
      @RtvFldDesc("CMCUST=$(E_CMCUST)", "HDCUST", "CHAR(COUNT(*))", recordCount)

      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "CUSTOMERMAINTAINAPPR")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (recordCount>"0")
                          @dtw_concat(stmtSQL, "Select * From HDCUST Where CMCUST=$(E_CMCUST)", stmtSQL)
                      %else
                          %INCLUDE "AddRecordSQL.icl"
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN CHAR(64)    profileHandle,
                                  CHAR(2)     dataBaseID,
                                  CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"
      $(hrTagAttr)

      @dtw_assign(edtVar, V_ADVAR)
      @Decat_Field("@@mncd")   @dtw_assign(E_MNCD, fieldValue)
      @Decat_Field("@@user")   @dtw_assign(E_USER, fieldValue)
      @Decat_Field("@@cust")   @dtw_assign(E_CMCUST, fieldValue)
      @Decat_Field("@@blto")   @dtw_assign(E_CMBLTO, fieldValue)
      @Decat_Field("@@alph")   @dtw_assign(E_CMALPH, fieldValue)
      @Decat_Field("@@cna1")   @dtw_assign(E_CMCNA1, fieldValue)
      @Decat_Field("@@cna2")   @dtw_assign(E_CMCNA2, fieldValue)
      @Decat_Field("@@cna3")   @dtw_assign(E_CMCNA3, fieldValue)
      @Decat_Field("@@cna4")   @dtw_assign(E_CMCNA4, fieldValue)
      @Decat_Field("@@ccty")   @dtw_assign(E_CMCCTY, fieldValue)
      @Decat_Field("@@st@@")   @dtw_assign(E_CMST,   fieldValue)
      @Decat_Field("@@zip@")   @dtw_assign(E_CMZIP,  fieldValue)
      @Decat_Field("@@ctry")   @dtw_assign(E_CMCTRY, fieldValue)
      @Decat_Field("@@ccls")   @dtw_assign(E_CMCCLS, fieldValue)
      @Decat_Field("@@loc@")   @dtw_assign(E_CMLOC#, fieldValue)
      @Decat_Field("@@phon")   @dtw_assign(E_CMPHON, fieldValue)
      @Decat_Field("@@ctrm")   @dtw_assign(E_CMCTRM, fieldValue)
      @Decat_Field("@@crct")   @dtw_assign(E_CMCRCT, fieldValue)
      @Decat_Field("@@ccrl")   @dtw_assign(E_CMCCRL, fieldValue)
      @Decat_Field("@@crfn")   @dtw_assign(E_CMCRFN, fieldValue)
      @Decat_Field("@@curt")   @dtw_assign(E_CMCURT, fieldValue)
      @Decat_Field("@@cstc")   @dtw_assign(E_CMCSTC, fieldValue)
      @Decat_Field("@@cscc")   @dtw_assign(E_CMCSCC, fieldValue)
      @Decat_Field("@@slsm")   @dtw_assign(E_CMSLSM, fieldValue)
      @Decat_Field("@@alsm")   @dtw_assign(E_CMALSM, fieldValue)
      @Decat_Field("@@crgn")   @dtw_assign(E_CMCRGN, fieldValue)
      @Decat_Field("@@fax@")   @dtw_assign(E_CMFAX,  fieldValue)
      @Decat_Field("@@hcbl")   @dtw_assign(E_CMHCBL, fieldValue)
      @Decat_Field("@@dfes")   @dtw_assign(E_CMDFES, fieldValue)
      @Decat_Field("@@mpty")   @dtw_assign(E_CMMPTY, fieldValue)
      @Decat_Field("@@fcus")   @dtw_assign(E_CMFCUS, fieldValue)
      @Decat_Field("@@fcrl")   @dtw_assign(E_CMFCRL, fieldValue)
      @Decat_Field("@@udf1")   @dtw_assign(E_CMUDF1, fieldValue)
      @Decat_Field("@@udf2")   @dtw_assign(E_CMUDF2, fieldValue)
      @Decat_Field("@@udf3")   @dtw_assign(E_CMUDF3, fieldValue)
      @Decat_Field("@@udf4")   @dtw_assign(E_CMUDF4, fieldValue)
      @Decat_Field("@@udf5")   @dtw_assign(E_CMUDF5, fieldValue)
      @Decat_Field("@@whs@")   @dtw_assign(E_CMWH#,  fieldValue)
      @Decat_Field("@@boal")   @dtw_assign(E_CMBOAL, fieldValue)
      @Decat_Field("@@sv@@")   @dtw_assign(E_CMSV,   fieldValue)
      @Decat_Field("@@fobc")   @dtw_assign(E_CMFOBC, fieldValue)
      @Decat_Field("@@ctxc")   @dtw_assign(E_CMCTXC, fieldValue)
      @Decat_Field("@@cntc")   @dtw_assign(E_CMCNTC, fieldValue)
      @Decat_Field("@@cttc")   @dtw_assign(E_CMCTTC, fieldValue)
      @Decat_Field("@@loc1")   @dtw_assign(E_CMLOC1, fieldValue)
      @Decat_Field("@@loc2")   @dtw_assign(E_CMLOC2, fieldValue)
      @Decat_Field("@@loc3")   @dtw_assign(E_CMLOC3, fieldValue)
      @Decat_Field("@@chld")   @dtw_assign(E_CMCHLD, fieldValue)
      @Decat_Field("@@bcde")   @dtw_assign(E_CMBCDE, fieldValue)
      @Decat_Field("@@imth")   @dtw_assign(E_CMIMTH, fieldValue)
      @Decat_Field("@@idos")   @dtw_assign(E_CMIDOS, fieldValue)
      @Decat_Field("@@rref")   @dtw_assign(E_CMRREF, fieldValue)
      @Decat_Field("@@moq@")   @dtw_assign(E_CMMOQ,  fieldValue)
      @Decat_Field("@@moa@")   @dtw_assign(E_CMMOA,  fieldValue)
      @Decat_Field("@@mow@")   @dtw_assign(E_CMMOW,  fieldValue)
      @Decat_Field("@@mwrn")   @dtw_assign(E_CMMWRN, fieldValue)
      @Decat_Field("@@acci")   @dtw_assign(E_CMACCI, fieldValue)
      @Decat_Field("@@aovs")   @dtw_assign(E_CMAOVS, fieldValue)
      @Decat_Field("@@ovsh")   @dtw_assign(E_CMOVSH, fieldValue)
      @Decat_Field("@@trdy")   @dtw_assign(E_CMTRDY, fieldValue)
      @dtw_assign(F_CMOVSH,  "@dtw_rformat(@dtw_rmultiply(E_CMOVSH, "100"),"","2")")
      @Format_Date(E_CMDFES, "D", F_CMDFES)

      @RtvFldDesc("APINST=$(wfInstance) and APINDT=$(wfInstanceDate)", "WFDTAP", "APVAR", V_APVAR)
      %if (V_APVAR != "")
          @dtw_assign(edtVar, V_APVAR)
          @Decat_Field("@@cust")   @dtw_assign(O_CMCUST, fieldValue)
          @Decat_Field("@@blto")   @dtw_assign(O_CMBLTO, fieldValue)
          @Decat_Field("@@alph")   @dtw_assign(O_CMALPH, fieldValue)
          @Decat_Field("@@cna1")   @dtw_assign(O_CMCNA1, fieldValue)
          @Decat_Field("@@cna2")   @dtw_assign(O_CMCNA2, fieldValue)
          @Decat_Field("@@cna3")   @dtw_assign(O_CMCNA3, fieldValue)
          @Decat_Field("@@cna4")   @dtw_assign(O_CMCNA4, fieldValue)
          @Decat_Field("@@ccty")   @dtw_assign(O_CMCCTY, fieldValue)
          @Decat_Field("@@st@@")   @dtw_assign(O_CMST,   fieldValue)
          @Decat_Field("@@zip@")   @dtw_assign(O_CMZIP,  fieldValue)
          @Decat_Field("@@ctry")   @dtw_assign(O_CMCTRY, fieldValue)
          @Decat_Field("@@ccls")   @dtw_assign(O_CMCCLS, fieldValue)
          @Decat_Field("@@loc@")   @dtw_assign(O_CMLOC#, fieldValue)
          @Decat_Field("@@phon")   @dtw_assign(O_CMPHON, fieldValue)
          @Decat_Field("@@ctrm")   @dtw_assign(O_CMCTRM, fieldValue)
          @Decat_Field("@@crct")   @dtw_assign(O_CMCRCT, fieldValue)
          @Decat_Field("@@ccrl")   @dtw_assign(O_CMCCRL, fieldValue)
          @Decat_Field("@@crfn")   @dtw_assign(O_CMCRFN, fieldValue)
          @Decat_Field("@@curt")   @dtw_assign(O_CMCURT, fieldValue)
          @Decat_Field("@@cstc")   @dtw_assign(O_CMCSTC, fieldValue)
          @Decat_Field("@@cscc")   @dtw_assign(O_CMCSCC, fieldValue)
          @Decat_Field("@@slsm")   @dtw_assign(O_CMSLSM, fieldValue)
          @Decat_Field("@@alsm")   @dtw_assign(O_CMALSM, fieldValue)
          @Decat_Field("@@crgn")   @dtw_assign(O_CMCRGN, fieldValue)
          @Decat_Field("@@fax@")   @dtw_assign(O_CMFAX,  fieldValue)
          @Decat_Field("@@hcbl")   @dtw_assign(O_CMHCBL, fieldValue)
          @Decat_Field("@@dfes")   @dtw_assign(O_CMDFES, fieldValue)
          @Decat_Field("@@mpty")   @dtw_assign(O_CMMPTY, fieldValue)
          @Decat_Field("@@fcus")   @dtw_assign(O_CMFCUS, fieldValue)
          @Decat_Field("@@fcrl")   @dtw_assign(O_CMFCRL, fieldValue)
          @Decat_Field("@@udf1")   @dtw_assign(O_CMUDF1, fieldValue)
          @Decat_Field("@@udf2")   @dtw_assign(O_CMUDF2, fieldValue)
          @Decat_Field("@@udf3")   @dtw_assign(O_CMUDF3, fieldValue)
          @Decat_Field("@@udf4")   @dtw_assign(O_CMUDF4, fieldValue)
          @Decat_Field("@@udf5")   @dtw_assign(O_CMUDF5, fieldValue)
          @Decat_Field("@@whs@")   @dtw_assign(O_CMWH#,  fieldValue)
          @Decat_Field("@@boal")   @dtw_assign(O_CMBOAL, fieldValue)
          @Decat_Field("@@sv@@")   @dtw_assign(O_CMSV,   fieldValue)
          @Decat_Field("@@fobc")   @dtw_assign(O_CMFOBC, fieldValue)
          @Decat_Field("@@ctxc")   @dtw_assign(O_CMCTXC, fieldValue)
          @Decat_Field("@@cntc")   @dtw_assign(O_CMCNTC, fieldValue)
          @Decat_Field("@@cttc")   @dtw_assign(O_CMCTTC, fieldValue)
          @Decat_Field("@@loc1")   @dtw_assign(O_CMLOC1, fieldValue)
          @Decat_Field("@@loc2")   @dtw_assign(O_CMLOC2, fieldValue)
          @Decat_Field("@@loc3")   @dtw_assign(O_CMLOC3, fieldValue)
          @Decat_Field("@@chld")   @dtw_assign(O_CMCHLD, fieldValue)
          @Decat_Field("@@bcde")   @dtw_assign(O_CMBCDE, fieldValue)
          @Decat_Field("@@imth")   @dtw_assign(O_CMIMTH, fieldValue)
          @Decat_Field("@@idos")   @dtw_assign(O_CMIDOS, fieldValue)
          @Decat_Field("@@rref")   @dtw_assign(O_CMRREF, fieldValue)
          @Decat_Field("@@moq@")   @dtw_assign(O_CMMOQ,  fieldValue)
          @Decat_Field("@@moa@")   @dtw_assign(O_CMMOA,  fieldValue)
          @Decat_Field("@@mow@")   @dtw_assign(O_CMMOW,  fieldValue)
          @Decat_Field("@@mwrn")   @dtw_assign(O_CMMWRN, fieldValue)
          @Decat_Field("@@acci")   @dtw_assign(O_CMACCI, fieldValue)
          @Decat_Field("@@aovs")   @dtw_assign(O_CMAOVS, fieldValue)
          @Decat_Field("@@ovsh")   @dtw_assign(O_CMOVSH, fieldValue)
          @Decat_Field("@@trdy")   @dtw_assign(O_CMTRDY, fieldValue)
      %endif

      %ROW {
          %if (once=="")			
              %if ((E_MNCD=="A" || E_MNCD=="Z") && recordCount>"0")
                  @dtw_assign(errorMessage, "Customer Already Exists")
                  @dtw_assign(showIconPassWith, "")
                  @dtw_assign(showIconPassWithout, "")
              %elif (E_MNCD=="D" && recordCount=="0")
                  @dtw_assign(errorMessage, "Customer Already Deleted")
                  @dtw_assign(showIconPassWith, "")
                  @dtw_assign(showIconPassWithout, "")
              %elif (E_MNCD=="C")
                  @dtw_assign(errorMessage, "")
                  @dtw_assign(showIconPassWith, "Y")
                  @dtw_assign(showIconPassWithout, "Y")
              %elif (E_MNCD=="D")
                  @dtw_assign(errorMessage, "")
                  @dtw_assign(showIconPassWith, "Y")
                  @dtw_assign(showIconPassWithout, "")
              %else
                  @dtw_assign(errorMessage, "")
                  @dtw_assign(showIconPassWith, "Y")
                  @dtw_assign(showIconPassWithout, "")
              %endif

              @dtw_assign(maintainVar, "$(d2wVarBase)")
              %INCLUDE "WFWorkListOptions.icl"
              %if (errorMessage!="")
                  <table $(contentTable)>
                      <h1>ERROR: $(errorMessage)</h1>
                  </table>

              %elif (E_MNCD=="C")
                  <table $(contentTable)>
                      <tr><th class="colhdr">Changes:</th></tr>
                  </table>

                  <table $(contentTable)>
                      @dtw_assign(Change,  "")
                      @Show_Changes(E_CMBLTO, O_CMBLTO, V_CMBLTO, "Bill-To Customer Number")
                      @Show_Changes(E_CMALPH, O_CMALPH, V_CMALPH, "Alpha Sequence")
                      @Show_Changes(E_CMCNA1, O_CMCNA1, V_CMCNA1, "Customer Name")
                      @Show_Changes(E_CMCNA2, O_CMCNA2, V_CMCNA2, "Address Line One")
                      @Show_Changes(E_CMCNA3, O_CMCNA3, V_CMCNA3, "Address Line Two")
                      @Show_Changes(E_CMCNA4, O_CMCNA4, V_CMCNA4, "Address Line Three")
                      @Show_Changes(E_CMCCTY, O_CMCCTY, V_CMCCTY, "City")
                      @Show_Changes(E_CMST, O_CMST, V_CMST, "State")
                      @Show_Changes(E_CMZIP, O_CMZIP, V_CMZIP, "Zip")
                      @Show_Changes(E_CMCTRY, O_CMCTRY, V_CMCTRY, "Country")
                      @Show_Changes(E_CMCCLS, O_CMCCLS, V_CMCCLS, "Class Code")
                      @Show_Changes(E_CMLOC#, O_CMLOC#, V_CMLOC#, "Location Number")
                      @Show_Changes(E_CMPHON, O_CMPHON, V_CMPHON, "Phone Number")
                      @Show_Changes(E_CMCTRM, O_CMCTRM, V_CMCTRM, "Terms Code")
                      @Show_Changes(E_CMCRCT, O_CMCRCT, V_CMCRCT, "Credit Contact")
                      @Show_Changes(E_CMCCRL, O_CMCCRL, V_CMCCRL, "Credit Limit")
                      @Show_Changes(E_CMCRFN, O_CMCRFN, V_CMCRFN, "Credit Reference Number")

                      %if (V_HDMCRL>"0" && V_CRPRMC=="Y")
                          @Show_Changes(E_CMCURT, O_CMCURT, V_CMCURT, "Currency Type")
                      %endif

                      @Show_Changes(E_CMCSTC, O_CMCSTC, V_CMCSTC, "Statement")
                      @Show_Changes(E_CMCSCC, O_CMCSCC, V_CMCSCC, "Service Charge")
                      @Show_Changes(E_CMSLSM, O_CMSLSM, V_CMSLSM, "Salesman Number")
                      @Show_Changes(E_CMALSM, O_CMALSM, V_CMALSM, "Alternate Salesman Number")
                      @Show_Changes(E_CMCRGN, O_CMCRGN, V_CMCRGN, "Region")
                      @Show_Changes(E_CMFAX, O_CMFAX, V_CMFAX, "Fax Number")
                      @Show_Changes(E_CMHCBL, O_CMHCBL, V_CMHCBL, "Highest Balance")

                      @Format_Date(E_CMDFES, "D", FE_CMDFES)
                      @Format_Date(O_CMDFES, "D", FO_CMDFES)
                      @Format_Date(V_CMDFES, "D", FV_CMDFES)
                      @Show_Changes(FE_CMDFES, FO_CMDFES, FV_CMDFES, "Date Established")
        	   		
                      @Show_Changes(E_CMMPTY, O_CMMPTY, V_CMMPTY, "Management Priority")
                      @Show_Changes(E_CMFCUS, O_CMFCUS, V_CMFCUS, "Factor Customer Number")
                      @Show_Changes(E_CMFCRL, O_CMFCRL, V_CMFCRL, "Factor Credit Limit")

                      %if (V_CRSCR1 != "")
                          @Show_Changes(E_CMUDF1, O_CMUDF1, V_CMUDF1, V_CRSCR1)
                      %endif

                      %if (V_CRSCR2 != "")
                          @Show_Changes(E_CMUDF2, O_CMUDF2, V_CMUDF2, V_CRSCR2)
                      %endif

                      %if (V_CRSCR3 != "")
                          @Show_Changes(E_CMUDF3, O_CMUDF3, V_CMUDF3, V_CRSCR3)
                      %endif

                      %if (V_CRSCR4 != "")
                          @Show_Changes(E_CMUDF4, O_CMUDF4, V_CMUDF4, V_CRSCR4)
                      %endif

                      %if (V_CRSCR5 != "")
                          @Show_Changes(E_CMUDF5, O_CMUDF5, V_CMUDF5, V_CRSCR5)
                      %endif

                      @Show_Changes(E_CMWH#, O_CMWH#, V_CMWH#, "Warehouse Number")
                      @Show_Changes(E_CMBOAL, O_CMBOAL, V_CMBOAL, "Allow Backorders")
                      @Show_Changes(E_CMSV, O_CMSV, V_CMSV, "Ship Via")
                      @Show_Changes(E_CMFOBC, O_CMFOBC, V_CMFOBC, "FOB Code")
                      @Show_Changes(E_CMCTXC, O_CMCTXC, V_CMCTXC, "Tax Code")
                      @Show_Changes("$(E_CMCNTC)-$(E_CMCTTC)-$(E_CMLOC1)-$(E_CMLOC2)-$(E_CMLOC3)", "$(O_CMCNTC)-$(O_CMCTTC)-$(O_CMLOC1)-$(O_CMLOC2)-$(O_CMLOC3)", "$(V_CMCNTC)-$(V_CMCTTC)-$(V_CMLOC1)-$(V_CMLOC2)-$(V_CMLOC3)", "Tax Definition")
                      @Show_Changes(E_CMCHLD, O_CMCHLD, V_CMCHLD, "Hold Code")
                      @Show_Changes(E_CMBCDE, O_CMBCDE, V_CMBCDE, "Billing Code")
                      @Show_Changes(E_CMIMTH, O_CMIMTH, V_CMIMTH, "Invoice Method")
                      @Show_Changes(E_CMIDOS, O_CMIDOS, V_CMIDOS, "Print Detail Or Summary")
                      @Show_Changes(E_CMRREF, O_CMRREF, V_CMRREF, "Require Reference Number")
                      @Show_Changes(E_CMMOQ, O_CMMOQ, V_CMMOQ, "Minimum Quantity Per Order")
                      @Show_Changes(E_CMMOA, O_CMMOA, V_CMMOA, "Minimum Value Per Order")
                      @Show_Changes(E_CMMOW, O_CMMOW, V_CMMOW, "Minimum Weight Per Order")
                      @Show_Changes(E_CMMWRN, O_CMMWRN, V_CMMWRN, "Below Minimum Warning")
                      @Show_Changes(E_CMACCI, O_CMACCI, V_CMACCI, "Auto Create Customer/Item")
                      @Show_Changes(E_CMAOVS, O_CMAOVS, V_CMAOVS, "Allow Over Shipments")

                      @dtw_assign(FE_CMOVSH,  "@dtw_rformat(@dtw_rmultiply(E_CMOVSH, "100"),"","2")")
                      @dtw_assign(FO_CMOVSH,  "@dtw_rformat(@dtw_rmultiply(O_CMOVSH, "100"),"","2")")
                      @dtw_assign(FV_CMOVSH,  "@dtw_rformat(@dtw_rmultiply(V_CMOVSH, "100"),"","2")")
                      @Show_Changes(FE_CMOVSH, FO_CMOVSH, FV_CMOVSH, "Over Shipment Percent")

                      @Show_Changes(E_CMTRDY, O_CMTRDY, V_CMTRDY, "Transit Days")
                      %if (Change == "")
                          <tr><td>&nbsp;</td></tr>
                          <tr><td class="dspalph" colspan="2">No changes were found</td></tr>
                          <tr><td>&nbsp;</td></tr>
                      %endif
                  </table>
              %endif

              @dtw_assign(once, "Y")
          %endif

          <table $(contentTable)>
              %if (E_MNCD=="C")
                  <tr>
                      <th class="colhdr">&nbsp;</th>
                      <th class="colhdr" colspan="2">With Current Values</th>
                      <th class="colhdr" colspan="2">Without Current Values</th>
                  </tr>
              %endif

              @Show_Detail(E_MNCD, E_MNCD, E_MNCD, "",  "", "Maintenance Code")
              @Show_Detail(E_USER, E_USER, E_USER, "", "", "User")
              @Show_Detail(E_CMCUST, E_CMCUST, E_CMCUST, "", "", "Customer Number")

              @Default_Zero(E_CMBLTO)
              @RtvFldDesc("CMCUST=$(E_CMBLTO)", "HDCUST", "CMCNA1", E_fieldDesc)
              %if (E_MNCD=="C")
                  @Default_Zero(O_CMBLTO)
                  @Default_Zero(V_CMBLTO)
                  @RtvFldDesc("CMCUST=$(V_CMBLTO)", "HDCUST", "CMCNA1", V_fieldDesc)
              %endif
              @Show_Detail(E_CMBLTO, O_CMBLTO, V_CMBLTO, E_fieldDesc, V_fieldDesc, "Bill-To Customer Number")

              @Show_Detail(E_CMALPH, O_CMALPH, V_CMALPH, "",  "", "Alpha Sequence")
              @Show_Detail(E_CMCNA1, O_CMCNA1, V_CMCNA1, "",  "", "Customer Name")
              @Show_Detail(E_CMCNA2, O_CMCNA2, V_CMCNA2, "",  "", "Address Line One")
              @Show_Detail(E_CMCNA3, O_CMCNA3, V_CMCNA3, "",  "", "Address Line Two")
              @Show_Detail(E_CMCNA4, O_CMCNA4, V_CMCNA4, "",  "", "Address Line Three")
              @Show_Detail(E_CMCCTY, O_CMCCTY, V_CMCCTY, "",  "", "City")

              @RtvFldDesc("STID='$(E_CMST)'", "HDSTID", "STDESC", E_fieldDesc)
              %if (E_MNCD=="C")
                  @RtvFldDesc("STID='$(V_CMST)'", "HDSTID", "STDESC", V_fieldDesc)
              %endif
              @Show_Detail(E_CMST, O_CMST, V_CMST, E_fieldDesc, V_fieldDesc, "State")

              @Show_Detail(E_CMZIP, O_CMZIP, V_CMZIP, "",  "", "Zip")

              @RtvFldDesc("CNCTCD='$(E_CMCTRY)'", "HDCTRY", "CNCDES", E_fieldDesc)
              %if (E_MNCD=="C")
                  @RtvFldDesc("CNCTCD='$(V_CMCTRY)'", "HDCTRY", "CNCDES", V_fieldDesc)
              %endif
              @Show_Detail(E_CMCTRY, O_CMCTRY, V_CMCTRY, E_fieldDesc, V_fieldDesc, "Country")

              @RtvFldDesc("CCCCLS='$(E_CMCCLS)'", "HDCCLS", "CCCCDS", E_fieldDesc)
              %if (E_MNCD=="C")
                  @RtvFldDesc("CCCCLS='$(V_CMCCLS)'", "HDCCLS", "CCCCDS", V_fieldDesc)
              %endif
              @Show_Detail(E_CMCCLS, O_CMCCLS, V_CMCCLS, E_fieldDesc, V_fieldDesc, "Class Code")

              @Default_Zero(E_CMLOC#)
              @RtvFldDesc("LOLOC#=$(E_CMLOC#)", "HDLCTN", "LOLNA1", E_fieldDesc)
              %if (E_MNCD=="C")
                  @Default_Zero(O_CMLOC#)
                  @Default_Zero(V_CMLOC#)
                  @RtvFldDesc("LOLOC#=$(V_CMLOC#)", "HDLCTN", "LOLNA1", V_fieldDesc)
              %endif
              @Show_Detail(E_CMLOC#, O_CMLOC#, V_CMLOC#, E_fieldDesc, V_fieldDesc, "Location Number")

              @Show_Detail(E_CMPHON, O_CMPHON, V_CMPHON, "",  "", "Phone Number")
	   		     		
              @RtvFldDesc("TMCTRM='$(E_CMCTRM)'", "HDTRMS", "TMCTDS", E_fieldDesc)
              %if (E_MNCD=="C")
                  @RtvFldDesc("TMCTRM='$(V_CMCTRM)'", "HDTRMS", "TMCTDS", V_fieldDesc)
              %endif
              @Show_Detail(E_CMCTRM, O_CMCTRM, V_CMCTRM, E_fieldDesc, V_fieldDesc, "Terms Code")

              @Show_Detail(E_CMCRCT, O_CMCRCT, V_CMCRCT, "",  "", "Credit Contact")
              @Show_Detail(E_CMCCRL, O_CMCCRL, V_CMCCRL, "",  "", "Credit Limit")
              @Show_Detail(E_CMCRFN, O_CMCRFN, V_CMCRFN, "",  "", "Credit Reference Number")

              %if (V_HDMCRL>"0" && V_CRPRMC=="Y")
                  @RtvFldDesc("CYTYPE='$(E_CMCURT)'", "HDCTYP", "CYDESC", E_fieldDesc)
                  %if (E_MNCD=="C")
                      @RtvFldDesc("CYTYPE='$(V_CMCURT)'", "HDCTYP", "CYDESC", V_fieldDesc)
                  %endif
                  @Show_Detail(E_CMCURT, O_CMCURT, V_CMCURT, E_fieldDesc, V_fieldDesc, "Currency Type")
              %endif

              @Show_Detail(E_CMCSTC, O_CMCSTC, V_CMCSTC, "",  "", "Statement")
              @Show_Detail(E_CMCSCC, O_CMCSCC, V_CMCSCC, "",  "", "Service Charge")
	   		
              @Default_Zero(E_CMSLSM)
              @RtvFldDesc("SMSLSM=$(E_CMSLSM)", "HDSLSM", "SMSNA1", E_fieldDesc)
              %if (E_MNCD=="C")
                  @Default_Zero(O_CMSLSM)
                  @Default_Zero(V_CMSLSM)
                  @RtvFldDesc("SMSLSM=$(V_CMSLSM)", "HDSLSM", "SMSNA1", V_fieldDesc)
              %endif
              @Show_Detail(E_CMSLSM, O_CMSLSM, V_CMSLSM, E_fieldDesc, V_fieldDesc, "Salesman Number")
	   		
              @Default_Zero(E_CMALSM)
              @RtvFldDesc("SMSLSM=$(E_CMALSM)", "HDSLSM", "SMSNA1", E_fieldDesc)
              %if (E_MNCD=="C")
                  @Default_Zero(O_CMALSM)
                  @Default_Zero(V_CMALSM)
                  @RtvFldDesc("SMSLSM=$(V_CMALSM)", "HDSLSM", "SMSNA1", V_fieldDesc)
              %endif
              @Show_Detail(E_CMALSM, O_CMALSM, V_CMALSM, E_fieldDesc, V_fieldDesc, "Alternate Salesman Number")

              @RtvFldDesc("RGCRGN='$(E_CMCRGN)'", "HDCRGN", "RGCRDS", E_fieldDesc)
              %if (E_MNCD=="C")
                  @RtvFldDesc("RGCRGN='$(V_CMCRGN)'", "HDCRGN", "RGCRDS", V_fieldDesc)
              %endif
              @Show_Detail(E_CMCRGN, O_CMCRGN, V_CMCRGN, E_fieldDesc, V_fieldDesc, "Region")

              @Show_Detail(E_CMFAX, O_CMFAX, V_CMFAX, "",  "", "Fax Number")
              @Show_Detail(E_CMHCBL, O_CMHCBL, V_CMHCBL, "",  "", "Highest Balance")

              @Format_Date(E_CMDFES, "D", FE_CMDFES)
              %if (E_MNCD=="C")
                  @Format_Date(O_CMDFES, "D", FO_CMDFES)
                  @Format_Date(V_CMDFES, "D", FV_CMDFES)
              %endif
              @Show_Detail(FE_CMDFES, FO_CMDFES, FV_CMDFES, "",  "", "Date Established")
	          		
              @Show_Detail(E_CMMPTY, O_CMMPTY, V_CMMPTY, "",  "", "Management Priority")
              @Show_Detail(E_CMFCUS, O_CMFCUS, V_CMFCUS, "",  "", "Factor Customer Number")
              @Show_Detail(E_CMFCRL, O_CMFCRL, V_CMFCRL, "",  "", "Factor Credit Limit")

              %if (V_CRSCR1 != "")
                  @Show_Detail(E_CMUDF1, O_CMUDF1, V_CMUDF1, "",  "", V_CRSCR1)
              %endif

              %if (V_CRSCR2 != "")
                  @Show_Detail(E_CMUDF2, O_CMUDF2, V_CMUDF2, "",  "", V_CRSCR2)
              %endif

              %if (V_CRSCR3 != "")
                  @Show_Detail(E_CMUDF3, O_CMUDF3, V_CMUDF3, "",  "", V_CRSCR3)
              %endif

              %if (V_CRSCR4 != "")
                  @Show_Detail(E_CMUDF4, O_CMUDF4, V_CMUDF4, "",  "", V_CRSCR4)
              %endif

              %if (V_CRSCR5 != "")
                  @Show_Detail(E_CMUDF5, O_CMUDF5, V_CMUDF5, "",  "", V_CRSCR5)
              %endif

              @Default_Zero(E_CMWH#)
              @RtvFldDesc("WHWHS=$(E_CMWH#)", "HDWHSM", "WHWHNM", E_fieldDesc)
              %if (E_MNCD=="C")
                  @Default_Zero(O_CMWH#)
                  @Default_Zero(V_CMWH#)
                  @RtvFldDesc("WHWHS=$(V_CMWH#)", "HDWHSM", "WHWHNM", V_fieldDesc)
              %endif
              @Show_Detail(E_CMWH#, O_CMWH#, V_CMWH#, E_fieldDesc, V_fieldDesc, "Warehouse Number")

              @Show_Detail(E_CMBOAL, O_CMBOAL, V_CMBOAL, "",  "", "Allow Backorders")
	   		
              @RtvFldDesc("SVSVSV='$(E_CMSV)'", "HDSHPV", "SVSVDS", E_fieldDesc)
              %if (E_MNCD=="C")
                  @RtvFldDesc("SVSVSV='$(V_CMSV)'", "HDSHPV", "SVSVDS", V_fieldDesc)
              %endif
              @Show_Detail(E_CMSV, O_CMSV, V_CMSV, E_fieldDesc, V_fieldDesc, "Ship Via")

              @RtvFldDesc("FBFBCD='$(E_CMFOBC)'", "HDFOBM", "FBFBDS", E_fieldDesc)
              %if (E_MNCD=="C")
                  @RtvFldDesc("FBFBCD='$(V_CMFOBC)'", "HDFOBM", "FBFBDS", V_fieldDesc)
              %endif
              @Show_Detail(E_CMFOBC, O_CMFOBC, V_CMFOBC, E_fieldDesc, V_fieldDesc, "FOB Code")

              @RtvFldDesc("TCCODE='$(E_CMCTXC)'", "HDTAXC", "TCDESC", E_fieldDesc)
              %if (E_MNCD=="C")
                  @RtvFldDesc("TCCODE='$(V_CMCTXC)'", "HDTAXC", "TCDESC", V_fieldDesc)
              %endif
              @Show_Detail(E_CMCTXC, O_CMCTXC, V_CMCTXC, E_fieldDesc, V_fieldDesc, "Tax Code")
	   	
              @Default_Zero(E_CMCNTC)
              @Default_Zero(E_CMCTTC)
              @Default_Zero(E_CMLOC1)
              @Default_Zero(E_CMLOC2)
              @Default_Zero(E_CMLOC3)
              @RtvFldDesc("TDSTCD='$(E_CMST)' and TDCNYC=$(E_CMCNTC) and TDCTYC=$(E_CMCTTC) and TDLOC1=$(E_CMLOC1) and TDLOC2=$(E_CMLOC2) and TDLOC3=$(E_CMLOC3)", "HDTAXD", "TDTDSC", E_fieldDesc)
              %if (E_MNCD=="C")
                  @Default_Zero(O_CMCNTC)
                  @Default_Zero(O_CMCTTC)
                  @Default_Zero(O_CMLOC1)
                  @Default_Zero(O_CMLOC2)
                  @Default_Zero(O_CMLOC3)
                  @Default_Zero(V_CMCNTC)
                  @Default_Zero(V_CMCTTC)
                  @Default_Zero(V_CMLOC1)
                  @Default_Zero(V_CMLOC2)
                  @Default_Zero(V_CMLOC3)
                  @RtvFldDesc("TDSTCD='$(V_CMST)' and TDCNYC=$(V_CMCNTC) and TDCTYC=$(V_CMCTTC) and TDLOC1=$(V_CMLOC1) and TDLOC2=$(V_CMLOC2) and TDLOC3=$(V_CMLOC3)", "HDTAXD", "TDTDSC", V_fieldDesc)
              %endif
              @Show_Detail("$(E_CMCNTC)-$(E_CMCTTC)-$(E_CMLOC1)-$(E_CMLOC2)-$(E_CMLOC3)", "$(O_CMCNTC)-$(O_CMCTTC)-$(O_CMLOC1)-$(O_CMLOC2)-$(O_CMLOC3)", "$(V_CMCNTC)-$(V_CMCTTC)-$(V_CMLOC1)-$(V_CMLOC2)-$(V_CMLOC3)", E_fieldDesc, V_fieldDesc, "Tax Definition")

              @Show_Detail(E_CMCHLD, O_CMCHLD, V_CMCHLD, "",  "", "Hold Code")

              @RtvFldDesc("BCBCDE='$(E_CMBCDE)'", "OEBCDE", "BCDESC", E_fieldDesc)
              %if (E_MNCD=="C")
                  @RtvFldDesc("BCBCDE='$(V_CMBCDE)'", "OEBCDE", "BCDESC", V_fieldDesc)
              %endif
              @Show_Detail(E_CMBCDE, O_CMBCDE, V_CMBCDE, E_fieldDesc, V_fieldDesc, "Billing Code")
	   		
              @Show_Detail(E_CMIMTH, O_CMIMTH, V_CMIMTH, "",  "", "Invoice Method")
              @Show_Detail(E_CMIDOS, O_CMIDOS, V_CMIDOS, "",  "", "Print Detail Or Summary")
              @Show_Detail(E_CMRREF, O_CMRREF, V_CMRREF, "",  "", "Require Reference Number")
              @Show_Detail(E_CMMOQ, O_CMMOQ, V_CMMOQ, "",  "", "Minimum Quantity Per Order")
              @Show_Detail(E_CMMOA, O_CMMOA, V_CMMOA, "",  "", "Minimum Value Per Order")
              @Show_Detail(E_CMMOW, O_CMMOW, V_CMMOW, "",  "", "Minimum Weight Per Order")
              @Show_Detail(E_CMMWRN, O_CMMWRN, V_CMMWRN, "",  "", "Below Minimum Warning")
              @Show_Detail(E_CMACCI, O_CMACCI, V_CMACCI, "",  "", "Auto Create Customer/Item")
              @Show_Detail(E_CMAOVS, O_CMAOVS, V_CMAOVS, "",  "", "Allow Over Shipments")

              @dtw_assign(FE_CMOVSH,  "@dtw_rformat(@dtw_rmultiply(E_CMOVSH, "100"),"","2")")
              %if (E_MNCD=="C")
                  @dtw_assign(FO_CMOVSH,  "@dtw_rformat(@dtw_rmultiply(O_CMOVSH, "100"),"","2")")
                  @dtw_assign(FV_CMOVSH,  "@dtw_rformat(@dtw_rmultiply(V_CMOVSH, "100"),"","2")")
              %endif
              @Show_Detail(FE_CMOVSH, FO_CMOVSH, FV_CMOVSH, "",  "", "Over Shipment Percent")

              @Show_Detail(E_CMTRDY, O_CMTRDY, V_CMTRDY, "",  "", "Transit Days")
          %}
      </table>
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Show_Changes (IN  CHAR(10) E_field,
                              IN  CHAR(10) O_field,
                              IN  CHAR(10) V_field,
                              IN  CHAR(50) fieldDesc)
{
  %if (@dtw_rstrip(E_field)!=@dtw_rstrip(O_field) || @dtw_rstrip(E_field)!=@dtw_rstrip(V_field))
      %if (Change=="")
          @dtw_assign(Change,  "Y")
      %else
          <tr><td class="dsphdr">&nbsp;</td></tr>
      %endif
      <tr><td class="dsphdr">$(fieldDesc)</td>
          <td class="dspnmbr">$(E_field)</td></tr>
      %if (E_field!=O_field)
          <tr><td class="dsphdr">Changed From:</td>
              <td class="dspnmbr">$(O_field)</td>
      %endif
      %if (E_field!=V_field && O_field!=V_field)
          <tr><td class="dsphdr">Current Value:</td>
              <td class="dspnmbr">$(V_field)</td>
          </tr>
      %endif
  %endif
%}

%MACRO_FUNCTION Show_Detail (IN  CHAR(10) E_field,
                             IN  CHAR(10) O_field,
                             IN  CHAR(10) V_field,
                             IN  CHAR(50) E_desc,
                             IN  CHAR(50) V_desc,
                             IN  CHAR(50) fieldDesc)
{
  <tr><td class="dsphdr">$(fieldDesc)</td>
      %if (E_MNCD=="C")
          %if (E_field!=O_field && E_field!=V_field)
              @dtw_assign(V_field, E_field)
              @dtw_assign(V_desc, E_desc)
          %endif
          <td class="dspnmbr">$(V_field)</td>
          <td class="dspnmbr">$(V_desc)</td>
      %endif
      <td class="dspnmbr">$(E_field)</td>
      <td class="dspnmbr">$(E_desc)</td>
  </tr>
%}

%FUNCTION(dtw_directcall) SetApprove_Data(IN    CHAR(64)    profileHandle,
                                                CHAR(2)     dataBaseID,
                                                CHAR(1)     approveCode,
                                                CHAR(32000) edtVar)
{%EXEC {HWFWIA_S.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(setFlag, "Y")
  @dtw_assign(edtVar, "")
  @Concat_Field("@@inst", wfInstance)
  @Concat_Field("@@indt", wfInstanceDate)
  @Concat_Field("@@witm", wfWorkItem)
  @Concat_Field("@@wisq", wfWorkItemSequence)
  @Concat_Field("@@ptid", wfParticipantId)
  @dtw_concat(edtVar, "}{", edtVar)
  @SetApprove_Data(profileHandle, dataBaseID, setFlag, edtVar)
  @Set_SQL(stmtSQL)
%}
