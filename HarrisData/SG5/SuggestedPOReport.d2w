%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Suggested Purchase Order Report"
  d2wName                 = "SuggestedPOReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "6"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.fromBuyerNumber, 7, 0) &&
                      editNum(document.Chg.toBuyerNumber, 7, 0) &&
                      editNum(document.Chg.fromVendorNumber, 7, 0) &&
                      editNum(document.Chg.toVendorNumber, 7, 0) &&
                      editNum(document.Chg.fromWarehouseNumber, 3, 0) &&
                      editNum(document.Chg.toWarehouseNumber, 3, 0) &&
                      editFromToAll(document.Chg.fromRequisitionNumber, document.Chg.toRequisitionNumber, document.Chg.allRequisitionNumber, "A") &&
                      editFromToAll(document.Chg.fromItemNumber, document.Chg.toItemNumber, document.Chg.allItemNumber, "A") &&
                      editFromToAll(document.Chg.fromBuyerNumber, document.Chg.toBuyerNumber, document.Chg.allBuyerNumber, 7) &&
                      editFromToAll(document.Chg.fromVendorNumber, document.Chg.toVendorNumber, document.Chg.allVendorNumber, 7) &&
                      editFromToAll(document.Chg.fromWarehouseNumber, document.Chg.toWarehouseNumber, document.Chg.allWarehouseNumber, 3) &&
                      editFromToAll(document.Chg.fromUserID, document.Chg.toUserID, document.Chg.allUserID, "A"))
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "SUGGESTEDPOREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromRequisitionNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@sug@", "mrpPlannedOrders")        @dtw_assign(Err_N1SUG, fieldValue)
                                  @DecatErr_Field("@@req@", "requisition")             @dtw_assign(Err_N1REQ, fieldValue)
                                  @DecatErr_Field("@@freq", "fromRequisitionNumber")   @dtw_assign(Err_FREQN, fieldValue)
                                  @DecatErr_Field("@@treq", "toRequisitionNumber")     @dtw_assign(Err_TREQN, fieldValue)
                                  @DecatErr_Field("@@areq", "allRequisitionNumber")    @dtw_assign(Err_AREQN, fieldValue)
                                  @DecatErr_Field("@@sreq", "sortRequisitionNumber")   @dtw_assign(Err_SREQN, fieldValue)
                                  @DecatErr_Field("@@preq", "totalRequisitionNumber")  @dtw_assign(Err_PREQN, fieldValue)
                                  @DecatErr_Field("@@fitm", "fromItemNumber")          @dtw_assign(Err_FITEM, fieldValue)
                                  @DecatErr_Field("@@titm", "toItemNumber")            @dtw_assign(Err_TITEM, fieldValue)
                                  @DecatErr_Field("@@aitm", "allItemNumber")           @dtw_assign(Err_AITEM, fieldValue)
                                  @DecatErr_Field("@@sitm", "sortItemNumber")          @dtw_assign(Err_SITEM, fieldValue)
                                  @DecatErr_Field("@@pitm", "totalItemNumber")         @dtw_assign(Err_PITEM, fieldValue)
                                  @DecatErr_Field("@@fbyr", "fromBuyerNumber")         @dtw_assign(Err_FBUYR, fieldValue)
                                  @DecatErr_Field("@@tbyr", "toBuyerNumber")           @dtw_assign(Err_TBUYR, fieldValue)
                                  @DecatErr_Field("@@abyr", "allBuyerNumber")          @dtw_assign(Err_ABUYR, fieldValue)
                                  @DecatErr_Field("@@sbyr", "sortBuyerNumber")         @dtw_assign(Err_SBUYR, fieldValue)
                                  @DecatErr_Field("@@pbyr", "totalBuyerNumber")        @dtw_assign(Err_PBUYR, fieldValue)
                                  @DecatErr_Field("@@fvnd", "fromVendorNumber")        @dtw_assign(Err_FVEND, fieldValue)
                                  @DecatErr_Field("@@tvnd", "toVendorNumber")          @dtw_assign(Err_TVEND, fieldValue)
                                  @DecatErr_Field("@@avnd", "allVendorNumber")         @dtw_assign(Err_AVEND, fieldValue)
                                  @DecatErr_Field("@@svnd", "sortVendorNumber")        @dtw_assign(Err_SVEND, fieldValue)
                                  @DecatErr_Field("@@pvnd", "totalVendorNumber")       @dtw_assign(Err_PVEND, fieldValue)
                                  @DecatErr_Field("@@fwhs", "fromWarehouseNumber")     @dtw_assign(Err_FWHS,  fieldValue)
                                  @DecatErr_Field("@@twhs", "toWarehouseNumber")       @dtw_assign(Err_TWHS,  fieldValue)
                                  @DecatErr_Field("@@awhs", "allWarehouseNumber")      @dtw_assign(Err_AWHS,  fieldValue)
                                  @DecatErr_Field("@@swhs", "sortWarehouseNumber")     @dtw_assign(Err_SWHS,  fieldValue)
                                  @DecatErr_Field("@@pwhs", "totalWarehouseNumber")    @dtw_assign(Err_PWHS,  fieldValue)
                                  @DecatErr_Field("@@fusr", "fromUserID")              @dtw_assign(Err_FUSER, fieldValue)
                                  @DecatErr_Field("@@tusr", "toUserID")                @dtw_assign(Err_TUSER, fieldValue)
                                  @DecatErr_Field("@@ausr", "allUserID")               @dtw_assign(Err_AUSER, fieldvalue)
                                  @DecatErr_Field("@@susr", "sortUserID")              @dtw_assign(Err_SUSER, fieldValue)
                                  @DecatErr_Field("@@pusr", "totalUserID")             @dtw_assign(Err_PUSER, fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@sug@")  @dtw_assign(V_N1SUG, fieldValue)
                                  @Decat_Field("@@req@")  @dtw_assign(V_N1REQ, fieldValue)
                                  @Decat_Field("@@freq")  @dtw_assign(V_FREQN, fieldValue)
                                  @Decat_Field("@@treq")  @dtw_assign(V_TREQN, fieldValue)
                                  @Decat_Field("@@areq")  @dtw_assign(V_AREQN, fieldValue)
                                  @Decat_Field("@@sreq")  @dtw_assign(V_SREQN, fieldValue)
                                  @Decat_Field("@@preq")  @dtw_assign(V_PREQN, fieldValue)
                                  @Decat_Field("@@fitm")  @dtw_assign(V_FITEM, fieldValue)
                                  @Decat_Field("@@titm")  @dtw_assign(V_TITEM, fieldValue)
                                  @Decat_Field("@@aitm")  @dtw_assign(V_AITEM, fieldValue)
                                  @Decat_Field("@@sitm")  @dtw_assign(V_SITEM, fieldValue)
                                  @Decat_Field("@@pitm")  @dtw_assign(V_PITEM, fieldValue)
                                  @Decat_Field("@@fbyr")  @dtw_assign(V_FBUYR, fieldValue)
                                  @Decat_Field("@@tbyr")  @dtw_assign(V_TBUYR, fieldValue)
                                  @Decat_Field("@@abyr")  @dtw_assign(V_ABUYR, fieldValue)
                                  @Decat_Field("@@sbyr")  @dtw_assign(V_SBUYR, fieldValue)
                                  @Decat_Field("@@pbyr")  @dtw_assign(V_PBUYR, fieldValue)
                                  @Decat_Field("@@fvnd")  @dtw_assign(V_FVEND, fieldValue)
                                  @Decat_Field("@@tvnd")  @dtw_assign(V_TVEND, fieldValue)
                                  @Decat_Field("@@avnd")  @dtw_assign(V_AVEND, fieldValue)
                                  @Decat_Field("@@svnd")  @dtw_assign(V_SVEND, fieldValue)
                                  @Decat_Field("@@pvnd")  @dtw_assign(V_PVEND, fieldValue)
                                  @Decat_Field("@@fwhs")  @dtw_assign(V_FWHS,  fieldValue)
                                  @Decat_Field("@@twhs")  @dtw_assign(V_TWHS,  fieldValue)
                                  @Decat_Field("@@awhs")  @dtw_assign(V_AWHS,  fieldValue)
                                  @Decat_Field("@@swhs")  @dtw_assign(V_SWHS,  fieldValue)
                                  @Decat_Field("@@pwhs")  @dtw_assign(V_PWHS,  fieldValue)
                                  @Decat_Field("@@fusr")  @dtw_assign(V_FUSER, fieldValue)
                                  @Decat_Field("@@tusr")  @dtw_assign(V_TUSER, fieldValue)
                                  @Decat_Field("@@ausr")  @dtw_assign(V_AUSER, fieldValue)
                                  @Decat_Field("@@susr")  @dtw_assign(V_SUSER, fieldValue)
                                  @Decat_Field("@@pusr")  @dtw_assign(V_PUSER, fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                                  %if (V_N1SUG == "1")
                                      @dtw_assign(checkedMRPPlannedOrders, "CHECKED")
                                  %else
                                      @dtw_assign(checkedMRPPlannedOrders, "")
                                  %endif
                                  %if (V_N1REQ == "1")
                                      @dtw_assign(checkedRequisition, "CHECKED")
                                  %else
                                      @dtw_assign(checkedRequisition, "")
                                  %endif
                                  %if (V_AREQN == "ALL")
                                      @dtw_assign(checkedallRequisitionNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallRequisitionNumber, "")
                                  %endif
                                  %if (V_AITEM == "ALL")
                                      @dtw_assign(checkedallItemNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallItemNumber, "")
                                  %endif
                                  %if (V_ABUYR == "ALL")
                                      @dtw_assign(checkedallBuyerNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallBuyerNumber, "")
                                  %endif
                                  %if (V_AVEND == "ALL")
                                      @dtw_assign(checkedallVendorNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallVendorNumber, "")
                                  %endif
                                  %if (V_AWHS == "ALL")
                                      @dtw_assign(checkedallWarehouseNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallWarehouseNumber, "")
                                  %endif
                                  %if (V_AUSER == "ALL")
                                      @dtw_assign(checkedallUserID, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallUserID, "")
                                  %endif

                                  %if (V_PREQN == "Y")
                                      @dtw_assign(checkedRequisitionNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedRequisitionNumberTotals, "")
                                  %endif
                                  %if (V_PITEM == "Y")
                                      @dtw_assign(checkedItemNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedItemNumberTotals, "")
                                  %endif
                                  %if (V_PBUYR == "Y")
                                      @dtw_assign(checkedBuyerNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedBuyerNumberTotals, "")
                                  %endif
                                  %if (V_PVEND == "Y")
                                      @dtw_assign(checkedVendorNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedVendorNumberTotals, "")
                                  %endif
                                  %if (V_PWHS == "Y")
                                      @dtw_assign(checkedWarehouseNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedWarehouseNumberTotals, "")
                                  %endif
                                  %if (V_PUSER == "Y")
                                      @dtw_assign(checkedUserIDTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedUserIDTotals, "")
                                  %endif
                              %else
                                  @dtw_assign(checkedMRPPlannedOrders, "CHECKED")
                                  @dtw_assign(checkedRequisition, "CHECKED")
                                  @dtw_assign(checkedallRequisitionNumber, "CHECKED")
                                  @dtw_assign(checkedallItemNumber, "CHECKED")
                                  @dtw_assign(checkedallBuyerNumber, "CHECKED")
                                  @dtw_assign(checkedallVendorNumber, "CHECKED")
                                  @dtw_assign(checkedallWarehouseNumber, "CHECKED")
                                  @dtw_assign(checkedallUserID, "CHECKED")
                                  @dtw_assign(checkedRequisitionNumberTotals, "")
                                  @dtw_assign(checkedItemNumberTotals, "")
                                  @dtw_assign(checkedBuyerNumberTotals, "")
                                  @dtw_assign(checkedVendorNumberTotals, "")
                                  @dtw_assign(checkedWarehouseNumberTotals, "")
                                  @dtw_assign(checkedUserIDTotals, "")
                              %endif

                              @SetTextOvr(Err_N1SUG)
                              <tr><td class="dsphdr"><span $(textOvr)>Include Type</span></td>
                                  %if (V_HDMPRL>"0")
                                      <td class="inputnmbr"><input name="mrpPlannedOrders" type="checkbox" VALUE='1' $(checkedMRPPlannedOrders)>MPS/MRP Planned Orders</td>
                                  %else
                                      <td class="inputnmbr"><input name="mrpPlannedOrders" type="checkbox" VALUE='1' $(checkedMRPPlannedOrders)>Suggested </td>
                                  %endif
                              </tr>
                              @DspErrMsg(Err_N1SUG)

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="requisition" type="checkbox" VALUE='1' $(checkedRequisition)>Requisition</td>
                              </tr>

                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                                  <td class="colhdr">Print<br>Totals</td>
                              </tr>

                              @SetTextOvr(Err_FREQN)
                              %if (textOvr == "") @SetTextOvr(Err_TREQN) %endif
                              %if (textOvr == "") @SetTextOvr(Err_AREQN) %endif
                              %if (textOvr == "") @SetTextOvr(Err_SREQN) %endif
                              %if (textOvr == "") @SetTextOvr(Err_PREQN) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Requisition Number</span></td>
                                  <td class="inputalph"><input name="fromRequisitionNumber" value="$(V_FREQN)" type="text" size="15" maxlength="15"></td>
                                  <td class="inputalph"><input name="toRequisitionNumber" value="$(V_TREQN)" type="text" size="15" maxlength="15"></td>
                                  <td class="inputalph"><input name="allRequisitionNumber" value='ALL' $(checkedallRequisitionNumber) type="checkbox" onClick="if (this.checked) this.form.fromRequisitionNumber.value='', this.form.toRequisitionNumber.value='';"></td>
                                  @Build_Sort_Select("sortRequisitionNumber", "$(V_SREQN)")
                                  <td align=center ><input name="totalRequisitionNumber" type="checkbox" $(checkedRequisitionNumberTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_FREQN)
                              @DspErrMsg(Err_TREQN)
                              @DspErrMsg(Err_AREQN)
                              @DspErrMsg(Err_SREQN)
                              @DspErrMsg(Err_PREQN)

                              @SetTextOvr(Err_FITEM)
                              %if (textOvr == "") @SetTextOvr(Err_TITEM) %endif
                              %if (textOvr == "") @SetTextOvr(Err_AITEM) %endif
                              %if (textOvr == "") @SetTextOvr(Err_SITEM) %endif
                              %if (textOvr == "") @SetTextOvr(Err_PITEM) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Item Number</span></td>
                                  <td class="inputalph"><input name="fromItemNumber" value="$(V_FITEM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromItemNumber&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="toItemNumber" value="$(V_TITEM)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toItemNumber&amp;fldDesc=toitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="allItemNumber" value='ALL' $(checkedallItemNumber) type="checkbox" onClick="if (this.checked) this.form.fromItemNumber.value='', this.form.toItemNumber.value='';"></td>
                                  @Build_Sort_Select("sortItemNumber", "$(V_SITEM)")
                                  <td align=center ><input name="totalItemNumber" type="checkbox" $(checkedItemNumberTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_FITEM)
                              @DspErrMsg(Err_TITEM)
                              @DspErrMsg(Err_AITEM)
                              @DspErrMsg(Err_SITEM)
                              @DspErrMsg(Err_PITEM)

                              @SetTextOvr(Err_FBUYR)
                              %if (textOvr == "") @SetTextOvr(Err_TBUYR) %endif
                              %if (textOvr == "") @SetTextOvr(Err_ABUYR) %endif
                              %if (textOvr == "") @SetTextOvr(Err_SBUYR) %endif
                              %if (textOvr == "") @SetTextOvr(Err_PBUYR) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Buyer Number</span></td>
                                  <td class="inputnmbr"><input name="fromBuyerNumber" value="$(V_FBUYR)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(cGIPath)BuyerSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromBuyerNumber&amp;fldDesc=analystName&amp;buyerAnalyst=Analyst" onclick="$(searchWinVar)"> $(searchImage) </a><input name="analystName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toBuyerNumber" value="$(V_TBUYR)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(cGIPath)BuyerSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toBuyerNumber&amp;fldDesc=analystName&amp;buyerAnalyst=Analyst" onclick="$(searchWinVar)"> $(searchImage) </a><input name="analystName" type="hidden"></td>
                                  <td class="inputalph"><input name="allBuyerNumber" value='ALL' $(checkedallBuyerNumber) type="checkbox" onClick="if (this.checked) this.form.fromBuyerNumber.value='', this.form.toBuyerNumber.value='';"></td>
                                  @Build_Sort_Select("sortBuyerNumber", "$(V_SBUYR)")
                                  <td align=center ><input name="totalBuyerNumber" type="checkbox" $(checkedBuyerNumberTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_FBUYR)
                              @DspErrMsg(Err_TBUYR)
                              @DspErrMsg(Err_ABUYR)
                              @DspErrMsg(Err_SBUYR)
                              @DspErrMsg(Err_PBUYR)

                              @SetTextOvr(Err_FVEND)
                              %if (textOvr == "") @SetTextOvr(Err_TVEND) %endif
                              %if (textOvr == "") @SetTextOvr(Err_AVEND) %endif
                              %if (textOvr == "") @SetTextOvr(Err_SVEND) %endif
                              %if (textOvr == "") @SetTextOvr(Err_PVEND) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Vendor Number</span></td>
                                  <td class="inputnmbr"><input name="fromVendorNumber" value="$(V_FVEND)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)VendorSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromVendorNumber&amp;fldDesc=vendorName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="vendorName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toVendorNumber" value="$(V_TVEND)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(phpPath)VendorSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toVendorNumber&amp;fldDesc=vendorName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="vendorName" type="hidden"></td>
                                  <td class="inputalph"><input name="allVendorNumber" value='ALL' $(checkedallVendorNumber) type="checkbox" onClick="if (this.checked) this.form.fromVendorNumber.value='', this.form.toVendorNumber.value='';"></td>
                                  @Build_Sort_Select("sortVendorNumber", "$(V_SVEND)")
                                  <td align=center ><input name="totalVendorNumber" type="checkbox" $(checkedVendorNumberTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_FVEND)
                              @DspErrMsg(Err_TVEND)
                              @DspErrMsg(Err_AVEND)
                              @DspErrMsg(Err_SVEND)
                              @DspErrMsg(Err_PVEND)

                              @SetTextOvr(Err_FWHS)
                              %if (textOvr == "") @SetTextOvr(Err_TWHS) %endif
                              %if (textOvr == "") @SetTextOvr(Err_AWHS) %endif
                              %if (textOvr == "") @SetTextOvr(Err_SWHS) %endif
                              %if (textOvr == "") @SetTextOvr(Err_PWHS) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Warehouse Number</span></td>
                                  <td class="inputnmbr"><input name="fromWarehouseNumber" value="$(V_FWHS)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)WarehouseSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromWarehouseNumber&amp;fldDesc=fwarehouseName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fwarehouseName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toWarehouseNumber" value="$(V_TWHS)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)WarehouseSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toWarehouseNumber&amp;fldDesc=twarehouseName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="twarehouseName" type="hidden"></td>
                                  <td class="inputalph"><input name="allWarehouseNumber" value='ALL' $(checkedallWarehouseNumber) type="checkbox" onClick="if (this.checked) this.form.fromWarehouseNumber.value='', this.form.toWarehouseNumber.value='';"></td>
                                  @Build_Sort_Select("sortWarehouseNumber", "$(V_SWHS)")
                                  <td align=center ><input name="totalWarehouseNumber" type="checkbox" $(checkedWarehouseNumberTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_FWHS)
                              @DspErrMsg(Err_TWHS)
                              @DspErrMsg(Err_AWHS)
                              @DspErrMsg(Err_SWHS)
                              @DspErrMsg(Err_PWHS)

                              @SetTextOvr(Err_FUSER)
                              %if (textOvr == "") @SetTextOvr(Err_TUSER) %endif
                              %if (textOvr == "") @SetTextOvr(Err_AUSER) %endif
                              %if (textOvr == "") @SetTextOvr(Err_SUSER) %endif
                              %if (textOvr == "") @SetTextOvr(Err_PUSER) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>User ID</span></td>
                                  <td class="inputalph"><input name="fromUserID" value="$(V_FUSER)" type="text" size="10" maxlength="10"></td>
                                  <td class="inputalph"><input name="toUserID" value="$(V_TUSER)" type="text" size="10" maxlength="10"></td>
                                  <td class="inputalph"><input name="allUserID" value='ALL' $(checkedallUserID) type="checkbox" onClick="if (this.checked) this.form.fromUserID.value='', this.form.toUserID.value='';"></td>
                                  @Build_Sort_Select("sortUserID", "$(V_SUSER)")
                                  <td align=center ><input name="totalUserID" type="checkbox" $(checkedUserIDTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_FUSER)
                              @DspErrMsg(Err_TUSER)
                              @DspErrMsg(Err_AUSER)
                              @DspErrMsg(Err_SUSER)
                              @DspErrMsg(Err_PUSER)

                          </table>

                          @dtw_assign(envProgram, "HPOSGR")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HPOSGS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(fromRequisitionNumber)
  @dtw_mUPPERCASE(toRequisitionNumber)
  @dtw_mUPPERCASE(allRequisitionNumber)
  @dtw_mUPPERCASE(fromItemNumber)
  @dtw_mUPPERCASE(toItemNumber)
  @dtw_mUPPERCASE(allItemNumber)
  @dtw_mUPPERCASE(allBuyerNumber)
  @dtw_mUPPERCASE(allVendorNumber)
  @dtw_mUPPERCASE(allWarehouseNumber)
  @dtw_mUPPERCASE(fromUserID)
  @dtw_mUPPERCASE(toUserID)
  @dtw_mUPPERCASE(allUserID)

  @dtw_assign(sortRequisitionNumber,@dtw_rstrip(sortRequisitionNumber))
  @dtw_assign(sortItemNumber,@dtw_rstrip(sortItemNumber))
  @dtw_assign(fromBuyerNumber,@dtw_rstrip(fromBuyerNumber))
  @dtw_assign(toBuyerNumber,@dtw_rstrip(toBuyerNumber))
  @dtw_assign(sortBuyerNumber,@dtw_rstrip(sortBuyerNumber))
  @dtw_assign(fromVendorNumber,@dtw_rstrip(fromVendorNumber))
  @dtw_assign(toVendorNumber,@dtw_rstrip(toVendorNumber))
  @dtw_assign(sortVendorNumber,@dtw_rstrip(sortVendorNumber))
  @dtw_assign(fromWarehouse,@dtw_rstrip(fromWarehouse))
  @dtw_assign(toWarehouse,@dtw_rstrip(toWarehouse))
  @dtw_assign(sortWarehouse,@dtw_rstrip(sortWarehouse))
  @dtw_assign(sortUserID,@dtw_rstrip(sortUserID))

  %if (allRequisitionNumber != "ALL")
      @dtw_assign(allRequisitionNumber, "")
  %endif
  %if (allItemNumber != "ALL")
      @dtw_assign(allItemNumber, "")
  %endif
  %if (allBuyerNumber != "ALL")
      @dtw_assign(allBuyerNumber, "")
  %endif
  %if (allVendorNumber != "ALL")
      @dtw_assign(allVendorNumber, "")
  %endif
  %if (allWarehouseNumber != "ALL")
      @dtw_assign(allWarehouseNumber, "")
  %endif
  %if (allUserID != "ALL")
      @dtw_assign(allUserID, "")
  %endif

  %if (totalRequisitionNumber != "Y")
      @dtw_assign(totalRequisitionNumber, "N")
  %endif
  %if (totalItemNumber != "Y")
      @dtw_assign(totalItemNumber, "N")
  %endif
  %if (totalBuyerNumber != "Y")
      @dtw_assign(totalBuyerNumber, "N")
  %endif
  %if (totalVendorNumber != "Y")
      @dtw_assign(totalVendorNumber, "N")
  %endif
  %if (totalWarehouseNumber != "Y")
      @dtw_assign(totalWarehouseNumber, "N")
  %endif
  %if (totalUserID != "Y")
      @dtw_assign(totalUserID, "N")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@sug@", mrpPlannedOrders)
  @Concat_Field("@@req@", requisition)
  @Concat_Field("@@freq", fromRequisitionNumber)
  @Concat_Field("@@treq", toRequisitionNumber)
  @Concat_Field("@@areq", allRequisitionNumber)
  @Concat_Field("@@sreq", sortRequisitionNumber)
  @Concat_Field("@@preq", totalRequisitionNumber)
  @Concat_Field("@@fitm", fromItemNumber)
  @Concat_Field("@@titm", toItemNumber)
  @Concat_Field("@@aitm", allItemNumber)
  @Concat_Field("@@sitm", sortItemNumber)
  @Concat_Field("@@pitm", totalItemNumber)
  @Concat_Field("@@fbyr", fromBuyerNumber)
  @Concat_Field("@@tbyr", toBuyerNumber)
  @Concat_Field("@@abyr", allBuyerNumber)
  @Concat_Field("@@sbyr", sortBuyerNumber)
  @Concat_Field("@@pbyr", totalBuyerNumber)
  @Concat_Field("@@fvnd", fromVendorNumber)
  @Concat_Field("@@tvnd", toVendorNumber)
  @Concat_Field("@@avnd", allVendorNumber)
  @Concat_Field("@@svnd", sortVendorNumber)
  @Concat_Field("@@pvnd", totalVendorNumber)
  @Concat_Field("@@fwhs", fromWarehouseNumber)
  @Concat_Field("@@twhs", toWarehouseNumber)
  @Concat_Field("@@awhs", allWarehouseNumber)
  @Concat_Field("@@swhs", sortWarehouseNumber)
  @Concat_Field("@@pwhs", totalWarehouseNumber)
  @Concat_Field("@@fusr", fromUserID)
  @Concat_Field("@@tusr", toUserID)
  @Concat_Field("@@ausr", allUserID)
  @Concat_Field("@@susr", sortUserID)
  @Concat_Field("@@pusr", totalUserID)


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}