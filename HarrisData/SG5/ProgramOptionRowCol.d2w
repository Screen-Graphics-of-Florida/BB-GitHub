%}

%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {	
  page_title              = "Program Option Security $(rowColDesc) Update"
  d2wName                 = "ProgramOptionRowCol.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;progName=@dtw_rurlescseq(progName)&amp;progDesc=@dtw_rurlescseq(progDesc)&amp;user=@dtw_rurlescseq(user)&amp;userName=@dtw_rurlescseq(userName)&amp;optNumber=@dtw_rurlescseq(optNumber)&amp;optDesc=@dtw_rurlescseq(optDesc)$(orderByVarBase)$(wildCardVarBase)&amp;forUserProfile=@dtw_rurlescseq(forUserProfile)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
  rowColDesc              = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %if (optNumber != "")
      @dtw_assign(rowColDesc, "Column")
  %else
      @dtw_assign(rowColDesc, "Row")
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          %INCLUDE "$(genericHead)"
          <script TYPE="text/javascript">
              %INCLUDE "NewWindowOpen.icl"
          </script>
      </head>

      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "AddRecordSQL.icl"
                      %INCLUDE "stmtSQLEnd.icl"
                      @Program_Option_RowCol(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Program_Option_RowCol (IN CHAR(64)    profileHandle,
				              CHAR(2)     dataBaseID,
                                             CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              <td class="toolbar">
                  <a href="$(homeURL)$(cGIPath)$(d2wName)/UPDATEALL$(d2wVarBase)&amp;updateAll=S">$(selectAllImage)</a>
                  <a href="$(homeURL)$(cGIPath)$(d2wName)/UPDATEALL$(d2wVarBase)&amp;updateAll=C">$(deselectAllImage)</a>
                  <a href="$(homeURL)$(cGIPath)$(d2wName)/CLOSE$(genericVarBase)">$(cancelImageMed)</a>
                  @dtw_assign(medIcon, "Y")
                  %INCLUDE "HelpPage.icl"
              </td>
          </tr>
      </table>
      $(searchhrTagAttr)

      <table $(contentTable)>
          @Format_Header("Program Name", $(progDesc), $(progName))
          %if (optNumber != "")
              @Format_Header("Option", $(optDesc), "")
          %else
              @Format_Header("User Profile", $(userName), user)
          %endif
      </table>

          %ROW{
          %}
      </table>
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}

%HTML(UPDATEALL) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "stmtSQLClear.icl"
  %if (updateAll == "C")
      @dtw_assign(updSel, "N")
  %else
      @dtw_assign(updSel, "Y")
  %endif
  %if (user != "")
      @dtw_concat(stmtSQL, " Update SYPGMW Set SWOP01='$(updSel)', SWOP02='$(updSel)', SWOP03='$(updSel)', SWOP04='$(updSel)', SWOP05='$(updSel)',", stmtSQL)
      @dtw_concat(stmtSQL, "                   SWOP06='$(updSel)', SWOP07='$(updSel)', SWOP08='$(updSel)', SWOP09='$(updSel)', SWOP10='$(updSel)',", stmtSQL)
      @dtw_concat(stmtSQL, "                   SWOP11='$(updSel)', SWOP12='$(updSel)', SWOP13='$(updSel)', SWOP14='$(updSel)', SWOP15='$(updSel)' ", stmtSQL)
  %else
      @dtw_concat(stmtSQL, " Update SYPGMW Set SWOP$(optNumber)='$(updSel)' ", stmtSQL)
  %endif
  @dtw_concat(stmtSQL, " Where SWXHND='$(profileHandle)' and SWPGID='$(progName)'", stmtSQL)
  %if (user != "")
      @dtw_concat(stmtSQL, " and SWUSER='$(user)' ", stmtSQL)
  %endif
  %if (wildCardSearch!="")
      @dtw_concat(stmtSQL, " $(wildCardSearch) ", stmtSQL)
  %endif
  @dtw_concat(stmtSQL, " @@endsql", stmtSQL)

  @SQL_Update(stmtSQL, status)

  <script TYPE="text/javascript">
      opener.location.href=opener.location.href;
      window.close();
  </script>
%}

%HTML(CLOSE) {
  %INCLUDE "setLibraryList.icl"
  <script TYPE="text/javascript">
      window.close();
  </script>
%}