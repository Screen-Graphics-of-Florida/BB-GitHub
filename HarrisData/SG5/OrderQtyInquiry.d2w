%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "InventoryControl$(dataBaseID).icl"
%INCLUDE "SystemControl$(dataBaseID).icl"

%Define {	
  page_title              = "Order $(orderNumber)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}
	
%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onLoad="window.focus()" onBlur="window.close()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td>
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " OEORDT ", fileSQL)
                      @dtw_concat(selectSQL, "ODORD#=$(orderNumber) and ODORL#=$(lineNumber) and ODBLN#=$(relNumber) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By ODORL# ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @OrderQty_Inquiry(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) OrderQty_Inquiry (IN CHAR(64)    profileHandle,
				         CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"

      %ROW{
          @RtvFldDesc("WHWHS=$(V_ODWH)", "HDWHSM", "WHWHNM", whsName)
          <table $(contentTable)>
              @Format_Header("Item", $(V_ODIMDS), $(V_ODITEM))
              @Format_Header("Warehouse", $(whsName), $(V_ODWH))
              @Format_Header("Line", $(lineNumber), "")
              @Format_Header("Release", $(relNumber), "")
          </table>

          $(inquiryhrTagAttr)

          <table $(contentTable)>
              <tr><td>&nbsp;</td>
                  <td class="colhdr">Quantity</td>
              </tr>

              <tr><td class="dsphdr">Ordered</td>
                  <td class="dspqty">$(V_ODQORD)</td>
              </tr>
	          		
              <tr><td class="dsphdr">Shipped To Date</td>
                  <td class="dspqty">$(V_ODQSTD)</td>
              </tr>
	          	
              <tr><td class="dsphdr">Shipped/Not Invoiced</td>
                  <td class="dspqty">$(V_ODQSTC)</td>
              </tr>

              <tr><td class="dsphdr">On Pick Tickets</td>
                  <td class="dspqty">$(V_ODQOPK)</td>
              </tr>

              <tr><td class="dsphdr">On Backorder</td>
                  <td class="dspqty">$(V_ODQOBO)</td>
              </tr>
          </table>
      %}
      $(inquiryhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(RPT_MAX_ROWS, "1000")
  @Set_SQL(stmtSQL)
%}