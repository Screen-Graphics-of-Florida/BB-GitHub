%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Freight Class Maintenance"
  d2wName                 = "FreightClassMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;freightclass=@dtw_rurlescseq(freightclass)&amp;longdescone=@dtw_rurlescseq(longdescone)&amp;maintenanceCode=D"
  programName             = "HHDFCU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              function validate(chgForm) {
                  if (document.Chg.freightclass.value =="" ||
                      document.Chg.hazmatlcode.value =="" ||
                      document.Chg.longdescone.value =="")
                     {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.reportqty, 9, 4))
                      return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "FREIGHTCLASSMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "SELECT * FROM HDFTCL WHERE FTCLAS = '$(freightclass)'", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=108")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" NAME="Chg" METHOD=POST ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {

                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "freightclass")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@clas", "freightclass")  @dtw_assign(Err_FTCLAS, fieldValue)
                          @DecatErr_Field("@@clsd", "shortdesc")     @dtw_assign(Err_FTCLSD, fieldValue)
                          @DecatErr_Field("@@ld01", "longdescone")   @dtw_assign(Err_FTLD01, fieldValue)
                          @DecatErr_Field("@@ld02", "longdesctwo")   @dtw_assign(Err_FTLD02, fieldValue)
                          @DecatErr_Field("@@ld03", "longdescthree") @dtw_assign(Err_FTLD03, fieldValue)
                          @DecatErr_Field("@@nmfc", "carrierclass")  @dtw_assign(Err_FTNMFC, fieldValue)
                          @DecatErr_Field("@@hazm", "hazmatlcode")   @dtw_assign(Err_FTHAZM, fieldValue)
                          @DecatErr_Field("@@rpqt", "reportqty")     @dtw_assign(Err_FTRPQT, fieldValue)
                          @DecatErr_Field("@@rqum", "reportqtyum")   @dtw_assign(Err_FTRQUM, fieldValue)
                      %endif

                      @Decat_Field("@@clas")   @dtw_assign(V_FTCLAS, fieldValue)
                      @Decat_Field("@@clsd")   @dtw_assign(V_FTCLSD, fieldValue)
                      @Decat_Field("@@ld01")   @dtw_assign(V_FTLD01, fieldValue)
                      @Decat_Field("@@ld02")   @dtw_assign(V_FTLD02, fieldValue)
                      @Decat_Field("@@ld03")   @dtw_assign(V_FTLD03, fieldValue)
                      @Decat_Field("@@nmfc")   @dtw_assign(V_FTNMFC, fieldValue)
                      @Decat_Field("@@hazm")   @dtw_assign(V_FTHAZM, fieldValue)
                      @Decat_Field("@@rpqt")   @dtw_assign(V_FTRPQT, fieldValue)
                      @Decat_Field("@@rqum")   @dtw_assign(V_FTRQUM, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(V_FTHAZM, "N")
                          @dtw_assign(focusField, "freightclass")
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(V_FTCLAS, "")
                      @dtw_assign(focusField, "freightclass")
                  %else
                      @dtw_assign(focusField, "shortdesc")
                  %endif

                  @SetTextOvr(Err_FTCLAS)
                  <tr><td class="dsphdr"><span $(textOvr)>Freight Class</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="freightclass" type="text" value="$(V_FTCLAS)" size="5" maxlength="5"> $(reqFieldChar) </td>
                      %else
                          <td class="inputalph"><input name="freightclass" type="hidden" value="$(V_FTCLAS)" size="5" maxlength="5">$(V_FTCLAS)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_FTCLAS)

                  @SetTextOvr(Err_FTCLSD)
                  <tr><td class="dsphdr"><span $(textOvr)>Short Description</span></td>
                      <td class="inputalph"><input name="shortdesc" type="text" value="$(V_FTCLSD)" size="15" maxlength="10"></td>
                  </tr>
                  @DspErrMsg(Err_FTCLSD)

                  @SetTextOvr(Err_FTLD01)
  	               <tr><td class="dsphdr"><span $(textOvr)>Long Description One</span></td>
                      <td class="inputalph"><input name="longdescone" type="text" value="$(V_FTLD01)" size="40" maxlength="30"><span class="reqfield"> $(reqFieldChar) </span</td>
                  </tr>
                  @DspErrMsg(Err_FTLD01)

                  @SetTextOvr(Err_FTLD02)
                  <tr><td class="dsphdr"><span $(textOvr)>Long Description Two</span></td>
                      <td class="inputalph"><input name="longdesctwo" type="text" value="$(V_FTLD02)" size="40" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_FTLD02)

                  @SetTextOvr(Err_FTLD03)
                  <tr><td class="dsphdr"><span $(textOvr)>Long Description Three</span></td>
                      <td class="inputalph"><input name="longdescthree" type="text" value="$(V_FTLD03)" size="40" maxlength="30"></td>
                  </tr>
                  @DspErrMsg(Err_FTLD03)

                  @SetTextOvr(Err_FTNMFC)
                  <tr><td class="dsphdr"><span $(textOvr)>Carrier Freight Class</span></td>
                      <td class="inputalph"><input name="carrierclass" type="text" value="$(V_FTNMFC)" size="5" maxlength="5"></td>
                  </tr>
                  @DspErrMsg(Err_FTNMFC)

                  @SetTextOvr(Err_FTHAZM)
                  <tr><td class="dsphdr"><span $(textOvr)>Hazardous Material Code</span></td>
                      @dtw_tb_rows(yn01Table, maxRows)
                      @dtw_assign(x, "1")
                      %while((@dtw_tb_rgetv(yn01Table, x, "1") != V_FTHAZM) && (x < maxRows))
                            {@dtw_add(x, "1", x)%}
                      <td>@dtw_tb_select(yn01Table, "hazmatlcode", "2", "1", "N", "", x, "1")</td>
                  </tr>
                  @DspErrMsg(Err_FTHAZM)

                  @SetTextOvr(Err_FTRPQT)
                  <tr><td class="dsphdr"><span $(textOvr)>HM Reportable Quantity</span></td>
                      <td class="inputnmbr"><input name="reportqty" type="text" value="$(V_FTRPQT)" size="14" maxlength="14"></td>
                  </tr>
                  @DspErrMsg(Err_FTRPQT)

                  @RtvFldDesc("UMUOM='$(V_FTRQUM)'", "HDUOM", "UMUMLD", fieldDesc)
                  @SetTextOvr(Err_FTRQUM)
                  <tr><td class="dsphdr"><span $(textOvr)>Reportable Quantity U/M</span></td>
                      <td class="inputnmbr"><input name="reportqtyum" type="text" value="$(V_FTRQUM)" size="2" maxlength="2"><a href="$(homeURL)$(cGIPath)UnitOfMeasureSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=reportqtyum&amp;fldDesc=reportqtyumDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="reportqtyumDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                  </tr>
                  @DspErrMsg(Err_FTRQUM)
              %}
          </table>
	
          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HHDFCU_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @yn01_Table_Query(profileHandle, dataBaseID, "YORN      ", yn01Table)
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(freightclass)
  @dtw_mUPPERCASE(hazmatlcode)
  @dtw_mUPPERCASE(reportqtyum)
  @dtw_assign(reportqty,@dtw_rstrip(reportqty))

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@clas", freightclass)
  @Concat_Field("@@clsd", shortdesc)
  @Concat_Field("@@ld01", longdescone)
  @Concat_Field("@@ld02", longdesctwo)
  @Concat_Field("@@ld03", longdescthree)
  @Concat_Field("@@nmfc", carrierclass)
  @Concat_Field("@@hazm", hazmatlcode)
  @Concat_Field("@@rpqt", reportqty)
  @Concat_Field("@@rqum", reportqtyum)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" || maintenanceCode == "D")
      %if (errFound == "")
          @Format_ConfMsg_Desc(maintenanceCode, $(longdescone), $(freightclass), "", "", "", "", confMessage)
      %else
          @DecatErr_Field("@@clas", "freightclass")
          @Format_ConfMsg_Desc("", $(longdescone), $(freightclass), "<br>$(fieldValue)", "", "", "", confMessage)
      %endif
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=108&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;freightclass=@dtw_rurlescseq(freightclass)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
