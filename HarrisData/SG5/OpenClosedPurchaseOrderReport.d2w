                              %if (reportselection == "O")
                                @SetTextOvr(Err_N1OPEN)
                                  <tr><td  class="dsphdr"><span $(textOvr)>Print Open Lines Only</span></td>
                                      <td class="inputnmbr"><input name="OpenLinesOnly" type="radio" VALUE='01' $(OpenLinesOnlyNo)>No</td>
                                  </tr>
                                  @DspErrMsg(Err_N1OPEN)

                                  <tr><td>&nbsp;</td>
                                      <td class="inputnmbr"><input name="OpenLinesOnly" type="radio" VALUE='02' $(OpenLinesOnlyYes)>Yes</td>
                                  </tr>
