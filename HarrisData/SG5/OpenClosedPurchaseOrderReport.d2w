                                  @dtw_assign(checkedallUserDate4, "CHECKED")
                                  @dtw_assign(checkedallItemNumber, "CHECKED")
                                  @dtw_assign(checkedallWarehouse, "CHECKED")
                                  @dtw_assign(checkedallProductClass, "CHECKED")
                                  @dtw_assign(checkedallVendorStockNumber, "CHECKED")
                                  @dtw_assign(checkedallPurchaseOrderType, "CHECKED")

                                  @dtw_assign(checkedPurchaseOrderNumberTotals, "N")
                                  @dtw_assign(checkedVendorNumberTotals, "N")
                                  @dtw_assign(checkedHeaderRequiredDateTotals, "N")
                                  @dtw_assign(checkedUserDate2Totals, "N")
                                  @dtw_assign(checkedUserDate3Totals, "N")
                                  @dtw_assign(checkedUserDate4Totals, "N")
                                  @dtw_assign(checkedItemNumberTotals, "N")
                                  @dtw_assign(checkedWarehouseTotals, "N")
                                  @dtw_assign(checkedProductClassTotals, "N")
                                  @dtw_assign(checkedVendorStockNumberTotals, "N")
                                  @dtw_assign(checkedPurchaseOrderTypeTotals, "N")
