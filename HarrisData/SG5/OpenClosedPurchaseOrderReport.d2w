                                  <td class="inputnmbr"><input name="toPurchaseOrderNumber" value="$(V_N1TORD)" type="text" size="8" maxlength="8"></td>
                                  <td class="inputalph"><input name="allPurchaseOrderNumber" value='ALL' $(checkedallPurchaseOrderNumber) type="checkbox" onClick="if (this.checked) this.form.fromPurchaseOrderNumber.value='', this.form.toPurchaseOrderNumber.value='';"></td>
