                              %if (textOvr == "") @SetTextOvr(Err_N1SVNS) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1PVNS) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Vendor Stock Number</span></td>
