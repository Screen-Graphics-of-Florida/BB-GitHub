                              %else
                                  @dtw_assign(OpenLinesOnlyNo, "CHECKED")
                                  @dtw_assign(OpenLinesOnlyYes, "")
                                  @dtw_assign(checkedallPurchaseOrderNumber, "CHECKED")
                                  @dtw_assign(checkedallVendorNumber, "CHECKED")
                                  @dtw_assign(checkedallHeaderRequiredDate, "CHECKED")
