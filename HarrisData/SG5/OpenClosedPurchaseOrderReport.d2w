  @Concat_Field("@@spcl", sortProductClass)
  @Concat_Field("@@ppcl", totalProductClass)
  @Concat_Field("@@fvns", fromVendorStockNumber)
  @Concat_Field("@@tvns", toVendorStockNumber)
  @Concat_Field("@@avns", allVendorStockNumber)
  @Concat_Field("@@svns", sortVendorStockNumber)
  @Concat_Field("@@pvns", totalVendorStockNumber)
  @Concat_Field("@@foty", fromPurchaseOrderType)
  @Concat_Field("@@toty", toPurchaseOrderType)
  @Concat_Field("@@aoty", allPurchaseOrderType)
  @Concat_Field("@@soty", sortPurchaseOrderType)
