                                  <td class="inputalph"><input name="toPurchaseOrderType" value="$(V_N1TOTY)" type="text" size="1" maxlength="1"><a href="$(homeURL)$(cGIPath)ordertypesearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toPurchaseOrderType&amp;fldDesc=toOrderTypeDescH&amp;appID=PO" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toOrderTypeDescH" type="hidden"></td>
