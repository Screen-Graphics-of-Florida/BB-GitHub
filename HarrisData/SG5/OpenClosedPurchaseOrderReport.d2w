%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HPOOSC_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  %if (errFound == "Y")
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @Decat_Field("@@mopt")
      %if (reportselection != fieldValue)
          <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/REPORT$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)&amp;reportselection=@dtw_rurlescseq(fieldValue)&amp;errFound=Y&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
      %endif
  %endif
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allPurchaseOrderNumber)
  @dtw_mUPPERCASE(allVendorNumber)
  @dtw_mUPPERCASE(allHeaderRequiredDate)
  @dtw_mUPPERCASE(allUserDate2)
  @dtw_mUPPERCASE(allUserDate3)
  @dtw_mUPPERCASE(allUserDate4)
  @dtw_mUPPERCASE(fromItemNumber)
  @dtw_mUPPERCASE(toItemNumber)
  @dtw_mUPPERCASE(allItemNumber)
  @dtw_mUPPERCASE(allWarehouse)
  @dtw_mUPPERCASE(fromProductClass)
  @dtw_mUPPERCASE(toProductClass)
  @dtw_mUPPERCASE(allProductClass)
  @dtw_mUPPERCASE(fromVendorStockNumber)
  @dtw_mUPPERCASE(toVendorStockNumber)
  @dtw_mUPPERCASE(allVendorStockNumber)
  @dtw_mUPPERCASE(fromPurchaseOrderType)
  @dtw_mUPPERCASE(toPurchaseOrderType)
  @dtw_mUPPERCASE(allPurchaseOrderType)

  @dtw_assign(fromPurchaseOrderNumber,@dtw_rstrip(fromPurchaseOrderNumber))
  @dtw_assign(toPurchaseOrderNumber,@dtw_rstrip(toPurchaseOrderNumber))
  @dtw_assign(sortPurchaseOrderNumber,@dtw_rstrip(sortPurchaseOrderNumber))
  @dtw_assign(fromVendorNumber,@dtw_rstrip(fromVendorNumber))
  @dtw_assign(toVendorNumber,@dtw_rstrip(toVendorNumber))
  @dtw_assign(sortVendorNumber,@dtw_rstrip(sortVendorNumber))
  @dtw_assign(fromHeaderRequiredDate,@dtw_rstrip(fromHeaderRequiredDate))
  @dtw_assign(toHeaderRequiredDate,@dtw_rstrip(toHeaderRequiredDate))
  @dtw_assign(sortHeaderRequiredDate,@dtw_rstrip(sortHeaderRequiredDate))
  @dtw_assign(fromUserDate2,@dtw_rstrip(fromUserDate2))
  @dtw_assign(toUserDate2,@dtw_rstrip(toUserDate2))
  @dtw_assign(sortUserDate2,@dtw_rstrip(sortUserDate2))
  @dtw_assign(fromUserDate3,@dtw_rstrip(fromUserDate3))
  @dtw_assign(toUserDate3,@dtw_rstrip(toUserDate3))
  @dtw_assign(sortUserDate3,@dtw_rstrip(sortUserDate3))
  @dtw_assign(fromUserDate4,@dtw_rstrip(fromUserDate4))
  @dtw_assign(toUserDate4,@dtw_rstrip(toUserDate4))
  @dtw_assign(sortUserDate4,@dtw_rstrip(sortUserDate4))
  @dtw_assign(sortItemNumber,@dtw_rstrip(sortItemNumber))
  @dtw_assign(fromWarehouse,@dtw_rstrip(fromWarehouse))
  @dtw_assign(toWarehouse,@dtw_rstrip(toWarehouse))
  @dtw_assign(sortWarehouse,@dtw_rstrip(sortWarehouse))
  @dtw_assign(sortProductClass,@dtw_rstrip(sortProductClass))
  @dtw_assign(sortVendorStockNumber,@dtw_rstrip(sortVendorStockNumber))
  @dtw_assign(sortPurchaseOrderType,@dtw_rstrip(sortPurchaseOrderType))


  %if (allPurchaseOrderNumber != "ALL")
      @dtw_assign(allPurchaseOrderNumber, "")
  %endif
  %if (allVendorNumber != "ALL")
      @dtw_assign(allVendorNumber, "")
  %endif
  %if (allHeaderRequiredDate != "ALL")
      @dtw_assign(allHeaderRequiredDate, "")
  %endif
  %if (allUserDate2 != "ALL")
      @dtw_assign(allUserDate2, "")
  %endif
  %if (allUserDate3 != "ALL")
      @dtw_assign(allUserDate3, "")
  %endif
  %if (allUserDate4 != "ALL")
      @dtw_assign(allUserDate4, "")
  %endif
  %if (allItemNumber != "ALL")
      @dtw_assign(allItemNumber, "")
  %endif
  %if (allWarehouse != "ALL")
      @dtw_assign(allWarehouse, "")
  %endif
  %if (allProductClass != "ALL")
      @dtw_assign(allProductClass, "")
  %endif
  %if (allVendorStockNumber != "ALL")
      @dtw_assign(allVendorStockNumber, "")
  %endif
  %if (allPurchaseOrderType != "ALL")
      @dtw_assign(allPurchaseOrderType, "")
  %endif

  %if (totalPurchaseOrderNumber != "Y")
      @dtw_assign(totalPurchaseOrderNumber, "N")
  %endif
  %if (totalVendorNumber != "Y")
      @dtw_assign(totalVendorNumber, "N")
  %endif
  %if (totalHeaderRequiredDate != "Y")
      @dtw_assign(totalHeaderRequiredDate, "N")
  %endif
  %if (totalUserDate2 != "Y")
      @dtw_assign(totalUserDate2, "N")
  %endif
  %if (totalUserDate3 != "Y")
      @dtw_assign(totalUserDate3, "N")
  %endif
  %if (totalUserDate4 != "Y")
      @dtw_assign(totalUserDate4, "N")
  %endif
  %if (totalItemNumber != "Y")
      @dtw_assign(totalItemNumber, "N")
  %endif
  %if (totalWarehouse != "Y")
      @dtw_assign(totalWarehouse, "N")
  %endif
  %if (totalProductClass != "Y")
      @dtw_assign(totalProductClass, "N")
  %endif
  %if (totalVendorStockNumber != "Y")
      @dtw_assign(totalVendorStockNumber, "N")
  %endif
  %if (totalPurchaseOrderType != "Y")
      @dtw_assign(totalPurchaseOrderType, "N")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@mopt", reportselection)
  @Concat_Field("@@open", OpenLinesOnly)
  @Concat_Field("@@ford", fromPurchaseOrderNumber)
  @Concat_Field("@@tord", toPurchaseOrderNumber)
