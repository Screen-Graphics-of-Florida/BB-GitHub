%Define {
  page_title              = "Open Order Report"
  d2wName                 = "OpenClosedPurchaseOrderReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportselection=@dtw_rurlescseq(reportselection)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "11"
  helpExt                 = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      %if (reportselection == "O")
         @dtw_assign(helpExt, " (Open)")
         @dtw_assign(page_title, "Open Purchase Order Report")
      %endif
      %if (reportselection == "C")
         @dtw_assign(helpExt, " (Closed)")
         @dtw_assign(page_title, "Closed Purchase Order Report")
         @dtw_assign(N1OPEN, "0")
      %endif
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.fromPurchaseOrderNumber, 8, 0) &&
                      editNum(document.Chg.toPurchaseOrderNumber, 8, 0) &&
                      editNum(document.Chg.fromVendorNumber, 7, 0) &&
                      editNum(document.Chg.toVendorNumber, 7, 0) &&
                      editdate(document.Chg.fromHeaderRequiredDate) &&
                      editdate(document.Chg.toHeaderRequiredDate) &&
                      editdate(document.Chg.fromUserDate2) &&
                      editdate(document.Chg.toUserDate2) &&
                      editdate(document.Chg.fromUserDate3) &&
                      editdate(document.Chg.toUserDate3) &&
                      editdate(document.Chg.fromUserDate4) &&
                      editdate(document.Chg.toUserDate4) &&
                      editNum(document.Chg.fromWarehouse, 3, 0) &&
                      editNum(document.Chg.toWarehouse, 3, 0) &&
                      editFromToAll(document.Chg.fromPurchaseOrderNumber, document.Chg.toPurchaseOrderNumber, document.Chg.allPurchaseOrderNumber, 8) &&
                      editFromToAll(document.Chg.fromVendorNumber, document.Chg.toVendorNumber, document.Chg.allVendorNumber, 7) &&
                      editFromToAll(document.Chg.fromHeaderRequiredDate, document.Chg.toHeaderRequiredDate, document.Chg.allHeaderRequiredDate, "D") &&
                      editFromToAll(document.Chg.fromUserDate2, document.Chg.toUserDate2, document.Chg.allUserDate2, "D") &&
                      editFromToAll(document.Chg.fromUserDate3, document.Chg.toUserDate3, document.Chg.allUserDate3, "D") &&
                      editFromToAll(document.Chg.fromUserDate4, document.Chg.toUserDate4, document.Chg.allUserDate4, "D") &&
                      editFromToAll(document.Chg.fromItemNumber, document.Chg.toItemNumber, document.Chg.allItemNumber, "A") &&
                      editFromToAll(document.Chg.fromWarehouse, document.Chg.toWarehouse, document.Chg.allWarehouse, 3) &&
                      editFromToAll(document.Chg.fromProductClass, document.Chg.toProductClass, document.Chg.allProductClass, "A") &&
                      editFromToAll(document.Chg.fromVendorStockNumber, document.Chg.toVendorStockNumber, document.Chg.allVendorStockNumber, "A") &&
                      editFromToAll(document.Chg.fromPurchaseOrderType, document.Chg.toPurchaseOrderType, document.Chg.allPurchaseOrderType, "A"))
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "OPENPURCHASEORDERREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromPurchaseOrderNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@open", "printOpenLinesOnly")   @dtw_assign(Err_N1OPEN,  fieldValue)
                                  @DecatErr_Field("@@ford", "fromPurchaseOrderNumber")   @dtw_assign(Err_N1FORD,  fieldValue)
                                  @DecatErr_Field("@@tord", "toPurchaseOrderNumber")     @dtw_assign(Err_N1TORD,  fieldValue)
                                  @DecatErr_Field("@@aord", "allPurchaseOrderNumber")    @dtw_assign(Err_N1AORD,  fieldValue)
                                  @DecatErr_Field("@@sord", "sortPurchaseOrderNumber")   @dtw_assign(Err_N1SORD,  fieldValue)
                                  @DecatErr_Field("@@pord", "totalPurchaseOrderNumber")   @dtw_assign(Err_N1PORD,  fieldValue)
                                  @DecatErr_Field("@@fvnd", "fromVendorNumber")          @dtw_assign(Err_N1FVND,  fieldValue)
                                  @DecatErr_Field("@@tvnd", "toVendorNumber")          @dtw_assign(Err_N1TVND,  fieldValue)
                                  @DecatErr_Field("@@avnd", "allVendorNumber")          @dtw_assign(Err_N1AVND,  fieldValue)
                                  @DecatErr_Field("@@svnd", "sortVendorNumber")          @dtw_assign(Err_N1SVND,  fieldValue)
                                  @DecatErr_Field("@@pvnd", "totalVendorNumber")          @dtw_assign(Err_N1PVND,  fieldValue)
                                  @DecatErr_Field("@@frdt", "fromHeaderRequiredDate")      @dtw_assign(Err_N1FRDT,  fieldValue)
                                  @DecatErr_Field("@@trdt", "toHeaderRequiredDate")        @dtw_assign(Err_N1TRDT,  fieldValue)
                                  @DecatErr_Field("@@ardt", "allHeaderRequiredDate")        @dtw_assign(Err_N1ARDT,  fieldValue)
                                  @DecatErr_Field("@@srdt", "sortHeaderRequiredDate")      @dtw_assign(Err_N1SRDT,  fieldValue)
                                  @DecatErr_Field("@@prdt", "totalHeaderRequiredDate")      @dtw_assign(Err_N1PRDT,  fieldValue)
                                  @DecatErr_Field("@@fdt1", "fromUserDate2")        @dtw_assign(Err_N1FDT1,  fieldValue)
                                  @DecatErr_Field("@@tdt1", "toUserDate2")        @dtw_assign(Err_N1TDT1,  fieldValue)
                                  @DecatErr_Field("@@adt1", "allUserDate2")        @dtw_assign(Err_N1ADT1,  fieldValue)
                                  @DecatErr_Field("@@sdt1", "sortUserDate2")        @dtw_assign(Err_N1SDT1,  fieldValue)
                                  @DecatErr_Field("@@pdt1", "totalUserDate2")        @dtw_assign(Err_N1PDT1,  fieldValue)
                                  @DecatErr_Field("@@fdt2", "fromUserDate3")        @dtw_assign(Err_N1FDT2,  fieldValue)
                                  @DecatErr_Field("@@tdt2", "toUserDate3")        @dtw_assign(Err_N1TDT2,  fieldValue)
                                  @DecatErr_Field("@@adt2", "allUserDate3")        @dtw_assign(Err_N1ADT2,  fieldValue)
                                  @DecatErr_Field("@@sdt2", "sortUserDate3")        @dtw_assign(Err_N1SDT2,  fieldValue)
                                  @DecatErr_Field("@@pdt2", "totalUserDate3")        @dtw_assign(Err_N1PDT2,  fieldValue)
                                  @DecatErr_Field("@@fdt3", "fromUserDate4")        @dtw_assign(Err_N1FDT3,  fieldValue)
                                  @DecatErr_Field("@@tdt3", "toUserDate4")        @dtw_assign(Err_N1TDT3,  fieldValue)
                                  @DecatErr_Field("@@adt3", "allUserDate4")        @dtw_assign(Err_N1ADT3,  fieldValue)
                                  @DecatErr_Field("@@sdt3", "sortUserDate4")        @dtw_assign(Err_N1SDT3,  fieldValue)
                                  @DecatErr_Field("@@pdt3", "totalUserDate4")        @dtw_assign(Err_N1PDT3,  fieldValue)
                                  @DecatErr_Field("@@fitm", "fromItemNumber")        @dtw_assign(Err_N1FITM,  fieldValue)
                                  @DecatErr_Field("@@titm", "toItemNumber")        @dtw_assign(Err_N1TITM,  fieldValue)
                                  @DecatErr_Field("@@aitm", "allItemNumber")        @dtw_assign(Err_N1AITM,  fieldValue)
                                  @DecatErr_Field("@@sitm", "sortItemNumber")        @dtw_assign(Err_N1SITM,  fieldValue)
                                  @DecatErr_Field("@@pitm", "totalItemNumber")        @dtw_assign(Err_N1PITM,  fieldValue)
                                  @DecatErr_Field("@@fwhs", "fromWarehouse")        @dtw_assign(Err_N1FWHS,  fieldValue)
                                  @DecatErr_Field("@@twhs", "toWarehouse")        @dtw_assign(Err_N1TWHS,  fieldValue)
                                  @DecatErr_Field("@@awhs", "allWarehouse")        @dtw_assign(Err_N1AWHS,  fieldValue)
                                  @DecatErr_Field("@@swhs", "sortWarehouse")        @dtw_assign(Err_N1SWHS,  fieldValue)
                                  @DecatErr_Field("@@pwhs", "totalWarehouse")        @dtw_assign(Err_N1PWHS,  fieldValue)
                                  @DecatErr_Field("@@fpcl", "fromProductClass")        @dtw_assign(Err_N1FPCL,  fieldValue)
                                  @DecatErr_Field("@@tpcl", "toProductClass")        @dtw_assign(Err_N1TPCL,  fieldValue)
                                  @DecatErr_Field("@@apcl", "allProductClass")        @dtw_assign(Err_N1APCL,  fieldvalue)
                                  @DecatErr_Field("@@spcl", "sortProductClass")        @dtw_assign(Err_N1SPCL,  fieldValue)
                                  @DecatErr_Field("@@ppcl", "totalProductClass")        @dtw_assign(Err_N1PPCL,  fieldValue)
                                  @DecatErr_Field("@@fvns", "fromVendorStockNumber")        @dtw_assign(Err_N1FVNS,  fieldValue)
                                  @DecatErr_Field("@@tvns", "toVendorStockNumber")          @dtw_assign(Err_N1TVNS,  fieldValue)
                                  @DecatErr_Field("@@avns", "allVendorStockNumber")        @dtw_assign(Err_N1AVNS,  fieldValue)
                                  @DecatErr_Field("@@svns", "sortVendorStockNumber")        @dtw_assign(Err_N1SVNS,  fieldValue)
                                  @DecatErr_Field("@@pvns", "totalVendorStockNumber")       @dtw_assign(Err_N1PVNS,  fieldValue)
                                  @DecatErr_Field("@@foty", "fromPurchaseOrderType")        @dtw_assign(Err_N1FOTY,  fieldValue)
                                  @DecatErr_Field("@@toty", "toPurchaseOrderType")        @dtw_assign(Err_N1TOTY,  fieldValue)
                                  @DecatErr_Field("@@aoty", "allPurchaseOrderType")        @dtw_assign(Err_N1AOTY,  fieldValue)
                                  @DecatErr_Field("@@soty", "sortPurchaseOrderType")        @dtw_assign(Err_N1SOTY,  fieldValue)
                                  @DecatErr_Field("@@poty", "totalPurchaseOrderType")       @dtw_assign(Err_N1POTY,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@open")  @dtw_assign(V_N1OPEN,  fieldValue)
                                  @Decat_Field("@@ford")  @dtw_assign(V_N1FORD,  fieldValue)
                                  @Decat_Field("@@tord")  @dtw_assign(V_N1TORD,  fieldValue)
                                  @Decat_Field("@@aord")  @dtw_assign(V_N1AORD,  fieldValue)
                                  @Decat_Field("@@sord")  @dtw_assign(V_N1SORD,  fieldValue)
                                  @Decat_Field("@@pord")  @dtw_assign(V_N1PORD,  fieldValue)
                                  @Decat_Field("@@fvnd")  @dtw_assign(V_N1FVND,  fieldValue)
                                  @Decat_Field("@@tvnd")  @dtw_assign(V_N1TVND,  fieldValue)
                                  @Decat_Field("@@avnd")  @dtw_assign(V_N1AVND,  fieldValue)
                                  @Decat_Field("@@svnd")  @dtw_assign(V_N1SVND,  fieldValue)
                                  @Decat_Field("@@pvnd")  @dtw_assign(V_N1PVND,  fieldValue)
                                  @Decat_Field("@@frdt")  @dtw_assign(V_N1FRDT,  fieldValue)
                                  @Decat_Field("@@trdt")  @dtw_assign(V_N1TRDT,  fieldValue)
                                  @Decat_Field("@@ardt")  @dtw_assign(V_N1ARDT,  fieldValue)
                                  @Decat_Field("@@srdt")  @dtw_assign(V_N1SRDT,  fieldValue)
                                  @Decat_Field("@@prdt")  @dtw_assign(V_N1PRDT,  fieldValue)
                                  @Decat_Field("@@fdt1")  @dtw_assign(V_N1FDT1,  fieldValue)
                                  @Decat_Field("@@tdt1")  @dtw_assign(V_N1TDT1,  fieldValue)
                                  @Decat_Field("@@adt1")  @dtw_assign(V_N1ADT1,  fieldValue)
                                  @Decat_Field("@@sdt1")  @dtw_assign(V_N1SDT1,  fieldValue)
                                  @Decat_Field("@@pdt1")  @dtw_assign(V_N1PDT1,  fieldValue)
                                  @Decat_Field("@@fdt2")  @dtw_assign(V_N1FDT2,  fieldValue)
                                  @Decat_Field("@@tdt2")  @dtw_assign(V_N1TDT2,  fieldValue)
                                  @Decat_Field("@@adt2")  @dtw_assign(V_N1ADT2,  fieldValue)
                                  @Decat_Field("@@sdt2")  @dtw_assign(V_N1SDT2,  fieldValue)
                                  @Decat_Field("@@pdt2")  @dtw_assign(V_N1PDT2,  fieldValue)
                                  @Decat_Field("@@fdt3")  @dtw_assign(V_N1FDT3,  fieldValue)
                                  @Decat_Field("@@tdt3")  @dtw_assign(V_N1TDT3,  fieldValue)
                                  @Decat_Field("@@adt3")  @dtw_assign(V_N1ADT3,  fieldValue)
                                  @Decat_Field("@@sdt3")  @dtw_assign(V_N1SDT3,  fieldValue)
                                  @Decat_Field("@@pdt3")  @dtw_assign(V_N1PDT3,  fieldValue)
                                  @Decat_Field("@@fitm")  @dtw_assign(V_N1FITM,  fieldValue)
                                  @Decat_Field("@@titm")  @dtw_assign(V_N1TITM,  fieldValue)
                                  @Decat_Field("@@aitm")  @dtw_assign(V_N1AITM,  fieldValue)
                                  @Decat_Field("@@sitm")  @dtw_assign(V_N1SITM,  fieldValue)
                                  @Decat_Field("@@pitm")  @dtw_assign(V_N1PITM,  fieldValue)
                                  @Decat_Field("@@fwhs")  @dtw_assign(V_N1FWHS,  fieldValue)
                                  @Decat_Field("@@twhs")  @dtw_assign(V_N1TWHS,  fieldValue)
                                  @Decat_Field("@@awhs")  @dtw_assign(V_N1AWHS,  fieldValue)
                                  @Decat_Field("@@swhs")  @dtw_assign(V_N1SWHS,  fieldValue)
                                  @Decat_Field("@@pwhs")  @dtw_assign(V_N1PWHS,  fieldValue)
                                  @Decat_Field("@@fpcl")  @dtw_assign(V_N1FPCL,  fieldValue)
                                  @Decat_Field("@@tpcl")  @dtw_assign(V_N1TPCL,  fieldValue)
                                  @Decat_Field("@@apcl")  @dtw_assign(V_N1APCL,  fieldValue)
                                  @Decat_Field("@@spcl")  @dtw_assign(V_N1SPCL,  fieldValue)
                                  @Decat_Field("@@ppcl")  @dtw_assign(V_N1PPCL,  fieldValue)
                                  @Decat_Field("@@fvns")  @dtw_assign(V_N1FVNS,  fieldValue)
                                  @Decat_Field("@@tvns")  @dtw_assign(V_N1TVNS,  fieldValue)
                                  @Decat_Field("@@avns")  @dtw_assign(V_N1AVNS,  fieldValue)
                                  @Decat_Field("@@svns")  @dtw_assign(V_N1SVNS,  fieldValue)
                                  @Decat_Field("@@pvns")  @dtw_assign(V_N1PVNS,  fieldValue)
                                  @Decat_Field("@@foty")  @dtw_assign(V_N1FOTY,  fieldValue)
                                  @Decat_Field("@@toty")  @dtw_assign(V_N1TOTY,  fieldValue)
                                  @Decat_Field("@@aoty")  @dtw_assign(V_N1AOTY,  fieldValue)
                                  @Decat_Field("@@soty")  @dtw_assign(V_N1SOTY,  fieldValue)
                                  @Decat_Field("@@poty")  @dtw_assign(V_N1POTY,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}

                                  %if (V_N1OPEN == "02")
                                      @dtw_assign(OpenLinesOnlyNo, "")
                                      @dtw_assign(OpenLinesOnlyYes, "CHECKED")
                                  %else
                                      @dtw_assign(OpenLinesOnlyNo, "CHECKED")
                                      @dtw_assign(OpenLinesOnlyYes, "")
                                  %endif

                                  %if (V_N1AORD == "ALL")
                                      @dtw_assign(checkedallPurchaseOrderNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallPurchaseOrderNumber, "")
                                  %endif
                                  %if (V_N1AVND == "ALL")
                                      @dtw_assign(checkedallVendorNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallVendorNumber, "")
                                  %endif
                                  %if (V_N1ARDT == "ALL")
                                      @dtw_assign(checkedallHeaderRequiredDate, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallHeaderRequiredDate, "")
                                  %endif
                                  %if (V_N1ADT1 == "ALL")
                                      @dtw_assign(checkedallUserDate2, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallUserDate2, "")
                                  %endif
                                  %if (V_N1ADT2 == "ALL")
                                      @dtw_assign(checkedallUserDate3, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallUserDate3, "")
                                  %endif
                                  %if (V_N1ADT3 == "ALL")
                                      @dtw_assign(checkedallUserDate4, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallUserDate4, "")
                                  %endif
                                  %if (V_N1AITM == "ALL")
                                      @dtw_assign(checkedallItemNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallItemNumber, "")
                                  %endif
                                  %if (V_N1AWHS == "ALL")
                                      @dtw_assign(checkedallWarehouse, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallWarehouse, "")
                                  %endif
                                  %if (V_N1APCL == "ALL")
                                      @dtw_assign(checkedallProductClass, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallProductClass, "")
                                  %endif
                                  %if (V_N1AVNS == "ALL")
                                      @dtw_assign(checkedallVendorStockNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallVendorStockNumber, "")
                                  %endif
                                  %if (V_N1AOTY == "ALL")
                                      @dtw_assign(checkedallPurchaseOrderType, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallPurchaseOrderType, "")
                                  %endif

                                  %if (V_N1PORD == "Y")
                                      @dtw_assign(checkedPurchaseOrderNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedPurchaseOrderNumberTotals, "")
                                  %endif
                                  %if (V_N1PVND == "Y")
                                      @dtw_assign(checkedVendorNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedVendorNumberTotals, "")
                                  %endif
                                  %if (V_N1PRDT == "Y")
                                      @dtw_assign(checkedHeaderRequiredDateTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedHeaderRequiredDateTotals, "")
                                  %endif
                                  %if (V_N1PDT1 == "Y")
                                      @dtw_assign(checkedUserDate2Totals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedUserDate2Totals, "")
                                  %endif
                                  %if (V_N1PDT2 == "Y")
                                      @dtw_assign(checkedUserDate3Totals, "CHECKED")
                                  %else
