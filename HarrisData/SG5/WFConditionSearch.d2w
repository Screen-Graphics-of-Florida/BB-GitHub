%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Condition Search"
  d2wName                 = "WFConditionSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  fldName                 = ""
  fldDesc                 = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL)  {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function selectCondition(wfCondition, wfConditionDescription){
                  window.opener.document.$(docName).$(fldName).value = wfCondition;
                  window.opener.document.$(docName).$(fldDesc).value = wfConditionDescription;
                  window.opener.document.$(docName).$(fldName).focus();
                  window.close();
              }
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select WFCNDM.* ", stmtSQL)
                      @dtw_concat(fileSQL, " WFCNDM ", fileSQL)
                      %if (moreInfo == "Y")
                          @dtw_concat(selectSQL, " CMCOND=$(wfCondition)", selectSQL)
                      %elif (wildCardSearch!="")
                          @dtw_concat(selectSQL, " CMCOND>0 ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)

                      %if (moreInfo == "Y")
                          %{Condition Expression %}
                          @dtw_assign(SAVE_ROW_NUM, START_ROW_NUM)
                          @dtw_assign(SAVE_MAX_ROWS, RPT_MAX_ROWS)
                          @dtw_assign(START_ROW_NUM, "1")
                          @dtw_assign(RPT_MAX_ROWS, "9999")
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select WFCNDE.*, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(a.FLDESC,' ') as anorFLDESC, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(b.FLDESC,' ') as ptypFLDESC, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(c.FLDESC,' ') as vtypFLDESC, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(d.PMPRMD,CEPFLD) as parmPMPRMD, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(e.PMPRMD,CEVFLD) as valuPMPRMD, ", stmtSQL)
                          @dtw_concat(stmtSQL, " coalesce(VIDESC,' ') as VIDESC ", stmtSQL)
                          @dtw_concat(stmtSQL, " From WFCNDE ", stmtSQL)
                          @dtw_concat(stmtSQL, " left join SYFLAG a on a.FLTYPE='WFCNDCONT' and a.FLVALU=CEANOR ", stmtSQL)
                          @dtw_concat(stmtSQL, " left join SYFLAG b on b.FLTYPE='WFCNDPTYP' and b.FLVALU=CEPTYP ", stmtSQL)
                          @dtw_concat(stmtSQL, " left join SYFLAG c on c.FLTYPE='WFCNDVTYP' and c.FLVALU=CEVTYP and CEVLID=0", stmtSQL)
                          @dtw_concat(stmtSQL, " left join WFPARM d on d.PMPARM=CEPFLD ", stmtSQL)
                          @dtw_concat(stmtSQL, " left join WFPARM e on e.PMPARM=CEVFLD ", stmtSQL)
                          @dtw_concat(stmtSQL, " left join WFVLID on VIVPGM=CEVPGM and VIVLID=CEVLID ", stmtSQL)
                          @dtw_concat(stmtSQL, " Where CECOND=$(wfCondition) ", stmtSQL)
                          @dtw_concat(stmtSQL, " Order By CECOND,CETSSQ ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          @ConditionExpressionList_Query(profileHandle, dataBaseID, stmtSQL)
                          @dtw_assign(START_ROW_NUM, SAVE_ROW_NUM)
                          @dtw_assign(RPT_MAX_ROWS, SAVE_MAX_ROWS)
                      %endif
                      $(searchhrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}
%FUNCTION(dtw_sql) List_Query (IN  CHAR(64)    profileHandle,
                                   CHAR(2)     dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"

      $(searchhrTagAttr)
      %if (moreInfo != "Y")	
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr>
                      <th class="colhdr">Description</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchDesc" size="15" maxlength="50">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>	

          %INCLUDE "WildCardPage.icl"

          <table $(contentTable)>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
                  @OrderBy_Sort("CMDESCU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description" title="Sequence By Description, Condition ID">Description</a></th>
                  @OrderBy_Sort("CMCOND", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Condition"   title="Sequence By Condition ID">Condition ID</a></th>
              </tr>

              %INCLUDE "NoRecordsFound.icl"
      %endif		
              %ROW{
                  @Format_Quote(V_CMDESC, F_CMDESC)

                  %if (moreInfo != "Y")	
                      %INCLUDE "SetRowClass.icl"
                      <tr class="$(rowClass)">
                          <td class="colalph"><a href="javascript:selectCondition($(V_CMCOND),'$(F_CMDESC)')" title="Select Condition">$(V_CMDESC)</a></td>
                          <td class="colnmbr">$(V_CMCOND)</td>
                          <td class="colicon"><a href="$(homeURL)$(cGIPath)$(d2wName)/MOREINFO$(d2wVarBase)$(orderByVarBase)&amp;wfCondition=@dtw_rurlescseq(V_CMCOND)&amp;moreInfo=Y">$(moreInfoImage)</a></td>
                      </tr>

                  %else
                      <table $(contentTable)>
                          <tr><td><a href="javascript:selectCondition($(V_CMCOND),'$(F_CMDESC)')" title="Select Condition">$(selectImageLrg)</a>
                          </td></tr>
                      </table>

                      <table $(contentTable)>
                          <tr><td class="dsphdr">Condition ID</td>
                              <td class="dspnmbr">$(V_CMCOND)</td></tr>

                          <tr><td class="dsphdr">Description</td>
                              <td class="dspalph">$(V_CMDESC)</td></tr>
                      </table>
                  %endif
              %}
          </table>
	   %if (moreInfo != "Y")	
              %INCLUDE "PageBottom.icl"
              %INCLUDE "WildCardPrint.icl"
	   %endif	   	
  %}
%}

%FUNCTION(dtw_sql) ConditionExpressionList_Query (IN  CHAR(64)    profileHandle,
                                                      CHAR(2)     dataBaseID,
                                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <fieldset class="legendBody">
          <legend class="legendTitle">Expression</legend>
          <table $(contentTable)>
              <tr>
                  <th class="colhdr" colspan="2">Expression</th>
                  <th class="colhdr">Test Sequence</th>
                  <th class="colhdr">&nbsp;</th>
                  <th class="colhdr">Section</th>
                  <th class="colhdr">Type</th>
                  <th class="colhdr">External Table</th>
                  <th class="colhdr">Where</th>
                  <th class="colhdr">Column</th>
                  <th class="colhdr">Operand</th>
                  <th class="colhdr">Value One</th>
                  <th class="colhdr">Value Two</th>
              </tr>

              %ROW{
                  %INCLUDE "SetRowClass.icl"

                  <tr class="$(rowClass)">
                      <td class="colalph" $(helpCursor)><span title="$(V_CEANOR)">$(V_anorFLDESC)</span></td>
                      <td class="colalph">$(V_CECONDE)</td>
                      <td class="colnmbr">$(V_CETSSQ)</td>
                      <td class="colcode" $(helpCursor)><span title="$(V_CEANOR)">$(V_anorFLDESC)</span></td>
                      %if (V_CEVLID>"0")
                          <td class="colalph" colspan="8" $(helpCursor)><span title="$(V_CEVPGM)-$(V_CEVLID)">Validation: $(V_VIDESC)</span></td>
                      %else
                          <td class="colalph">Parameter:</td>
                          <td class="colalph" $(helpCursor)><span title="$(V_CEPTYP)">$(V_ptypFLDESC)</span></td>
                          <td class="colalph">$(V_CEPEXT)</td>
                          <td class="colalph">$(V_CEPWHR)</td>
                          <td class="colalph" $(helpCursor)><span title="$(V_CEPFLD)">$(V_parmPMPRMD)</span></td>
                          <td class="colalph">$(V_CEOPER)</td>
                          <td class="colalph">&nbsp;</td>
                          <td class="colalph">&nbsp;</td>
                      %endif
                      %if (V_CEVLID<="0")
                          <tr>
                              <td class="colalph">&nbsp;</td>
                              <td class="colalph">&nbsp;</td>
                              <td class="colalph">&nbsp;</td>
                              <td class="colalph">&nbsp;</td>
                              <td class="colalph">Value:</td>
                              <td class="colalph" $(helpCursor)><span title="$(V_CEVTYP)">$(V_vtypFLDESC)</span></td>
                              <td class="colalph">$(V_CEVEXT)</td>
                              <td class="colalph">$(V_CEVWHR)</td>
                              <td class="colalph" $(helpCursor)><span title="$(V_CEVFLD)">$(V_valuPMPRMD)</span></td>
                              <td class="colalph">&nbsp;</td>
                              <td class="colalph">$(V_CEVAL1)</td>
                              <td class="colalph">$(V_CEVAL2)</td>
                          </tr>
                      %endif
                  </tr>
              %}
          </table>
      </fieldset>
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "CMDESCU,CMCOND")
      @DTW_ASSIGN(orderByDisplay, "Description, Condition ID")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MOREINFO) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, "1000")
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Description")
      %if (orderBy == "CMDESCU,CMCOND")
          @DTW_ASSIGN(orderBy, "CMDESCU DESC,CMCOND")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Condition ID")
      %else
          @DTW_ASSIGN(orderBy, "CMDESCU,CMCOND")
          @DTW_ASSIGN(orderByDisplay, "Description, Condition ID")
      %endif
  %elif (sequence == "Condition")
      %if (orderBy == "CMCOND")
          @DTW_ASSIGN(orderBy, "CMCOND DESC")
          @DTW_ASSIGN(orderByDisplay, "Condition ID (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CMCOND")
          @DTW_ASSIGN(orderByDisplay, "Condition ID")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          @dtw_assign(formName, "Search")
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchCondition, 15, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "WFCONDITIONSEARCH")
                  <td>
                      %INCLUDE "SearchPageTitle.icl"
                      $(searchhrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDesc" size="15" maxlength="50"></td>
                          </tr>

                          <tr><td class="dsphdr">Condition ID</td>
                              @dtw_assign(operNbr, "operCondition")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchCondition" size="15" maxlength="15"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchDesc.focus();
                          </script>
                      </form>
                      $(searchhrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("CMDESCU", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("CMCOND", "Condition ID", $(srchCondition), "", operCondition, "N")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}