%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Item Features"
  d2wName                 = "ItemFeature.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;featuredItem=@dtw_rurlescseq(featuredItem)&amp;featureFamily=@dtw_rurlescseq(featureFamily)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HPDFIM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @PlantUserView(profileHandle, dataBaseID, userPass, plantNumber)
  %if (userPass == "Y" && featureFamily == "I")
      @ItemUserView(profileHandle, dataBaseID, userPass, featuredItem)
      %if (userPass == "Y")
          @ItemPlantUserView(profileHandle, dataBaseID, userPass, plantNumber, featuredItem)
      %endif
  %endif
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %if (featureFamily == "F")
          @dtw_assign(page_title, "Family Features")
      %elif (featureFamily == "C")
          @dtw_assign(page_title, "Vendor Item Features")
      %endif
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  %INCLUDE "CheckEnterSearch.icl"
                  %INCLUDE "Menu.js"
                  %INCLUDE "NoFormValidate.icl"
                  function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                           @dtw_assign(pageID, "ITEMFEATURE")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, "Select FIFEAT, FIDSEQ, FIIMQT, FIVARQ, FIMAND, FINS, FIMULT, FIFDSC, ", stmtSQL)
                          @dtw_concat(stmtSQL, "upper(FIFDSC) as FIFDSCU " , stmtSQL)
                          @dtw_concat(fileSQL, " HDMFIT ", fileSQL)
                          @dtw_concat(selectSQL, " FIPLT=$(plantNumber) and FIFPRT='$(featuredItem)' ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By $(orderBy)", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @ItemFeature_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) ItemFeature_Query (IN CHAR(64)    profileHandle,
				          CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{

      @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
      %if (featureFamily == "I")
          @RtvFldDesc("IMITEM='$(featuredItem)'", "HDIMST", "IMIMDS", itemDescription)
      %elif (featureFamily == "F")
          @RtvFldDesc("IGTYPE='F' and IGIGRP='$(featuredItem)' and IGPLT=$(plantNumber)", "HDIGPH", "IGDESC", itemDescription)
      %elif (featureFamily == "C")
          @RtvFldDesc("VCPITM='$(featuredItem)'", "HDVCAT", "VCIMDS", itemDescription)
      %endif
      @dtw_assign(returnVar, "$(d2wName)/REPORT$(d2wVarBase)")
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      <a href="$(homeURL)$(cGIPath)FeaturedItem.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;dspFeatFamily=@dtw_rurlescseq(featureFamily)" title="Back Home">$(portalHome)</a>
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)ItemFeatureMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %if (sec_01=="Y" && sec_04=="Y" && sql_Record_Count != "0")
                          <a href="$(homeURL)$(cGIPath)ItemFeatureMaintain.d2w/COPYALL$(d2wVarBase)&amp;maintenanceCode=Z">$(copyImageLrg)</a>
                      %endif
                      %if (sec_03 == "Y" && sql_Record_Count != "0")
                          @Format_Confirm_Desc("All Features", "", "", "", "", "", confirmDesc)
                          <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)ItemFeatureMaintain.d2w/DELETEALL$(d2wVarBase)&amp;maintenanceCode=D">$(deleteImageLrg)</a>
                      %endif
                      %if (productCfgFormat == "O" && formatToPrint != "Y" && sql_Record_Count != "0" && (sec_01 == "Y" || sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                          <a href="$(homeURL)$(cGIPath)FeaturedItemExpSelection.d2w/REPORT$(d2wVarBase)&amp;reportSelType=R&amp;backHome=@dtw_rurlescseq(returnVar)">$(publishLrg)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      <table $(contentTable)>
          @Format_Header_URL("Plant", $(plantName), $(plantNumber), "$(homeURL)$(cGIPath)PlantSelect.d2w/REPORT$(d2wVarBase)")
          %if (featureFamily == "I")
              @Format_Header_URL("Item", $(itemDescription), $(featuredItem), "$(homeURL)$(cGIPath)ItemSelect.d2w/REPORT$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(featuredItem)&amp;itemDescription=@dtw_rurlescseq(itemDescription)")
          %elif (featureFamily == "F")
              @Format_Header("Family", $(itemDescription), $(featuredItem))
          %elif (featureFamily == "C")
              @Format_Header("Vendor Item", $(itemDescription), $(featuredItem))
          %endif
      </table>
      %INCLUDE "ConfMessageDisplay.icl"
	
      $(hrTagAttr)	

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Feature</th>
                      <th class="colhdr">Description</th>
                  </tr>

                  <tr><td><input type="text" class="inputalph" name="srchFeat" size="15" maxlength="15">
                          <input type="hidden" name="operFeat" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchDesc" size="30" maxlength="30">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchFeat.focus();
              </script>
          </form>
	
          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @OrderBy_Sort("FIFEAT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=feature" title="Sequence By Feature">Feature</a></th>
              @OrderBy_Sort("FIDSEQ", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=dspSeq" title="Sequence By Display Sequence, Feature">Display<br>Sequence</a></th>
              <th class="colhdr">Quantity</th>
              @OrderBy_Sort("FIVARQ", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=varFeat" title="Sequence By Variable">Variable</a></th>
              @OrderBy_Sort("FIMAND", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=mandFeat" title="Sequence By Mandatory">Mandatory</a></th>
              <th class="colhdr">N/S</th>
              @OrderBy_Sort("FIMULT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=multFeat" title="Sequence By Multiple">Multiple</a></th>
              @OrderBy_Sort("FIFDSC", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=featDesc" title="Sequence By Description">Description</a></th>
          </tr>		
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_FIFEAT), "", "", "", "", "", confirmDesc)
              @Format_Nbr($(V_FIDSEQ), F_FIDSEQ, "2", "3", "", "", "")
              @Format_Nbr($(V_FIIMQT), F_FIIMQT, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;feature=@dtw_rurlescseq(V_FIFEAT)")

	       <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)ItemFeatureMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_01=="Y" && sec_04=="Y")
                              <a href="$(homeURL)$(cGIPath)ItemFeatureMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href=$(homeURL)$(cGIPath)ItemFeatureMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D>$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph">$(V_FIFEAT)</td>
                  <td class="colnmbr">$(F_FIDSEQ)</td>
                  <td class="colnmbr">$(F_FIIMQT)</td>
                  <td class="colcode">$(V_FIVARQ)</td>
                  <td class="colcode">$(V_FIMAND)</td>
                  <td class="colcode">$(V_FINS)</td>
                  <td class="colcode">$(V_FIMULT)</td>
                  <td class="colalph">$(V_FIFDSC)</td>
	       </tr>
	   %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "FIFEAT")
          @DTW_ASSIGN(orderByDisplay, "Feature")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "feature")
      %if (orderBy == "FIFEAT")
          @DTW_ASSIGN(orderBy, "FIFEAT DESC")
          @DTW_ASSIGN(orderByDisplay, "Feature (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FIFEAT")
          @DTW_ASSIGN(orderByDisplay, "Feature")
      %endif
  %elif (sequence == "dspSeq")
      %if (orderBy == "FIDSEQ,FIFEAT")
          @DTW_ASSIGN(orderBy, "FIDSEQ DESC,FIFEAT")
          @DTW_ASSIGN(orderByDisplay, "Display Sequence (descending), Feature")
      %else
          @DTW_ASSIGN(orderBy, "FIDSEQ,FIFEAT")
          @DTW_ASSIGN(orderByDisplay, "Display Sequence, Feature")
      %endif
  %elif (sequence == "varFeat")
      %if (orderBy == "FIVARQ")
          @DTW_ASSIGN(orderBy, "FIVARQ DESC")
          @DTW_ASSIGN(orderByDisplay, "Variable (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FIVARQ")
          @DTW_ASSIGN(orderByDisplay, "Variable")
      %endif
  %elif (sequence == "mandFeat")
      %if (orderBy == "FIMAND")
          @DTW_ASSIGN(orderBy, "FIMAND DESC")
          @DTW_ASSIGN(orderByDisplay, "Mandatory (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FIMAND")
          @DTW_ASSIGN(orderByDisplay, "Mandatory")
      %endif
  %elif (sequence == "multFeat")
      %if (orderBy == "FIMULT")
          @DTW_ASSIGN(orderBy, "FIMULT DESC")
          @DTW_ASSIGN(orderByDisplay, "Multiple (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FIMULT")
          @DTW_ASSIGN(orderByDisplay, "Multiple")
      %endif
  %elif (sequence == "featDesc")
      %if (orderBy == "FIFDSCU")
          @DTW_ASSIGN(orderBy, "FIFDSCU DESC")
          @DTW_ASSIGN(orderByDisplay, "Description (descending)")
      %else
          @DTW_ASSIGN(orderBy, "FIFDSCU")
          @DTW_ASSIGN(orderByDisplay, "Description")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("FIFEAT", "Feature", $(srchFeat), "U", operFeat, "A")
  @Build_WildCard ("upper(FIFDSC)", "Description", $(srchDesc), "U", operDesc, "A")
		
  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}