%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title 	        = "Payroll Control"
  d2wName              = "PRControlSelect.d2w"
  d2wVarBase           = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  programName          = "HPRCTU"
  DATABASE             = "*LOCAL"
  DTW_DEFAULT_REPORT   = "NO"
  RPT_MAX_ROWS 	= "99"
  ROW_NUM              = "0"
  START_ROW_NUM        = "1"
  dspMaxRows           = "$(dspMaxRowsDft)"
  prtMaxRows           = "$(prtMaxRowsDft)"
  rowIndexNext	        = "1"
  totalPages	        = "0"	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "NewWindowOpen.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                           @dtw_assign(pageID, "PRCTRLSELECT")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          @dtw_assign(stmtSQL, "")
                          @dtw_concat(stmtSQL, "SELECT * FROM PRCTRL ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          @PrControl_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) PrControl_Query (IN CHAR(64) profileHandle,
				        CHAR(2)   dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">

              <tr><td><h1>$(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      <td>&nbsp;</td>
                      <td class="toolbar">
                          %if ((backHome != "$(d2wName)/report") && (backHome != ""))
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)&amp;hrCompany=@dtw_rurlescseq(hrCompany)" title="Back Home">$(portalHome)</a>
                          %endif
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %ROW {
          <table $(contentTable)>
             <tr><td class="dsphdr">Check Printing Program Name</td>
                 <td class="dspalph">$(V_PRCKPG)</td>
             </tr>
             %if ($(V_PRTETM) == "S")
                 @dtw_assign(entryType, "Standard")
             %elseif ($(V_PRTETM) == "M")
                 @dtw_assign(entryType, "Military")
             %endif
             <tr><td class="dsphdr">Pay Transaction Entry Time Format</td>
                 <td class="dspalph">$(entryType)</td>
             </tr>
             <tr><td class="dsphdr">Print Maintenance Audits</td>
                 @RtvYNDesc($(V_PRMNTA), syFlagDesc)
                 <td class="dspalph">$(syFlagDesc)</td>
             </tr>
             <tr><td class="dsphdr">Print Pay Transaction Entry Audits</td>
                 @RtvYNDesc($(V_PRENTA), syFlagDesc)
                 <td class="dspalph">$(syFlagDesc)</td>
             </tr>
             <tr><td class="dsphdr">Reclaim Resource Level</td>
                 <td class="dspalph">$(V_PRRCLR)</td>
             </tr>
             %if ($(V_PRDDAV) == "Y")
                 @dtw_assign(adviceType, "Advice Only")
             %elseif ($(V_PRDDAV) == "N")
                 @dtw_assign(adviceType, "Check Only")
             %elseif ($(V_PRDDAV) == "B")
                 @dtw_assign(adviceType, "Advice And Check")
             %endif
             <tr><td class="dsphdr">Print Direct Deposit Advice</td>
                 <td class="dspalph">$(adviceType)</td>
             </tr>
             <tr><td class="dsphdr">Retain Multiple Years Of History</td>
                 @RtvYNDesc($(V_PRMYHS), syFlagDesc)
                 <td class="dspalph">$(syFlagDesc)</td>
             </tr>
             <tr><td class="dsphdr">Process Inter Co/Dept Wages</td>
                 @RtvYNDesc($(V_PRICWG), syFlagDesc)
                 <td class="dspalph">$(syFlagDesc)</td>
             </tr>
             <tr><td class="dsphdr">Process Inter Co/Dept FICA</td>
                 @RtvYNDesc($(V_PRICFI), syFlagDesc)
                 <td class="dspalph">$(syFlagDesc)</td>
             </tr>
             <tr><td class="dsphdr">Process Inter Co/Dept FUI</td>
                 @RtvYNDesc($(V_PRICFU), syFlagDesc)
                 <td class="dspalph">$(syFlagDesc)</td>
             </tr>
             <tr><td class="dsphdr">Process Inter Co/Dept SUI</td>
                 @RtvYNDesc($(V_PRICSU), syFlagDesc)
                 <td class="dspalph">$(syFlagDesc)</td>
             </tr>
             <tr><td class="dsphdr">Process Inter Co/Dept SDI</td>
                 @RtvYNDesc($(V_PRICSD), syFlagDesc)
                 <td class="dspalph">$(syFlagDesc)</td>
             </tr>
             <tr><td class="dsphdr">Process Inter Co/Dept SWC</td>
                 @RtvYNDesc($(V_PRICSW), syFlagDesc)
                 <td class="dspalph">$(syFlagDesc)</td>
             </tr>
             <tr><td class="dsphdr">Process Inter Co/Dept LIT</td>
                 @RtvYNDesc($(V_PRICLI), syFlagDesc)
                 <td class="dspalph">$(syFlagDesc)</td>
             </tr>
             <tr><td class="dsphdr">Consolidated Reporting Database</td>
                 <td class="dspalph">$(V_PRLB)</td>
             </tr>
              @Format_Nbr(V_PRGPAP, F_PRGPAP, "3", $(pctEditCode), "Y", "", "")
             <tr><td class="dsphdr">Employee % Of Gross After Pre-Tax</td>
                 <td class="dspalph">$(F_PRGPAP)</td>
             </tr>
             %if ($(V_PRAAEN) == "0")
                 @dtw_assign(assignType, "No")
             %elseif ($(V_PRAAEN) == "1")
                 @dtw_assign(assignType, "Next Available Within Company/Facility")
             %elseif ($(V_PRAAEN) == "2")
                 @dtw_assign(assignType, "Next Available Within Data Base")
             %endif
             <tr><td class="dsphdr">Auto Assign Employee Number</td>
                 <td class="dspalph">$(assignType)</td>
             </tr>
          </table>

          <fieldset class="legendBody">
              <legend class="legendTitle">User-Defined Data</legend>
              <table $(contentTable)>
                  <tr><th>&nbsp;</th>
                      <th class="colhdr">Description</th>
                      <th class="colhdr">Report Heading</th>
                  </tr>	

                  <tr><td class="dsphdr">User Defined Numeric 1</td>
                      <td class="dspalph">$(V_PRU1DS)</td>
                      <td class="dspalph">$(V_PRU1HD)</td>
                  </tr>
                  <tr><td class="dsphdr">User Defined Numeric 2</td>
                      <td class="dspalph">$(V_PRU2DS)</td>
                      <td class="dspalph">$(V_PRU2HD)</td>
                  </tr>
                  <tr><td class="dsphdr">User Defined Numeric 3</td>
                      <td class="dspalph">$(V_PRU3DS)</td>
                      <td class="dspalph">$(V_PRU3HD)</td>
                  </tr>
                  <tr><td class="dsphdr">User Defined Alpha 1</td>
                      <td class="dspalph">$(V_PRU4DS)</td>
                      <td class="dspalph">$(V_PRU4HD)</td>
                  </tr>
                  <tr><td class="dsphdr">User Defined Alpha 2</td>
                      <td class="dspalph">$(V_PRU5DS)</td>
                      <td class="dspalph">$(V_PRU5HD)</td>
                  </tr>
                  <tr><td class="dsphdr">User Defined Alpha 3</td>
                      <td class="dspalph">$(V_PRU6DS)</td>
                      <td class="dspalph">$(V_PRU6HD)</td>
                  </tr>
              </table>
          </fieldset>

          <fieldset class="legendBody">
              <legend class="legendTitle">Tax Liability Defaults</legend>
              <table $(contentTable)>
                  <tr><th>&nbsp;</th>
                      <th class="colhdr">Export<br> Tax Data</th>
                      <th class="colhdr">Auto Select<br>For Payment</th>
                      <th class="colhdr">Vendor<br>Number</th>
                      <th class="colhdr">EFT</th>
                  </tr>	

                  <tr><td class="dsphdr"> Federal/FICA Tax</td>
                      @RtvYNDesc($(V_PRXFIT), syFlagDesc)
                      <td class="colcode">$(syFlagDesc)</td>
                      @RtvYNDesc($(V_PRAFIT), syFlagDesc)
                      <td class="colcode">$(syFlagDesc)</td>
                      <td class="colnmbr">$(V_PRVFIT)</td>
                      @RtvYNDesc($(V_PREFIT), syFlagDesc)
                      <td class="colcode">$(syFlagDesc)</td>
                  </tr>
                  <tr><td class="dsphdr">Federal Unemployment Insurance</td>
                      @RtvYNDesc($(V_PRXFUI), syFlagDesc)
                      <td class="colcode">$(syFlagDesc)</td>
                      @RtvYNDesc($(V_PRAFUI), syFlagDesc)
                      <td class="colcode">$(syFlagDesc)</td>
                      <td class="colnmbr">$(V_PRVFUI)</td>
                      @RtvYNDesc($(V_PREFUI), syFlagDesc)
                      <td class="colcode">$(syFlagDesc)</td>
                  </tr>
                  <tr><td class="dsphdr">State Tax</td>
                      @RtvYNDesc($(V_PRXSIT), syFlagDesc)
                      <td class="colcode">$(syFlagDesc)</td>
                      @RtvYNDesc($(V_PRASIT), syFlagDesc)
                      <td class="colcode">$(syFlagDesc)</td>
                      <td class="colnmbr">$(V_PRVSIT)</td>
                      @RtvYNDesc($(V_PRESIT), syFlagDesc)
                      <td class="colcode">$(syFlagDesc)</td>
                  </tr>
                  <tr><td class="dsphdr">SUI/SUI Surtax</td>
                      @RtvYNDesc($(V_PRXSUI), syFlagDesc)
                      <td class="colcode">$(syFlagDesc)</td>
                      @RtvYNDesc($(V_PRASUI), syFlagDesc)
                      <td class="colcode">$(syFlagDesc)</td>
                      <td class="colnmbr">$(V_PRVSUI)</td>
                      @RtvYNDesc($(V_PRESUI), syFlagDesc)
                      <td class="colcode">$(syFlagDesc)</td>
                  </tr>
                  <tr><td class="dsphdr">State Disability Insurance</td>
                      @RtvYNDesc($(V_PRXSDI), syFlagDesc)
                      <td class="colcode">$(syFlagDesc)</td>
                      @RtvYNDesc($(V_PRASDI), syFlagDesc)
                      <td class="colcode">$(syFlagDesc)</td>
                      <td class="colnmbr">$(V_PRVSDI)</td>
                      @RtvYNDesc($(V_PRESDI), syFlagDesc)
                      <td class="colcode">$(syFlagDesc)</td>
                  </tr>
                  <tr><td class="dsphdr">State Workers' Compensation</td>
                      @RtvYNDesc($(V_PRXSWC), syFlagDesc)
                      <td class="colcode">$(syFlagDesc)</td>
                      @RtvYNDesc($(V_PRASWC), syFlagDesc)
                      <td class="colcode">$(syFlagDesc)</td>
                      <td class="colnmbr">$(V_PRVSWC)</td>
                      @RtvYNDesc($(V_PRESWC), syFlagDesc)
                      <td class="colcode">$(syFlagDesc)</td>
                  </tr>
                  <tr><td class="dsphdr">Local Tax</td>
                      @RtvYNDesc($(V_PRXLIT), syFlagDesc)
                      <td class="colcode">$(syFlagDesc)</td>
                      @RtvYNDesc($(V_PRALIT), syFlagDesc)
                      <td class="colcode">$(syFlagDesc)</td>
                      <td class="colnmbr">$(V_PRVLIT)</td>
                      @RtvYNDesc($(V_PRELIT), syFlagDesc)
                      <td class="colcode">$(syFlagDesc)</td>
                  </tr>
              </table>
          </fieldset>
      %}	
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if (sec_05 == "N")
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)progOptSecError.d2w/DISPLAY$(genericVarBase)&amp;page_title=@dtw_rurlescseq(page_title)">
  %else
      @Set_SQL(stmtSQL)
  %endif
%}