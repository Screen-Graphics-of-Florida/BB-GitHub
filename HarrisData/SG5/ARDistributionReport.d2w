%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "A/R Distribution Report"
  d2wName                 = "ARDistributionReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "6"
  V_CRPRMC                = ""
  fromCompanyFacility     = ""
  toCompanyFacility       = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  %if (V_HDMCRL > "0")
      @RtvFldDesc("CRPRMC>' '", "ARCTRL", "CRPRMC", V_CRPRMC)
  %endif
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {

                  if (document.Chg.purgedInvoices.checked == false &&
                      document.Chg.openInvoices.checked == false)
                      {alert("Must make at least one selection");
                      return false;}

                  if (document.Chg.allCompanyFacility.checked == true &&
                     (document.Chg.fromCompany.value > "" ))
                     {alert("From and to values are not valid with all selection");
                     document.Chg.fromCompany.focus();
                     document.Chg.fromCompany.select();
                     return false;}

                  if (document.Chg.allCompanyFacility.checked == true &&
                     (document.Chg.fromFacility.value > "" ))
                     {alert("From and to values are not valid with all selection");
                     document.Chg.fromFacility.focus();
                     document.Chg.fromFacility.select();
                     return false;}

                  if (document.Chg.allCompanyFacility.checked == true &&
                     (document.Chg.toCompany.value > "" ))
                     {alert("From and to values are not valid with all selection");
                     document.Chg.toCompany.focus();
                     document.Chg.toCompany.select();
                     return false;}

                  if (document.Chg.allCompanyFacility.checked == true &&
                     (document.Chg.toFacility.value > "" ))
                     {alert("From and to values are not valid with all selection");
                     document.Chg.toFacility.focus();
                     document.Chg.toFacility.select();
                     return false;}

                  if (document.Chg.allCompanyFacility.checked == false &&
                     (document.Chg.fromCompany.value == "" && document.Chg.toCompany.value == "" && document.Chg.fromFacility.value == "" && document.Chg.toFacility.value == ""))
                     {alert("From to and all selections are all blank");
                     document.Chg.fromCompany.focus();
                     document.Chg.fromCompany.select();
                     return false;}

                  if (document.Chg.allAccountSubaccount.checked == true &&
                     (document.Chg.fromAccount.value > "" ))
                     {alert("From and to values are not valid with all selection");
                     document.Chg.fromAccount.focus();
                     document.Chg.fromAccount.select();
                     return false;}

                  if (document.Chg.allAccountSubaccount.checked == true &&
                     (document.Chg.fromSubaccount.value > "" ))
                     {alert("From and to values are not valid with all selection");
                     document.Chg.fromSubaccount.focus();
                     document.Chg.fromSubaccount.select();
                     return false;}

                  if (document.Chg.allAccountSubaccount.checked == true &&
                     (document.Chg.toAccount.value > "" ))
                     {alert("From and to values are not valid with all selection");
                     document.Chg.toAccount.focus();
                     document.Chg.toAccount.select();
                     return false;}

                  if (document.Chg.allAccountSubaccount.checked == true &&
                     (document.Chg.toSubaccount.value > "" ))
                     {alert("From and to values are not valid with all selection");
                     document.Chg.toSubaccount.focus();
                     document.Chg.toSubaccount.select();
                     return false;}

                  if (document.Chg.allAccountSubaccount.checked == false &&
                     (document.Chg.fromAccount.value == "" && document.Chg.toAccount.value == "" && document.Chg.fromSubaccount.value == "" && document.Chg.toSubaccount.value == ""))
                     {alert("From to and all selections are all blank");
                     document.Chg.fromAccount.focus();
                     document.Chg.fromAccount.select();
                     return false;}

                  if (editNum(document.Chg.fromLocationNumber, 3, 0) &&
                      editNum(document.Chg.toLocationNumber, 3, 0) &&
                      editNum(document.Chg.fromCompany, 2, 0) &&
                      editNum(document.Chg.toCompany, 2, 0) &&
                      editNum(document.Chg.fromFacility, 4, 0) &&
                      editNum(document.Chg.toFacility, 4, 0) &&
                      editNum(document.Chg.fromAccount, 4, 0) &&
                      editNum(document.Chg.toAccount, 4, 0) &&
                      editNum(document.Chg.fromSubaccount, 4, 0) &&
                      editNum(document.Chg.toSubaccount, 4, 0) &&
                      editNum(document.Chg.fromCustomerNumber, 7, 0) &&
                      editNum(document.Chg.toCustomerNumber, 7, 0) &&
                      editNum(document.Chg.fromInvoiceNumber, 7, 0) &&
                      editNum(document.Chg.toInvoiceNumber, 7, 0) &&
                      editNum(document.Chg.fromDistributionPeriod, 4, 0) &&
                      editNum(document.Chg.toDistributionPeriod, 4, 0) &&
                      editFromToAll(document.Chg.fromLocationNumber, document.Chg.toLocationNumber, document.Chg.allLocationNumber, 3) &&
                      editFromToAll(document.Chg.fromCustomerNumber, document.Chg.toCustomerNumber, document.Chg.allCustomerNumber, 7) &&
                      editFromToAll(document.Chg.fromInvoiceNumber, document.Chg.toInvoiceNumber, document.Chg.allInvoiceNumber, 7) &&
                      editFromToAll(document.Chg.fromDistributionPeriod, document.Chg.toDistributionPeriod, document.Chg.allDistributionPeriod, "P")
                      )

                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "ARDISTRIBUTIONREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromLocationNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@ipiv", "purgedInvoices") @dtw_assign(Err_N1IPIV,  fieldValue)
                                  @DecatErr_Field("@@ioiv", "openInvoices")     @dtw_assign(Err_N1IOIV,  fieldValue)
                                  @DecatErr_Field("@@sloc", "sortLocationNumber")        @dtw_assign(Err_N1SLOC,  fieldValue)
                                  @DecatErr_Field("@@fco@", "fromCompany")        @dtw_assign(Err_N1FCO#,  fieldValue)
                                  @DecatErr_Field("@@scof", "sortCompanyFacility")        @dtw_assign(Err_N1SCOF,  fieldValue)
                                  @DecatErr_Field("@@fact", "fromAccount")        @dtw_assign(Err_N1FACT,  fieldValue)
                                  @DecatErr_Field("@@sact", "sortAccountSubaccount")        @dtw_assign(Err_N1SACT,  fieldValue)
                                  @DecatErr_Field("@@scus", "sortCustomerNumber")        @dtw_assign(Err_N1SCUS,  fieldValue)
                                  @DecatErr_Field("@@sinv", "sortInvoiceNumber")        @dtw_assign(Err_N1SINV,  fieldValue)
                                  @DecatErr_Field("@@sper", "sortDistributionPeriod")    @dtw_assign(Err_N1SPER,  fieldValue)
                                  %if (V_CRPRMC == "Y")
                                      @DecatErr_Field("@@idcr", "currencyID") @dtw_assign(Err_IDCR,  fieldValue)
                                      @DecatErr_Field("@@curt", "currencyType") @dtw_assign(Err_CURT,  fieldValue)
                                  %endif
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@ipiv")  @dtw_assign(V_N1IPIV,  fieldValue)
                                  @Decat_Field("@@ioiv")  @dtw_assign(V_N1IOIV,  fieldValue)
                                  @Decat_Field("@@floc")  @dtw_assign(V_N1FLOC,  fieldValue)
                                  @Decat_Field("@@tloc")  @dtw_assign(V_N1TLOC,  fieldValue)
                                  @Decat_Field("@@aloc")  @dtw_assign(V_N1ALOC,  fieldValue)
                                  @Decat_Field("@@sloc")  @dtw_assign(V_N1SLOC,  fieldValue)
                                  @Decat_Field("@@ploc")  @dtw_assign(V_N1PLOC,  fieldValue)
                                  @Decat_Field("@@fco@")  @dtw_assign(V_N1FCO#,  fieldValue)
                                  @Decat_Field("@@ffac")  @dtw_assign(V_N1FFAC,  fieldValue)
                                  @Decat_Field("@@tco@")  @dtw_assign(V_N1TCO#,  fieldValue)
                                  @Decat_Field("@@tfac")  @dtw_assign(V_N1TFAC,  fieldValue)
                                  @Decat_Field("@@acof")  @dtw_assign(V_N1ACOF,  fieldValue)
                                  @Decat_Field("@@scof")  @dtw_assign(V_N1SCOF,  fieldValue)
                                  @Decat_Field("@@pcof")  @dtw_assign(V_N1PCOF,  fieldValue)
                                  @Decat_Field("@@fact")  @dtw_assign(V_N1FACT,  fieldValue)
                                  @Decat_Field("@@fsub")  @dtw_assign(V_N1FSUB,  fieldValue)
                                  @Decat_Field("@@tact")  @dtw_assign(V_N1TACT,  fieldValue)
                                  @Decat_Field("@@tsub")  @dtw_assign(V_N1TSUB,  fieldValue)
                                  @Decat_Field("@@aact")  @dtw_assign(V_N1AACT,  fieldValue)
                                  @Decat_Field("@@sact")  @dtw_assign(V_N1SACT,  fieldValue)
                                  @Decat_Field("@@pact")  @dtw_assign(V_N1PACT,  fieldValue)
                                  @Decat_Field("@@fcus")  @dtw_assign(V_N1FCUS,  fieldValue)
                                  @Decat_Field("@@tcus")  @dtw_assign(V_N1TCUS,  fieldValue)
                                  @Decat_Field("@@acus")  @dtw_assign(V_N1ACUS,  fieldValue)
                                  @Decat_Field("@@scus")  @dtw_assign(V_N1SCUS,  fieldValue)
                                  @Decat_Field("@@pcus")  @dtw_assign(V_N1PCUS,  fieldValue)
                                  @Decat_Field("@@finv")  @dtw_assign(V_N1FINV,  fieldValue)
                                  @Decat_Field("@@tinv")  @dtw_assign(V_N1TINV,  fieldValue)
                                  @Decat_Field("@@ainv")  @dtw_assign(V_N1AINV,  fieldValue)
                                  @Decat_Field("@@sinv")  @dtw_assign(V_N1SINV,  fieldValue)
                                  @Decat_Field("@@pinv")  @dtw_assign(V_N1PINV,  fieldValue)
                                  @Decat_Field("@@fper")  @dtw_assign(V_N1FPER,  fieldValue)
                                  @Decat_Field("@@tper")  @dtw_assign(V_N1TPER,  fieldValue)
                                  @Decat_Field("@@aper")  @dtw_assign(V_N1APER,  fieldValue)
                                  @Decat_Field("@@sper")  @dtw_assign(V_N1SPER,  fieldValue)
                                  @Decat_Field("@@pper")  @dtw_assign(V_N1PPER,  fieldValue)
                                  %if (V_CRPRMC == "Y")
                                      @Decat_Field("@@idcr")  @dtw_assign(V_IDCR,  fieldValue)
                                      @Decat_Field("@@curt")  @dtw_assign(V_CURT,  fieldValue)
                                  %endif
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                                  %if (V_N1IPIV == "1")
                                      @dtw_assign(checkedPurgedInvoices, "CHECKED")
                                  %else
                                      @dtw_assign(checkedPurgedInvoices, "")
                                  %endif
                                  %if (V_N1IOIV == "1")
                                      @dtw_assign(checkedOpenInvoices, "CHECKED")
                                  %else
                                      @dtw_assign(checkedOpenInvoices, "")
                                  %endif
                                  %if (V_N1ALOC == "ALL")
                                      @dtw_assign(checkedAllLocationNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllLocationNumber, "")
                                  %endif
                                  %if (V_N1ACOF == "ALL")
                                      @dtw_assign(checkedAllCompanyFacility, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllCompanyFacility, "")
                                  %endif
                                  %if (V_N1AACT == "ALL")
                                      @dtw_assign(checkedAllAccountSubaccount, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllAccountSubaccount, "")
                                  %endif
                                  %if (V_N1ACUS == "ALL")
                                      @dtw_assign(checkedAllCustomerNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllCustomerNumber, "")
                                  %endif
                                  %if (V_N1AINV == "ALL")
                                      @dtw_assign(checkedAllInvoiceNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllInvoiceNumber, "")
                                  %endif
                                  %if (V_N1APER == "ALL")
                                      @dtw_assign(checkedAllDistributionPeriod, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllDistributionPeriod, "")
                                  %endif

                                  %if (V_N1PLOC == "Y")
                                      @dtw_assign(checkedLocationNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedLocationNumberTotals, "")
                                  %endif
                                  %if (V_N1PCOF == "Y")
                                      @dtw_assign(checkedCompanyFacilityTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedCompanyFacilityTotals, "")
                                  %endif
                                  %if (V_N1PACT == "Y")
                                      @dtw_assign(checkedAccountSubaccountTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAccountSubaccountTotals, "")
                                  %endif
                                  %if (V_N1PCUS == "Y")
                                      @dtw_assign(checkedCustomerNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedCustomerNumberTotals, "")
                                  %endif
                                  %if (V_N1PINV == "Y")
                                      @dtw_assign(checkedInvoiceNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedInvoiceNumberTotals, "")
                                  %endif
                                  %if (V_N1PPER == "Y")
                                      @dtw_assign(checkedDistributionPeriodTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedDistributionPeriodTotals, "")
                                  %endif
                              %else
                                  @dtw_assign(checkedPurgedInvoices, "CHECKED")
                                  @dtw_assign(checkedOpenInvoices, "CHECKED")
                                  @dtw_assign(checkedAllLocationNumber, "CHECKED")
                                  @dtw_assign(checkedAllCompanyFacility, "CHECKED")
                                  @dtw_assign(checkedAllAccountSubaccount, "CHECKED")
                                  @dtw_assign(checkedAllCustomerNumber, "CHECKED")
                                  @dtw_assign(checkedAllInvoiceNumber, "CHECKED")
                                  @dtw_assign(checkedAllDistributionPeriod, "CHECKED")
                                  %if (V_CRPRMC == "Y")
                                      @dtw_assign(V_IDCR, "D")
                                      @dtw_assign(currencyType, "")
                                  %endif
                              %endif

                              <td><input type="hidden" name="multiCurrency" value="$(V_CRPRMC)"></td>

                              @SetTextOvr(Err_N1IPIV)
                              <tr><td class="dsphdr"><span $(textOvr)>Select Options </span></td>
                                  <td class="inputnmbr"><input name="purgedInvoices" type="checkbox" VALUE='1' $(checkedPurgedInvoices)>Include Distribution For Purged Invoices</td>
                              </tr>
                              @DspErrMsg(Err_N1IPIV)

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="openInvoices" type="checkbox" VALUE='1' $(checkedOpenInvoices)>Include Distribution For Open Invoices</td>
                              </tr>
                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                                  <td class="colhdr">Print<br>Totals</td>
                              </tr>

                              @SetTextOvr(Err_N1FLOC)
                              %if (textOvr == "") @SetTextOvr(Err_N1SLOC) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Location Number</span></td>
                                  <td class="inputnmbr"><input name="fromLocationNumber" value="$(V_N1FLOC)" type="text" size="3" maxlength="3"></td>
                                  <td class="inputnmbr"><input name="toLocationNumber" value="$(V_N1TLOC)" type="text" size="3" maxlength="3"></td>
                                  <td class="inputalph"><input name="allLocationNumber" value='ALL' $(checkedAllLocationNumber) type="checkbox" onClick="if (this.checked) this.form.fromLocationNumber.value='', this.form.toLocationNumber.value='';"></td>
                                  @Build_Sort_Select("sortLocationNumber", "$(V_N1SLOC)")
                                  <td align=center ><input name="totalLocationNumber" type="checkbox" $(checkedLocationNumberTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N1SLOC)

                              @SetTextOvr(Err_N1FCO#)
                              %if (textOvr == "") @SetTextOvr(Err_N1SCOF) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Company/Facility</span></td>
                                  <td class="inputnmbr"><input name="fromCompany" value="$(V_N1FCO#)" type="text" size="2" maxlength="2"> / <input name="fromFacility" value="$(V_N1FFAC)" type="text" size="4" maxlength="4"></td>
                                  <td class="inputnmbr"><input name="toCompany" value="$(V_N1TCO#)" type="text" size="2" maxlength="2"> / <input name="toFacility" value="$(V_N1TFAC)" type="text" size="4" maxlength="4"></td>
                                  <td class="inputalph"><input name="allCompanyFacility" value='ALL' $(checkedAllCompanyFacility) type="checkbox" onClick="if (this.checked) this.form.fromCompany.value='', this.form.fromFacility.value='', this.form.toCompany.value='', this.form.toFacility.value='';"></td>
                                  @Build_Sort_Select("sortCompanyFacility", "$(V_N1SCOF)")
                                  <td align=center ><input name="totalCompanyFacility" type="checkbox" $(checkedCompanyFacilityTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N1FCO#)
                              @DspErrMsg(Err_N1SCOF)

                              @SetTextOvr(Err_N1FACT)
                              %if (textOvr == "") @SetTextOvr(Err_N1SACT) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>G/L Account</span></td>
                                  <td class="inputnmbr"><input name="fromAccount" value="$(V_N1FACT)" type="text" size="4" maxlength="4"> / <input name="fromSubaccount" value="$(V_N1FSUB)" type="text" size="4" maxlength="4"></td>
                                  <td class="inputnmbr"><input name="toAccount" value="$(V_N1TACT)" type="text" size="4" maxlength="4"> / <input name="toSubaccount" value="$(V_N1TSUB)" type="text" size="4" maxlength="4"></td>
                                  <td class="inputalph"><input name="allAccountSubaccount" value='ALL' $(checkedAllAccountSubaccount) type="checkbox" onClick="if (this.checked) this.form.fromAccount.value='', this.form.fromSubaccount.value='', this.form.toAccount.value='', this.form.toSubaccount.value='';"></td>
                                  @Build_Sort_Select("sortAccountSubaccount", "$(V_N1SACT)")
                                  <td align=center ><input name="totalAccountSubaccount" type="checkbox" $(checkedAccountSubaccountTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N1FACT)
                              @DspErrMsg(Err_N1SACT)

                              @SetTextOvr(Err_N1FCUS)
                              %if (textOvr == "") @SetTextOvr(Err_N1SCUS) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Customer Number</span></td>
                                  <td class="inputnmbr"><input name="fromCustomerNumber" value="$(V_N1FCUS)" type="text" size="7" maxlength="7"></td>
                                  <td class="inputnmbr"><input name="toCustomerNumber" value="$(V_N1TCUS)" type="text" size="7" maxlength="7"></td>
                                  <td class="inputalph"><input name="allCustomerNumber" value='ALL' $(checkedAllCustomerNumber) type="checkbox" onClick="if (this.checked) this.form.fromCustomerNumber.value='', this.form.toCustomerNumber.value='';"></td>
                                  @Build_Sort_Select("sortCustomerNumber", "$(V_N1SCUS)")
                                  <td align=center ><input name="totalCustomerNumber" type="checkbox" $(checkedCustomerNumberTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N1SCUS)

                              @SetTextOvr(Err_N1FINV)
                              %if (textOvr == "") @SetTextOvr(Err_N1SINV) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Invoice Number</span></td>
                                  <td class="inputnmbr"><input name="fromInvoiceNumber" value="$(V_N1FINV)" type="text" size="7" maxlength="7"></td>
                                  <td class="inputnmbr"><input name="toInvoiceNumber" value="$(V_N1TINV)" type="text" size="7" maxlength="7"></td>
                                  <td class="inputalph"><input name="allInvoiceNumber" value='ALL' $(checkedAllInvoiceNumber) type="checkbox" onClick="if (this.checked) this.form.fromInvoiceNumber.value='', this.form.toInvoiceNumber.value='';"></td>
                                  @Build_Sort_Select("sortInvoiceNumber", "$(V_N1SINV)")
                                  <td align=center ><input name="totalInvoiceNumber" type="checkbox" $(checkedInvoiceNumberTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N1SINV)

                              @SetTextOvr(Err_N1FPER)
                              %if (textOvr == "") @SetTextOvr(Err_N1SPER) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Distribution Period</td>
                                  <td class="inputnmbr"><input name="fromDistributionPeriod" value="$(V_N1FPER)" type="text" size="4" maxlength="4"></td>
                                  <td class="inputnmbr"><input name="toDistributionPeriod" value="$(V_N1TPER)" type="text" size="4" maxlength="4"></td>
                                  <td class="inputalph"><input name="allDistributionPeriod" value='ALL' $(checkedAllDistributionPeriod) type="checkbox" onClick="if (this.checked) this.form.fromDistributionPeriod.value='', this.form.toDistributionPeriod.value='';"></td>
                                  @Build_Sort_Select("sortDistributionPeriod", "$(V_N1SPER)")
                                  <td align=center ><input name="totalDistributionPeriod" type="checkbox" $(checkedDistributionPeriodTotals) VALUE='Y'>
                              </tr>
                              @DspErrMsg(Err_N1SPER)

                              %if (V_CRPRMC == "Y")
                                  @SetTextOvr(Err_IDCR )
                                  <tr><td class="dsphdr"><span $(textOvr)>Invoice/Domestic Currency (I,D)</span></td>
                                         <td class="inputalph"><input name="currencyID" value="$(V_IDCR)" type="text" size="1" maxlength="1"></td>
                                  </tr>
                                  @DspErrMsg(Err_IDCR)

                                 <tr><td class="dsphdr">--OR--</td></tr>

                                  @SetTextOvr(Err_CURT)
                                  <tr><td class="dsphdr"><span $(textOvr)>Convert To Currency Type</span></td>
                                         <td class="inputalph"><input name="currencyType" value="$(V_CURT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(cGIPath)CurrencyTypeSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=currencyType&amp;fldDesc=currencyTypeDesc" onclick="$(searchWinVar)">  $(searchImage) </a> <input name="currencyTypeDesc" type="hidden"></td>
                                  </tr>
                                  @DspErrMsg(Err_CURT)
                              %endif
                          </table>

                          @dtw_assign(envProgram, "HARDRP")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HARDRS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allLocationNumber)
  @dtw_mUPPERCASE(allCompanyFacility)
  @dtw_mUPPERCASE(allAccountSubaccount)
  @dtw_mUPPERCASE(allCustomerNumber)
  @dtw_mUPPERCASE(allInvoiceNumberPeriod)
  @dtw_mUPPERCASE(allDistributionPeriod)
  @dtw_mUPPERCASE(currencyID)
  @dtw_mUPPERCASE(currencyType)

  @dtw_assign(fromLocationNumber,@dtw_rstrip(fromLocationNumber))
  @dtw_assign(toLocationNumber,@dtw_rstrip(toLocationNumber))
  @dtw_assign(sortLocationNumber,@dtw_rstrip(sortLocationNumber))
  @dtw_assign(fromCompany,@dtw_rstrip(fromCompany))
  @dtw_assign(fromFacility,@dtw_rstrip(fromFacility))
  @dtw_assign(toCompany,@dtw_rstrip(toCompany))
  @dtw_assign(toFacility,@dtw_rstrip(toFacility))
  @dtw_assign(sortCompanyFacility,@dtw_rstrip(sortCompanyFacility))
  @dtw_assign(fromAccount,@dtw_rstrip(fromAccount))
  @dtw_assign(fromSubaccount,@dtw_rstrip(fromSubaccount))
  @dtw_assign(toAccount,@dtw_rstrip(toAccount))
  @dtw_assign(toSubaccount,@dtw_rstrip(toSubaccount))
  @dtw_assign(sortAccountSubaccount,@dtw_rstrip(sortAccountSubaccount))
  @dtw_assign(fromCustomerNumber,@dtw_rstrip(fromCustomerNumber))
  @dtw_assign(toCustomerNumber,@dtw_rstrip(toCustomerNumber))
  @dtw_assign(sortCustomerNumber,@dtw_rstrip(sortCustomerNumber))
  @dtw_assign(fromInvoiceNumber,@dtw_rstrip(fromInvoiceNumber))
  @dtw_assign(toInvoiceNumber,@dtw_rstrip(toInvoiceNumber))
  @dtw_assign(sortInvoiceNumber,@dtw_rstrip(sortInvoiceNumber))
  @dtw_assign(fromDistributionPeriod,@dtw_rstrip(fromDistributionPeriod))
  @dtw_assign(toDistributionPeriod,@dtw_rstrip(toDistributionPeriod))
  @dtw_assign(sortDistributionPeriod,@dtw_rstrip(sortDistributionPeriod))

  %if (allLocationNumber != "ALL")
      @dtw_assign(allLocationNumber, "")
  %endif
  %if (allCompanyFacility != "ALL")
      @dtw_assign(allCompanyFacility, "")
  %endif
  %if (allAccountSubaccount != "ALL")
      @dtw_assign(allAccountSubaccount, "")
  %endif
  %if (allCustomerNumber != "ALL")
      @dtw_assign(allCustomerNumber, "")
  %endif
  %if (allInvoiceNumber != "ALL")
      @dtw_assign(allInvoiceNumber, "")
  %endif
  %if (allDistributionPeriod != "ALL")
      @dtw_assign(allDistributionPeriod, "")
  %endif

  %if (totalLocationNumber != "Y")
      @dtw_assign(totalLocationNumber, "N")
  %endif
  %if (totalCompanyFacility != "Y")
      @dtw_assign(totalCompanyFacility, "N")
  %endif
  %if (totalAccountSubaccount != "Y")
      @dtw_assign(totalAccountSubaccount, "N")
  %endif
  %if (totalCustomerNumber != "Y")
      @dtw_assign(totalCustomerNumber, "N")
  %endif
  %if (totalInvoiceNumber != "Y")
      @dtw_assign(totalInvoiceNumber, "N")
  %endif
  %if (totalDistributionPeriod != "Y")
      @dtw_assign(totalDistributionPeriod, "N")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@mult", multiCurrency)
  @Concat_Field("@@ipiv", purgedInvoices)
  @Concat_Field("@@ioiv", openInvoices)
  @Concat_Field("@@floc", fromLocationNumber)
  @Concat_Field("@@tloc", toLocationNumber)
  @Concat_Field("@@aloc", allLocationNumber)
  @Concat_Field("@@sloc", sortLocationNumber)
  @Concat_Field("@@ploc", totalLocationNumber)
  @Concat_Field("@@fco@", fromCompany)
  @Concat_Field("@@ffac", fromFacility)
  @Concat_Field("@@tco@", toCompany)
  @Concat_Field("@@tfac", toFacility)
  @Concat_Field("@@acof", allCompanyFacility)
  @Concat_Field("@@scof", sortCompanyFacility)
  @Concat_Field("@@pcof", totalCompanyFacility)
  @Concat_Field("@@fact", fromAccount)
  @Concat_Field("@@fsub", fromSubaccount)
  @Concat_Field("@@tact", toAccount)
  @Concat_Field("@@tsub", toSubaccount)
  @Concat_Field("@@aact", allAccountSubaccount)
  @Concat_Field("@@sact", sortAccountSubaccount)
  @Concat_Field("@@pact", totalAccountSubaccount)
  @Concat_Field("@@fcus", fromCustomerNumber)
  @Concat_Field("@@tcus", toCustomerNumber)
  @Concat_Field("@@acus", allCustomerNumber)
  @Concat_Field("@@scus", sortCustomerNumber)
  @Concat_Field("@@pcus", totalCustomerNumber)
  @Concat_Field("@@finv", fromInvoiceNumber)
  @Concat_Field("@@tinv", toInvoiceNumber)
  @Concat_Field("@@ainv", allInvoiceNumber)
  @Concat_Field("@@sinv", sortInvoiceNumber)
  @Concat_Field("@@pinv", totalInvoiceNumber)
  @Concat_Field("@@fper", fromDistributionPeriod)
  @Concat_Field("@@tper", toDistributionPeriod)
  @Concat_Field("@@aper", allDistributionPeriod)
  @Concat_Field("@@sper", sortDistributionPeriod)
  @Concat_Field("@@pper", totalDistributionPeriod)
  %if (multiCurrency == "Y")
      @Concat_Field("@@idcr", currencyID)
      @Concat_Field("@@curt", currencyType)
  %endif


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}