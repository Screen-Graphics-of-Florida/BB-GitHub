%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Payment Code Search"
  d2wName                 = "ARPaymentCodeSearch.d2w"
  d2wVarBase              = "$(genericVarBase))&amp;docName=@dtw_rurlescseq(docName)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  advanceSearch           = "N"
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	          %INCLUDE "numedit.icl"
              function selectPaymentCode(paymentCode, desc){
                  window.opener.document.$(docName).$(fldName).value = paymentCode;
                  window.opener.document.$(docName).$(fldDesc).value = desc;
                  window.opener.document.$(docName).$(fldName).focus();
                  window.close();
              }
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                 return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select PYPYCD, PYALPH, PYACCT, PYSUB, PYSTDS, PYPYDS, ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(PYPYDS) as PYPYDSU ", stmtSQL)
                      @dtw_concat(fileSQL, " ARPYCD ", fileSQL)
                      %if (wildCardSearch!="" || moreInfo == "Y")
                          @dtw_concat(selectSQL, "PYPYCD<>' ' ", selectSQL)
                      %endif
                      %if (moreInfo == "Y")
                          @dtw_concat(selectSQL, " and PYPYCD='$(paymentCode)'", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @PaymentCode_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}
%FUNCTION(dtw_sql) PaymentCode_Search (IN CHAR(64) profileHandle,
     	                                CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      %INCLUDE "PageTitle.icl"
      $(searchhrTagAttr)
      %if (moreInfo != "Y")	
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Description</th>
                      <th class="colhdr">Code</th>
                  </tr>
                  <tr>
                      <td class="inputalph">
                          <input type="text" name="srchDesc" size="20" maxlength="30">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td class="inputalph">
                          <input type="text" name="srchCode" size="1" maxlength="1">
                          <input type="hidden" name="operCode" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>
	
          %INCLUDE "WildCardPage.icl"

          <table $(contentTable)>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              <tr>
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("PYPYDSU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description" title="Sequence By Description, Payment Code">Description</a></th>
                  @OrderBy_Sort("PYPYCD", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Code" title="Sequence By Payment Code ">Code</a></th>
              </tr>
              %INCLUDE "NoRecordsFound.icl"
      %else
          <table $(contentTable)>
      %endif		
              %ROW{
                  %INCLUDE "SetRowClass.icl"
    	           %if (moreInfo != "Y")	
                      <tr class="$(rowClass)">
                          <td class="colalph"><a href="javascript:selectPaymentCode('$(V_PYPYCD)','$(V_PYPYDS)')" title="Select Payment Code">$(V_PYPYDS)</a></td>
                          <td class="colcode">$(V_PYPYCD)</td>                                      	
                          <td class="colicon"><a href="$(homeURL)$(cGIPath)$(d2wName)/MOREINFO$(d2wVarBase)&amp;paymentCode=@dtw_rurlescseq(V_PYPYCD)&amp;moreInfo=Y">$(moreInfoImage)</a></td>
                      </tr>

                  %else
                      %{ More Information Screen %}

                      <tr><td><a href="javascript:selectPaymentCode('$(V_PYPYCD)','$(V_PYPYDS)')" title="Select Payment Code">$(selectImageLrg)</a></td></tr>

                      <tr><td class="dsphdr">Payment Code</td>
                          <td class="dspalph">$(V_PYPYCD)</td>
                      </tr>
    	   		
                      <tr><td class="dsphdr">Payment Description</td>
                          <td class="dspalph">$(V_PYPYDS)</td>
                      </tr>

                      <tr><td class="dsphdr">Alpha Sequence</td>
                          <td class="dspalph">$(V_PYALPH)</td></tr>

                      <tr><td class="dsphdr">Statement Description</td>
                          <td class="dspalph">$(V_PYSTDS)</td></tr>

                      @Format_Acct("$(V_PYACCT)", "$(V_PYSUB)", "Y", F_AcctSub)
                      <tr><td class="dsphdr">Account</td>
                          <td class="dspalph">$(F_AcctSub)</td></tr>

                  %endif
              %}
          </table>
	   %if (moreInfo != "Y")	
              %INCLUDE "PageBottom.icl"
              %INCLUDE "WildCardPrint.icl"
	   %endif	   	
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "PYPYDSU,PYPYCD")
      @DTW_ASSIGN(orderByDisplay, "Payment Code Description")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}
%HTML(MOREINFO) {
  %INCLUDE "setLibraryList.icl"
  @DTW_ASSIGN(orderBy, "PYPYCD")
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Description")
      %if (orderBy == "PYPYDSU")
          @DTW_ASSIGN(orderBy, "PYPYDSU DESC")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Payment Code")
      %else
          @DTW_ASSIGN(orderBy, "PYPYDSU")
          @DTW_ASSIGN(orderByDisplay, "Description, Payment Code")
      %endif
  %elseif (sequence == "Code")
      %if (orderBy == "PYPYCD")
          @DTW_ASSIGN(orderBy, "PYPYCD DESC")
          @DTW_ASSIGN(orderByDisplay, "Payment Code (descending)")
      %else
          @DTW_ASSIGN(orderBy, "PYPYCD")
          @DTW_ASSIGN(orderByDisplay, "Payment Code")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("PYPYCD", "Payment Code", $(srchCode), "U", operCode, "A")
  @Build_WildCard ("upper(PYPYDS)", "Payment Code Description", $(srchDesc), "U", operDesc, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}