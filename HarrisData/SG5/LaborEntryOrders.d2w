%INCLUDE "$(baseVar)"
%INCLUDE "EdtVar.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Labor Entry Orders"
  d2wName                 = "LaborEntryOrders.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;addOrders=@dtw_rurlescseq(addOrders)&amp;touchScreen=Y"
  currentURL              = "$(d2wName)/REPORT$(d2wVarBase)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HSI214"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "8"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "8"
  rowIndexNext            = "1"
  totalPages              = "0"
  groupNbr                = "0"
  coNumber                = "0"
  facNumber               = "0"
  emplNumber              = "0"
  lastTran                = " "
  sec_01                  = ""
  sec_02                  = ""
  sec_03                  = ""
  sec_04                  = ""
  sec_05                  = ""
  sec_06                  = ""
  sec_07                  = ""
  sec_08                  = ""
  sec_09                  = ""
  sec_10                  = ""
  sec_11                  = ""
  sec_12                  = ""
  sec_13                  = ""
  sec_14                  = ""
  sec_15                  = ""
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
              %INCLUDE "AJAXRequestFunction.icl"
              %INCLUDE "KeyboardFunctionsTS.icl"
              %INCLUDE "ShowHideSelCriteria.icl"

              function selUpdate(plt,ord,seq,row) {
                 var selFld="selRec"+row;
                 var url = "$(homeURL)$(cGIPath)ShopFloorDispatchSelUpdate.d2w/UPDATE?baseVar=@dtw_rurlescseq(baseVar)&eID=@dtw_rurlescseq(eID)";
                     url += "&plantNumber=" + escape(plt);
                     url += "&mfgOrder=" + escape(ord);
                     url += "&seqNumber=" + escape(seq);
                 var sel='';
                     if (document.getElementById(selFld).checked) {sel='Y';}
                     url += "&selFlag=" + escape(sel);
	          var ajaxRequest = new ajaxObject(url,selUpdateResponse);
	              ajaxRequest.update();
              }

              function selUpdateResponse(responseText, responseStatus) {
                 if (responseStatus==200) {
                 } else  { alert(responseStatus + " -- Error Processing Request");}
              }

              function saveCurrURL() {
                  var url = "$(homeURL)$(cGIPath)SaveCurrentURL.d2w/SAVE?baseVar=@dtw_rurlescseq(baseVar)&currentURL=@dtw_rurlescseq(currentURL)";
	              var saveRequest = new getXMLHTTPRequest();
                  saveRequest.open("GET", url, false);
                  saveRequest.send(null);
              }

          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">

%{ Labor Entry Heading %}
                      @dtw_assign(SAVE_ROW_NUM, START_ROW_NUM)
                      @dtw_assign(START_ROW_NUM, "1")
                      @dtw_assign(stmtSQL, "")
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(stmtSQL, " From SIDCTW Where WDXHND='$(profileHandle)' ", stmtSQL)
                      @dtw_concat(stmtSQL, " Fetch First 1 Row Only With NC  @@endsql", stmtSQL)
                      @Labor_Entry_Header(profileHandle, dataBaseID, stmtSQL)

%{ Labor Entry Orders %}
                      @dtw_assign(START_ROW_NUM, SAVE_ROW_NUM)
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select  a.* ", stmtSQL)
                      %if (addOrders == "Y")
                          @dtw_concat(fileSQL, " SIDOPW a ", fileSQL)
                      %else
                          @dtw_concat(fileSQL, " SILOPW a ", fileSQL)
                      %endif
                      @dtw_concat(selectSQL, " a.WOXHND='$(profileHandle)' ", selectSQL)
                      %if (addOrders == "Y")
                          @dtw_concat(selectSQL, " and not exists (Select * From SILOPW b Where a.WOXHND=b.WOXHND and a.WOMORD=b.WOMORD and a.WOSEQN=b.WOSEQN)", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      %if (START_ROW_NUM > sql_Record_Count)
                          @dtw_assign(START_ROW_NUM, "1")
                      %endif	
                      @Labor_Entry_Orders(profileHandle, dataBaseID, stmtSQL)
                  </td>
                  <td>
                      <ul class="toolbarTS">
                          %if (addOrders == "Y")
                              <li class="optionTS"><a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(genericVarBase)&amp;refresh=Y&amp;touchScreen=Y">&nbsp;<br>Exit</a></li>                          
                              <li class="optionTS"><a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(genericVarBase)&amp;accept=Y&amp;touchScreen=Y">&nbsp;<br>Accept</a></li>
                              <li class="optionTS"><a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;refresh=Y">&nbsp;<br>Refresh</a></li>
                          %else
                              <li class="optionTS"><a href="$(homeURL)$(cGIPath)EmployeeSignOn.d2w/REPORT$(d2wVarBase)">&nbsp;<br>Exit</a></li>                          
                              <li class="optionTS"><a href="$(homeURL)$(cGIPath)LaborEntry.d2w/REPORT$(d2wVarBase)">&nbsp;<br>Labor Entry</a></li>
                              %if (groupNbr > "0")
                                  <li class="optionTS"><a href="$(homeURL)$(cGIPath)LaborEntryEmployees.d2w/REPORT$(d2wVarBase)">&nbsp;<br>Maintain Employees</a></li>
                              %endif
                              <li class="optionTS"><a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(genericVarBase)&amp;addOrders=Y&amp;touchScreen=Y">&nbsp;<br>Add Orders</a></li>
                          %endif
                      </ul>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Labor_Entry_Header (IN CHAR(64)    profileHandle,
				           CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <tr><td><h1> $(page_title)</h1></td></tr>
      </table>

      %ROW{
          <table $(contentTable)>
              @dtw_assign(lastTran, V_WDLSTR)
              %if (V_WDGRP == "0")
                  @dtw_assign(groupNbr, "0")
                  @dtw_assign(coNumber, V_WDCOMP)
                  @dtw_assign(facNumber, V_WDFACL)
                  @dtw_assign(emplNumber, V_WDEMPL)
                  @Format_Header("Employee", $(V_WDENAM), "")
              %else
                  @dtw_assign(groupNbr, V_WDGRP)
                  @dtw_assign(coNumber, "0")
                  @dtw_assign(facNumber, "0")
                  @dtw_assign(emplNumber, "0")                  
                  @Format_Header("Group", $(V_WDGDSC), "")
              %endif
              @RtvFldDesc("DFCODE='$(V_WDLSTR)'", "ETDCDF", "DFDESC", lastTranDesc)
              @Format_Header("Last Transaction", $(lastTranDesc), $(V_WDLSTR))
          </table>
       %}

      %INCLUDE "ConfMessageDisplay.icl"
      $(hrTagAttr)
  %}
%}


%FUNCTION(dtw_sql) Labor_Entry_Orders (IN CHAR(64)    profileHandle,
				           CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <form class="formClass" method="post" name="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
          <table $(quickSearchTable)>
              <tr><th class="colhdr">Item Number</th>
                  <th class="colhdr">Order</th>
                  <td>&nbsp;</td>
              </tr>
              <tr><td class="inputalph">
                      <input class="input" id="srchItem" onfocus="kbActive(this, 'keyboard');" name="srchItem" type="text" size="15" maxlength="15">
                      <input type="hidden" name="operItem" value="LIKE">
                  </td>
                  <td class="inputalph">
                      <input class="input" id="srchOrder" onfocus="kbActive(this, 'keyboard');" name="srchOrder" type="text" size="9" maxlength="9">
                      <input type="hidden" name="operOrder" value="LIKE">
                  </td>
                  <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  <td><input type="hidden" id="submitSearch"></td>
              </tr>
          </table>
      </form>

      @dtw_assign(pageSelectList, "N")
      @dtw_assign(wildCardDefault, "N")
      @dtw_assign(advanceSearch, "N")
      %INCLUDE "WildCardPage.icl"

      <form class="formClass" method="post" name="Select" action="">
          <table $(contentTable)>
              <tr>
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("WOITEM", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ITEM" title="Sequence By Item Number">Item Number</a></th>
                  @OrderBy_Sort("WOCPNS", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CPNS" title="Sequence By Component Shortage">Sh</a></th>
                  @OrderBy_Sort("WOMORD", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ORD" title="Sequence By Order Number">Order</a></th>
                  @OrderBy_Sort("WOSEQN", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=SEQN" title="Sequence By Routing Sequence">Seq</a></th>
                  @OrderBy_Sort("WOCSDT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CSDT" title="Sequence By Start Date">Start Date</a></th>
                  @OrderBy_Sort("WOCDDT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CDDT" title="Sequence By Due Date">Due Date</a></th>
                  @OrderBy_Sort("WOQTYR", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=QTYR" title="Sequence By Quantity Remaining">Quantity</a></th>
                  @OrderBy_Sort("WOHRSR", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=HRSR" title="Sequence By Hours Remaining">Hours</a></th>
                  %if (addOrders == "Y" && V_WORPTL != "N")
                      <th class="colhdr">Sel</th>
                  %endif
              </tr>		
              %INCLUDE "NoRecordsFound.icl"

              %ROW{
                  %if (V_WOOACT == "Y")
                     @dtw_assign(selClass, "selRow")
                  %else
                     %INCLUDE "SetRowClass.icl"
                     @dtw_assign(selClass, rowClass)
                  %endif
                  @Format_Date(V_WOCSDT, "D", F_WOCSDT)
                  @Format_Date(V_WOCDDT, "D", F_WOCDDT)
                  @Format_Nbr($(V_WOQTYR), F_WOQTYR, $(qtyNbrDec), $(qtyEditCode), "", "", "")
                  @Format_Nbr($(V_WOHRSR), F_WOHRSR, $(hrsNbrDec), $(hrsEditCode), "", "", "")
                  %if (V_WOOSEL == "Y")
                      @dtw_assign(orderChecked, "CHECKED")
                  %else
                      @dtw_assign(orderChecked, "")
                  %endif
                  <tr class="$(selClass)">
                      <td class="colalph" onclick="showSel('selData$(ROW_NUM)');">$(V_WOITEM)</td>
                      <td class="colcode" onclick="showSel('selData$(ROW_NUM)');">$(V_WOCPNS)</td>
                      <td class="colalph" onclick="showSel('selData$(ROW_NUM)');">$(V_WOMORD)</td>
                      <td class="colnmbr" onclick="showSel('selData$(ROW_NUM)');">$(V_WOSEQN)</td>
                      <td class="colnmbr" onclick="showSel('selData$(ROW_NUM)');">$(F_WOCSDT)</td>
                      <td class="colnmbr" onclick="showSel('selData$(ROW_NUM)');">$(F_WOCDDT)</td>
                      <td class="colnmbr" onclick="showSel('selData$(ROW_NUM)');">$(F_WOQTYR)</td>
                      <td class="colnmbr">$(F_WOHRSR)</td>
                      %if (addOrders == "Y" && V_WORPTL != "N")
                          <td align="center"><input id="selRec$(ROW_NUM)" name="selRec$(ROW_NUM)" class="bigcheck" type="checkbox" $(orderChecked) onClick="selUpdate('$(V_WOPLT)','$(V_WOMORD)','$(V_WOSEQN)',$(ROW_NUM));"/></td>
                      %endif
                  </tr>
                  <tr>
                      <td>
                          @dtw_assign(moreInfo, "")
                          @Build_More_Info("Item Number", V_WOITEM, "", moreInfo)
                          @Build_More_Info("Description", V_WOIMDS, "", moreInfo)
                          @Build_More_Info("Shortage", V_WOCPNS, "", moreInfo)
                          @Build_More_Info("Order Number", V_WOMORD, "", moreInfo)
                          @Build_More_Info("Sequence", V_WOSEQN, "", moreInfo)
                          @Build_More_Info("Start Date", F_WOCSDT, "", moreInfo)
                          @Build_More_Info("Due Date", F_WOCDDT, "", moreInfo)
                          @Build_More_Info("Quantity", F_WOQTYR, "", moreInfo)
                          @Build_More_Info("Hours", F_WOHRSR, "", moreInfo)
                          %if (V_WOORD# != "0")
                              @Build_More_Info("Sales Order", V_WOORD#, "", moreInfo)
                          %endif
                          %if (V_WOSLTO != "0")
                              @Format_Code($(V_WOSLTO), F_WOSLTO)
                              @RtvFldDesc("CMCUST=$(V_WOSLTO) ", "HDCUST", "CMCNA1", V_CMCNA1)
                              @Build_More_Info("Customer", V_CMCNA1, F_WOSLTO, moreInfo)
                          %endif
                          %if (V_WOMGTP != ".0")
                              @Build_More_Info("Priority", V_WOMGTP, "", moreInfo)
                          %endif
                          %if (V_WONXWC != "")
                              @Build_More_Info("Next W/C", V_WONXWC, "", moreInfo)
                          %endif
                          %if (V_WOLSWC != "")
                              @Build_More_Info("Last W/C", V_WOLSWC, "", moreInfo)
                          %endif
                          %if (V_WOEMGR != "0")
                              @Build_More_Info("Employee/Group", V_WOEMGR, "", moreInfo)
                          %endif
                          <div id="selData$(ROW_NUM)" class="moreInfoPos">
                              <table $(quickSearchTable)>
                                  <tr>
                                      <td>&nbsp;</td>
                                      <td>&nbsp;</td>
                                      <td rowspan="20">
                                          <ul class="toolbarTS">
                                              <li class="optionTS2"><a href="javascript:void+0" onClick="hideSel('selData$(ROW_NUM)')">&nbsp;<br>Exit</a></li>
                                              %if (addOrders != "Y")
                                                  %if (sec_04 == "Y")
                                                      <li class="optionTS2"><a onClick="saveCurrURL();"  href="$(homeURL)$(cGIPath)ComponentMaterialRequisition.d2w/REPORT$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(V_WOPLT)&amp;mfgOrder=@dtw_rurlescseq(V_WOMORD)&amp;parentItem=@dtw_rurlescseq(V_WOITEM)">Component<br>Material<br>Requisition</a></li>
                                                  %endif
                                                  %if (sec_05 == "Y")
                                                      <li class="optionTS2"><a onClick="saveCurrURL();"  href="$(homeURL)$(cGIPath)MfgOrderReceipt.d2w/REPORT$(d2wVarBase)&amp;turnaroundNumber=@dtw_rurlescseq(V_WOORTN)">Finished<br>Goods<br>Receipt</a></li>
                                                  %endif
                                              %endif
                                          </ul>
                                      </td>
                                      %if (addOrders != "Y")
                                          <td rowspan="20">
                                              <ul class="toolbarTS">
                                                  <li class="optionTS2"><a href="$(homeURL)$(cGIPath)$(d2wName)/REPORT$(d2wVarBase)&amp;groupNbr=@dtw_rurlescseq($(groupNbr))&amp;coNumber=@dtw_rurlescseq($(coNumber))&amp;facNumber=@dtw_rurlescseq($(facNumber))&amp;emplNumber=@dtw_rurlescseq($(emplNumber))&amp;lastTran=@dtw_rurlescseq($(lastTran))&amp;plantNumber=@dtw_rurlescseq($(V_WOPLT))&amp;mfgOrder=@dtw_rurlescseq($(V_WOMORD))&amp;sequenceNumber=@dtw_rurlescseq(V_WOSEQN)&amp;removeOrder=Y&amp;START_ROW_NUM=@dtw_rurlescseq(START_ROW_NUM)">&nbsp;<br>Remove Order</a></li>
                                                  %if (sec_10 == "Y")
                                                      <li class="optionTS2"><a href="$(homeURL)$(cGIPath)SelectMfgOrder.d2w/REPORT$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq($(V_WOPLT))&amp;mfgOrder=@dtw_rurlescseq($(V_WOMORD))" onclick="$(inquiryWinVar)">&nbsp;<br>Order Inquiry</a></li>
                                                  %endif
                                                  %if (V_WONTCD != "")
                                                      <li class="optionTS2"><a href="$(homeURL)$(cGIPath)LaborInProcessNotesInquiry.d2w/REPORT$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(V_WOPLT)&amp;mfgOrder=@dtw_rurlescseq(V_WOMORD)&amp;sequenceNumber=@dtw_rurlescseq(V_WOSEQN)&amp;documentType=RTG" onclick="$(commentWinVar)">&nbsp;<br>Routing Notes</a></li>
                                                  %endif
                                              </ul>
                                          </td>
                                      %endif
                                  </tr>
                                  $(moreInfo)
                              </table>
                          </div>
                      </td>
                  </tr>
	       %}
          </table>
      </form>

      %INCLUDE "KeyboardTS.icl"

      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HETLBE_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "WOCSDT,WOMORD,WOSEQN")
      @DTW_ASSIGN(orderByDisplay, "Current Start Date")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)

  %if (refresh == "Y")
      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Update SIDOPW a Set WOOSEL=' ' ", stmtSQL)
      @dtw_concat(stmtSQL, " Where a.WOXHND='$(profileHandle)' and not exists ", stmtSQL)
      @dtw_concat(stmtSQL, " (Select * From SILOPW b Where a.WOXHND=b.WOXHND  and a.WOMORD=b.WOMORD and a.WOSEQN=b.WOSEQN)  @@endsql", stmtSQL)
      @SQL_Update(stmtSQL, status)

  %elif (removeOrder == "Y")
      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Delete From HDMECH ", stmtSQL)
      %if (groupNbr > "0")
          @dtw_concat(stmtSQL, " Where EHGRP=$(groupNbr) and EHTRAN='$(lastTran)' and EHPLNT=$(plantNumber) and EHORD='$(mfgOrder)' and EHSEQN=$(sequenceNumber) @@endsql", stmtSQL)
      %else
          @dtw_concat(stmtSQL, " Where EHCO=$(coNumber) and EHFAC=$(facNumber) and EHEMP=$(emplNumber) and EHTRAN='$(lastTran)' and EHPLNT=$(plantNumber) and EHORD='$(mfgOrder)' and EHSEQN=$(sequenceNumber) @@endsql", stmtSQL)
      %endif
      @SQL_Update(stmtSQL, status)
    
      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Update SIDOPW Set WOOSEL=' ' ", stmtSQL)
      @dtw_concat(stmtSQL, " Where WOPLT=$(plantNumber) and WOMORD='$(mfgOrder)' and WOSEQN=$(sequenceNumber) and WOXHND='$(profileHandle)' @@endsql", stmtSQL)
      @SQL_Update(stmtSQL, status)

      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Delete From SILOPW ", stmtSQL)
      @dtw_concat(stmtSQL, " Where WOMORD='$(mfgOrder)' and WOSEQN=$(sequenceNumber) and WOXHND='$(profileHandle)' @@endsql", stmtSQL)
      @SQL_Update(stmtSQL, status)

  %elif (accept == "Y")
      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Insert Into SILOPW (WOXHND,WOMORD,WOSEQN,WOPLT,WODEPT,WOWC,WOQTYR,WOHRSR,WOCSDT,WOCDDT,WOMGTP,WONTCD,WONXWC,WOLSWC,WOORTN,WOSLTO,WOORD#,WOITEM,WOIMDS,WOCPNS,WOOACT,WOEMGR,WOOSEL)", stmtSQL)
      @dtw_concat(stmtSQL, " Select a.WOXHND,a.WOMORD,a.WOSEQN,a.WOPLT,a.WODEPT,a.WOWC,a.WOQTYR,a.WOHRSR,a.WOCSDT,a.WOCDDT,a.WOMGTP,a.WONTCD,a.WONXWC,a.WOLSWC,a.WOORTN,a.WOSLTO,a.WOORD#,a.WOITEM,a.WOIMDS,a.WOCPNS,'Y',a.WOEMGR,'Y' ", stmtSQL)
      @dtw_concat(stmtSQL, " From SIDOPW a Where a.WOXHND='$(profileHandle)' and a.WOOSEL='Y' and not exists ", stmtSQL)
      @dtw_concat(stmtSQL, " (Select * From SILOPW b Where a.WOXHND=b.WOXHND and a.WOMORD=b.WOMORD and a.WOSEQN=b.WOSEQN) @@endsql ", stmtSQL)
      @SQL_Update(stmtSQL, status)
  %endif

  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "ITEM")
      %if (orderBy == "WOITEM,WOCSDT,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderBy, "WOITEM DESC,WOCSDT,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderByDisplay, "Item Number (descending), Start Date, Order")
      %else
          @DTW_ASSIGN(orderBy, "WOITEM,WOCSDT,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderByDisplay, "Item Number, Start Date, Order")
      %endif
  %elif (sequence == "CPNS")
      %if (orderBy == "WOCPNS,WOCSDT,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderBy, "WOCPNS DESC,WOCSDT,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderByDisplay, "Shortage (descending), Start Date, Order")
      %else
          @DTW_ASSIGN(orderBy, "WOCPNS,WOCSDT,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderByDisplay, "Shortage, Start Date, Order")
      %endif
  %elif (sequence == "ORD")
      %if (orderBy == "WOMORD,WOSEQN")
          @DTW_ASSIGN(orderBy, "WOMORD DESC,WOSEQN")
          @DTW_ASSIGN(orderByDisplay, "Order (descending), Sequence")
      %else
          @DTW_ASSIGN(orderBy, "WOMORD,WOSEQN")
          @DTW_ASSIGN(orderByDisplay, "Order, Sequence")
      %endif
  %elif (sequence == "SEQN")
      %if (orderBy == "WOSEQN,WOMORD")
          @DTW_ASSIGN(orderBy, "WOSEQN DESC,WOMORD")
          @DTW_ASSIGN(orderByDisplay, "Sequence (descending), Order")
      %else
          @DTW_ASSIGN(orderBy, "WOSEQN,WOMORD")
          @DTW_ASSIGN(orderByDisplay, "Sequence, Order")
      %endif
  %elif (sequence == "CSDT")
      %if (orderBy == "WOCSDT,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderBy, "WOCSDT DESC,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderByDisplay, "Start Date (descending), Order, Sequence")
      %else
          @DTW_ASSIGN(orderBy, "WOCSDT,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderByDisplay, "Start Date, Order, Sequence")
      %endif
  %elif (sequence == "CDDT")
      %if (orderBy == "WOCDDT,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderBy, "WOCDDT DESC,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderByDisplay, "Due Date (descending), Order, Sequence")
      %else
          @DTW_ASSIGN(orderBy, "WOCDDT,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderByDisplay, "Due Date, Order, Sequence")
      %endif
  %elif (sequence == "QTYR")
      %if (orderBy == "WOQTYR,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderBy, "WOQTYR DESC,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderByDisplay, "Quantity (descending), Order, Sequence")
      %else
          @DTW_ASSIGN(orderBy, "WOQTYR,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderByDisplay, "Quantity, Order, Sequence")
      %endif
  %elif (sequence == "HRSR")
      %if (orderBy == "WOHRSR,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderBy, "WOHRSR DESC,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderByDisplay, "Hours (descending), Order, Sequence")
      %else
          @DTW_ASSIGN(orderBy, "WOHRSR,WOMORD,WOSEQN")
          @DTW_ASSIGN(orderByDisplay, "Hours, Order, Sequence")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("WOITEM", "Item Number", $(srchItem), "U", operItem, "A")
  @Build_WildCard ("WOMORD", "Order Number", $(srchOrder), "U", operOrder, "A")
		
  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}

%HTML(NOUPDATE) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(confMessage, "")
  @dtw_assign(returnURL, "EmployeeSignOn.d2w/REPORT$(genericVarBase)")
  %INCLUDE "ReturnTS.icl"
%}