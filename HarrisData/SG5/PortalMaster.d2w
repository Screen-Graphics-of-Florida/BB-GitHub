%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Portal"
  d2wName                 = "PortalMaster.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HSYPRM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
   @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\r" + "\r" + text);}
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "PORTALMASTER")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select SYPORT.*, ", stmtSQL)
                      @dtw_concat(stmtSQL, " ifnull(FUDESC,' ') as FUDESC, ifnull(FUDESCU,' ') as FUDESCU  ", stmtSQL)
                      @dtw_concat(fileSQL, " SYPORT ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYURLM on FPID=FUID ", fileSQL)
                      %if (wildCardSearch!="")
                          @dtw_concat(selectSQL, " FPPORT <>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Portal_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Portal_Query (IN CHAR(64)    profileHandle,
                                    CHAR(2)     dataBaseID,
                                    CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                      %endif
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)portalmastermaintain.d2w/MAINTAIN$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr"> Portal</th>
                      <th class="colhdr"> Page</th>
                      <th class="colhdr"> URL ID</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchPortal" size="20" maxlength="20">
                          <input type="hidden" name="operPortal" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchPage" size="20" maxlength="20">
                          <input type="hidden" name="operPage" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchURL" size="20 maxlength="55">
                          <input type="hidden" name="operURL" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchPortal.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("FPPORT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Portal" title="Sequence By Portal, Page, Sequence"> Portal</a></th>
              @OrderBy_Sort("FPPAGE", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Page" title="Sequence By Page, Portal, Sequence"> Page</a></th>
              @OrderBy_Sort("FPSEQ", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Sequence" title="Sequence By Sequence, Portal, Page"> Sequence</a></th>
              @OrderBy_Sort("FPID", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=URLID" title="Sequence By URL ID, Portal, Page, Sequence"> URL ID</a></th>
              @OrderBy_Sort("FUDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=URLDesc" title="Sequence By URL ID Description, Portal, Page, Sequence"> URL ID<br>Description</a></th>
              @OrderBy_Sort("FPDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Desc" title="Sequence By Description, Portal, Page, Sequence">Override<br>Description</a></th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;urlPortal=@dtw_rurlescseq(V_FPPORT)&amp;urlPage=@dtw_rurlescseq(V_FPPAGE)&amp;urlSequence=@dtw_rurlescseq(V_FPSEQ)&amp;urlDesc=@dtw_rurlescseq(V_FPDESC)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc("Portal", $(V_FPPORT), "Page", $(V_FPPAGE), "Sequence", $(V_FPSEQ), confirmDesc)

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                      <td class="opticon">
                          %if ((sec_02 == "Y" || sec_03 == "Y") && V_FPRESV != "Y")
                              <a href="$(homeURL)$(cGIPath)portalmastermaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_04 == "Y")
                              <a href="$(homeURL)$(cGIPath)portalmastermaintain.d2w/MAINTAIN$(maintainVar)&amp;fromUrlPortal=@dtw_rurlescseq(V_FPPORT)&amp;fromUrlPage=@dtw_rurlescseq(V_FPPAGE)&amp;fromUrlSequence=@dtw_rurlescseq(V_FPSEQ)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if ((sec_03 == "Y") && V_FPRESV != "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)portalmastermaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph">$(V_FPPORT)</td>
                  <td class="colalph">$(V_FPPAGE)</td>
                  <td class="colnmbr">$(V_FPSEQ)</td>
                  <td class="colalph">$(V_FPID)</td>
                  <td class="colalph">$(V_FUDESC)</td>
                  <td class="colalph">$(V_FPDESC)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select SYPORT.*, ", stmtSQL)
  @dtw_concat(stmtSQL, " ifnull(FUDESC,' ') as FUDESC, ifnull(FUDESCU,' ') as FUDESCU  ", stmtSQL)
  @dtw_concat(fileSQL, " SYPORT ", fileSQL)
  @dtw_concat(fileSQL, " left join SYURLM on FPID=FUID ", fileSQL)
  %if (wildCardSearch!="")
      @dtw_concat(selectSQL, " FPPORT <>' ' ", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @List_Export_Query(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) List_Export_Query (IN CHAR(64)    profileHandle,
                                         CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @XMLBeginTag("PortalList")
          %ROW{
	       @XMLIDTag("$(V_FPPORT)/$(V_FPPAGE)/$(V_FPSEQ)", "Portal ID")
                  @XMLTag(V_FPPORT, "Portal")
                  @XMLTag(V_FPPAGE, "Page")
                  @XMLTag(V_FPSEQ, "Sequence")
                  @XMLTag(V_FPDESC, "Description")
                  @XMLTag(V_FPID, "URLId")
                  @XMLTag(V_FPTITL, "URL_Title")
              @XMLEndTag("Portal")
	       %}
      @XMLEndTag("PortalList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "FPPORT,FPPAGE,FPSEQ")
          @DTW_ASSIGN(orderByDisplay, "Portal, Page, Sequence")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit ()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Portal")
      %if (orderBy == "FPPORT,FPPAGE,FPSEQ")
          @DTW_ASSIGN(orderBy, "FPPORT DESC,FPPAGE,FPSEQ")
          @DTW_ASSIGN(orderByDisplay, "Portal (descending), Page, Sequence")
      %else
          @DTW_ASSIGN(orderBy, "FPPORT,FPPAGE,FPSEQ")
          @DTW_ASSIGN(orderByDisplay, "Portal, Page, Sequence")
      %endif
  %elseif (sequence == "Page")
      %if (orderBy == "FPPAGE,FPPORT,FPSEQ")
          @DTW_ASSIGN(orderBy, "FPPAGE DESC,FPPORT,FPSEQ")
          @DTW_ASSIGN(orderByDisplay, "Page (descending), Portal, Sequence")
      %else
          @DTW_ASSIGN(orderBy, "FPPAGE,FPPORT,FPSEQ")
          @DTW_ASSIGN(orderByDisplay, "Page (descending), Portal, Sequence")
      %endif
  %elseif (sequence == "Sequence")
      %if (orderBy == "FPSEQ,FPPORT,FPPAGE")
          @DTW_ASSIGN(orderBy, "FPSEQ DESC,FPPORT,FPPAGE")
          @DTW_ASSIGN(orderByDisplay, "Sequence (descending), Portal, Page")
      %else
          @DTW_ASSIGN(orderBy, "FPSEQ,FPPORT,FPPAGE")
          @DTW_ASSIGN(orderByDisplay, "Sequence, Portal, Page")
      %endif
  %elseif (sequence == "URLID")
      %if (orderBy == "FPID,FPPORT,FPPAGE,FPSEQ")
          @DTW_ASSIGN(orderBy, "FPID DESC,FPPORT,FPPAGE,FPSEQ")
          @DTW_ASSIGN(orderByDisplay, "URL ID (descending), Portal, Page, Sequence")
      %else
          @DTW_ASSIGN(orderBy, "FPID,FPPORT,FPPAGE,FPSEQ")
          @DTW_ASSIGN(orderByDisplay, "URL ID, Portal, Page, Sequence")
      %endif
  %elseif (sequence == "URLDesc")
      %if (orderBy == "FUDESCU,FPPORT,FPPAGE,FPSEQ")
          @DTW_ASSIGN(orderBy, "FUDESCU DESC,FPPORT,FPPAGE,FPSEQ")
          @DTW_ASSIGN(orderByDisplay, "URL ID Description (descending), Portal, Page, Sequence")
      %else
          @DTW_ASSIGN(orderBy, "FUDESCU,FPPORT,FPPAGE,FPSEQ")
          @DTW_ASSIGN(orderByDisplay, "URL ID Description, Portal, Page, Sequence")
      %endif
  %elseif (sequence == "Desc")
      %if (orderBy == "FPDESCU,FPPORT,FPPAGE,FPSEQ")
          @DTW_ASSIGN(orderBy, "FPDESCU DESC,FPPORT,FPPAGE,FPSEQ")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Portal, Page, Sequence")
      %else
          @DTW_ASSIGN(orderBy, "FPDESCU,FPPORT,FPPAGE,FPSEQ")
          @DTW_ASSIGN(orderByDisplay, "Description, Portal, Page, Sequence")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchSeq, 5, 2))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "PORTALMASTERSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Portal</td>
                              @dtw_assign(operNbr, "operPortal")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchPortal" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Page</td>
                              @dtw_assign(operNbr, "operPage")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchPage" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Sequence</td>
                              @dtw_assign(operNbr, "operSeq")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchSeq" size="9" maxlength="9"></td>
                          </tr>

                          <tr><td class="dsphdr">URL ID</td>
                              @dtw_assign(operNbr, "operURL")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchURL" size="20" maxlength="55"></td>
                          </tr>

                          <tr><td class="dsphdr">URL ID Description</td>
                              @dtw_assign(operNbr, "operURLIDDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchURLIDDesc" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Override Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchDesc" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Title</td>
                              @dtw_assign(operNbr, "operTitle")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchTitle" size="20" maxlength="50"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchPortal.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("FPPORT", "Portal", $(srchPortal), "U", operPortal, "A")
  @Build_WildCard ("FPPAGE", "Page", $(srchPage), "U", operPage, "A")
  @Build_WildCard ("FPSEQ", "Sequence", $(srchSeq), "", operSeq, "N")
  @Build_WildCard ("FPID", "URL ID", $(srchURL), "U", operURL, "A")
  @Build_WildCard ("FUDESCU", "URL ID Description", $(srchURLIDDesc), "U", operURLIDDesc, "A")
  @Build_WildCard ("FPDESCU", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("upper(FPTITL)", "Title", $(srchTitle), "U", operTitle, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
