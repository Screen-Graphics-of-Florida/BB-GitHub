%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Fixed Assets Detail"
  d2wName                 = "GLDDDetailFa.d2w"
  d2wVarBase              = "$(genericVarBase)$(glDDVarBase)&amp;glJrnl=@dtw_rurlescseq(glJrnl)&amp;glPer=@dtw_rurlescseq(glPer)&amp;glDate=@dtw_rurlescseq(glDate)&amp;glJrnlSeq=@dtw_rurlescseq(glJrnlSeq)&amp;glJrnlRec=@dtw_rurlescseq(glJrnlRec)&amp;unpostedRRN=@dtw_rurlescseq(unpostedRRN)&amp;glDDSeq=@dtw_rurlescseq(glDDSeq)&amp;glDDAp=@dtw_rurlescseq(glDDAp)&amp;glDDFile=@dtw_rurlescseq(glDDFile)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  acctName                = ""
  balanceIncome           = ""
  currencyUnit            = ""
  currencyType            = ""
  uv_Sql                  = ""
  backHome                = "glDDReport.d2w/REPORT"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <link rel=stylesheet type="text/css" href="$(homeURL)$(homePath)$(GLDDStyleSheet)">
          <script TYPE="text/javascript">
	       %INCLUDE "DateEdit.icl"
	       %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchAmt, 13, 2) &&
                      editNum(document.Search.srchAsset, 12, 0) &&
                      editdate(document.Search.srchBegDeprDate))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- End Of Banner Code -->

          %if (unpostedRRN>"0")
              @dtw_assign(uv_CompanyName, "JFCO")
              @dtw_assign(uv_FacilityName, "JFFAC")
              @dtw_assign(uv_AccountName, "JFACC")
              @dtw_assign(uv_SubaccountName, "JFSUB")
              %INCLUDE "userview.icl"
              @dtw_assign(uv_Sql1, uv_Sql)
          %else
              @dtw_assign(uv_CompanyName, "TDCO")
              @dtw_assign(uv_FacilityName, "TDFAC")
              @dtw_assign(uv_AccountName, "TDACCT")
              @dtw_assign(uv_SubaccountName, "TDSUB")
              %INCLUDE "userview.icl"
              @dtw_assign(uv_Sql1, uv_Sql)
          %endif

          @dtw_assign(uv_CompanyName, "GFCO")
          @dtw_assign(uv_FacilityName, "GFFAC")
          @dtw_assign(uv_AccountName, "GFACCT")
          @dtw_assign(uv_SubaccountName, "GFSUB")
          @dtw_assign(uv_SiteName, "AMSITE")
          @dtw_assign(uv_PropertyTypeName, "AMPROP")
          @dtw_assign(uv_FamilyCodeName, "AMFMCD")
          %INCLUDE "userview.icl"
          @dtw_assign(uv_Sql2, uv_Sql)

          <table $(contentTable)>
              <tr><td>
                  <table $(contentTable)>
                      <colgroup>
                          <col width="80%">
                          <col width="15%">
                      <tr><td><h1>$(page_title)</h1></td>
                          %if (formatToPrint != "Y")
                              <td class="toolbar">
                                  %if (ddReport!="")
                                      <a href="$(homeURL)$(cGIPath)GLDDReport.d2w/REPORT$(genericVarBase)$(glDDVarBase)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))" title="Return To Drill Down Report">$(portalHome)</a>
                                  %endif
                                  <a href="$(homeURL)$(cGIPath)$(d2wName)/ENTRY$(d2wVarBase)&amp;formatToPrint=Y" target=_blank>$(formatPrintDesc)</a>
                                  %INCLUDE "HelpPage.icl"
                              </td>
                          %endif
                      </tr>

                      %if (uv_Sql != "")
                         <tr><td><h3> You may not be authorized to view some transactions </h3></td></tr>
                      %endif
                  </table>

                  $(inquiryhrTagAttr)

                  @dtw_assign(SAVE_ROW_NUM, START_ROW_NUM)
                  @dtw_assign(SAVE_MAX_ROWS, RPT_MAX_ROWS)
                  @dtw_assign(START_ROW_NUM, "1")
                  @dtw_assign(RPT_MAX_ROWS, "9999")

                  %if (unpostedRRN>"0")
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_assign(uv_Sql, uv_Sql1)
                      @dtw_assign(appendUserView, "")
                      @dtw_assign(appendWildCard, "N")
                      @dtw_concat(stmtSQL, "SELECT HDFATR.*, ", stmtSQL)
                      @dtw_concat(stmtSQL, " ifnull(CFCFNM,' ') as CFCFNM, ifnull(CFCURT,' ') as CFCURT, ", stmtSQL)
                      @dtw_concat(stmtSQL, " ifnull(CHCHDS,' ') as CHCHDS, ifnull(CHACSG,' ') as CHACSG, ", stmtSQL)
                      @dtw_concat(stmtSQL, " ifnull(FLDESC,' ') as FLDESC,  upper(ifnull(FLDESC,' ')) as FLDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " ifnull(CYDESC,' ') as CYDESC,  upper(ifnull(CYDESC,' ')) as CYDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " HDFATR ", fileSQL)
                      @dtw_concat(fileSQL, " left join HDCFAC on CFCO#=JFCO and CFFAC#=JFFAC", fileSQL)
                      @dtw_concat(fileSQL, " left join HDCHRT on CHACCT=JFACC and CHSUB=JFSUB", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG on FLTYPE='USAGE' and FLVALU=CHACSG ", fileSQL)
                      @dtw_concat(fileSQL, " left join HDCTYP on CYTYPE=CFCURT ", fileSQL)
                      @dtw_concat(selectSQL, " RRN(HDFATR)=$(unpostedRRN) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @UnpJrnlHdg_Query(profileHandle, dataBaseID, stmtSQL)
                      @dtw_assign(START_ROW_NUM, SAVE_ROW_NUM)
                      @dtw_assign(RPT_MAX_ROWS, SAVE_MAX_ROWS)
                  %else
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_assign(uv_Sql, uv_Sql1)
                      @dtw_assign(appendUserView, "")
                      @dtw_assign(appendWildCard, "N")
                      @dtw_concat(stmtSQL, "SELECT * ", stmtSQL)
                      @dtw_concat(fileSQL, " GLTRDT ", fileSQL)
                      @dtw_concat(selectSQL, " TDJRNL='$(glJrnl)' and TDPER#=$(glPer) and TDTDTE=$(glDate) and TDJSEQ=$(glJrnlSeq) ", selectSQL)
                      @dtw_concat(selectSQL, " and TDREC=$(glJrnlRec) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " order by TDJRNL  ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @JrnlHdg_Query(profileHandle, dataBaseID, stmtSQL)
                      @dtw_assign(START_ROW_NUM, SAVE_ROW_NUM)
                      @dtw_assign(RPT_MAX_ROWS, SAVE_MAX_ROWS)
                  %endif

                  %INCLUDE "stmtSQLClear.icl"
                  @dtw_assign(uv_Sql, uv_Sql2)
                  @dtw_assign(appendUserView, "")
                  @dtw_assign(appendWildCard, "")
                  @dtw_concat(stmtSQL, "SELECT FAGLDD.*, FLDESC, ", stmtSQL)
                  @dtw_concat(stmtSQL, " upper(GFDESC) as GFDESCU,  ", stmtSQL)
                  @dtw_concat(stmtSQL, " ifnull(SMDESC,' ') as SMDESC, upper(ifnull(SMDESC,' ')) as SMDESCU, ", stmtSQL)
                  @dtw_concat(stmtSQL, " ifnull(ACLONM,' ') as ACLONM, upper(ifnull(ACLONM,' ')) as ACLONMU, ", stmtSQL)
                  @dtw_concat(stmtSQL, " ifnull(PTDESC,' ') as PTDESC, upper(ifnull(PTDESC,' ')) as PTDESCU ", stmtSQL)
                  @dtw_concat(fileSQL, " FAGLDD ", fileSQL)
                  @dtw_concat(fileSQL, " left join SYFLAG on FLTYPE='FAFEED' and FLVALU=GFRPTS ", fileSQL)
                  @dtw_concat(fileSQL, " left join FASCHD on SMSCHD=GFSCHD ", fileSQL)
                  @dtw_concat(fileSQL, " left join FASITE on ACLOCN=GFSITE ", fileSQL)
                  @dtw_concat(fileSQL, " left join FAPROP on PTTYPE=GFPROP ", fileSQL)
                  @dtw_concat(selectSQL, " GFPER#=$(glPer) and GFDDSQ=$(glDDSeq) ", selectSQL)
                  %INCLUDE "stmtSQLSelect.icl"
                  @dtw_concat(stmtSQL, " ORDER BY $(orderBy) ", stmtSQL)
                  %INCLUDE "stmtSQLEnd.icl"
                  %INCLUDE "stmtSQLTotalRows.icl"
                  @List_Query(profileHandle, dataBaseID, stmtSQL)
              </td></tr>
          </table>

          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) JrnlHdg_Query (IN  CHAR(64) profileHandle,
                                      CHAR(2)   dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (sql_Record_Count == "0")
          @DTW_EXIT()
      %endif

      %ROW{
          <table $(contentTable)>
              <tr><th class="colhdr">Reference</th>
                  <th class="colhdr">Co/Fac</th>
                  <th class="colhdr">Name</th>
                  <th class="colhdr">Account</th>
                  <th class="colhdr">Account Name</th>
                  <th class="colhdr">Usage</th>
                  %if (V_HDMCRL > "0")
                      <th class="colhdr">Cur</th>
                  %endif
                  <th class="colhdr">Amount</th>
                  <th class="colhdr">Description</th>
              </tr>

              @dtw_assign(coNumber, V_TDCO)
              @dtw_assign(facNumber, V_TDFAC)
              @dtw_assign(accountNumber, V_TDACCT)
              @dtw_assign(subAccount, V_TDSUB)
              @dtw_assign(fromPer, V_TDPER#)
              @dtw_assign(toPer, V_TDPER#)
              @dtw_assign(incUnposted, "N")
              @Retrieve_AcctJrnl_Data(profileHandle,
                                     dataBaseID,
                                     coNumber,
                                     facNumber,
                                     accountNumber,
                                     subAccount,
                                     fromPer,
                                     toPer,
                                     incUnposted,
                                     acctName,
                                     coFacName,
                                     balanceIncome,
                                     currencyUnit,
                                     currencyType,
                                     beginBal)

              @Format_CoFac("$(V_TDCO)", "$(V_TDFAC)", "", F_CoFac)
              @Format_Acct("$(V_TDACCT)", "$(V_TDSUB)", "", F_AcctSub)
              @Format_Nbr($(V_TDAMT), F_TDAMT, "2", $(amtEditCode), "Y", "", "")

              %INCLUDE "SetRowClass.icl"

              <tr class="$(rowClass)">
                  <td class="colalph">$(V_TDREF)</td>
                  <td class="colnmbr">$(F_CoFac)</td>
                  <td class="colalph">$(coFacName)</td>
                  <td class="colnmbr">$(F_AcctSub)</td>
                  <td class="colalph">$(acctName)</td>
                  <td class="colalph">$(currencyUnit)</td>
                  %if (V_HDMCRL > "0")
                      <td class="colalph">$(currencyType)</td>
                  %endif
                  <td class="colnmbr">$(F_TDAMT)</td>
                  <td class="colalph">$(V_TDDESC)</td>
              </tr>
          </table>
          <br>
      %}
  %}
%}

%FUNCTION(dtw_sql) UnpJrnlHdg_Query (IN  CHAR(64) profileHandle,
                                         CHAR(2)   dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (sql_Record_Count == "0")
          @DTW_EXIT()
      %endif

      %ROW{
          <table $(contentTable)>
              <tr><th class="colhdr">Reference</th>
                  <th class="colhdr">Co/Fac</th>
                  <th class="colhdr">Name</th>
                  <th class="colhdr">Account</th>
                  <th class="colhdr">Account Description</th>
                  <th class="colhdr">Usage</th>
                  %if (V_HDMCRL > "0")
                      <th class="colhdr">Cur</th>
                  %endif
                  <th class="colhdr">Amount</th>
                  <th class="colhdr">Description</th>
              </tr>

              @Format_Acct("$(V_JFACC)", "$(V_JFSUB)", "", F_AcctSub)
              @Format_Nbr($(V_JFAMT), F_JFAMT, "2", $(amtEditCode), "Y", "", "")
              @Format_CoFac("$(V_JFCO)", "$(V_JFFAC)", "", F_CoFac)
              %INCLUDE "SetRowClass.icl"

              <tr class="$(rowClass)">
                  <td class="colalph">$(V_JFREF)</td>
                  <td class="colnmbr">$(F_CoFac)</td>
                  <td class="colalph">$(V_CFCFNM)</td>
                  <td class="colnmbr">$(F_AcctSub)</td>
                  <td class="colalph">$(V_CHCHDS)</td>
                  <td class="colnmbr" $(helpCursor)><span title="$(V_CHACSG)">$(V_FLDESC)</span></td>
                  %if (V_HDMCRL > "0")
                      <td class="colnmbr" $(helpCursor)><span title="$(V_CFCURT)">$(V_CYDESC)</span></td>
                  %endif
                  <td class="colnmbr">$(F_JFAMT)</td>
                  <td class="colalph">$(V_JFDESC)</td>
              </tr>
          </table>
          <br>
      %}
  %}
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64) profileHandle,
                                   CHAR(2)   dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Amount</th>
                      <th class="colhdr">Asset</th>
                      <th class="colhdr">Asset<br>Description</th>
                      <th class="colhdr">Property<br>Type</th>
                      <th class="colhdr">Begin<br>Depr<br>Date</th>
                      <th class="colhdr">Site<br>Name</th>
                  </tr>
                  <tr>
                      <td><input type="text" class="inputnmbr"  name="srchAmt" size="12" maxlength="15">
                          <input type="hidden" name="operAmt" value="=">
                      </td>
                      <td><input type="text" class="inputnmbr"  name="srchAsset" size="12" maxlength="12">
                          <input type="hidden" name="operAsset" value="=">
                      </td>
                      <td><input type="text" class="inputalph" name="srchAssetDescr" size="10" maxlength="60">
                          <input type="hidden" name="operAssetDescr" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchProperty" size="10" maxlength="30">
                          <input type="hidden" name="operProperty" value="LIKE">
                      </td>
                      <td><input type="text" class="inputnmbr"  name="srchBegDeprDate" size="6" maxlength="6">
                          <input type="hidden" name="operBegDeprDate" value="=">
                      </td>
                      <td><input type="text" class="inputalph" name="srchSiteName" size="10" maxlength="26">
                          <input type="hidden" name="operSiteName" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchAmt.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          @dtw_assign(headOnce, "")

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %if (headOnce == "")
                  @dtw_assign(headOnce, "Y")
                  <tr>
                      @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                      @OrderBy_Sort("GFAMT", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Amount" title="Sequence By Amount, Site, Asset"> Amount</a></th>
                      @OrderBy_Sort("GFRPTS", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=TransType" title="Sequence By Transaction Type, Site, Asset"> Trans<br>Type</a></th>
                      @OrderBy_Sort("GFASST", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Asset" title="Sequence By Asset, Site"> Asset</a></th>
                      @OrderBy_Sort("GFDESCU", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=AssetDescr" title="Sequence By Asset Description, Site, Asset"> Asset<br>Description</a></th>
                      @OrderBy_Sort("PTDESCU", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PropType" title="Sequence By Property Type, Site, Asset"> Property Type</a></th>
                      %if (V_GFRPTS == "RET")
                          @OrderBy_Sort("GFFPCD", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=RetireCode" title="Sequence By Retirement Code, Site, Asset"> Retire<br>Code</a></th>
                          @OrderBy_Sort("GFRTDT", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=RetireDate" title="Sequence By Retirement Date, Site, Asset"> Retirement<br>Date</a></th>
                          @OrderBy_Sort("GFRRES", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=RetireReason" title="Sequence By Retirement Reason, Site, Asset"> Retirement<br>Reason</a></th>
                      %endif
                      %if (V_GFRPTS == "TRF" && V_GFTRFG == "F")
                          @OrderBy_Sort("GFFPCD", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=TrfCode" title="Sequence By Transfer Code, Site, Asset"> Transfer<br>Code</a></th>
                          @OrderBy_Sort("GFRTDT", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=TrfDate" title="Sequence By Transfer Date, Site, Asset"> Transfer<br>Date</a></th>
                          @OrderBy_Sort("GFTSIT", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=TrfToAsset" title="Sequence By Transfer To Asset, Site, Asset"> Transfer To<br>Asset</a></th>
                      %endif
                      %if (V_GFRPTS == "TRF")
                          @OrderBy_Sort("GFTFPD", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=TrfPeriod" title="Sequence By Transfer Period, Site, Asset"> Transfer<br>Period</a></th>
                      %endif
                      %if (V_GFRPTS == "TRF" && V_GFTRFG == "T")
                          @OrderBy_Sort("GFTSIT", sortVar)
                          <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=TrfFrAsset" title="Sequence By Transfer From Asset, Site, Asset"> Transfer From<br>Asset</a></th>
                      %endif
                      @OrderBy_Sort("GFBDDT", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=BeginDeprDate" title="Sequence By Begin Depr Date, Site, Asset">Begin<br>Depr<br>Date</a></th>
                      @OrderBy_Sort("GFLFYY", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Life" title="Sequence By Life, Site, Asset">Life</a></th>
                      @OrderBy_Sort("GFDPCD", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DeprMeth" title="Sequence By Depreciation Method, Site, Asset"> Depr<br>Meth</a></th>
                      @OrderBy_Sort("GFPER#", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DeprPeriod" title="Sequence By Depreciation Period, Site, Asset">Depr<br>Period</a></th>
                      @OrderBy_Sort("ACLONMU", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=SiteName" title="Sequence By Site Name, Asset"> Site<br>Name</a></th>
                      @OrderBy_Sort("SMDESCU", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Schedule" title="Sequence By Schedule Name, Site, Asset">Schedule</a></th>
                 </tr>
              %endif

              %INCLUDE "SetRowClass.icl"

              @dtw_assign(SV_GFPER#, V_GFPER#)
              @PeriodFromCYP(V_GFRTPD)
              @PeriodFromCYP(V_GFTFPD)
              @PeriodFromCYP(V_GFPER#)
              @Format_Nbr($(V_GFAMT), F_GFAMT, "2", $(amtEditCode), "Y", "", "")
              @Format_Date(V_GFRTDT, "D", F_GFRTDT)
              @Format_Date(V_GFBDDT, "D", F_GFBDDT)

              <tr class="$(rowClass)">
                  <td class="colnmbr"><a href="$(homeURL)$(cGIPath)GLDDFAAssetDetail.d2w/ENTRY$(genericVarBase)$(glDDVarBase)&amp;backHome=@dtw_rurlescseq(backHome)&amp;siteNumber=@dtw_rurlescseq(V_GFSITE)&amp;assetNumber=@dtw_rurlescseq(V_GFASST)&amp;scheduleNumber=@dtw_rurlescseq(V_GFSCHD)&amp;ddRptRef=@dtw_rurlescseq(V_GFRPTS)&amp;deprPeriod=@dtw_rurlescseq(SV_GFPER#)&amp;glJrnl=@dtw_rurlescseq(V_GFJRNL)&amp;glDDSeq=@dtw_rurlescseq(glDDSeq)" title="View Asset Drill Down History For Transaction">$(F_GFAMT)</a></td>
                  <td class="colcode" $(helpCursor)><span title="$(V_FLDESC)">$(V_GFRPTS)</span></td>
                  <td class="colnmbr"><a href="$(homeURL)$(cGIPath)GLDDFAAssetDetail.d2w/ENTRY$(genericVarBase)$(glDDVarBase)&amp;backHome=@dtw_rurlescseq(backHome)&amp;siteNumber=@dtw_rurlescseq(V_GFSITE)&amp;assetNumber=@dtw_rurlescseq(V_GFASST)&amp;scheduleNumber=@dtw_rurlescseq(V_GFSCHD)&amp;glJrnl=@dtw_rurlescseq(V_GFJRNL)&amp;glDDSeq=@dtw_rurlescseq(glDDSeq)" title="View Asset Drill Down History">$(V_GFASST)</a></td>
                  @RtvFldDesc("AMSITE=$(V_GFSITE) and AMASST=$(V_GFASST)", "FAMSTR", "Char(Count(*))", recordsHave)
                  %if (recordsHave>"0")
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)FAAssetSelect.d2w/ENTRY$(genericVarBase)$(glDDVarBase)&amp;backHome=@dtw_rurlescseq(backHome)&amp;siteNumber=@dtw_rurlescseq(V_GFSITE)&amp;assetNumber=@dtw_rurlescseq(V_GFASST)&amp;scheduleNumber=@dtw_rurlescseq(V_GFSCHD)&amp;glJrnl=@dtw_rurlescseq(V_GFJRNL)&amp;glDDSeq=@dtw_rurlescseq(glDDSeq)" title="View Asset">$(V_GFDESC)</a></td>
                  %else
                      <td class="colnmbr">$(V_GFDESC)</td>
                  %endif
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)FAPropertyInquiry.d2w/DISPLAY$(genericVarBase)&amp;propertyType=@dtw_rurlescseq(V_GFPROP)" onclick="$(inquiryWinVar)" title="Property Type Quickview">$(V_PTDESC)</a></td>
                  %if (V_GFRPTS == "RET")
                      <td class="colcode">$(V_GFFPCD)</td>
                      <td class="coldate">$(F_GFRTDT)</td>
                      <td class="colalph">$(V_GFRRES)</td>
                  %endif
                  %if (V_GFRPTS == "TRF" && V_GFTRFG == "F")
                      <td class="colcode">$(V_GFFPCD)</td>
                      <td class="coldate">$(F_GFRTDT)</td>
                      <td class="colnmbr">$(V_GFTSIT)-$(V_GFTAST)</td>
                  %endif
                  %if (V_GFRPTS == "TRF")
                      <td class="colnmbr">$(V_GFTFPD)</td>
                  %endif
                  %if (V_GFRPTS == "TRF" && V_GFTRFG == "T")
                      <td class="colnmbr">$(V_GFTSIT)-$(V_GFTAST)</td>
                  %endif
                  <td class="coldate">$(F_GFBDDT)</td>
                  <td class="colnmbr">$(V_GFLFYY)/$(V_GFLFMM)</td>
                  <td class="colcode"><a href="$(homeURL)$(cGIPath)FADeprMethodInquiry.d2w/DISPLAY$(genericVarBase)&amp;deprMethod=@dtw_rurlescseq(V_GFDPCD)" onclick="$(inquiryWinVar)" title="Depreciation Method Quickview">$(V_GFDPCD)</a></td>
                  <td class="colnmbr">$(V_GFPER#)</td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)FASiteInquiry.d2w/DISPLAY$(genericVarBase)&amp;siteNumber=@dtw_rurlescseq(V_GFSITE)" onclick="$(inquiryWinVar)" title="Site Quickview">$(V_ACLONM)</a></td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)FAScheduleInquiry.d2w/DISPLAY$(genericVarBase)&amp;scheduleNumber=@dtw_rurlescseq(V_GFSCHD)" onclick="$(inquiryWinVar)" title="Schedule Quickview">$(V_SMDESC)</a></td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(inquiryhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "GFRPTS,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Transaction Type, Site, Asset")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Amount")
      %if (orderBy == "GFAMT,GFSITE,GFASST")
          @DTW_ASSIGN(orderBy, "GFAMT DESC,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Amount (descending), Site, Asset")
      %else
          @DTW_ASSIGN(orderBy, "GFAMT,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Amount, Site, Asset")
      %endif
  %elseif (sequence == "TransType")
      %if (orderBy == "GFRPTS,GFSITE,GFASST")
          @DTW_ASSIGN(orderBy, "GFRPTS DESC,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Transaction Type (descending), Site, Asset")
      %else
          @DTW_ASSIGN(orderBy, "GFRPTS,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Transaction Type, Site, Asset")
      %endif
  %elseif (sequence == "Asset")
      %if (orderBy == "GFASST,GFSITE")
          @DTW_ASSIGN(orderBy, "GFASST DESC,GFSITE")
          @DTW_ASSIGN(orderByDisplay, "Asset (descending), Site")
      %else
          @DTW_ASSIGN(orderBy, "GFASST,GFSITE")
          @DTW_ASSIGN(orderByDisplay, "Asset, Site")
      %endif
  %elseif (sequence == "AssetDescr")
      %if (orderBy == "GFDESCU,GFSITE,GFASST")
          @DTW_ASSIGN(orderBy, "GFDESCU DESC,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Asset Description (descending), Site, Asset")
      %else
          @DTW_ASSIGN(orderBy, "GFDESCU,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Asset Description, Site, Asset")
      %endif
  %elseif (sequence == "PropType")
      %if (orderBy == "PTDESCU,GFSITE,GFASST")
          @DTW_ASSIGN(orderBy, "PTDESCU DESC,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Property Type (descending), Site, Asset")
      %else
          @DTW_ASSIGN(orderBy, "PTDESCU,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Property Type, Site, Asset")
      %endif
  %elseif (sequence == "RetireCode")
      %if (orderBy == "GFFPCD,GFSITE,GFASST")
          @DTW_ASSIGN(orderBy, "GFFPCD DESC,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Retirement Code (descending), Site, Asset")
      %else
          @DTW_ASSIGN(orderBy, "GFFPCD,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Retirement Code, Site, Asset")
      %endif
  %elseif (sequence == "RetireDate")
      %if (orderBy == "GFRTDT,GFSITE,GFASST")
          @DTW_ASSIGN(orderBy, "GFRTDT DESC,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Retirement Date (descending), Site, Asset")
      %else
          @DTW_ASSIGN(orderBy, "GFRTDT,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Retirement Date, Site, Asset")
      %endif
  %elseif (sequence == "RetireReason")
      %if (orderBy == "GFRRES,GFSITE,GFASST")
          @DTW_ASSIGN(orderBy, "GFRRES DESC,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Retirement Reason (descending), Site, Asset")
      %else
          @DTW_ASSIGN(orderBy, "GFRRES,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Retirement Reason, Site, Asset")
      %endif
  %elseif (sequence == "TrfCode")
      %if (orderBy == "GFFPCD,GFSITE,GFASST")
          @DTW_ASSIGN(orderBy, "GFFPCD DESC,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Transfer Code (descending), Site, Asset")
      %else
          @DTW_ASSIGN(orderBy, "GFFPCD,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Transfer Code, Site, Asset")
      %endif
  %elseif (sequence == "TrfDate")
      %if (orderBy == "GFRTDT,GFSITE,GFASST")
          @DTW_ASSIGN(orderBy, "GFRTDT DESC,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Transfer Date (descending), Site, Asset")
      %else
          @DTW_ASSIGN(orderBy, "GFRTDT,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Transfer Date, Site, Asset")
      %endif
  %elseif (sequence == "TrfToAsset")
      %if (orderBy == "GFTSIT,GFTAST,GFSITE,GFASST")
          @DTW_ASSIGN(orderBy, "GFTSIT DESC,GFTAST DESC,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Transfer To Asset (descending), Site, Asset")
      %else
          @DTW_ASSIGN(orderBy, "GFTSIT,GFTAST,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Transfer To Asset, Site, Asset")
      %endif
  %elseif (sequence == "TrfPeriod")
      %if (orderBy == "GFTFPD,GFSITE,GFASST")
          @DTW_ASSIGN(orderBy, "GFTFPD DESC,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Transfer Period (descending), Site, Asset")
      %else
          @DTW_ASSIGN(orderBy, "GFTFPD,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Transfer Period, Site, Asset")
      %endif
  %elseif (sequence == "TrfFrAsset")
      %if (orderBy == "GFTSIT,GFTAST,GFSITE,GFASST")
          @DTW_ASSIGN(orderBy, "GFTSIT DESC,GFTAST DESC,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Transfer From Asset (descending), Site, Asset")
      %else
          @DTW_ASSIGN(orderBy, "GFTSIT,GFTAST,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Transfer From Asset, Site, Asset")
      %endif
  %elseif (sequence == "BeginDeprDate")
      %if (orderBy == "GFBDDT,GFSITE,GFASST")
          @DTW_ASSIGN(orderBy, "GFBDDT DESC,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Begin Depr Date (descending), Site, Asset")
      %else
          @DTW_ASSIGN(orderBy, "GFBDDT,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Begin Depr Date, Site, Asset")
      %endif
  %elseif (sequence == "Life")
      %if (orderBy == "GFLFYY,GFLFMM,GFSITE,GFASST")
          @DTW_ASSIGN(orderBy, "GFLFYY DESC,GFLFMM DESC,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Life (descending), Site, Asset")
      %else
          @DTW_ASSIGN(orderBy, "GFLFYY,GFLFMM,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Life, Site, Asset")
      %endif
  %elseif (sequence == "DeprMeth")
      %if (orderBy == "GFDPCD,GFSITE,GFASST")
          @DTW_ASSIGN(orderBy, "GFDPCD DESC,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Depreciation Method (descending), Site, Asset")
      %else
          @DTW_ASSIGN(orderBy, "GFDPCD,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Depreciation Method, Site, Asset")
      %endif
  %elseif (sequence == "DeprPeriod")
      %if (orderBy == "GFPER#,GFSITE,GFASST")
          @DTW_ASSIGN(orderBy, "GFPER# DESC,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Depreciation Period (descending), Site, Asset")
      %else
          @DTW_ASSIGN(orderBy, "GFPER#,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Depreciation Period, Site, Asset")
      %endif
  %elseif (sequence == "SiteName")
      %if (orderBy == "ACLONMU,GFASST")
          @DTW_ASSIGN(orderBy, "ACLONMU DESC,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Site Name (descending), Asset")
      %else
          @DTW_ASSIGN(orderBy, "ACLONMU,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Site Name, Asset")
      %endif
  %elseif (sequence == "Schedule")
      %if (orderBy == "SMDESCU,GFSITE,GFASST")
          @DTW_ASSIGN(orderBy, "SMDESCU DESC,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Schedule Name (descending), Site, Asset")
      %else
          @DTW_ASSIGN(orderBy, "SMDESCU,GFSITE,GFASST")
          @DTW_ASSIGN(orderByDisplay, "Schedule Name, Site, Asset")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <link rel=stylesheet type="text/css" href="$(homeURL)$(homePath)$(GLDDStyleSheet)">
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              %INCLUDE "calendar.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchAmt, 13, 2) &&
                      editNum(document.Search.srchAsset, 12, 0) &&
                      editdate(document.Search.srchBegDeprDate) &&
                      editdate(document.Search.srchAcqDate) &&
                      editNum(document.Search.srchLife, 2, 0) &&
                      editNum(document.Search.srchPeriod, 4, 0) &&
                      editNum(document.Search.srchSite, 3, 0) &&
                      editNum(document.Search.srchSched, 2, 0))
                       return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td>
                      %INCLUDE "SearchPageTitle.icl"
                      $(inquiryhrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Amount</td>
                              @dtw_assign(operNbr, "operAmt")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchAmt" size="15" maxlength="15"></td>
                          </tr>

                          <tr><td class="dsphdr">Transaction Type</td>
                              @dtw_assign(operNbr, "operTransType")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchTransType" size="3" maxlength="3"></td>
                          </tr>

                          <tr><td class="dsphdr">Asset</td>
                              @dtw_assign(operNbr, "operAsset")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchAsset" size="12" maxlength="12"></td>
                          </tr>

                          <tr><td class="dsphdr">Asset Description</td>
                              @dtw_assign(operNbr, "operAssetDescr")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchAssetDescr" size="20" maxlength="60"></td>
                          </tr>

                          <tr><td class="dsphdr">Property Type</td>
                              @dtw_assign(operNbr, "operProperty")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchProperty" size="30" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Begin Depreciation Date</td>
                              @dtw_assign(operNbr, "operBegDeprDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchBegDeprDate" size="6" maxlength="6"><a href="javascript:calWindow('srchBegDeprDate');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">Acquisition Date</td>
                              @dtw_assign(operNbr, "operAcqDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchAcqDate" size="6" maxlength="6"><a href="javascript:calWindow('srchAcqDate');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">Life</td>
                              @dtw_assign(operNbr, "operLife")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchLife" size="2" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Depreciation Method</td>
                              @dtw_assign(operNbr, "operDeprMeth")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDeprMeth" size="2" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Depreciation Period</td>
                              @dtw_assign(operNbr, "operPeriod")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchPeriod" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">Site</td>
                              @dtw_assign(operNbr, "operSite")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchSite" size="3" maxlength="3"></td>
                          </tr>

                          <tr><td class="dsphdr">Site Name</td>
                              @dtw_assign(operNbr, "operSiteName")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchSiteName" size="26" maxlength="26"></td>
                          </tr>

                          <tr><td class="dsphdr">Schedule</td>
                              @dtw_assign(operNbr, "operSched")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchSched" size="2" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Schedule Description</td>
                              @dtw_assign(operNbr, "operSchedDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchSchedDesc" size="30" maxlength="30"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchAmt.focus();
                          </script>
                      </form>
                      $(inquiryhrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("GFAMT", "Amount", $(srchAmt), "", $(operAmt), "N")
  @Build_WildCard ("GFRPTS", "Transaction Type", $(srchTransType), "U", $(operTransType), "A")
  @Build_WildCard ("GFASST", "Asset", $(srchAsset), "", $(operAsset), "N")
  @Build_WildCard ("upper(GFDESC)", "Asset Description", $(srchAssetDescr), "U", $(operAssetDescr), "A")
  @Build_WildCard ("upper(PTDESC)", "Property Type", $(srchProperty), "U", $(operProperty), "A")
  @Build_WildCard ("GFBDDT", "Begin Depreciation Date", $(srchBegDeprDate), "", $(operBegDeprDate), "D")
  @Build_WildCard ("GFAQDT", "Acquisition Date", $(srchAcqDate), "", $(operAcqDate), "D")
  @Build_WildCard ("GFLFYY", "Life", $(srchLife), "", $(operLife), "N")
  @Build_WildCard ("GFDPCD", "Depreciation Method", $(srchDeprMeth), "U", $(operDeprMeth), "A")
  @PeriodToCYP(srchPeriod)
  @Build_WildCard ("GFPER#", "Depreciation Period", $(srchPeriod), "", $(operPeriod), "N")
  @Build_WildCard ("GFSITE", "Site", $(srchSite), "", $(operSite), "N")
  @Build_WildCard ("upper(ACLONM)", "Site Name", $(srchSiteName), "U", $(operSiteName), "A")
  @Build_WildCard ("GFSCHD", "Schedule", $(srchSched), "", $(operSched), "N")
  @Build_WildCard ("upper(SMDESC)", "Schedule Description", $(srchSchedDesc), "U", $(operSchedDesc), "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
