%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Import Row Type Maintenance"
  d2wName                 = "MapImportRecordTypeMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;importKey=@dtw_rurlescseq(importKey)&amp;passedImportTable=@dtw_rurlescseq(passedImportTable)&amp;fromImportTable=@dtw_rurlescseq(fromImportTable)&amp;fromImportRecordType=@dtw_rurlescseq(fromImportRecordType)&amp;fromD2w=@dtw_rurlescseq(fromD2w)&amp;updRecNbr=@dtw_rurlescseq(updRecNbr)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;importTable=@dtw_rurlescseq(importTable)&amp;importRecordType=@dtw_rurlescseq(importRecordType)&amp;maintenanceCode=D"
  programName             = "HSYIRM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	

  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              function confirmDelete() {return confirm("$(delRecordConf)")}
              function validate(chgForm) {
                  if (document.Chg.importTable.value =="" ||
                      document.Chg.importRecordTypeDescription.value =="")
                         {alert("$(reqFieldError)"); return false;}
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "MAPIMPORTRECTYPEMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " SYMIRT ", fileSQL)
                          @dtw_concat(selectSQL, " FRIMKY=$(importKey) and FRIFIL='$(importTable)' and FRRTYP='$(importRecordType)' ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      <table $(contentTable)>
          @RtvFldDesc("FHIMKY=$(importKey)", "SYMIHD", "FHDESC", V_FHDESC)
          @RtvFldDesc("FHIMKY=$(importKey)", "SYMIHD", "CHAR(FHMPKY)", V_FHMPKY)
          @Format_Header("Import Definition", $(V_FHDESC), $(importKey))

          @RtvFldDesc("MHMPKY=$(V_FHMPKY)", "SYMMHD", "MHDESC", V_MHDESC)
          @RtvFldDesc("MHMPKY=$(V_FHMPKY)", "SYMMHD", "MHWPGM", V_MHWPGM)
          @Format_Header("Map Definition", $(V_MHDESC), $(V_MHWPGM))
      </table>
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          %ROW {
              %if (passedImportTable != "")
                  @dtw_assign(specificTable, passedImportTable)
                  @dtw_assign(V_FRIFIL, passedImportTable)
              %else
                  @RtvFldDesc("FFIMKY=$(importKey)", "SYMITB", "CHAR(COUNT(*))", recCount)
                  %if (recCount == "1")
                      @RtvFldDesc("FFIMKY=$(importKey)", "SYMITB", "MAX(FFIFIL)", specificTable)
                      @dtw_assign(V_FRIFIL, specificTable)
                  %else
                      @dtw_assign(specificTable, "")
                  %endif
              %endif

              %if (errFound != "" || maintenanceCode == "A")
                  %if (errFound == "" && maintenanceCode == "A")
                      @dtw_assign(edtVar, "")
                      @dtw_assign(focusField, "importTable")
                  %else
                      @dtw_assign(focusField, "")
                      @EdtVarErr(profileHandle, typeValue, edtVar)
                      @ErrVarErr(profileHandle, typeError, errVar)
                      @DecatErr_Field("@@ifil", "importTable")                  @dtw_assign(Err_FRIFIL, fieldValue)
                      @DecatErr_Field("@@rtyp", "importRecordType")             @dtw_assign(Err_FRRTYP, fieldValue)
                      @DecatErr_Field("@@desc", "importRecordTypeDescription")  @dtw_assign(Err_FRDESC, fieldValue)
                      @DecatErr_Field("@@mfil", "interfaceTable")               @dtw_assign(Err_FRMFIL, fieldValue)
                  %endif

                  %if (specificTable == "")
                      @Decat_Field("@@ifil")   @dtw_assign(V_FRIFIL, fieldValue)
                  %endif
                  @Decat_Field("@@rtyp")   @dtw_assign(V_FRRTYP, fieldValue)
                  @Decat_Field("@@desc")   @dtw_assign(V_FRDESC, fieldValue)
                  @Decat_Field("@@mfil")   @dtw_assign(V_FRMFIL, fieldValue)

                  %if (errFound == "" && maintenanceCode == "A")
                      %if (specificTable == "")
                          @dtw_assign(focusField, "importTable")
                      %else
                          @dtw_assign(focusField, "importRecordType")
                      %endif
                  %endif
                  @dtw_assign(errFound, "")

              %elif (maintenanceCode == "Z")
                  %if (specificTable == "")
                      @dtw_assign(focusField, "importTable")
                  %else
                      @dtw_assign(focusField, "importRecordType")
                  %endif
              %else
                  @dtw_assign(focusField, "importRecordTypeDescription")
              %endif

              <table $(contentTable)>
                  @RtvFldDesc("FFIMKY=$(importKey) and FFIFIL='$(V_FRIFIL)'", "SYMITB", "FFDESC", fieldDesc)
                  @SetTextOvr(Err_FRIFIL)
                  <tr><td class="dsphdr"><span $(textOvr)>Import Table</span></td>
                      %if ((maintenanceCode == "A" || maintenanceCode == "Z") && specificTable == "")
                          <td class="inputalph"><input type="text" name="importTable" value="$(V_FRIFIL)" size="10" maxlength="10">
                                                <a href="$(homeURL)$(cGIPath)MapImportTableSearch.d2w/REPORT$(d2wVarBase)&amp;specificImportKey=@dtw_rurlescseq(importKey)&amp;docName=Chg&amp;fldName=importTable&amp;fldDesc=importTableDesc" onclick="$(searchWinVar)">$(reqFieldChar) $(searchImage)</a>
                                                <input type="text" disabled name="importTableDesc" value="$(fieldDesc)" size="30"></td>
                      %else
                          <td class="inputalph"><input type="hidden" name="importTable" value="$(V_FRIFIL)">$(V_FRIFIL) $(fieldDesc)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_FRIFIL)

                  %if (specificTable != "")
                      @RtvFldDesc("FFIMKY=$(importKey) and FFIFIL='$(specificTable)'", "SYMITB", "char(FFRTLN)", V_FFRTLN)
                  %else
                      @RtvFldDesc("FFIMKY=$(importKey) ", "SYMITB", "Char(Max(FFRTLN))", V_FFRTLN)
                  %endif
                  @SetTextOvr(Err_FRRTYP)
                  <tr><td class="dsphdr"><span $(textOvr)>Row Type</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input type="text" name="importRecordType" value="$(V_FRRTYP)" size="10" maxlength="$(V_FFRTLN)"></td>
                      %else
                          <td class="inputalph"><input type="hidden" name="importRecordType" value="$(V_FRRTYP)">$(V_FRRTYP)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_FRRTYP)

                  @SetTextOvr(Err_FRDESC)
                  <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input type="text" name="importRecordTypeDescription" value="$(V_FRDESC)" size="50" maxlength="50">$(reqFieldChar)</td>
                  </tr>
                  @DspErrMsg(Err_FRDESC)

                  @RtvFldDesc("MFMPKY=$(V_FHMPKY) and MFMFIL='$(V_FRMFIL)'", "SYMMTB", "MFDESC", fieldDesc)
                  @SetTextOvr(Err_FRMFIL)
                  <tr><td class="dsphdr"><span $(textOvr)>Primary Interface Table</span></td>
                      <td class="inputalph"><input type="text" name="interfaceTable" value="$(V_FRMFIL)" size="10" maxlength="10">
                                            <a href="$(homeURL)$(cGIPath)MapTableSearch.d2w/REPORT$(genericVarBase)&amp;specificMapKey=@dtw_rurlescseq(V_FHMPKY)&amp;docName=Chg&amp;fldName=interfaceTable&amp;fldDesc=interfaceTableDesc" onclick="$(searchWinVar)">$(searchImage)</a>
                                            <input type="text" disabled name="interfaceTableDesc" value="$(fieldDesc)" size="30"></td>
                  </tr>
                  @DspErrMsg(Err_FRMFIL)
              </table>
          %}

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>
      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HSYIRM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  %if (importRecordTypeDescription == "")
      @RtvFldDesc("FRIMKY=$(importKey) and FRIFIL='$(importTable)' and FRRTYP='$(importRecordType)' ", "SYMIRT", "FRDESC", importRecordTypeDescription)
  %endif

  @dtw_mUPPERCASE(importTable)
  @dtw_mUPPERCASE(importRecordType)
  @dtw_mUPPERCASE(interfaceTable)

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@frm1", fromImportTable)
  @Concat_Field("@@frm2", fromImportRecordType)
  @Concat_Field("@@imky", importKey)
  @Concat_Field("@@ifil", importTable)
  @Concat_Field("@@rtyp", importRecordType)
  @Concat_Field("@@desc", importRecordTypeDescription)
  @Concat_Field("@@mfil", interfaceTable)
  @dtw_concat(edtVar, "}{", edtVar)
  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, $(importRecordTypeDescription), "$(importTable)-$(importRecordType)", "", "", "", "", confMessage)
      %if (maintenanceCode == "D" || fromD2w == "MapImportRecordType.d2w")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)MapImportRecordType.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          %if (passedImportTable != "")
              @dtw_assign(passedImportTable, "")
              @dtw_assign(passedRecordType, "")
          %endif
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(fromD2w)/REPORT$(d2wVarBase)&amp;passedImportTable=@dtw_rurlescseq(importTable)&amp;passedRecordType=@dtw_rurlescseq(importRecordType)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@ifil", "importTable")
      @Format_ConfMsg_Desc("", $(importRecordTypeDescription), "$(importTable)-$(importRecordType)", "<br>$(fieldValue)", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)MapImportRecordType.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;importTable=@dtw_rurlescseq(importTable)&amp;importRecordType=@dtw_rurlescseq(importRecordType)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
