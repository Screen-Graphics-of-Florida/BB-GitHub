%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Software Updates By ID"
  d2wName                 = "SoftwareUpdate.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=$(d2wName)/REPORT&amp;showInstalled=@dtw_rurlescseq(showInstalled)&amp;showUnInstalled=@dtw_rurlescseq(showUnInstalled)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  hasReadMeTableChanges   = "ReadMe, Table Changes"

%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
	       %INCLUDE "numedit.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchProblemID, 6, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "SOFTWAREMGMTPROB")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select b.PIPRID as PLPRID, b.PICLRL as PLCLRL, b.PIRFSH as PLRFSH, b.PIPRFS as PLPRFS , b.PITSTP as PLTSTP, b.PIPRDS as PLPRDS, b.PIPRDSU as PLPRDSU,'         ' as Status", stmtSQL)
                      @dtw_concat(stmtSQL, " , case when (PRPRID is not null) then 'ReadMe' else ' ' end as hasReadMe ", stmtSQL)
                      @dtw_concat(stmtSQL, " , case when (select Count(*) from SUPRCN where POPRID=b.PIPRID and (POSRCF='QSQLSRC' or (POSRCF='QDDSSRC' and POSRCM in ('SIMLBE','SIMLBD','PRSTAD','PRSTTXE')))) > 0 then 'Table Changes' else ' ' end as hasTableChanges ", stmtSQL)
			    @dtw_concat(stmtSQL, " from SUPRID_D b left join suredm on prprid=b.piprid and prredm<>' ' ", stmtSQL)
			    @dtw_concat(fileSQL, " SUPRID_D ", fileSQL)
                      @dtw_concat(stmtSQL, " where b.PIPRID not in (select c.plprid from SUPRLG c) ", stmtSQL)
                      @dtw_replace(wildCardSearch, "@@", "PI", wildCardSearch2)
                      @dtw_replace(wildCardSearch2, "SUPRID", "PIPRID", wildCardSearch2)
                      %if (showUnInstalled != "Y")
                          @dtw_concat(wildCardSearch2, " and PIPRID=0 ", wildCardSearch2)
                      %endif
                      @dtw_concat(stmtSQL, wildCardSearch2, stmtSQL)
                      @dtw_assign(stmtSQL2, stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"

                      @dtw_concat(selectSQL, " PIPRID not in (select d.plprid from SUPRLG d) ", selectSQL)
                      @dtw_concat(selectSQL, wildCardSearch2, selectSQL)
                      @RtvFldDesc("$(selectSQL)", "$(fileSQL)", "char(count(*))", sql_Record_Count)
                      @dtw_assign(sql_Record_Count2, sql_Record_Count)

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select a.PLPRID, a.PLCLRL, a.PLRFSH, a.PLPRFS, a.PLTSTP, a.PLPRDS, upper(a.PLPRDS) as UPLPRDSU,'Installed' as Status", stmtSQL)
                      @dtw_concat(stmtSQL, " , case when (PRPRID is not null) then 'ReadMe' else ' ' end as hasReadMe", stmtSQL)
                      @dtw_concat(stmtSQL, " , case when (select Count(*) from SUPRCN where POPRID=a.PLPRID and (POSRCF='QSQLSRC' or (POSRCF='QDDSSRC' and POSRCM in ('SIMLBE','SIMLBD','PRSTAD','PRSTTXE')))) > 0 then 'Table Changes' else ' ' end as hasTableChanges ", stmtSQL)
			    @dtw_concat(stmtSQL, " from SUPRLG a left join suredm on prprid=a.plprid and prredm<>' ' ", stmtSQL)
			    @dtw_concat(fileSQL, " SUPRLG ", fileSQL)
                      @dtw_concat(stmtSQL, "WHERE a.PLPRID<>0 ", stmtSQL)
                      @dtw_replace(wildCardSearch, "@@", "PL", wildCardSearch1)
                      %if (showInstalled != "Y")
                           @dtw_concat(wildCardSearch1, " and a.PLPRID = 0 ", wildCardSearch1)
                      %endif
                      @dtw_concat(stmtSQL, wildCardSearch1, stmtSQL)
                      @dtw_assign(stmtSQL1, stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @dtw_concat(selectSQL, " plprid <> 0  ", selectSQL)
                      @dtw_concat(selectSQL, wildCardSearch1, selectSQL)
                      @RtvFldDesc("$(selectSQL)", "$(fileSQL)", "char(count(*))", sql_Record_Count)
                      @dtw_assign(sql_Record_Count1, sql_Record_Count)

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, stmtSQL1, stmtSQL)
                      @dtw_concat(stmtSQL, " UNION ", stmtSQL)
                      @dtw_concat(stmtSQL, stmtSQL2, stmtSQL)
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      @dtw_add(sql_Record_Count1, sql_Record_Count2, sql_Record_Count)
                      %INCLUDE "stmtSQLEnd.icl"
                      @ProblemID_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) ProblemID_Query (IN CHAR(64)    profileHandle,
                                       CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")

                  <td class="toolbar">

                      %INCLUDE "downLoadProblemFiles.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"

                  </td>
              %endif
          </tr>
      </table>

      %INCLUDE "ConfMessageDisplay.icl"
      @RtvFldDesc("PIPRID=0", "SUPRID_D", "(PIPRDS)", downloadError)
      %if (downloadError != " ")
          $(downloadError)
      %endif
           

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Software Update Description</th>
                      <th class="colhdr">Software<br>Update</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchDesc" size="30" maxlength="30">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td align=center><input type="text" class="inputnmbr" name="srchProblemID" size="6" maxlength="6">
                          <input type="hidden" name="operProblemID" value="=">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>
          %if (showInstalled == "Y")
              @dtw_assign(showInstalledOnlyChecked, "CHECKED")
          %else
              @dtw_assign(showInstalledOnlyChecked, "")
          %endif
          %if (showUnInstalled == "Y")
              @dtw_assign(showUnInstalledOnlyChecked, "CHECKED")
          %else
              @dtw_assign(showUnInstalledOnlyChecked, "")
          %endif
          @dtw_assign(viewCheckBox, "SoftwareUpdate")
          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("@@PRID", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=IDNumber" title="Sequence By Software Update">Software Update</a></th>
              @OrderBy_Sort("@@PRDSU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description" title="Sequence By Software Update Description, Software Update"> Software Update Description</a></th>
              @OrderBy_Sort("@@CLRL", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CPP" title="Sequence By Control Panel Release"> Control Panel Release</a></th>
              @OrderBy_Sort("@@RFSH", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Refresh" title="Sequence By Refresh Level, Software Update"> Refresh Level</a></th>
              @OrderBy_Sort("@@PRFS", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PointRefresh" title="Sequence By Point Refresh, Software Update"> Point Refresh</a></th>
              @OrderBy_Sort("@@TSTP", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Date" title="Sequence By Date Installed, Software Update"> Date  Installed</a></th>
              <th class="colhdr">Notification</th>


			
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colnmbr">$(V_PlPRID)</td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)SoftwareUpdateSelect.d2w/REPORT$(d2wVarBase)&amp;problemIDNumber=@dtw_rurlescseq(V_PLPRID)&amp;problemDescription=@dtw_rurlescseq(V_PLPRDS)" title="View Software Update">$(V_PLPRDS)</a></td>
                  <td class="colnmbr">$(V_PLCLRL)</td>
                  <td class="colnmbr">$(V_PLRFSH)</td>
                  <td class="colnmbr">$(V_PLPRFS)</td>
                  %if (V_STATUS == "Installed")
                      <td class="colcode">$(V_PLTSTP)</td>
                  %else
                      <td class="colcode">   </td>
                  %endif
		 	%if (V_hasReadMe == "ReadMe" && V_hasTableChanges == "Table Changes")
				<td class="colcode">ReadMe,Table Changes</td>
			%elseif (V_hasReadMe == "ReadMe")
			      <td class="colcode">$(V_hasReadMe)</td>
			%elseif (V_hasTableChanges == "Table Changes")
				<td class="colcode">$(V_hasTableChanges)</td>
			%endif
      	               
              </tr>
          %}
      </table>
          %INCLUDE "PageBottom.icl"
          %INCLUDE "WildCardPrint.icl"
          $(hrTagAttr)
          %INCLUDE "Copyright.icl"
  %}
%}

%HTML(REPORT) {

  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"

  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "PLPRID")
          @DTW_ASSIGN(orderByDisplay, "IDNumber")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      %if (showInstalled == "Y" && showInstalledOnly == "Y")
          @dtw_assign(showInstalled, "")
      %else
          @dtw_assign(showInstalled, "Y")
      %endif
      %if (showUnInstalled == "Y" && showUnInstalledOnly == "Y")
          @dtw_assign(showUnInstalled, "")
      %else
          @dtw_assign(showUnInstalled, "Y")
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "IDNumber")
      %if (orderBy == "PLPRID")
          @DTW_ASSIGN(orderBy, "PLPRID DESC")
          @DTW_ASSIGN(orderByDisplay, "Software Update (descending)")
      %else
          @DTW_ASSIGN(orderBy, "PLPRID")
          @DTW_ASSIGN(orderByDisplay, "Software Update")
      %endif
  %elif (sequence == "Description")
      %if (orderBy == "PLPRDS,PLPRID")
          @DTW_ASSIGN(orderBy, "PLPRDS DESC,PLPRID")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Software Update")
      %else
          @DTW_ASSIGN(orderBy, "PLPRDS,PLPRID")
          @DTW_ASSIGN(orderByDisplay, "Description, Software Update")
      %endif
  %elif (sequence == "CPP")
      %if (orderBy == "PLCLRL,PLPRID")
          @DTW_ASSIGN(orderBy, "PLCLRL DESC,PLPRID")
          @DTW_ASSIGN(orderByDisplay, "CPP Release (descending), Software Update")
      %else
          @DTW_ASSIGN(orderBy, "PLCLRL,PLPRID")
          @DTW_ASSIGN(orderByDisplay, "CPP Release, Software Update")
      %endif
  %elif (sequence == "Refresh")
      %if (orderBy == "PLRFSH,PLPRID")
          @DTW_ASSIGN(orderBy, "PLRFSH DESC,PLPRID")
          @DTW_ASSIGN(orderByDisplay, "Refresh Level (descending), Software Update")
      %else
          @DTW_ASSIGN(orderBy, "PLRFSH,PLPRID")
          @DTW_ASSIGN(orderByDisplay, "Refresh Level, Software Update")
      %endif
  %elif (sequence == "PointRefresh")
      %if (orderBy == "PLPRFS,PLPRID")
          @DTW_ASSIGN(orderBy, "PLPRFS DESC,PLPRID")
          @DTW_ASSIGN(orderByDisplay, "Point Refresh (descending), Software Update")
      %else
          @DTW_ASSIGN(orderBy, "PLPRFS,PLPRID")
          @DTW_ASSIGN(orderByDisplay, "Point Refresh, Software Update")
      %endif
  %elif (sequence == "Date")
      %if (orderBy == "PLTSTP,PLPRID")
          @DTW_ASSIGN(orderBy, "PLTSTP DESC,PLPRID")
          @DTW_ASSIGN(orderByDisplay, "Date Installed (descending), Software Update")
      %else
          @DTW_ASSIGN(orderBy, "PLTSTP,PLPRID")
          @DTW_ASSIGN(orderByDisplay, "Date Installed, Software Update")
      %endif
  


  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"

  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
	          %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchProblemID, 6, 0) &&
                      editNum(document.Search.srchReqRefresh, 6, 0) &&
                      editNum(document.Search.srchPointRefresh, 3, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "SOFTWAREMGMT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      @RtvFldDesc("PRCLRL>0", "SUPRCT", "char(PRCLRL)", releaseLevel)
                      @RtvFldDesc("PRCLRL>0", "SUPRCT", "char(PRCLLL)", libraryLevel)
                      %while(@dtw_rlength(libraryLevel) != "3") {@dtw_insert("0", libraryLevel, libraryLevel)%}
                      @RtvFldDesc("PRCLRL>0", "SUPRCT", "char(PRRFSH)", requiredRefresh)

                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Software Update</td>
                              @dtw_assign(operNbr, "operProblemID")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchProblemID" size="6" maxlength="6"></td>
                          </tr>

                          <tr><td class="dsphdr">Software Update Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDesc" size="30" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Required Refresh Level</td>
                              @dtw_assign(operNbr, "operReqRefresh")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchReqRefresh" size="6" maxlength="6"></td>
                          </tr>

                          <tr><td class="dsphdr">Point Refresh</td>
                              @dtw_assign(operNbr, "operPointRefresh")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchPointRefresh" size="3" maxlength="3"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchProblemID.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("@@PRID", "Software Update", $(srchProblemID), "", operProblemID, "N")
  @Build_WildCard ("upper(@@PRDS)", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("@@RFSH", "Required Refresh Level", $(srchReqRefresh), "", operReqRefresh, "N")
  @Build_WildCard ("@@PRFS", "Point Refresh Number", $(srchPointRefresh), "", operPointRefresh, "N")
  @Build_WildCard ("@@RFS", "Included In Refresh", $(srchIncludeRefresh), "", operIncludeRefresh, "N")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
%FUNCTION(dtw_directcall) Download_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) errVar)
{%EXEC {HSUDLP_W.PGM %}
%}

%HTML(Get_Data) {
  %INCLUDE "setLibraryList.icl"

  @Download_Data(profileHandle, errFound, errVar)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, $(skipFile), $(comment), "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)SoftwareUpdate.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase);errFound=@dtw_rurlescseq(errFound)">
  %endif
%}
