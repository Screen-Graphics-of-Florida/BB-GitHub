%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "A/P Check Reconciliation Report"
  d2wName                 = "APCheckReconciliationReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "dateedit.icl"
              %INCLUDE "calendar.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "NumZero.icl"
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "NewWindowOpen.icl"
              function validate(chgForm) {
                  if (document.Chg.bank.value =="")
                     {alert("$(reqFieldError)"); return false;}
                  if (editdate(document.Chg.checkDate) &&
                      editZero(document.Chg.bank, 2, 0))
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "CHECKRECONCILIATION")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
                      %INCLUDE "RequiredField.icl"
            			
                      <form class="formClass" METHOD=POST NAME="Chg" onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;submitSchedule=@dtw_rurlescseq(submitSchedule)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "bank")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@bnk@", "bank")        @dtw_assign(Err_N1BNK,  fieldValue)
                                  @DecatErr_Field("@@codt", "checkDate")        @dtw_assign(Err_N1CODT,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}

                                  @Decat_Field("@@bnk@")   @dtw_assign(V_N1BNK,  fieldValue)
                                  @Decat_Field("@@codt")   @dtw_assign(V_N1CODT,  fieldValue)
                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                              %endif
                              @Default_Zero(V_N1BNK)
                              @RtvFldDesc("BKBANK=$(V_N1BNK)", "HDBANK", "BKBKNM", fieldDesc)
                              @SetTextOvr(Err_N1BNK)
                              <tr><td class="dsphdr"><span $(textOvr)>Bank</span></td>
                                  <td class="inputnmbr"><input type="text" name="bank" value="$(V_N1BNK)" size="6" maxlength="2">
                                                        <a href="$(homeURL)$(phpPath)BankSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=bank&amp;fldDesc=bankName" onclick="$(searchWinVar)">$(reqFieldChar) $(searchImage)</a>
                                                        <input type="text" disabled name="bankName" value="$(fieldDesc)" size="30"></td>
                              </tr>
                              @DspErrMsg(Err_N1BNK)

                              @SetTextOvr(Err_N1CODT)
                              <tr><td class="dsphdr"><span $(textOvr)>Check Date Cutoff</span></td>
                                  <td class="inputnmbr"><input type="text" name="checkDate" VALUE="$(V_N1CODT)" size="6" maxlength="6">
                                                        <a href="javascript:calWindow('checkDate');">$(calendarImage)</a></td>
                              </tr>
                              @DspErrMsg(Err_N1CODT)
                          </table>
                          @dtw_assign(envProgram, "CAPPCR")
                          @dtw_assign(envPrinter, "")
                          %INCLUDE "schedulejob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                            	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HAPPCP_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(checkDate,@dtw_rstrip(checkDate))
  @dtw_assign(bank,@dtw_rstrip(bank))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@bnk@", bank)
  @Concat_Field("@@codt", checkDate)
  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}