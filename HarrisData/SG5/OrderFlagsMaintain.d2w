%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Order Flags Maintenance"
  d2wName                 = "OrderFlagsMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;orderType=@dtw_rurlescseq(orderType)&amp;orderApplication=@dtw_rurlescseq(orderApplication)&amp;description=@dtw_rurlescseq(description)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;flagNumber=@dtw_rurlescseq(flagNumber)&amp;flagDesc=@dtw_rurlescseq(flagDesc)&amp;maintenanceCode=D"
  programName             = "HHDOFU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              function validate(chgForm) {
                  if (document.Chg.flagDesc.value =="" ||
                      document.Chg.flagOpt01.value =="")
                     {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.flagNumber, 2, 0))
                      return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "ORDERFLAGSMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select FGAPID, FGORTY, FGFGFG, FGFGDS, SUBSTR(FGFGOP,1,1) as FGOP01, SUBSTR(FGFGOP,2,1) as FGOP02, SUBSTR(FGFGOP,3,1) as FGOP03, SUBSTR(FGFGOP,4,1) as FGOP04, SUBSTR(FGFGOP,5,1) as FGOP05, SUBSTR(FGFGOP,6,1) as FGOP06, SUBSTR(FGFGOP,7,1) as FGOP07, SUBSTR(FGFGOP,8,1) as FGOP08, SUBSTR(FGFGOP,9,1) as FGOP09, SUBSTR(FGFGOP,10,1) as FGOP10 From HDORFG Where FGORTY='$(orderType)' and FGAPID='$(orderApplication)' and FGFGFG=$(flagNumber)", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"

      <table $(contentTable)>
          @RtvFldDesc("AIAPID='$(orderApplication)'", "SYAPID", "AIAPDS", apidDesc)
          @Format_Header_URL("Application ID", $(apidDesc), "", "")
          @Format_Header_URL("Order Type", $(description), $(orderType), "")
      </table>

      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          %ROW {
              <table $(contentTable)>
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@apid", "orderApplication")  @dtw_assign(Err_FGAPID, fieldValue)
                          @DecatErr_Field("@@orty", "orderType")         @dtw_assign(Err_FGORTY, fieldValue)
                          @DecatErr_Field("@@fgfg", "flagNumber")        @dtw_assign(Err_FGFGFG, fieldValue)
                          @DecatErr_Field("@@fgds", "flagDesc")          @dtw_assign(Err_FGFGDS, fieldValue)
                          @DecatErr_Field("@@fo01", "flagOpt01")         @dtw_assign(Err_FGOP01, fieldValue)
                          @DecatErr_Field("@@fo02", "flagOpt02")         @dtw_assign(Err_FGOP02, fieldValue)
                          @DecatErr_Field("@@fo03", "flagOpt03")         @dtw_assign(Err_FGOP03, fieldValue)
                          @DecatErr_Field("@@fo04", "flagOpt04")         @dtw_assign(Err_FGOP04, fieldValue)
                          @DecatErr_Field("@@fo05", "flagOpt05")         @dtw_assign(Err_FGOP05, fieldValue)
                          @DecatErr_Field("@@fo06", "flagOpt06")         @dtw_assign(Err_FGOP06, fieldValue)
                          @DecatErr_Field("@@fo07", "flagOpt07")         @dtw_assign(Err_FGOP07, fieldValue)
                          @DecatErr_Field("@@fo08", "flagOpt08")         @dtw_assign(Err_FGOP08, fieldValue)
                          @DecatErr_Field("@@fo09", "flagOpt09")         @dtw_assign(Err_FGOP09, fieldValue)
                          @DecatErr_Field("@@fo10", "flagOpt10")         @dtw_assign(Err_FGOP10, fieldValue)
                      %endif

                      @Decat_Field("@@apid")  @dtw_assign(V_FGAPID, fieldValue)
                      @Decat_Field("@@orty")  @dtw_assign(V_FGORTY, fieldValue)
                      @Decat_Field("@@fgfg")  @dtw_assign(V_FGFGFG, fieldValue)
                      @Decat_Field("@@fgds")  @dtw_assign(V_FGFGDS, fieldValue)
                      @Decat_Field("@@fo01")  @dtw_assign(V_FGOP01, fieldValue)
                      @Decat_Field("@@fo02")  @dtw_assign(V_FGOP02, fieldValue)
                      @Decat_Field("@@fo03")  @dtw_assign(V_FGOP03, fieldValue)
                      @Decat_Field("@@fo04")  @dtw_assign(V_FGOP04, fieldValue)
                      @Decat_Field("@@fo05")  @dtw_assign(V_FGOP05, fieldValue)
                      @Decat_Field("@@fo06")  @dtw_assign(V_FGOP06, fieldValue)
                      @Decat_Field("@@fo07")  @dtw_assign(V_FGOP07, fieldValue)
                      @Decat_Field("@@fo08")  @dtw_assign(V_FGOP08, fieldValue)
                      @Decat_Field("@@fo09")  @dtw_assign(V_FGOP09, fieldValue)
                      @Decat_Field("@@fo10")  @dtw_assign(V_FGOP10, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "flagNumber")
                      %endif

                      @dtw_assign(errFound, "")

                  %else
                      @dtw_assign(focusField, "flagDesc")
                  %endif


                  @SetTextOvr(Err_FGFGFG)
	           <tr><td class="dsphdr"><span $(textOvr)>Flag Number</span></td>
                      %if (maintenanceCode == "A")
                          <td class="inputnmbr"><input name="flagNumber" type="text" value="$(V_FGFGFG)" size="1" maxlength="2">$(reqFieldChar)</td>
                      %else
                          <td class="inputnmbr"><input name="flagNumber" type="hidden" value="$(V_FGFGFG)">$(V_FGFGFG)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_FGFGFG)

                  @SetTextOvr(Err_FGFGDS)
                  <tr><td class="dsphdr"><span $(textOvr)>Description</span></td>
                      <td class="inputalph"><input name="flagDesc" type="text" value="$(V_FGFGDS)" size="35" maxlength="23">$(reqFieldChar)</td>
                  </tr>
                  @DspErrMsg(Err_FGFGDS)
              </table>


              <fieldset class="legendBody">
                  <legend class="legendTitle">Valid Flag Options</legend>
                  <table $(contentTable)>
    	         		
                      @dtw_assign(flagNumber, V_FGFGFG)
                      %while(@dtw_rlength(flagNumber) != "2") {@dtw_insert("0", flagNumber, flagNumber)%}

                      @dtw_assign(fieldDesc, "")
                      %if (V_FGOP01 != "" && V_FGOP01 != " ")
                          @RtvFldDesc("FLTYPE='$(orderApplication)FLAG$(flagNumber)' AND FLVALU='$(V_FGOP01)'", "SYFLAG", "FLDESC", fieldDesc)
                          %if (fieldDesc == "")
                              @dtw_assign(fieldDesc, "Unsupported")
                          %endif
                      %endif
                      @SetTextOvr(Err_FGOP01)
                      <tr><td class="dsphdr"><span $(textOvr)>Default</span></td>
                          <td class="inputalph"><input name="flagOpt01" type="text" value="$(V_FGOP01)" size="1" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=$(orderApplication)FLAG$(flagNumber)&amp;flagSrchHdr=@dtw_rurlescseq("Flag Option")&amp;docName=Chg&amp;fldName=flagOpt01&amp;fldDesc=flagOpt01Desc" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a><input disabled name="flagOpt01Desc" value="$(fieldDesc)" type="text" size="30"></td>
                      </tr>
                      @DspErrMsg(Err_FGOP01)
    	         		
                      @dtw_assign(fieldDesc, "")
                      %if (V_FGOP02 != "" && V_FGOP02 != " ")
                          @RtvFldDesc("FLTYPE='$(orderApplication)FLAG$(flagNumber)' AND FLVALU='$(V_FGOP02)'", "SYFLAG", "FLDESC", fieldDesc)
                          %if (fieldDesc == "")
                              @dtw_assign(fieldDesc, "Unsupported")
                          %endif
                      %endif
                      <tr><td>&nbsp;</td>
                          <td class="inputalph"><input name="flagOpt02" type="text" value="$(V_FGOP02)" size="1" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=$(orderApplication)FLAG$(flagNumber)&amp;flagSrchHdr=@dtw_rurlescseq("Flag Option")&amp;docName=Chg&amp;fldName=flagOpt02&amp;fldDesc=flagOpt02Desc" onclick="$(searchWinVar)"> &nbsp; $(searchImage) </a><input disabled name="flagOpt02Desc" value="$(fieldDesc)" type="text" size="30"></td>
                      </tr>
    	         		
                      @dtw_assign(fieldDesc, "")
                      %if (V_FGOP03 != "" && V_FGOP03 != " ")
                          @RtvFldDesc("FLTYPE='$(orderApplication)FLAG$(flagNumber)' AND FLVALU='$(V_FGOP03)'", "SYFLAG", "FLDESC", fieldDesc)
                          %if (fieldDesc == "")
                              @dtw_assign(fieldDesc, "Unsupported")
                          %endif
                      %endif
                      <tr><td>&nbsp;</td>
                          <td class="inputalph"><input name="flagOpt03" type="text" value="$(V_FGOP03)" size="1" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=$(orderApplication)FLAG$(flagNumber)&amp;flagSrchHdr=@dtw_rurlescseq("Flag Option")&amp;docName=Chg&amp;fldName=flagOpt03&amp;fldDesc=flagOpt03Desc" onclick="$(searchWinVar)"> &nbsp; $(searchImage) </a><input disabled name="flagOpt03Desc" value="$(fieldDesc)" type="text" size="30"></td>
                      </tr>
    	         		
                      @dtw_assign(fieldDesc, "")
                      %if (V_FGOP04 != "" && V_FGOP04 != " ")
                          @RtvFldDesc("FLTYPE='$(orderApplication)FLAG$(flagNumber)' AND FLVALU='$(V_FGOP04)'", "SYFLAG", "FLDESC", fieldDesc)
                          %if (fieldDesc == "")
                              @dtw_assign(fieldDesc, "Unsupported")
                          %endif
                      %endif
                      <tr><td>&nbsp;</td>
                          <td class="inputalph"><input name="flagOpt04" type="text" value="$(V_FGOP04)" size="1" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=$(orderApplication)FLAG$(flagNumber)&amp;flagSrchHdr=@dtw_rurlescseq("Flag Option")&amp;docName=Chg&amp;fldName=flagOpt04&amp;fldDesc=flagOpt04Desc" onclick="$(searchWinVar)"> &nbsp; $(searchImage) </a><input disabled name="flagOpt04Desc" value="$(fieldDesc)" type="text" size="30"></td>
                      </tr>
    	         		
                      @dtw_assign(fieldDesc, "")
                      %if (V_FGOP05 != "" && V_FGOP05 != " ")
                          @RtvFldDesc("FLTYPE='$(orderApplication)FLAG$(flagNumber)' AND FLVALU='$(V_FGOP05)'", "SYFLAG", "FLDESC", fieldDesc)
                          %if (fieldDesc == "")
                              @dtw_assign(fieldDesc, "Unsupported")
                          %endif
                      %endif
                      <tr><td>&nbsp;</td>
                          <td class="inputalph"><input name="flagOpt05" type="text" value="$(V_FGOP05)" size="1" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=$(orderApplication)FLAG$(flagNumber)&amp;flagSrchHdr=@dtw_rurlescseq("Flag Option")&amp;docName=Chg&amp;fldName=flagOpt05&amp;fldDesc=flagOpt05Desc" onclick="$(searchWinVar)"> &nbsp; $(searchImage) </a><input disabled name="flagOpt05Desc" value="$(fieldDesc)" type="text" size="30"></td>
                      </tr>
    	         		
                      @dtw_assign(fieldDesc, "")
                      %if (V_FGOP06 != "" && V_FGOP06 != " ")
                          @RtvFldDesc("FLTYPE='$(orderApplication)FLAG$(flagNumber)' AND FLVALU='$(V_FGOP06)'", "SYFLAG", "FLDESC", fieldDesc)
                          %if (fieldDesc == "")
                              @dtw_assign(fieldDesc, "Unsupported")
                          %endif
                      %endif
                      <tr><td>&nbsp;</td>
                          <td class="inputalph"><input name="flagOpt06" type="text" value="$(V_FGOP06)" size="1" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=$(orderApplication)FLAG$(flagNumber)&amp;flagSrchHdr=@dtw_rurlescseq("Flag Option")&amp;docName=Chg&amp;fldName=flagOpt06&amp;fldDesc=flagOpt06Desc" onclick="$(searchWinVar)"> &nbsp; $(searchImage) </a><input disabled name="flagOpt06Desc" value="$(fieldDesc)" type="text" size="30"></td>
                      </tr>
    	         		
                      @dtw_assign(fieldDesc, "")
                      %if (V_FGOP07 != "" && V_FGOP07 != " ")
                          @RtvFldDesc("FLTYPE='$(orderApplication)FLAG$(flagNumber)' AND FLVALU='$(V_FGOP07)'", "SYFLAG", "FLDESC", fieldDesc)
                          %if (fieldDesc == "")
                              @dtw_assign(fieldDesc, "Unsupported")
                          %endif
                      %endif
                      <tr><td>&nbsp;</td>
                          <td class="inputalph"><input name="flagOpt07" type="text" value="$(V_FGOP07)" size="1" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=$(orderApplication)FLAG$(flagNumber)&amp;flagSrchHdr=@dtw_rurlescseq("Flag Option")&amp;docName=Chg&amp;fldName=flagOpt07&amp;fldDesc=flagOpt07Desc" onclick="$(searchWinVar)"> &nbsp; $(searchImage) </a><input disabled name="flagOpt07Desc" value="$(fieldDesc)" type="text" size="30"></td>
                      </tr>
    	         		
                      @dtw_assign(fieldDesc, "")
                      %if (V_FGOP08 != "" && V_FGOP08 != " ")
                          @RtvFldDesc("FLTYPE='$(orderApplication)FLAG$(flagNumber)' AND FLVALU='$(V_FGOP08)'", "SYFLAG", "FLDESC", fieldDesc)
                          %if (fieldDesc == "")
                              @dtw_assign(fieldDesc, "Unsupported")
                          %endif
                      %endif
                      <tr><td>&nbsp;</td>
                          <td class="inputalph"><input name="flagOpt08" type="text" value="$(V_FGOP08)" size="1" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=$(orderApplication)FLAG$(flagNumber)&amp;flagSrchHdr=@dtw_rurlescseq("Flag Option")&amp;docName=Chg&amp;fldName=flagOpt08&amp;fldDesc=flagOpt08Desc" onclick="$(searchWinVar)"> &nbsp; $(searchImage) </a><input disabled name="flagOpt08Desc" value="$(fieldDesc)" type="text" size="30"></td>
                      </tr>
    	         		
                      @dtw_assign(fieldDesc, "")
                      %if (V_FGOP09 != "" && V_FGOP09 != " ")
                          @RtvFldDesc("FLTYPE='$(orderApplication)FLAG$(flagNumber)' AND FLVALU='$(V_FGOP09)'", "SYFLAG", "FLDESC", fieldDesc)
                          %if (fieldDesc == "")
                              @dtw_assign(fieldDesc, "Unsupported")
                          %endif
                      %endif
                      <tr><td>&nbsp;</td>
                          <td class="inputalph"><input name="flagOpt09" type="text" value="$(V_FGOP09)" size="1" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=$(orderApplication)FLAG$(flagNumber)&amp;flagSrchHdr=@dtw_rurlescseq("Flag Option")&amp;docName=Chg&amp;fldName=flagOpt09&amp;fldDesc=flagOpt09Desc" onclick="$(searchWinVar)"> &nbsp; $(searchImage) </a><input disabled name="flagOpt09Desc" value="$(fieldDesc)" type="text" size="30"></td>
                      </tr>
    	         		
                      @dtw_assign(fieldDesc, "")
                      %if (V_FGOP10 != "" && V_FGOP10 != " ")
                          @RtvFldDesc("FLTYPE='$(orderApplication)FLAG$(flagNumber)' AND FLVALU='$(V_FGOP10)'", "SYFLAG", "FLDESC", fieldDesc)
                          %if (fieldDesc == "")
                              @dtw_assign(fieldDesc, "Unsupported")
                          %endif
                      %endif
                      <tr><td>&nbsp;</td>
                          <td class="inputalph"><input name="flagOpt10" type="text" value="$(V_FGOP10)" size="1" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=$(orderApplication)FLAG$(flagNumber)&amp;flagSrchHdr=@dtw_rurlescseq("Flag Option")&amp;docName=Chg&amp;fldName=flagOpt10&amp;fldDesc=flagOpt10Desc" onclick="$(searchWinVar)"> &nbsp; $(searchImage) </a><input disabled name="flagOpt10Desc" value="$(fieldDesc)" type="text" size="30"></td>
                      </tr>

                  </table>       			
              </fieldset>

          %}

          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HHDOFU_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(orderApplication)
  @dtw_mUPPERCASE(orderType)
  @dtw_mUPPERCASE(flagOpt01)
  @dtw_mUPPERCASE(flagOpt02)
  @dtw_mUPPERCASE(flagOpt03)
  @dtw_mUPPERCASE(flagOpt04)
  @dtw_mUPPERCASE(flagOpt05)
  @dtw_mUPPERCASE(flagOpt06)
  @dtw_mUPPERCASE(flagOpt07)
  @dtw_mUPPERCASE(flagOpt08)
  @dtw_mUPPERCASE(flagOpt09)
  @dtw_mUPPERCASE(flagOpt10)

  @dtw_assign(flagNumber,@dtw_rstrip(flagNumber))

  @dtw_assign(edtVar, "")
  @Concat_Field("@@apid", orderApplication)
  @Concat_Field("@@orty", orderType)
  @Concat_Field("@@fgfg", flagNumber)
  @Concat_Field("@@fgds", flagDesc)
  @Concat_Field("@@fo01", flagOpt01)
  @Concat_Field("@@fo02", flagOpt02)
  @Concat_Field("@@fo03", flagOpt03)
  @Concat_Field("@@fo04", flagOpt04)
  @Concat_Field("@@fo05", flagOpt05)
  @Concat_Field("@@fo06", flagOpt06)
  @Concat_Field("@@fo07", flagOpt07)
  @Concat_Field("@@fo08", flagOpt08)
  @Concat_Field("@@fo09", flagOpt09)
  @Concat_Field("@@fo10", flagOpt10)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "")
      %if (orderApplication != "")
          @RtvFldDesc("AIAPID='$(orderApplication)'", "SYAPID", "AIAPDS", apidDesc)
          @Format_ConfMsg_Desc(maintenanceCode, $(flagDesc), $(flagNumber), "", "", "", "", confMessage)
      %else
          @Format_ConfMsg_Desc(maintenanceCode, $(flagDesc), $(flagNumber), "", "", "", "", confMessage)
      %endif
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)OrderFlags.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@fgfg", "flagNumber")
      @Format_ConfMsg_Desc("", $(flagDesc), $(flagNumber), "<br>$(fieldValue)", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)OrderFlags.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;flagNumber=@dtw_rurlescseq(flagNumber)&amp;flagDesc=@dtw_rurlescseq(flagDesc)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}