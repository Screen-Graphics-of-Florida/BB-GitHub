%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Configuration Header"
  d2wName                 = "ConfigurationHeader.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;plantName=@dtw_rurlescseq(plantName)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HPD023"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  documentType            = "CFG"
  plantNumber             = ""
%}

%FUNCTION(DTW_directcall) Get_Item_Comments(INOUT CHAR(64)     profileHandle,
				                   CHAR(2)      dataBaseID,
                                                  DEC(3,0)     plantNumber,
				      		   CHAR(15)     itemNumber,
                                                  CHAR(5)      configurationType,
                                                  CHAR(5)      configurationID,
				      		   CHAR(3)      documentType,
				                   CHAR(32000)  comment)
{%EXEC {HPDCHN_P.PGM %}
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @dtw_assign(userPass, "")
  %if (plantNumber > "0")
      @PlantUserView(profileHandle, dataBaseID, userPass, plantNumber)
  %endif
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              %INCLUDE "$(headInclude)"
              <script type="text/javascript">
                  function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
                  function confirmRelease(text) {return confirm("OK To Release?" + "\n" + "\n" + text);}
                  %INCLUDE "CheckEnterSearch.icl"
                  %INCLUDE "Menu.js"
                  %INCLUDE "NoFormValidate.icl"
               </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                          @dtw_assign(pageID, "CONFIGURATIONHEADER")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, "Select CHPLT, CHITEM, CHCFGT, CHCFGI, CHCDSC, ", stmtSQL)
                          @dtw_concat(stmtSQL, "CHDATI, CHDATO, CHECN, CHDSGP, CHREL, ", stmtSQL)
                          @dtw_concat(stmtSQL, "upper(CHCDSC) as CHCDSCU, CHUPSM, CHURTG " , stmtSQL)
                          %if (plantNumber == "")
                              @dtw_concat(stmtSQL, " , coalesce(PLNAME,' ') as PLNAME, ", stmtSQL)
                              @dtw_concat(stmtSQL, " coalesce(upper(PLNAME),' ') as PLNAMEU ", stmtSQL)
                          %endif
                          @dtw_concat(fileSQL, " HDCFGH ", fileSQL)
                          %if (plantNumber == "")
                              @dtw_concat(fileSQL, " left join HDPLNT on CHPLT=PLPLNT ", fileSQL)
                          %endif
                          %if (wildCardSearch!="" || plantNumber>"0" || uv_Sql!="")
                              @dtw_concat(selectSQL, "CHITEM>' ' ", selectSQL)
                          %endif
                          %if (plantNumber > "0")
                              @dtw_concat(selectSQL, " and CHPLT=$(plantNumber) ", selectSQL)
                          %endif
                          %INCLUDE "stmtSQLSelect.icl"
                          @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                          %INCLUDE "stmtSQLEnd.icl"
                          %INCLUDE "stmtSQLTotalRows.icl"
                          @ConfigurationHeader_Query(profileHandle, dataBaseID, stmtSQL)
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) ConfigurationHeader_Query (IN  CHAR(64)    profileHandle,
                                                  CHAR(2)     dataBaseID,
                                                  CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (plantNumber > "0")
          @RtvFldDesc("PLPLNT=$(plantNumber)", "HDPLNT", "PLNAME", plantName)
      %endif
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)ConfigurationHeaderMaintain.d2w/MAINTAIN$(genericVarBase)&amp;fromPlant=@dtw_rurlescseq(plantNumber)&amp;fromName=@dtw_rurlescseq(plantName)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %if (sec_07 == "Y")
                          <a href="$(homeURL)$(cGIPath)ConfigurationHeaderMaintain.d2w/COPYSTD$(genericVarBase)&amp;fromPlant=@dtw_rurlescseq(plantNumber)&amp;fromName=@dtw_rurlescseq(plantName)&amp;maintenanceCode=X">$(copyStdImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      %if (plantNumber > "0")
          <table $(contentTable)>
              @Format_Header_URL("Plant", $(plantName), $(plantNumber), "$(homeURL)$(cGIPath)PlantSelect.d2w/REPORT$(d2wVarBase)")
          </table>
      %endif
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint != "Y")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr><th class="colhdr">Item Number</th>
                      <th class="colhdr">Type</th>
                      <th class="colhdr">ID</th>
                      <th class="colhdr">Type Description</th>
                      %if (plantNumber == "")
                          <th class="colhdr">Plant</th>
                      %endif
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchItem" size="10" maxlength="15">
                          <input type="hidden" name="operItem" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchType" size="10" maxlength="5">
                          <input type="hidden" name="operType" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchID" size="10" maxlength="5">
                          <input type="hidden" name="operID" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchDescription" size="10" maxlength="30">
                          <input type="hidden" name="operDescription" value="LIKE">
                      </td>
                      %if (plantNumber == "")
                          <td><input type="text" class="inputnmbr" name="srchPlant" size="10" maxlength="3">
                              <input type="hidden" name="operPlant" value="=">
                          </td>
                      %endif
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchItem.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y" || sec_05 == "Y" || sec_06 == "Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("CHITEM", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Item" title="Sequence By Item Number, Configuration Type, Configuration ID"> Item Number</a></th>
              @OrderBy_Sort("CHCFGT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Type" title="Sequence By Configuration Type, Configuration ID, Item Number"> Type</a></th>
              @OrderBy_Sort("CHCFGI", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ID" title="Sequence By Configuration ID, Configuration Type, Item Number"> ID</a></th>
              @OrderBy_Sort("CHCDSCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description" title="Sequence By Configuration Type Description, Item Number"> Type Description</a></th>
              @OrderBy_Sort("CHECN", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=ECN" title="Sequence By ECN, Item Number, Configuration Type, Configuration ID"> ECN</a></th>
              @OrderBy_Sort("CHDSGP", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Phase" title="Sequence By Desigh Phase, Item Number, Configuration Type, Configuration ID"> Design<br>Phase</a></th>
              @OrderBy_Sort("CHREL", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Release" title="Sequence By Release To Production, Item Number, Configuration Type, Configuration ID"> Release To<br>Production</a></th>
              %if (plantNumber == "")
                  @OrderBy_Sort("CHPLT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PlantNumber" title="Sequence By Plant">Plant</a></th>
                  @OrderBy_Sort("PLNAMEU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PlantName" title="Sequence By Plant Name">Plant Name</a></th>
              %endif
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(genericVarBase)&amp;fromPlant=@dtw_rurlescseq(plantNumber)&amp;fromName=@dtw_rurlescseq(plantName)&amp;plantNumber=@dtw_rurlescseq(V_CHPLT)&amp;itemNumber=@dtw_rurlescseq(V_CHITEM)&amp;configurationType=@dtw_rurlescseq(V_CHCFGT)&amp;configurationID=@dtw_rurlescseq(V_CHCFGI)&amp;configurationTypeDescription=@dtw_rurlescseq(V_CHCDSC)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_CHCDSC), "$(V_CHITEM) / $(V_CHCFGT) / $(V_CHCFGI)", "", "", "", "", confirmDesc)
              @Get_Item_Comments(profileHandle, dataBaseID, V_CHPLT, V_CHITEM, V_CHCFGT, V_CHCFGI, documentType, commentCFG)

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_01=="Y" && sec_04=="Y" || sec_05 == "Y" || sec_06 == "Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)ConfigurationHeaderMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_01=="Y" && sec_04=="Y")
                              <a href="$(homeURL)$(cGIPath)ConfigurationHeaderMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)ConfigurationHeaderMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                          %if (sec_05 == "Y" && V_CHREL != "Y")
                              <a onClick="return confirmRelease('$(confirmDesc)')" href="$(homeURL)$(cGIPath)ConfigurationHeaderMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=R">$(releaseImage)</a>
                          %endif
                          %if (sec_06 == "Y" && V_CHREL == "Y")
                              <a href="$(homeURL)$(cGIPath)ConfigurationHeaderTransfer.d2w/TRANSFER$(maintainVar)&amp;maintenanceCode=T">$(cfgHdrTransImage)</a>
                          %endif
    		           %if (commentCFG != "")
                              <a href="$(homeURL)$(cGIPath)ConfigurationHeaderNotesMaint.d2w/REPORT$(maintainVar)" onclick="$(commentWinVar)">$(commentExistImage)</a>
                          %else
                              <a href="$(homeURL)$(cGIPath)ConfigurationHeaderNotesMaint.d2w/REPORT$(maintainVar)" onclick="$(commentWinVar)">$(commentImage)</a>
                          %endif
                          %if (sec_07 == "Y")
                              <a href="$(homeURL)$(cGIPath)ConfigurationHeaderMaintain.d2w/COPYALL$(maintainVar)&amp;maintenanceCode=X">$(copyAllImageSml)</a>
                          %endif
                          %if ($(V_CHUPSM) == "Y")
                              <a href="$(homeURL)$(cGIPath)AltProductStructure.d2w/REPORT$(maintainVar)">$(altPsmImage)</a>
                          %else
                               &nbsp; &nbsp; &nbsp;
                          %endif
                          %if ($(V_CHURTG) == "Y")
                              <a href="$(homeURL)$(cGIPath)AltRoutings.d2w/REPORT$(maintainVar)">$(altRtgImage)</a>
                          %endif
                      </td>
                  %endif
                  @RtvFldDesc("(FLTYPE='DSGNPHASE' and FLVALU='$(V_CHDSGP)')", "SYFLAG", "FLDESC", dsgpDesc)
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)iteminquiry.d2w/DISPLAY$(maintainVar)" onclick="$(inquiryWinVar)" title="Item Quickview">$(V_CHITEM)</a></td>
                  <td class="colalph">$(V_CHCFGT)</td>
                  <td class="colalph">$(V_CHCFGI)</td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)ConfigurationHeaderSelect.d2w/REPORT$(maintainVar)" title="View Configuration Header">$(V_CHCDSC)</a></td>
                  <td class="colalph">$(V_CHECN)</td>
                  <td class="colcode" $(helpCursor)><span title="$(dsgpDesc)">$(V_CHDSGP)</span></td>
                  <td class="colcode">$(V_CHREL)</td>
                  %if (plantNumber == "")
                      <td class="colnmbr">$(V_CHPLT)</td>
                      <td class="colalph"><a href="$(homeURL)$(cGIPath)PlantSelect.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(V_CHPLT)&amp;plantName=@dtw_rurlescseq(V_PLNAME)" title="View Plant">$(V_PLNAME)</a></td>
                  %endif
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, "Select CHPLT, CHITEM, CHCFGT, CHCFGI, CHCDSC, ", stmtSQL)
  @dtw_concat(stmtSQL, "CHDATI, CHDATO, CHECN, CHDSGP, CHREL, ", stmtSQL)
  @dtw_concat(stmtSQL, "upper(CHCDSC) as CHCDSCU " , stmtSQL)
  %if (plantNumber == "")
      @dtw_concat(stmtSQL, " , coalesce(PLNAME,' ') as PLNAME, ", stmtSQL)
      @dtw_concat(stmtSQL, " coalesce(upper(PLNAME),' ') as PLNAMEU ", stmtSQL)
  %endif
  @dtw_concat(fileSQL, " HDCFGH ", fileSQL)
  %if (plantNumber == "")
      @dtw_concat(fileSQL, " left join HDPLNT on CHPLT=PLPLNT ", fileSQL)
  %endif
  %if (wildCardSearch!="" || plantNumber>"0" || uv_Sql!="")
      @dtw_concat(selectSQL, "CHITEM>' ' ", selectSQL)
  %endif
  %if (plantNumber > "0")
      @dtw_concat(selectSQL, " and CHPLT=$(plantNumber) ", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @ConfigurationHeader_XMLQuery(profileHandle, dataBaseID, stmtSQL)

%}

%FUNCTION(dtw_sql) ConfigurationHeader_XMLQuery (IN  CHAR(64)    profileHandle,
			                                     CHAR(2)     dataBaseID,
                                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("ConfigurationHeaderList")
      %if (plantNumber > "0")
	   @XMLIDTag(plantNumber, "Plant ID")
              @XMLTag(plantNumber, "PlantNumber")
              @XMLTag(plantName, "PlantName")
      %endif		
		
      %ROW{
          @XMLIDTag("$(V_CHITEM)/$(V_CHCFGT)/$(V_CHCFGI)", "Configuration Header")
              @XMLTag(V_CHITEM, "ItemNumber")
              @XMLTag(V_CHCFGT, "ConfigurationType")
              @XMLTag(V_CHCFGI, "ConfigurationID")
              @XMLTag(V_CHCDSC, "ConfigurationTypeDescription")
              @XMLTag(V_CHECN, "ECN")
              @XMLTag(V_CHDSGP, "DesignPhase")
              @XMLTag(V_CHREL, "ReleaseToProduction")
              %if (plantNumber == "")
                  @XMLTag(V_CHPLT, "PlantNumber")
                  @XMLTag(V_PLNAME, "PlantName")
              %endif
          @XMLEndTag("Configuration")
      %}
      %if (plantNumber > "0")
          @XMLEndTag("Plant")
      %endif
      @XMLEndTag("ConfigurationHeaderList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (plantNumber > "0" && orderBy == "PLNAMEU,CHITEM,CHCFGT,CHCFGI")
          @dtw_assign(orderBy, "")
      %endif
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "CHITEM,CHCFGT,CHCFGI")
          @DTW_ASSIGN(orderByDisplay, "Item Number, Configuration Type, Configuration ID")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Item")
      %if (orderBy == "CHITEM,CHCFGT,CHCFGI")
          @DTW_ASSIGN(orderBy, "CHITEM DESC,CHCFGT,CHCFGI")
          @DTW_ASSIGN(orderByDisplay, "Item Number (descending), Configuration Type, Configuration ID")
      %else
          @DTW_ASSIGN(orderBy, "CHITEM,CHCFGT,CHCFGI")
          @DTW_ASSIGN(orderByDisplay, "Item Number, Configuration Type, Configuration ID")
      %endif
  %elif (sequence == "Type")
      %if (orderBy == "CHCFGT,CHCFGI,CHITEM")
          @DTW_ASSIGN(orderBy, "CHCFGT DESC,CHCFGI,CHITEM")
          @DTW_ASSIGN(orderByDisplay, "Configuration Type (descending), Configuration ID, Item Number")
      %else
          @DTW_ASSIGN(orderBy, "CHCFGT,CHCFGI,CHITEM")
          @DTW_ASSIGN(orderByDisplay, "Configuration Type, Configuration ID, Item Number")
      %endif
  %elif (sequence == "ID")
      %if (orderBy == "CHCFGI,CHCFGT,CHITEM")
          @DTW_ASSIGN(orderBy, "CHCFGI DESC,CHCFGT,CHITEM")
          @DTW_ASSIGN(orderByDisplay, "Configuration ID (descending), Configuration Type, Item Number")
      %else
          @DTW_ASSIGN(orderBy, "CHCFGI,CHCFGT,CHITEM")
          @DTW_ASSIGN(orderByDisplay, "Configuration ID, Configuration Type, Item Number")
      %endif
  %elif (sequence == "Description")
      %if (orderBy == "CHCDSCU,CHCFGI,CHITEM")
          @DTW_ASSIGN(orderBy, "CHCDSCU DESC,CHCFGI,CHITEM")
          @DTW_ASSIGN(orderByDisplay, "Configuration Type Description (descending), Configuration ID, Item Number")
      %else
          @DTW_ASSIGN(orderBy, "CHCDSCU,CHCFGI,CHITEM")
          @DTW_ASSIGN(orderByDisplay, "Configuration Type Description, Configuration ID, Item Number")
      %endif
  %elif (sequence == "ECN")
      %if (orderBy == "CHECN,CHITEM,CHCFGT,CHCFGI")
          @DTW_ASSIGN(orderBy, "CHECN DESC,CHITEM,CHCFGT,CHCFGI")
          @DTW_ASSIGN(orderByDisplay, "ECN (descending), Item Number, Configuration Type, Configuration ID")
      %else
          @DTW_ASSIGN(orderBy, "CHECN,CHITEM,CHCFGT,CHCFGI")
          @DTW_ASSIGN(orderByDisplay, "ECN, Item Number, Configuration Type, Configuration ID")
      %endif
  %elif (sequence == "Phase")
      %if (orderBy == "CHDSGP,CHITEM,CHCFGT,CHCFGI")
          @DTW_ASSIGN(orderBy, "CHDSGP DESC,CHITEM,CHCFGT,CHCFGI")
          @DTW_ASSIGN(orderByDisplay, "Design Phase (descending), Item Number, Configuration Type, Configuration ID")
      %else
          @DTW_ASSIGN(orderBy, "CHDSGP,CHITEM,CHCFGT,CHCFGI")
          @DTW_ASSIGN(orderByDisplay, "Design Phase, Item Number, Configuration Type, Configuration ID")
      %endif
  %elif (sequence == "Release")
      %if (orderBy == "CHREL,CHITEM,CHCFGT,CHCFGI")
          @DTW_ASSIGN(orderBy, "CHREL DESC,CHITEM,CHCFGT,CHCFGI")
          @DTW_ASSIGN(orderByDisplay, "Release To Production (descending), Item Number, Configuration Type, Configuration ID")
      %else
          @DTW_ASSIGN(orderBy, "CHREL,CHITEM,CHCFGT,CHCFGI")
          @DTW_ASSIGN(orderByDisplay, "Release To Production, Item Number, Configuration Type, Configuration ID")
      %endif
  %elif (sequence == "PlantNumber")
      %if (orderBy == "CHPLT,CHITEM,CHCFGT,CHCFGI")
          @DTW_ASSIGN(orderBy, "CHPLT DESC,CHITEM,CHCFGT,CHCFGI")
          @DTW_ASSIGN(orderByDisplay, "Plant Number (descending), Item Number, Configuration Type, Configuration ID")
      %else
          @DTW_ASSIGN(orderBy, "CHPLT,CHITEM,CHCFGT,CHCFGI")
          @DTW_ASSIGN(orderByDisplay, "Plant Number, Item Number, Configuration Type, Configuration ID")
      %endif
  %elif (sequence == "PlantName")
      %if (orderBy == "PLNAMEU,CHITEM,CHCFGT,CHCFGI")
          @DTW_ASSIGN(orderBy, "PLNAMEU DESC,CHITEM,CHCFGT,CHCFGI")
          @DTW_ASSIGN(orderByDisplay, "Plant Name (descending), Item Number, Configuration Type, Configuration ID")
      %else
          @DTW_ASSIGN(orderBy, "PLNAMEU,CHITEM,CHCFGT,CHCFGI")
          @DTW_ASSIGN(orderByDisplay, "Plant Name, Item Number, Configuration Type, Configuration ID")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"

  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
	       %INCLUDE "numedit.icl"
              %if (plantNumber == "")
                  function validate(searchForm) {
                      if (editNum(document.Search.srchPlant, 3, 0))
                          return true;
                  }
              %else
                  %INCLUDE "NoFormValidate.icl"
              %endif
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "CONFIGURATIONHEADERSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Item Number</td>
                              @dtw_assign(operNbr, "operItem")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchItem" size="15" maxlength="15"></td>
                          </tr>

                          <tr><td class="dsphdr">Configuration Type</td>
                              @dtw_assign(operNbr, "operType")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchType" size="5" maxlength="5"></td>
                          </tr>

                          <tr><td class="dsphdr">Configuration ID</td>
                              @dtw_assign(operNbr, "operID")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchID" size="5" maxlength="5"></td>
                          </tr>

                          <tr><td class="dsphdr">Configuration Type Description</td>
                              @dtw_assign(operNbr, "operDescription")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDescription" size="30" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">ECN</td>
                              @dtw_assign(operNbr, "operECN")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchECN" size="5" maxlength="5"></td>
                          </tr>

                          <tr><td class="dsphdr">Design Phase</td>
                              @dtw_assign(operNbr, "operPhase")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchPhase" size="1" maxlength="1"></td>
                          </tr>

                          <tr><td class="dsphdr">Release To Production</td>
                              @dtw_assign(operNbr, "operRelease")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchRelease" size="1" maxlength="1"></td>
                          </tr>

                          %if (plantNumber == "")
                              <tr><td class="dsphdr">Plant Number</td>
                                  @dtw_assign(operNbr, "operPlant")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"><input type="text" name="srchPlant" size="5" maxlength="3"></td>
                              </tr>

                              <tr><td class="dsphdr">Plant Name</td>
                                  @dtw_assign(operNbr, "operName")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"> <input type="text" name="srchName" size="30" maxlength="26"></td>
                              </tr>
                          %endif

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchItem.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("CHITEM", "Item Number", $(srchItem), "U", operItem, "A")
  @Build_WildCard ("CHCFGT", "Configuration Type", $(srchType), "U", operType, "A")
  @Build_WildCard ("CHCFGI", "Configuration ID", $(srchID), "U", operID, "A")
  @Build_WildCard ("upper(CHCDSC)", "Description", $(srchDescription), "U", operDescription, "A")
  @Build_WildCard ("CHECN", "ECN", $(srchECN), "", operECN, "A")
  @Build_WildCard ("CHDSGP", "Design Phase", $(srchPhase), "", operPhase, "A")
  @Build_WildCard ("CHREL", "Release To Production", $(srchRelease), "U", operRelease, "A")
  %if (plantNumber == "")
      @Build_WildCard ("CHPLT", "Plant Number", $(srchPlant), "", operPlant, "N")
      @Build_WildCard ("upper(PLNAME)", "Plant Name", $(srchName), "U", operName, "A")
  %endif

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
