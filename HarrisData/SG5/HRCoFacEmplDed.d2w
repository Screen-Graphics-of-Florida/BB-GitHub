%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Employee Deductions"
  d2wName                 = "HRCoFacEmplDed.d2w"
  d2wVarBase              = "$(genericVarBase)$(hrCoFacVarBase)&amp;inclActive=@dtw_rurlescseq(inclActive)&amp;inclTerminated=@dtw_rurlescseq(inclTerminated)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HHREDM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  dedsec_02               = ""
  dedsec_03               = ""
  dedsec_04               = ""
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  inclActive              = ""
  inclTerminated          = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "HrCoFacURL.icl"
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchEmployee, 5, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "COFACEMPLDED")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "UserViewEmpl.icl"
                      %INCLUDE "UserView.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select EDCOMP, EDFACL, EDEMPL, EDDDNO, EDAMT, EDPCT, EDMTHD, EDLIMT, HVDDNM, EMCOMP, EMFACL, EMEMPL, EMPECP, EMPEMP, EMLNAM, EMFNAM, EMMIDI, EMRNAM, EMLNAMU, EMFNAMU, EMDEPT, EMLOC, EMTYPE, EMTRCD ", stmtSQL)
                      @dtw_concat(fileSQL, " HREDED inner join HRDEDM on EDDDNO=HVDDNO  ", fileSQL)
                      @dtw_concat(fileSQL, "        inner join HREMPL on EDCOMP=EMCOMP and EDFACL=EMFACL and EDEMPL=EMEMPL  ", fileSQL)
                      @dtw_concat(selectSQL, " EMCOMP=$(prCompany) and EMFACL=$(prFacility)", selectSQL)
                      %INCLUDE "activeTerminatedEmplSQL.icl"
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @EmployeeDeduction_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) EmployeeDeduction_Query (IN CHAR(64)    profileHandle,
                                        CHAR(2)     dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (sql_Record_Count != "1")
          @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                      @dtw_assign(dedsec_02, "$(sec_02)")
                      @dtw_assign(dedsec_03, "$(sec_03)")
                      @dtw_assign(dedsec_04, "$(sec_04)")
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      <td class="toolbar">
                          %if ((backHome != "$(d2wName)/REPORT") && (backHome != ""))
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                          %endif
                          %INCLUDE "XMLFormat.icl"
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>

              @RetHrCompNam(profileHandle, dataBaseID, prCompany, prFacility, coFacName)
              <tr><td><h2>$(coFacName)</h2></td></tr>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"
          $(hrTagAttr)

          %if (formatToPrint != "Y")
              <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
                  <table $(quickSearchTable)>
                      <tr><th class="colhdr">Last<br>Name</th>
                          <th class="colhdr">Employee<br>Number</th>
                      </tr>
                      <tr><td><input type="text" class="inputalph" name="srchLast" size="18" maxlength="18">
                              <input type="hidden" name="operLast" value="LIKE">
                          </td>
                          <td><input type="text" class="inputalph" name="srchEmployee" size="9" maxlength="9">
                              <input type="hidden" name="operEmployee" value="=">
                          </td>
                          <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                      </tr>
                  </table>
                  <script TYPE="text/javascript">
                      document.Search.srchLast.focus();
                  </script>
              </form>

              %INCLUDE "ActiveTerminatedChecked.icl"
              @dtw_assign(viewCheckBox, "HR")
              %INCLUDE "WildCardPage.icl"
          %endif

          <table $(contentTable)>
              <tr>
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y") && (sec_06 == "Y" || sec_07 == "Y"))
                      <th class="colhdr">$(optionHeading)</th>
                  %endif
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("EDEMPL", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=EmplNumber" title="Sequence By Employee Number, Deduction Number">Employee<br>Number</a></th>

                  @OrderBy_Sort("EMLNAMU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=LastName" title="Sequence By Last Name, First Name, Employee Number, Deduction Number">Name</a></th>

                  @OrderBy_Sort("EMDEPT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Department" title="Sequence By Department, Last Name, First Name, Employee Number, Deduction Number">Dept</a></th>

                  <th class="colhdr">Department<br>Name</th>

                  @OrderBy_Sort("EDDDNO", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DedNumber" title="Sequence By Deduction Number, Employee Number">Deduction<br>Number</a></th>

                  <th class="colhdr">Deduction Name</th>
                  <th class="colhdr">Calculation<br>Method</th>
                  <th class="colhdr">Deduction<br>Amt/Pct</th>
              </tr>
          %INCLUDE "NoRecordsFound.icl"
      %endif

              %ROW{
                  %if (sql_Record_Count == "1")
                      @Save_WebReg(webRegCurFile, profileHandle, d2wName, "", orderBy, orderByDisplay, "")
                      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)EmployeeDedSelect.d2w/report$(d2wVarBase)&amp;prEmployee=@dtw_rurlescseq(V_EDEMPL)&amp;deductionNumber=@dtw_rurlescseq(V_EDDDNO)">
                  %else
                      %INCLUDE "SetRowClass.icl"
                      @Format_EmplName(V_EMFNAM, V_EMLNAM, V_EMMIDI, V_EMRNAM, V_EMTRCD, "D", F_EmpName)
                      @dtw_assign(fromD2w, "$(d2wName)")
                      @dtw_assign(maintainVar, "$(d2wVarBase)&amp;prEmployee=@dtw_rurlescseq(V_EDEMPL)&amp;hrEmployee=@dtw_rurlescseq(V_EMPEMP)&amp;deductionNumber=@dtw_rurlescseq(V_EDDDNO)&amp;fromD2w=@dtw_rurlescseq(fromD2w)")
                      <tr class="$(rowClass)">
                          @dtw_assign(sec_02, "$(dedsec_02)")
                          @dtw_assign(sec_03, "$(dedsec_03)")
                          @dtw_assign(sec_04, "$(dedsec_04)")

                          %if ((sec_06 == "N" && V_EMTYPE == "H") || (sec_07 == "N" && V_EMTYPE != "H"))
                              @dtw_assign(sec_02, "")
                              @dtw_assign(sec_03, "")
                              @dtw_assign(sec_04, "")
                          %endif
                          %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y") && (sec_06 == "Y" || sec_07 == "Y"))
                              %if (dedsec_02 == "N" && dedsec_03 == "N" && dedsec_04 == "N")
                                  <td class="opticon">
                              %else
                                  <td class="opticon">
                                  %if (sec_02 == "Y" || sec_03 == "Y")
                                      <a href="$(homeURL)$(cGIPath)EmplMaintainDed.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                                  %endif
                                  %if (sec_04 == "Y")
                                      <a href="$(homeURL)$(cGIPath)EmplMaintainDed.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                                  %endif
                                  %if (sec_03 == "Y")
                                      <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)EmplMaintainDed.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                                  %endif
                                  </td>
                              %endif
                          %endif
                          <td class="colcode">$(V_EMEMPL)</td>
                          <td class="colalph"><a href="$(homeURL)$(cGIPath)EmployeeDeductions.d2w/report$(d2wVarBase)&amp;prEmployee=@dtw_rurlescseq(V_EDEMPL)&amp;hrEmployee=@dtw_rurlescseq(V_EMPEMP)" title="View All Deductions For This employee">$(F_EmpName)</a></td>
                          <td class="colalph">$(V_EMDEPT)</td>
                          @RtvFldDesc("EADEPT='$(V_EMDEPT)'", "PREXAC", "EANAME", prDeptName)
                          <td class="colalph">$(prDeptName)</td>
                          <td class="colnmbr"><a href="$(homeURL)$(cGIPath)EmployeeDedSelect.d2w/report$(d2wVarBase)&amp;prEmployee=@dtw_rurlescseq(V_EDEMPL)&amp;deductionNumber=@dtw_rurlescseq(V_EDDDNO)" title="View Deduction">$(V_EDDDNO)</a></td>
                          <td class="colalph">$(V_HVDDNM)</td>
                          <td class="colcode">$(V_EDMTHD)</td>
                          %if (V_EDAMT > ".00")
                              @Format_Nbr($(V_EDAMT), F_EDAMT, "2", $(amtEditCode), "", "$", "")
    	                       <td class="colnmbr">$(F_EDAMT)</td>
                          %else
                              @Format_Nbr("@dtw_rmultiply(V_EDPCT, "100")", F_EDPCT, "3", $(pctEditCode), "", "", "%")
    	                      <td class="colnmbr">$(F_EDPCT)</td>
                          %endif
                      </tr>
                  %endif
          %}
          </table>
          %if (sql_Record_Count != "1")
              %INCLUDE "PageBottom.icl"
              %INCLUDE "WildCardPrint.icl"
              $(hrTagAttr)
              %INCLUDE "Copyright.icl"
          %endif
  %}
%}
%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select EDCOMP, EDFACL, EDEMPL, EDDDNO, EDAMT, EDPCT, EDMTHD, EDLIMT, HVDDNM, EMCOMP, EMFACL, EMEMPL, EMPECP, EMPEMP, EMLNAM, EMFNAM, EMMIDI, EMRNAM, EMLNAMU, EMFNAMU, EMDEPT, EMLOC, EMTYPE, EMTRCD ", stmtSQL)
  @dtw_concat(fileSQL, " HREDED inner join HRDEDM on EDDDNO=HVDDNO  ", fileSQL)
  @dtw_concat(fileSQL, "        inner join HREMPL on EDCOMP=EMCOMP and EDFACL=EMFACL and EDEMPL=EMEMPL  ", fileSQL)
  @dtw_concat(selectSQL, " EMCOMP = $(prCompany) and EMFACL = $(prFacility)", selectSQL)
  %INCLUDE "activeTerminatedEmplSQL.icl"
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @EmployeeDeduction_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) EmployeeDeduction_XMLQuery (IN CHAR(64) profileHandle,
				           CHAR(2)   dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
           @XMLBeginTag("DeductionList")
               %ROW{
                   @dtw_rMULTIPLY(EDPCT, "100")
                   @dtw_assign(V_EDPCT, "@dtw_rformat(@dtw_rmultiply(V_EDPCT, "100"),"","3")")

                   @XMLIDTag(@DTW_rCONCAT(V_EMCOMP, @DTW_rCONCAT("/", @DTW_rCONCAT(V_EMFACL, @DTW_rCONCAT("/", @DTW_rCONCAT(V_EMEMPL, @DTW_rCONCAT("/", V_EDDDNO)))))), "EmployeeDed ID")
                   @XMLTag(V_EMCOMP, "CompanyNumber")
                   @XMLTag(V_EMFACL, "FacilityNumber")
                   @XMLTag(V_EMEMPL, "EmployeeNumber")
                       @XMLBeginTag("PersonName")
                           @XMLTag(V_EMRNAM, "FormattedName")
                           @XMLTag(V_EMFNAM, "GivenName")
                           @XMLTag(V_EMMIDI, "MiddleName")
                           @XMLTag(V_EMLNAM, "FamilyName")
                       @XMLEndTag("PersonName")
                       @XMLTag(V_EDDDNO, "DeductionNumber")
                       @XMLTag(V_HVDDNM, "DeductionName")
                       @XMLTag(V_EDMTHD, "CalculationMethod")
                       @XMLTag(V_EDAMT, "DeductionAmount")
                       @XMLTag(V_EDPCT, "DeductionPercent")
                   @XMLEndTag("EmployeeDed")
		%}
           @XMLEndTag("DeductionList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTestView.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      %INCLUDE "WebReg.icl"
      %if (formatToPrint != "")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          %if (orderBy == "")
              @DTW_ASSIGN(orderBy, "EDEMPL, EDDDNO")
              @DTW_ASSIGN(orderByDisplay, "Employee Number, Deduction Number")
              @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
          %elif (chgActive == "Y" && inclActive == "Y")
              @dtw_assign(inclActive, "")
          %elif (chgActive == "Y")
              @dtw_assign(inclActive, "Y")
          %elif (chgTerminated == "Y" && inclTerminated == "Y")
              @dtw_assign(inclTerminated, "")
          %elif (chgTerminated == "Y")
              @dtw_assign(inclTerminated, "Y")
          %endif
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      %endif
      %if (inclActive == "" && inclTerminated == "" && chgActive != "Y" && chgTerminated != "Y")
          @dtw_assign(inclActive, activeEmpl)
          @dtw_assign(inclTerminated, terminatedEmpl)
      %endif
      %INCLUDE "SearchReturn.icl"
  %endif
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "EmplNumber")
      %if (orderBy == "EDEMPL,EDDDNO")
          @DTW_ASSIGN(orderBy, "EDEMPL DESC,EDDDNO")
          @DTW_ASSIGN(orderByDisplay, "Employee Number (descending), Deduction Number")
      %else
          @DTW_ASSIGN(orderBy, "EDEMPL,EDDDNO")
          @DTW_ASSIGN(orderByDisplay, "Employee Number, Deduction Number")
      %endif
  %elif (sequence == "LastName")
      %if (orderBy == "EMLNAMU,EMFNAMU,EDEMPL,EDDDNO")
          @DTW_ASSIGN(orderBy, "EMLNAMU DESC,EMFNAMU,EDEMPL,EDDDNO")
          @DTW_ASSIGN(orderByDisplay, "Last Name (descending), First Name, Employee Number, Deduction Number")
      %else
          @DTW_ASSIGN(orderBy, "EMLNAMU,EMFNAMU,EDEMPL,EDDDNO")
          @DTW_ASSIGN(orderByDisplay, "Last Name, First Name, Employee Number, Deduction Number")
      %endif
  %elif (sequence == "Department")
      %if (orderBy == "EMDEPT,EMLNAMU,EMFNAMU,EDEMPL,EDDDNO")
          @DTW_ASSIGN(orderBy, "EMDEPT DESC,EMLNAMU,EMFNAMU,EDEMPL,EDDDNO")
          @DTW_ASSIGN(orderByDisplay, "Department (descending), Last Name, First Name, Employee Number, Deduction Number")
      %else
          @DTW_ASSIGN(orderBy, "EMDEPT,EMLNAMU,EMFNAMU,EDEMPL,EDDDNO")
          @DTW_ASSIGN(orderByDisplay, "Department, Last Name, First Name, Employee Number, Deduction Number")
      %endif
  %elif (sequence == "DedNumber")
      %if (orderBy == "EDDDNO,EDEMPL")
          @DTW_ASSIGN(orderBy, "EDDDNO DESC,EDEMPL")
          @DTW_ASSIGN(orderByDisplay, "Deduction Number (descending), Employee Number")
      %else
          @DTW_ASSIGN(orderBy, "EDDDNO,EDEMPL")
          @DTW_ASSIGN(orderByDisplay, "Deduction Number, Employee Number")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              @dtw_assign(formName, "Search")
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchDeduction, 3, 0) &&
                      editNum(document.Search.srchAmount, 5, 2) &&
                      editNum(document.Search.srchRate, 2, 3) &&
                      editNum(document.Search.srchMethod, 2, 0) &&
                      editNum(document.Search.srchLimit, 7, 2) &&
                      editNum(document.Search.srchAmountDue, 5, 2) &&
                      editNum(document.Search.srchInception, 7, 2) &&
                      editNum(document.Search.srchYTDAmount, 7, 2) &&
                      editdate(document.Search.srchEffectiveDate) &&
                      editdate(document.Search.srchExpirationDate) &&
                      editNum(document.Search.srchEmployee, 5, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "CFDEDUCTIONS")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      @RetHrCompNam(profileHandle, dataBaseID, prCompany, prFacility, coFacName)
                      <h2>$(coFacName)</h2>

                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><th class="dsphdr"> <br>Deduction</th></tr>

                          <tr><td class="dsphdr"><br>Deduction Number</td>
                              @dtw_assign(operNbr, "operDeduction")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input name="srchDeduction" type="text" size="3" maxlength="3"> <a href="$(homeURL)$(cGIPath)DeductionSearch.d2w/ENTRY$(d2wVarBase)&amp;docName=Search&amp;fldName=srchDeduction&amp;fldDesc=dedDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="dedDesc" value="$(dedDesc)"  type="text" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Deduction Amount</td>
                              @dtw_assign(operNbr, "operAmount")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchAmount" size="9" maxlength="8"></td>
                          </tr>

                          <tr><td class="dsphdr">Deduction Rate</td>
                              @dtw_assign(operNbr, "operRate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchRate" size="7" maxlength="6"></td>
                          </tr>

                          <tr><td class="dsphdr">Calculation Method</td>
                              @dtw_assign(operNbr, "operMethod")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchMethod" size="2" maxlength="1"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=DEDCALCMTH&amp;flagSrchHdr=@dtw_rurlescseq("Deduction Calculation Method")&amp;docName=Search&amp;fldName=srchMethod&amp;fldDesc=srchCalcDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="srchCalcDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                          </tr>

                          <tr><td class="dsphdr">Deduction Limit</td>
                              @dtw_assign(operNbr, "operLimit")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchLimit" size="11" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Accumulated Amount Due</td>
                              @dtw_assign(operNbr, "operAmountDue")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchAmountDue" size="9" maxlength="8"></td>
                          </tr>

                          <tr><td class="dsphdr">Inception To Date Amount</td>
                              @dtw_assign(operNbr, "operInception")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchInception" size="11" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Year To Date Amount</td>
                              @dtw_assign(operNbr, "operYTDAmount")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchYTDAmount" size="11" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Effective Date</td>
                              @dtw_assign(operNbr, "operEffectiveDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchEffectiveDate" size="6" maxlength="6">
                              <a href="javascript:calWindow('srchEffectiveDate');">$(calendarImage)</a></td>
                          </tr>

                          <tr><td class="dsphdr">Expiration Date</td>
                              @dtw_assign(operNbr, "operExpirationDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchExpirationDate" size="6" maxlength="6">
                              <a href="javascript:calWindow('srchExpirationDate');">$(calendarImage)</a></td>
                          </tr>

                          <tr><th class="dsphdr"> <br>Employee</th></tr>

                          <tr><td class="dsphdr"> <br>Number</td>
                              @dtw_assign(operNbr, "operEmployee")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchEmployee" size="5" maxlength="5"></td>
                          </tr>

                          <tr><td class="dsphdr">First Name</td>
                              @dtw_assign(operNbr, "operFirst")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchFirst" size="18" maxlength="18"></td>
                          </tr>

                          <tr><td class="dsphdr">Last Name</td>
                              @dtw_assign(operNbr, "operLast")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchLast" size="18" maxlength="18"></td>
                          </tr>

                          <tr><td class="dsphdr">Location</td>
                              @dtw_assign(operNbr, "operLoc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchLoc" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)HRCodesSearch.php$(altVarBase)&amp;docName=Search&amp;fldComp=@dtw_rurlescseq(hrCompany)&amp;fldType=O&amp;fldName=srchLoc&amp;fldDesc=locCodeDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="locCodeDesc" value="$(codeDesc)"  type="text" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Department</td>
                              @dtw_assign(operNbr, "operDept")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchDept" type="text" size="5" maxlength="5"> <a href="$(homeURL)$(phpPath)DepartmentSearch.php$(altVarBase)&amp;docName=Search&amp;fldName=srchDept&amp;fldDesc=deptDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="deptDesc" value="$(deptDesc)"  type="text" size="20" maxlength="20"></td>
                          </tr>

                          <tr><td class="dsphdr">Job Code</td>
                              @dtw_assign(operNbr, "operJob")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input name="srchJob" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)HRCodesSearch.php$(altVarBase)&amp;docName=Search&amp;fldComp=@dtw_rurlescseq(hrCompany)&amp;fldType=J&amp;fldName=srchJob&amp;fldDesc=jobCodeDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="jobCodeDesc" value="$(codeDesc)"  type="text" size="20" maxlength="20"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchDeduction.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("EDDDNO", "Deduction Number", $(srchDeduction), "", operDeduction, "N")
  @Build_WildCard ("EDAMT", "Deduction Amount", $(srchAmount), "", operAmount, "N")
  @dtw_divide(srchRate, "100", srchRate)
  @Build_WildCard ("EDPCT", "Deduction Rate", $(srchRate), "", operRate, "N")
  @Build_WildCard ("EDMTHD", "Calculation Method", $(srchMethod), "", operMethod, "N")
  @Build_WildCard ("EDLIMT", "Deduction Limit", $(srchLimit), "", operLimit, "N")
  @Build_WildCard ("EDACUM", "Accumulated Amount Due", $(srchAmountDue), "", operAmountDue, "N")
  @Build_WildCard ("EDITD", "Inception To Date Amount", $(srchInception), "", operInception, "N")
  @Build_WildCard ("EDYTD", "Year To Date Amount", $(srchYTDAmount), "", operYTDAmount, "N")
  @Build_WildCard ("EDEFDT", "Effective Date", $(srchEffectiveDate), "", operEffectiveDate, "D")
  @Build_WildCard ("EDEXDT", "Expiration Date", $(srchExpirationDate), "", operExpirationDate, "D")
  @Build_WildCard ("EDEMPL", "Employee Number", $(srchEmployee), "", operEmployee, "N")
  @Build_WildCard ("EMFNAMU", "First Name", $(srchFirst), "U", operFirst, "A")
  @Build_WildCard ("EMLNAMU", "Last Name", $(srchLast), "U", operLast, "A")
  @Build_WildCard ("EMLOC", "Location", $(srchLoc), "U", operLoc, "A")
  @Build_WildCard ("EMDEPT", "Department", $(srchDept), "U", operDept, "A")
  @Build_WildCard ("EMJOB", "Job Code", $(srchJob), "U", operJob, "A")


  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}