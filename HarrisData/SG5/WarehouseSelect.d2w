%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorNoWarning.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "InventoryControl$(dataBaseID).icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "QuickLink.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Warehouse"
  d2wName                 = "WarehouseSelect.d2w"
  attachFolder            = "Warehouse"
  d2wVarBase              = "$(genericVarBase)&amp;warehouseNumber=@dtw_rurlescseq(warehouseNumber)&amp;warehouseName=@dtw_rurlescseq(warehouseName)&amp;fromSel=Y"
  programName             = "HHDWHU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  rowIndexNext            = "1"
  totalPages              = "0"	
  salesTotal              = ""
  purchasesTotal          = ""
  totalQuantity           = ""
  PDBRelease              = ""
  quickLinkByUser         = "Y"
  lgTTitle                = "Click here to view Transfer Tickets"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@warehouseName", "@dtw_rurlescseq(warehouseName)", "1", "a", workURL)
  @dtw_replace(workURL, "@@warehouseNumber", "@dtw_rurlescseq(warehouseNumber)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @WarehouseUserView(profileHandle, dataBaseID, userPass, warehouseNumber)
  %if (userPass == "N")
      %INCLUDE "userViewError.icl"
  %else
      %INCLUDE "$(docType)"
      <html>
          <head>
              @dtw_assign(title, @dtw_rconcat(warehouseNumber, @dtw_rconcat(" ", warehouseName)))
	       %INCLUDE "$(headInclude)"
              <script TYPE="text/javascript">
                  function confirmDelete(text) {return confirm("$(delRecordConf)" + "\n" + "\n" + text);}
                  %INCLUDE "Menu.js"
                  %INCLUDE "NewWindowOpen.icl"
              </script>
              %INCLUDE "$(genericHead)"
          </head>
          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      %if (formatToPrint == "")
                           @dtw_assign(pageID, "WAREHOUSESELECT")
                          <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      %endif
                      <td class="content">

%{ QuickLink Table %}     %INCLUDE "QuickLinkTable.icl"

%{ PDBRelease %}
                          %if (V_HDPDRL>"0")		
                              @dtw_assign(PDBRelease, "Y")
                          %else
                              @Remove_Quick_Link("plants")
                          %endif

%{ QuickLink By User %}   %INCLUDE "QuickLinkByUser.icl"

%{ Warehouse Heading %}
                          @dtw_assign(RPT_MAX_ROWS, "99")
                          @dtw_assign(dspMaxRows, "10")
                          @dtw_assign(uv_Sql, "")  %{ No user view security. %}
                          @dtw_assign(wildCardSearch, "")  %{ No wildCardSearch %}
                          %INCLUDE "stmtSQLClear.icl"
                          @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                          @dtw_concat(fileSQL, " HDWHSM ", fileSQL)
                          @dtw_concat(selectSQL, "WHWHS=$(warehouseNumber) ", selectSQL)
                          %INCLUDE "stmtSQLSelect.icl"
                          %INCLUDE "stmtSQLEnd.icl"
                          @Warehouse_Select_Header(profileHandle, dataBaseID, stmtSQL)

%{ Quicklink Begin %}     %INCLUDE "QuickLinkBegLoop.icl"

    %{ Demographics %}
                              %if (quicklinkRef == "demographics")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDWHSM ", fileSQL)
                                  @dtw_concat(selectSQL, "WHWHS=$(warehouseNumber) ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Warehouse_Select_Demographics(profileHandle, dataBaseID, stmtSQL)

    %{ Cycle Count %}
                              %elif (quicklinkRef == "cyclecount")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDWHSM ", fileSQL)
                                  @dtw_concat(selectSQL, "WHWHS=$(warehouseNumber) ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Warehouse_Select_Cycle_Count(profileHandle, dataBaseID, stmtSQL)

    %{ Account Numbers %}
                              %elif (quicklinkRef == "accountnumbers")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDWHSM ", fileSQL)
                                  @dtw_concat(selectSQL, "WHWHS=$(warehouseNumber) ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %INCLUDE "stmtSQLEnd.icl"
                                  @Warehouse_Select_Account_Numbers(profileHandle, dataBaseID, stmtSQL)

    %{ Plants %}
                              %elif (quicklinkRef == "plants")
                                  %INCLUDE "QuickLinkClear.icl"
                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(stmtSQL, " Select WSPLWH, WSSORD, WSSEQ#, WSWH, ", stmtSQL)
                                  @dtw_concat(stmtSQL, " PLNAME, PLCITY, PLST, PLZIP ", stmtSQL)
                                  @dtw_concat(fileSQL, " HDWSPM, HDPLNT ", fileSQL)
                                  @dtw_concat(selectSQL, "WSPLWH=PLPLNT and WSWH=$(warehouseNumber) and WSTYPE='P' ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  %if (orderBy == "")
                                      @dtw_assign(orderBy, "WSPLWH")
                                      @dtw_assign(orderByDisplay, "Plant Number")
                                  %endif
                                  @dtw_concat(stmtSQL, " Order By $(orderBy)", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Warehouse_Select_Plants(profileHandle, dataBaseID, stmtSQL)

    %{ Top Customers %}
                              %elif (quicklinkRef == "lastyeartopcustomers" || quicklinkRef == "ytdtopcustomers")
                                  %INCLUDE "QuickLinkClear.icl"
                                  @dtw_date("S", sysDateYYYYMMDD)
                                  @dtw_substr(sysDateYYYYMMDD,"3","2",sysYearYY)
                                  %if (quicklinkRef == "lastyeartopcustomers")
                                      @dtw_subtract(sysYearYY,"1",yearYY)
                                  %else
                                      @dtw_assign(yearYY, sysYearYY)
                                  %endif
                                  @Build_Date_Range(yearYY, startCMD, endCMD)
                                  @RtvFldDesc("DHSEQ#>0 and DHWH=$(warehouseNumber) and DHRQDT>=$(startCMD) and DHRQDT<=$(endCMD)", "OEORDH", "char(SUM((DHQSTC*DHSLPR)/DHORUF))", salesTotal)

                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(distinctSQL, "DHSHTO ", distinctSQL)
                                  @dtw_concat(stmtSQL, " Select DHSHTO, SUM((DHQSTC*DHSLPR)/DHORUF) as SALES ", stmtSQL)
                                  @dtw_concat(fileSQL, " OEORDH ", fileSQL)
                                  @dtw_concat(selectSQL, "DHSEQ#>0 and DHWH=$(warehouseNumber) and DHRQDT>=$(startCMD) and DHRQDT<=$(endCMD)", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  @dtw_concat(stmtSQL, " GROUP BY DHSHTO", stmtSQL)
                                  @dtw_assign(orderBy, "SALES Desc")
                                  @dtw_assign(orderByDisplay, "Sales (descending)")
                                  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Warehouse_Select_Top_Customers(profileHandle, dataBaseID, stmtSQL)

    %{ Top Items %}
                              %elif (quicklinkRef == "lastyeartopitems" || quicklinkRef == "ytdtopitems")
                                  %INCLUDE "QuickLinkClear.icl"
                                  @dtw_date("S", sysDateYYYYMMDD)
                                  @dtw_substr(sysDateYYYYMMDD,"3","2",sysYearYY)
                                  %if (quicklinkRef == "lastyeartopitems")
                                      @dtw_subtract(sysYearYY,"1",yearYY)
                                  %else
                                      @dtw_assign(yearYY, sysYearYY)
                                  %endif
                                  @Build_Date_Range(yearYY, startCMD, endCMD)
                                  @RtvFldDesc("DHSEQ#>0 and DHWH=$(warehouseNumber) and DHRQDT>=$(startCMD) and DHRQDT<=$(endCMD)", "OEORDH", "char(SUM((DHQSTC*DHSLPR)/DHORUF))", salesTotal)

                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(distinctSQL, "DHITEM ", distinctSQL)
                                  @dtw_concat(stmtSQL, " Select DHITEM, SUM((DHQSTC*DHSLPR)/DHORUF) as SALES, ", stmtSQL)
                                  @dtw_concat(stmtSQL, " SUM(DHQSTC) as QTYSHIPPED ", stmtSQL)
                                  @dtw_concat(fileSQL, " OEORDH ", fileSQL)
                                  @dtw_concat(selectSQL, "DHSEQ#>0 and DHWH=$(warehouseNumber) ", selectSQL)
                                  @dtw_concat(selectSQL, "and DHRQDT>=$(startCMD) and DHRQDT<=$(endCMD) ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  @dtw_concat(stmtSQL, " GROUP BY DHITEM", stmtSQL)
                                  @dtw_assign(orderBy, "SALES Desc")
                                  @dtw_assign(orderByDisplay, "Sales (descending)")
                                  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Warehouse_Select_Top_Items(profileHandle, dataBaseID, stmtSQL)

    %{ Top Vendors %}
                              %elif (quicklinkRef == "lastyeartopvendors" || quicklinkRef == "ytdtopvendors")
                                  %INCLUDE "QuickLinkClear.icl"
                                  @dtw_date("S", sysDateYYYYMMDD)
                                  @dtw_substr(sysDateYYYYMMDD,"3","2",sysYearYY)
                                  %if (quicklinkRef == "lastyeartopvendors")
                                      @dtw_subtract(sysYearYY,"1",yearYY)
                                  %else
                                      @dtw_assign(yearYY, sysYearYY)
                                  %endif
                                  @Build_Date_Range(yearYY, startCMD, endCMD)
                                  @RtvFldDesc("PHWHS=$(warehouseNumber) and PHLRDT>=$(startCMD) and PHLRDT<=$(endCMD)", "POPOHH inner join POPOHD on PHPO=PIPO and PHSEQ#=PISEQ#", "char(SUM((PIDSCC*PITRQT)/PIPCPB))", purchasesTotal)

                                  %INCLUDE "stmtSQLClear.icl"
                                  @dtw_concat(distinctSQL, "PHVEND ", distinctSQL)
                                  @dtw_concat(stmtSQL, " Select PHVEND, SUM((PIDSCC*PITRQT)/PIPCPB) as PURCHASES ", stmtSQL)
                                  @dtw_concat(fileSQL, " POPOHH inner join POPOHD on PHPO=PIPO and PHSEQ#=PISEQ# ", fileSQL)
                                  @dtw_concat(selectSQL, "PHWHS=$(warehouseNumber) and PHLRDT>=$(startCMD) and PHLRDT<=$(endCMD) ", selectSQL)
                                  %INCLUDE "stmtSQLSelect.icl"
                                  @dtw_concat(stmtSQL, " GROUP BY PHVEND", stmtSQL)
                                  @dtw_assign(orderBy, "PURCHASES Desc")
                                  @dtw_assign(orderByDisplay, "Purchases (descending)")
                                  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                                  %INCLUDE "stmtSQLEnd.icl"
                                  %INCLUDE "stmtSQLTotalRows.icl"
                                  @Warehouse_Select_Top_Vendors(profileHandle, dataBaseID, stmtSQL)
                              %endif

    %{ Attachments %}         %INCLUDE "AttachmentSQL.icl"

%{ Quicklink End %}       %INCLUDE "QuickLinkEndLoop.icl"

                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(dtw_sql) Warehouse_Select_Header (IN  CHAR(64)    profileHandle,
				                 CHAR(2)     dataBaseID,
                                                CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              @dtw_assign(attachVarKey, warehouseNumber)
              @dtw_assign(attachForDesc, warehouseName)
              @dtw_assign(attachPrg1, "HDWHSM Where WHWHS=$(warehouseNumber)")
              %if (formatToPrint != "Y")
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;fromD2w=")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (V_CICWHS > "000" && V_CISTKL == "Y")
                          <a href="$(homeURL)$(cGIPath)TransferTicket.d2w/REPORT$(d2wVarBase)">$(lgT)</a>
                      %endif
                      %while(@dtw_rlength(attachVarKey) != "3") {@dtw_insert("0", attachVarKey, attachVarKey)%}
                      %INCLUDE "Attachment.icl"
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)WarehouseMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %if (sec_01=="Y" && sec_04=="Y")
                          <a href="$(homeURL)$(cGIPath)WarehouseMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageLrg)</a>
                      %endif
                      %if (sec_02 == "Y" || sec_03 == "Y")
                          <a href="$(homeURL)$(cGIPath)WarehouseMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageLrg)</a>
                      %endif
                      %if (sec_03 == "Y")
                          @Format_Confirm_Desc($(warehouseName), $(warehouseNumber), "", "", "", "", confirmDesc)
                          <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)WarehouseMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageLrg)</a>
                      %endif
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>
      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)
	   		
      %ROW{
          <table $(contentTable)>
              <colgroup>
                  <col width="60%">
                  <col width="20%">

              <tr><td rowspan="4" class="dspalph"> $(V_WHWHNM) <br>
                      %if (V_WHWHAD != "")
                          $(V_WHWHAD) <br>
                      %endif
                      %if (V_WHWHA2 != "")
                          $(V_WHWHA2) <br>
                      %endif
                      $(V_WHWHCT), $(V_WHWHST) $(V_WHHWZP)
                  </td>

                  <td class="dsphdr">Warehouse Number</td>
                  <td class="dspnmbr">$(V_WHWHS)</td>
              </tr>
          </table>

          $(hrTagAttr)	

          %INCLUDE "QuickLinkDisplay.icl"
      %}
  %}
%}

%FUNCTION(dtw_sql) Warehouse_Select_Demographics (IN  CHAR(64)    profileHandle,
				                       CHAR(2)     dataBaseID,
                                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="demographics"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %ROW{
              @Format_CoFac("$(V_WHCO#)", "$(V_WHFAC#)", "F", F_CoFac)
              <tr><td class="dsphdr">Company/Facility</td>
                  <td class="dspalph">$(returnFldDesc)</td>
                  <td class="dspalph">$(F_CoFac)</td>
              </tr>

              @RtvFldDesc("CNCTCD='$(V_WHCTRY)'", "HDCTRY", "CNCDES", fieldDesc)
              @Format_Code(V_WHCTRY, F_WHCTRY)
              <tr><td class="dsphdr">Country</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_WHCTRY)</td>
              </tr>

              @RtvFldDesc("SMSCHD=$(V_WHSCHD)", "HDSCHM", "SMDESC", fieldDesc)
              @Format_Code(V_WHSCHD, F_WHSCHD)
              <tr><td class="dsphdr">Schedule</td>
                  <td class="dspalph">$(fieldDesc)</td>
                  <td class="dspalph">$(F_WHSCHD)</td>
              </tr>

              <tr><td class="dsphdr">Page Segment Name</td>
                 <td class="dspalph">$(V_WHPSEG)</td>
              </tr>
              	   		
              @RtvYNDesc($(V_WHSTKL), fieldDesc)
              <tr><td class="dsphdr">Stock Locator Active</td>
                  <td class="dspalph">$(fieldDesc)</td>
              </tr>

              @RtvYNDesc($(V_WHACS), fieldDesc)
              <tr><td class="dsphdr">Auto Update Item Stock Loc</td>
                  <td class="dspalph">$(fieldDesc)</td>
              </tr>

              @RtvYNDesc($(V_WHMRPN), fieldDesc)
              <tr><td class="dsphdr">MRP Netable Warehouse</td>
                  <td class="dspalph">$(fieldDesc)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Warehouse_Select_Cycle_Count (IN  CHAR(64)    profileHandle,
				                      CHAR(2)     dataBaseID,
                                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="cyclecount"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      %ROW{
          <table $(contentTable)>
              @RtvYNDesc($(V_WHABCI), fieldDesc)
              <tr><td class="dsphdr">ABC Analysis By Inventory Type</td>
                  <td class="dspalph">$(fieldDesc)</td>
              </tr>
              <tr><td class="dsphdr">Item Count</td>
                  <td class="dspnmbr">$(V_WHTP)</td>
              </tr>
              <tr><td class="dsphdr">Inactive Items</td>
                  <td class="dspnmbr">$(V_WHTIP)</td>
              </tr>
              <tr><td>&nbsp;</td></tr>

              <tr><td>&nbsp;</td>
                  <td class="colhdr">Class A</td>
                  <td class="colhdr">Class B</td>
                  <td class="colhdr">Class C</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr">Acceptance Limit Percentage</td>
                  <td class="dspnmbr">@dtw_rformat(@dtw_rmultiply(V_WHVLA, "100"),"","1")</td>
                  <td class="dspnmbr">@dtw_rformat(@dtw_rMultiply(V_WHVLB, "100"),"","1")</td>
                  <td class="dspnmbr">@dtw_rformat(@dtw_rMultiply(V_WHVLC, "100"),"","1")</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr">Cycle Days</td>
                  <td class="dspnmbr">$(V_WHCAW)</td>
                  <td class="dspnmbr">$(V_WHCBW)</td>
                  <td class="dspnmbr">$(V_WHCCW)</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr">Percentage For</td>
                  <td class="dspnmbr">$(V_WHPCA)</td>
                  <td class="dspnmbr">$(V_WHPCB)</td>
                  <td class="dspalph">&nbsp;</td>
              </tr>

              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr">Item Count</td>
                  <td class="dspnmbr">$(V_WHTCA)</td>
                  <td class="dspnmbr">$(V_WHTCB)</td>
                  <td class="dspnmbr">$(V_WHTCC)</td>
              </tr>
          </table>
      %}
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Warehouse_Select_Account_Numbers  (IN  CHAR(64)    profileHandle,
				                           CHAR(2)     dataBaseID,
                                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("COSMC1<>' '", "POCTRL", "COSMC1", V_COSMC1)
      @RtvFldDesc("COSMC2<>' '", "POCTRL", "COSMC2", V_COSMC2)
      @RtvFldDesc("COSMC3<>' '", "POCTRL", "COSMC3", V_COSMC3)
      @RtvFldDesc("COSMC4<>' '", "POCTRL", "COSMC4", V_COSMC4)
      @RtvFldDesc("COSMC5<>' '", "POCTRL", "COSMC5", V_COSMC5)
      @RtvFldDesc("COSMC6<>' '", "POCTRL", "COSMC6", V_COSMC6)

      <a name="accountnumbers"></a>
      @dtw_assign(displayMaxRowsMsg, "N")
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          <tr><td>&nbsp;</td>
              <td class="colhdr">Expense Account</td>
              <td class="colhdr">Variance Account</td>
          </tr>
          %ROW{
              @Format_Acct($(V_WHTCVA), $(V_WHTCVS), "Y", acctDesc)
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr">Transfer Cost</td>
                  <td class="dspalph">&nbsp;</td>
                  <td class="dspalph">$(acctDesc)</td>
              </tr>

              @Format_Acct($(V_WHUVRA), $(V_WHUVRS), "Y", acctDesc)
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr">Unvouchered Receipts</td>
                  <td class="dspalph">$(acctDesc)</td>
                  <td class="dspalph">&nbsp;</td>
              </tr>
              	   		
              @Format_Acct($(V_WHPRVA), $(V_WHPRV), "Y", acctDesc)
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr">Standard</td>
                  <td class="dspalph">&nbsp;</td>
                  <td class="dspalph">$(acctDesc)</td>
              </tr>
              	   		
              @Format_Acct($(V_WHFGHA), $(V_WHFGHS), "Y", expAcct)
              @Format_Acct($(V_WHFGVA), $(V_WHFGVS), "Y", varAcct)
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr">Freight</td>
                  <td class="dspalph">$(expAcct)</td>
                  <td class="dspalph">$(varAcct)</td>
              </tr>
              	   		
              @Format_Acct($(V_WHSLTA), $(V_WHSLTS), "Y", expAcct)
              @Format_Acct($(V_WHSTVA), $(V_WHSTVS), "Y", varAcct)
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr">Sales Tax</td>
                  <td class="dspalph">$(expAcct)</td>
                  <td class="dspalph">$(varAcct)</td>
              </tr>
              	   		
              @Format_Acct($(V_WHSPGA), $(V_WHSPCS), "Y", expAcct)
              @Format_Acct($(V_WHSCVA), $(V_WHSCVS), "Y", varAcct)
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="dsphdr">Special Charge</td>
                  <td class="dspalph">$(expAcct)</td>
                  <td class="dspalph">$(varAcct)</td>
              </tr>

              %if (V_COSMC1 != "")
                  @Format_Acct($(V_WHMC1A), $(V_WHMC1S), "Y", expAcct)
                  @Format_Acct($(V_WHMV1A), $(V_WHMV1S), "Y", varAcct)
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="dsphdr">$(V_COSMC1)</td>
                      <td class="dspalph">$(expAcct)</td>
                      <td class="dspalph">$(varAcct)</td>
                  </tr>
              %endif

              %if (V_COSMC2 != "")
                  @Format_Acct($(V_WHMC2A), $(V_WHMC2S), "Y", expAcct)
                  @Format_Acct($(V_WHMV2A), $(V_WHMV2S), "Y", varAcct)
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="dsphdr">$(V_COSMC2)</td>
                      <td class="dspalph">$(expAcct)</td>
                      <td class="dspalph">$(varAcct)</td>
                  </tr>
              %endif

              %if (V_COSMC3 != "")
                  @Format_Acct($(V_WHMC3A), $(V_WHMC3S), "Y", expAcct)
                  @Format_Acct($(V_WHMV3A), $(V_WHMV3S), "Y", varAcct)
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="dsphdr">$(V_COSMC3)</td>
                      <td class="dspalph">$(expAcct)</td>
                      <td class="dspalph">$(varAcct)</td>
                  </tr>
              %endif

              %if (V_COSMC4 != "")
                  @Format_Acct($(V_WHMC4A), $(V_WHMC4S), "Y", expAcct)
                  @Format_Acct($(V_WHMV4A), $(V_WHMV4S), "Y", varAcct)
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="dsphdr">$(V_COSMC4)</td>
                      <td class="dspalph">$(expAcct)</td>
                      <td class="dspalph">$(varAcct)</td>
                  </tr>
              %endif

              %if (V_COSMC5 != "")
                  @Format_Acct($(V_WHMC5A), $(V_WHMC5S), "Y", expAcct)
                  @Format_Acct($(V_WHMV5A), $(V_WHMV5S), "Y", varAcct)
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="dsphdr">$(V_COSMC5)</td>
                      <td class="dspalph">$(expAcct)</td>
                      <td class="dspalph">$(varAcct)</td>
                  </tr>
              %endif

              %if (V_COSMC6 != "")
                  @Format_Acct($(V_WHMC6A), $(V_WHMC6S), "Y", expAcct)
                  @Format_Acct($(V_WHMV6A), $(V_WHMV6S), "Y", varAcct)
                  %INCLUDE "SetRowClass.icl"
                  <tr class="$(rowClass)">
                      <td class="dsphdr">$(V_COSMC6)</td>
                      <td class="dspalph">$(expAcct)</td>
                      <td class="dspalph">$(varAcct)</td>
                  </tr>
              %endif
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Warehouse_Select_Plants (IN  CHAR(64)    profileHandle,
		 		                 CHAR(2)     dataBaseID,
                                                CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <a name="plants"></a>
      @dtw_assign(moreURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=14")
      %INCLUDE "QuickLinkTopOfForm.icl"

      <table $(contentTable)>
          %if (sql_Record_Count == "0")
              %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              <tr>
                  @Format_Column_Header("WSPLWH", "Plant<br>Number")
                  @Format_Column_Header("PLNAME", "Plant Name")
                  @Format_Column_Header("PLCITY", "City, State, Zip")
              </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              <tr class="$(rowClass)">
                  <td class="colnmbr">$(V_WSPLWH)</td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)PlantSelect.d2w/REPORT$(genericVarBase)&amp;plantNumber=@dtw_rurlescseq(V_WSPLWH)&amp;plantName=@dtw_rurlescseq(V_PLNAME)" title="View Plant"> $(V_PLNAME)</a></td>
                  <td class="colalph">$(V_PLCITY), $(V_PLST) $(V_PLZIP)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Warehouse_Select_Top_Customers (IN CHAR(64)    profileHandle,
				                       CHAR(2)     dataBaseID,
                                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (quicklinkRef == "ytdtopcustomers" )
          <a name="ytdtopcustomers"></a>
      %else
          <a name="lastyeartopcustomers"></a>
      %endif
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

          %if (sql_Record_Count == "0")
              <table $(contentTable)>
                  %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              @Format_Nbr(salesTotal, F_salesTotal, "2", $(amtEditCode), "", "$", "")
              <div class="page">
                   Total Sales: $(F_salesTotal)
              </div>

              <table $(contentTable)>
                  <tr>
                      @Format_Column_Header("DHSHTO", "Customer<br>Number")
                      @Format_Column_Header("xxx", "Customer Name")
                      @Format_Column_Header("SALES", "Sales")
                      @Format_Column_Header("xxx", "Percent<br>of Total")
                  </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              %if (salesTotal > "0")
                  @dtw_multiply(V_SALES, "100", percentOfTotal)
                  @dtw_divide(percentOfTotal, salesTotal, percentOfTotal)
                  @Format_Nbr($(percentOfTotal), F_percentOfTotal, "2", $(pctEditCode), "Y", "", "%")
              %else
                  @dtw_assign(F_percentOfTotal, "")
              %endif
              @Format_Nbr($(V_SALES), F_SALES, "2", $(amtEditCode), "", "", "")
              @RtvFldDesc("CMCUST=$(V_DHSHTO)", "HDCUST", "CMCNA1", fieldDesc)
              <tr class="$(rowClass)">
                  <td class="colnmbr"><a href="$(homeURL)$(cGIPath)CustomerInquiry.d2w/DISPLAY$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(V_DHSHTO)" onclick="$(inquiryWinVar)" title="Customer Quickview">$(V_DHSHTO)</a></td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)CustomerSelect.d2w/REPORT$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(V_DHSHTO)&amp;customerName=@dtw_rurlescseq(fieldDesc)" title="View Customer">$(fieldDesc)</a></td>
                  <td class="colnmbr">$(F_SALES)</td>
                  <td class="colnmbr">$(F_percentOfTotal)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Warehouse_Select_Top_Items (IN CHAR(64)    profileHandle,
				                   CHAR(2)     dataBaseID,
                                                  CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (quicklinkRef == "ytdtopitems" )
          <a name="ytdtopitems"></a>
      %else
          <a name="lastyeartopitems"></a>
      %endif
      @dtw_assign(moreURL, "")
      %INCLUDE "QuickLinkTopOfForm.icl"

          %if (sql_Record_Count == "0")
              <table $(contentTable)>
                  %INCLUDE "QuickLinkNoInfoMsg.icl"
          %else
              @Format_Nbr(salesTotal, F_salesTotal, "2", $(amtEditCode), "", "$", "")
              <div class="page">
                   Total Sales: $(F_salesTotal)
              </div>

              <table $(contentTable)>
                  <tr>
                      @Format_Column_Header("DHITEM", "Item Number")
                      @Format_Column_Header("xxx", "Item Description")
                      @Format_Column_Header("SALES", "Sales")
                      @Format_Column_Header("xxx", "Percent<br>of Total")
                      @Format_Column_Header("QTYSHIPPED", "Quantity")
                  </tr>
          %endif

          %ROW{
              %INCLUDE "SetRowClass.icl"
              %if (salesTotal > "0")
                  @dtw_multiply(V_SALES, "100", percentOfTotal)
                  @dtw_divide(percentOfTotal, salesTotal, percentOfTotal)
                  @Format_Nbr($(percentOfTotal), F_percentOfTotal, "2", $(pctEditCode), "Y", "", "%")
              %else
                  @dtw_assign(F_percentOfTotal, "")
              %endif
              @Format_Nbr(V_QTYSHIPPED, F_QTYSHIPPED, $(qtyNbrDec), $(qtyEditCode), "", "", "")
              @Format_Nbr($(V_SALES), F_SALES, "2", $(amtEditCode), "", "", "")
              @RtvFldDesc("IMITEM='$(V_DHITEM)'", "HDIMST", "IMIMDS", fieldDesc)
              <tr class="$(rowClass)">
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)ItemInquiry.d2w/DISPLAY$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq($(V_DHITEM))" onclick="$(inquiryWinVar)" title="Item Quickview">$(V_DHITEM)</a></td>
                  <td class="colalph"><a href="$(homeURL)$(cGIPath)ItemSelect.d2w/REPORT$(genericVarBase)&amp;itemNumber=@dtw_rurlescseq(V_DHITEM)&amp;itemDescription=@dtw_rurlescseq(fieldDesc)" title="View Item">$(fieldDesc)</a></td>
                  <td class="colnmbr">$(F_SALES)</td>
                  <td class="colnmbr">$(F_percentOfTotal)</td>
                  <td class="colnmbr">$(F_QTYSHIPPED)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

%FUNCTION(dtw_sql) Warehouse_Select_Top_Vendors (IN CHAR(64)    profileHandle,
				                     CHAR(2)     dataBaseID,
                                                    CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
