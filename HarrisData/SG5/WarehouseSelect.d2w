                  <td class="colalph"><a href="$(homeURL)$(cGIPath)VendorSelect.d2w/REPORT$(genericVarBase)&amp;vendorNumber=@dtw_rurlescseq(V_PHVEND)&amp;vendorName=@dtw_rurlescseq(fieldDesc)" title="View Vendor">$(fieldDesc)</a></td>
                  <td class="colnmbr">$(F_PURCHASES)</td>
                  <td class="colnmbr">$(F_percentOfTotal)</td>
              </tr>
          %}
      </table>
      </fieldset>
  %}
%}

