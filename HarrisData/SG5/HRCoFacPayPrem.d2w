%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Premium Rates"
  d2wName                 = "HRCoFacPayPrem.d2w"
  d2wVarBase              = "$(genericVarBase)$(hrCoFacVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HPRPRM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  %INCLUDE "HrCoFacURL.icl"
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "PREMRATES")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      @dtw_assign(uv_CompanyName, "PPCOMP")
                      @dtw_assign(uv_FacilityName, "PPFACL")
                      @dtw_assign(uv_HomeDepartmentName, "PPDEPT")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select PPCOMP, PPFACL, PPDEPT, PPSHFT, PPDESC, PPHRLY, PPSLRY, PPAMT, PPPCT, PPOTM, ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(PPDESC) as PPDESCU", stmtSQL)
                      @dtw_concat(fileSQL, " PRPREM ", fileSQL)
                      @dtw_concat(selectSQL, " PPCOMP=$(prCompany) and PPFACL=$(prFacility)", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Premium_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Premium_Query (IN CHAR(64)    profileHandle,
                                     CHAR(2)     dataBaseID,
                                     CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (sql_Record_Count != "1")
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1> $(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      @dtw_assign(programName, "HPRPYM")
                      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                      <td class="toolbar">
                          %if ((backHome != "$(d2wName)/report") && (backHome != ""))
                              <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                          %endif
                          %INCLUDE "XMLFormat.icl"
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>

              @RetHrCompNam(profileHandle, dataBaseID, prCompany, prFacility, coFacName)
              <tr><td><h2>$(coFacName)</h2></td></tr>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"
          $(hrTagAttr)

          %if (formatToPrint != "Y")
              <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
                  <table $(quickSearchTable)>
                      <tr><th class="colhdr">Description</th></tr>
                      <tr><td><input type="text" class="inputalph" name="srchDesc" size="20" maxlength="20">
                              <input type="hidden" name="operDesc" value="LIKE">
                          </td>
                          <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                      </tr>
                  </table>
                  <script TYPE="text/javascript">
                      document.Search.srchDesc.focus();
                  </script>
              </form>

              %INCLUDE "WildCardPage.icl"
          %endif

          <table $(contentTable)>
              <tr>
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("PPSHFT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PayPrem" title="Sequence By Shift Worked, Description">Shift<br>Worked</a></th>
                  @OrderBy_Sort("PPDESCU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PayPremDesc" title="Sequence By Description, Shift Worked">Description</a></th>
                  @OrderBy_Sort("PPDEPT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PremDept" title="Sequence By Department Worked, Shift Worked">Dept<br>Worked</a></th>
                  <th class="colhdr">Department<br>Name</th>
                  @OrderBy_Sort("PPAMT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PremAmount" title="Sequence By Premium Amount, Shift Worked">Premium<br>Amount</a></th>
                  @OrderBy_Sort("PPPCT", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PremPercent" title="Sequence By Premium Percent, Shift Worked">Premium<br>Percent</a></th>
                  <th class="colhdr">Apply To<br>Hourly</th>
                  <th class="colhdr">Apply To<br>Salary</th>
                  <th class="colhdr">Process OT/DT<br>Multipliers</th>
              </tr>
          %INCLUDE "NoRecordsFound.icl"
      %endif

              %ROW{
                  @dtw_assign(maintainVar, "$(d2wVarBase)&amp;shiftDept=@dtw_rurlescseq(V_PPDEPT)&amp;shiftWorked=@dtw_rurlescseq(V_PPSHFT)")
                  %if (sql_Record_Count == "1")
                      @Save_WebReg(webRegCurFile, profileHandle, d2wName, "", orderBy, orderByDisplay, "")
                      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)HRCoFacPayPremSelect.d2w/REPORT$(maintainVar)">
                  %else
                      %INCLUDE "SetRowClass.icl"
                      <tr class="$(rowClass)">
                          <td class="colcode">$(V_PPSHFT)</td>
                          <td class="colalph"><a href="$(homeURL)$(cGIPath)HRCoFacPayPremSelect.d2w/REPORT$(maintainVar)" title="View Shift Premium">$(V_PPDESC)</a></td>
                          <td class="colalph">$(V_PPDEPT)</td>
                          %if (V_PPDEPT != "")
                              @RtvFldDesc("EADEPT='$(V_PPDEPT)'", "PREXAC", "EANAME", prDeptName)
                              <td class="colalph">$(prDeptName)</td>
                          %else
                              <td class="colalph">All</td>
                          %endif
                          @Format_Nbr($(V_PPAMT), F_PPAMT, "2", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_PPAMT)</td>
                          @Format_Nbr($(V_PPPCT), F_PPPCT, "4", $(pctEditCode), "", "", "")
                          <td class="colnmbr">$(F_PPPCT)</td>
                          @RtvYNDesc($(V_PPHRLY), syFlagDesc)
                          <td class="colcode">$(syFlagDesc)</td>
                          @RtvYNDesc($(V_PPSLRY), syFlagDesc)
                          <td class="colcode">$(syFlagDesc)</td>
                          @RtvYNDesc($(V_PPOTM), syFlagDesc)
                          <td class="colcode">$(syFlagDesc)</td>
                      </tr>
                  %endif
              %}
          </table>
          %if (sql_Record_Count != "1")
              %INCLUDE "PageBottom.icl"
              %INCLUDE "WildCardPrint.icl"
              $(hrTagAttr)
              %INCLUDE "Copyright.icl"
          %endif
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if (sec_05 == "N")
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)progOptSecError.d2w/DISPLAY$(genericVarBase)&amp;page_title=@dtw_rurlescseq(page_title)">
  %else
      %INCLUDE "WebReg.icl"
      %if (formatToPrint != "")
          @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
      %else
          %if (orderBy == "")
              @DTW_ASSIGN(orderBy, "PPDESCU")
              @DTW_ASSIGN(orderByDisplay, "Description")
              @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
          %endif
          @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
      %endif
      %INCLUDE "SearchReturn.icl"
  %endif
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  @dtw_assign(uv_CompanyName, "PPCOMP")
  @dtw_assign(uv_FacilityName, "PPFACL")
  @dtw_assign(uv_HomeDepartmentName, "PPDEPT")
  %INCLUDE "userview.icl"
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, "Select PPCOMP, PPFACL, PPDEPT, PPSHFT, PPDESC, PPHRLY, PPSLRY, PPAMT, PPPCT, PPOTM, ", stmtSQL)
  @dtw_concat(stmtSQL, " upper(PPDESC) as PPDESCU", stmtSQL)
  @dtw_concat(fileSQL, " PRPREM ", fileSQL)
  @dtw_concat(selectSQL, " PPCOMP=$(prCompany) and PPFACL=$(prFacility)", selectSQL)
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @Premium_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) Premium_XMLQuery (IN CHAR(64)    profileHandle,
			                  CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
       @XMLBeginTag("PayPremiumList")
           %ROW{

	        @XMLIDTag(@DTW_rCONCAT(prCompany, @DTW_rCONCAT("/", @DTW_rCONCAT(prFacility, @DTW_rCONCAT("/", @DTW_rCONCAT(V_PPDEPT, @DTW_rCONCAT("/", V_PPSHFT)))))), "PayPremium ID")
                   @XMLTag(prCompany, "CompanyNumber")
                   @XMLTag(prFacility, "FacilityNumber")
                   @XMLTag(V_PPDEPT, "DepartmentWorked")
                   @XMLTag(V_PPSHFT, "ShiftWorked")
                   @XMLTag(V_PPDESC, "DescriptionOfPremium")
                   @XMLTag(V_PPHRLY, "ApplyToHourly")
                   @XMLTag(V_PPSLRY, "ApplyToSalary")
                   @XMLTag(V_PPAMT, "PremiumAmount")
                   @XMLTag(V_PPPCT, "PremiumPercent")
                   @XMLTag(V_PPOTM, "ProcessOvertimeMultiplier")

               @XMLEndTag("PayPremium")
           %}
       @XMLEndTag("PayPremiumList")
  %}
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "PayPrem")
      %if (orderBy == "PPSHFT,PPDESCU")
          @DTW_ASSIGN(orderBy, "PPSHFT DESC,PPDESCU")
          @DTW_ASSIGN(orderByDisplay, "Shift Worked (descending), Description")
      %else
          @DTW_ASSIGN(orderBy, "PPSHFT,PPDESCU")
          @DTW_ASSIGN(orderByDisplay, "Shift Worked, Description")
      %endif
  %elseif (sequence == "PayPremDesc")
      %if (orderBy == "PPDESCU,PPSHFT")
          @DTW_ASSIGN(orderBy, "PPDESCU DESC,PPSHFT")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Shift Worked")
      %else
          @DTW_ASSIGN(orderBy, "PPDESCU,PPSHFT")
          @DTW_ASSIGN(orderByDisplay, "Description, Shift Worked")
      %endif
  %elseif (sequence == "PremDept")
      %if (orderBy == "PPDEPT,PPSHFT")
          @DTW_ASSIGN(orderBy, "PPDEPT DESC,PPSHFT")
          @DTW_ASSIGN(orderByDisplay, "Department Worked (descending), Shift Worked")
      %else
          @DTW_ASSIGN(orderBy, "PPDEPT,PPSHFT")
          @DTW_ASSIGN(orderByDisplay, "Department Worked, Shift Worked")
      %endif
  %elseif (sequence == "PremAmount")
      %if (orderBy == "PPAMT,PPSHFT")
          @DTW_ASSIGN(orderBy, "PPAMT DESC,PPSHFT")
          @DTW_ASSIGN(orderByDisplay, "Premium Amount (descending), Shift Worked")
      %else
          @DTW_ASSIGN(orderBy, "PPAMT,PPSHFT")
          @DTW_ASSIGN(orderByDisplay, "Premium Amount, Shift Worked")
      %endif
  %elseif (sequence == "PremPercent")
      %if (orderBy == "PPPCT,PPSHFT")
          @DTW_ASSIGN(orderBy, "PPPCT DESC,PPSHFT")
          @DTW_ASSIGN(orderByDisplay, "Premium Percent (descending), Shift Worked")
      %else
          @DTW_ASSIGN(orderBy, "PPPCT,PPSHFT")
          @DTW_ASSIGN(orderByDisplay, "Premium Percent, Shift Worked")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchAmount, 3, 2) &&
                      editNum(document.Search.srchPercent, 3, 4))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
          <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
              <!-- Start Of Banner Code -->
              %INCLUDE "banner.icl"
              <!-- End Of Banner Code -->
              <table $(baseTable)>
                  <tr valign="top">
                      @dtw_assign(pageID, "PAYPREMSEARCH")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                      <td class="content">
                          %INCLUDE "SearchPageTitle.icl"
                          @RetHrCompNam(profileHandle, dataBaseID, prCompany, prFacility, coFacName)
                          <h2> $(coFacName) </h2>
                          $(hrTagAttr)

                          @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                          %INCLUDE "WildCardReset.icl"

                          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                              <tr><td class="dsphdr">Shift Worked</td>
                                  @dtw_assign(operNbr, "operShift")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input name="srchShift" type="text" size="2" maxlength="2"> <a href="$(homeURL)$(cGIPath)ShiftSearch.d2w/ENTRY$(d2wVarBase)&amp;docName=Search&amp;fldName=srchShift&amp;fldDesc=shiftDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="shiftDesc" value="$(codeDesc)"  type="text" size="20" maxlength="20"></td>
                              </tr>

                              <tr><td class="dsphdr">Description</td>
                                  @dtw_assign(operNbr, "operDesc")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"> <input type="text" name="srchDesc" size="20" maxlength="20"></td>
                              </tr>

                              <tr><td class="dsphdr">Department Worked</td>
                                  @dtw_assign(operNbr, "operDept")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"><input name="srchDept" type="text" size="5" maxlength="5"> <a href="$(homeURL)$(cGIPath)DepartmentSearch.d2w/ENTRY$(d2wVarBase)&amp;docName=Search&amp;fldName=srchDept&amp;fldDesc=deptDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="deptDesc" value="$(deptDesc)"  type="text" size="20" maxlength="20"></td>
                              </tr>

                              <tr><td class="dsphdr">Premium Amount</td>
                                  @dtw_assign(operNbr, "operAmount")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"> <input type="text" name="srchAmount" size="7" maxlength="7"></td>
                              </tr>

                              <tr><td class="dsphdr">Premium Percent</td>
                                  @dtw_assign(operNbr, "operPercent")
                                  <td>%INCLUDE "opersel_num_short.icl"</td>
                                  <td class="inputnmbr"> <input type="text" name="srchPercent" size="8" maxlength="8"></td>
                              </tr>

                              <tr><td class="dsphdr">Apply To Hourly</td>
                                  @dtw_assign(operNbr, "operHrly")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"> <input type="text" name="srchHrly" size="1" maxlength="1"></td>
                              </tr>

                              <tr><td class="dsphdr">Apply To Salary</td>
                                  @dtw_assign(operNbr, "operSlry")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"> <input type="text" name="srchSlry" size="1" maxlength="1"></td>
                              </tr>

                              <tr><td class="dsphdr">Process OT/DT Multipliers</td>
                                  @dtw_assign(operNbr, "operOTDT")
                                  <td>%INCLUDE "opersel_alph_short.icl"</td>
                                  <td class="inputalph"> <input type="text" name="srchOTDT" size="1" maxlength="1"></td>
                              </tr>

                              %INCLUDE "SearchBottom.icl"
                              <script TYPE="text/javascript">
                                  document.Search.srchShift.focus();
                              </script>
                          </form>
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "trailer.icl"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("PPSHFT", "Shift Worked", $(srchShift), "U", operShift, "A")
  @Build_WildCard ("upper(PPDESC)", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("PPDEPT", "Department Worked", $(srchDept), "U", operDept, "A")
  @Build_WildCard ("PPAMT", "Premium Amount", $(srchAmount), "", operAmount, "N")
  @Build_WildCard ("PPPCT", "Premium Percent", $(srchPercent), "", operPercent, "N")
  @Build_WildCard ("PPHRLY", "Apply To Hourly", $(srchHrly), "U", operHrly, "A")
  @Build_WildCard ("PPSLRY", "Apply To Salary", $(srchSlry), "U", operSlry, "A")
  @Build_WildCard ("PPOTM", "Process OT/DT Multipliers", $(srchOTDT), "U", operOTDT, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}