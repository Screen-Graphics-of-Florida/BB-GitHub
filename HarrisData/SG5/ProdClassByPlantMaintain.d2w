%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Product Class By Plant Maintenance"
  d2wName                 = "ProdClassByPlantMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;productClass=@dtw_rurlescseq(productClass)&amp;productClassDesc=@dtw_rurlescseq(productClassDesc)&amp;caller=@dtw_rurlescseq(caller)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;plantName=@dtw_rurlescseq(plantName)&amp;maintenanceCode=D"
  programName             = "HHDPCP"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "NoFormValidate.icl"
              function confirmDelete() {return confirm("$(delRecordConf)")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "PRODCLASSBYPLANTMAINT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select a.* ", stmtSQL)
						                            
						  %if ($(accountsByProdClass) == "Y")
						      @dtw_concat(stmtSQL, ", coalesce(CAFSIA,'0') as CAFSIA ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAFSIS,'0') as CAFSIS ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAVSVA,'0') as CAVSVA ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAVSVS,'0') as CAVSVS ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAUVRA,'0') as CAUVRA ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAUVRS,'0') as CAUVRS ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAWP1A,'0') as CAWP1A ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAWP1S,'0') as CAWP1S ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAWP2A,'0') as CAWP2A ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAWP2S,'0') as CAWP2S ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAWP3A,'0') as CAWP3A ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAWP3S,'0') as CAWP3S ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAWP4A,'0') as CAWP4A ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAWP4S,'0') as CAWP4S ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAWP5A,'0') as CAWP5A ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAWP5S,'0') as CAWP5S ", stmtSQL)
                              @dtw_concat(stmtSQL, ", coalesce(CAWV1A,'0') as CAWV1A ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAWV1S,'0') as CAWV1S ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAWV2A,'0') as CAWV2A ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAWV2S,'0') as CAWV2S ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAWV3A,'0') as CAWV3A ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAWV3S,'0') as CAWV3S ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAWV4A,'0') as CAWV4A ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAWV4S,'0') as CAWV4S ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAWV5A,'0') as CAWV5A ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAWV5S,'0') as CAWV5S ", stmtSQL) 	
					          @dtw_concat(stmtSQL, ", coalesce(CAMA1A,'0') as CAMA1A ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAMA1S,'0') as CAMA1S ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAMA2A,'0') as CAMA2A ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAMA2S,'0') as CAMA2S ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAMA3A,'0') as CAMA3A ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAMA3S,'0') as CAMA3S ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAMA4A,'0') as CAMA4A ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAMA4S,'0') as CAMA4S ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAMA5A,'0') as CAMA5A ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAMA5S,'0') as CAMA5S ", stmtSQL)
                              @dtw_concat(stmtSQL, ", coalesce(CAPA1A,'0') as CAPA1A ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAPA1S,'0') as CAPA1S ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAPA2A,'0') as CAPA2A ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAPA2S,'0') as CAPA2S ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAPA3A,'0') as CAPA3A ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAPA3S,'0') as CAPA3S ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAPA4A,'0') as CAPA4A ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAPA4S,'0') as CAPA4S ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAPA5A,'0') as CAPA5A ", stmtSQL) 
						      @dtw_concat(stmtSQL, ", coalesce(CAPA5S,'0') as CAPA5S ", stmtSQL) 							  
						  %endif	
						  
						  @dtw_concat(stmtSQL, " From HDPCLP a ", stmtSQL)
						  
						  %if ($(accountsByProdClass) == "Y")
						      @dtw_concat(stmtSQL, " left outer join HDPCLA on a.PPPLT=CAPLNT and a.PPPCLS=CAPCLS ", stmtSQL)
						  %endif
						  
                          @dtw_concat(stmtSQL, " Where PPPCLS='$(productClass)'", stmtSQL)
                          @dtw_concat(stmtSQL, " and PPPLT=$(plantNumber)", stmtSQL) 					  
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (caller != "Accounts")
          @dtw_assign(backURL, "$(homeURL)$(cGIPath)ProdClassByPlant.d2w/REPORT$(d2wVarBase)")
	  %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %if (plantNumber=="0")
          @dtw_assign(sec_03, "N")
      %endif
      %INCLUDE "MaintainTop.icl"
      <table $(contentTable)>
          @Format_Header_URL("Product Class", $(productClassDesc), $(productClass), "")
      </table>
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "plantNumber")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@plt@", "plantNumber")       @dtw_assign(Err_PPPLT,  fieldValue)
                          @DecatErr_Field("@@slac", "salesAcct")         @dtw_assign(Err_PPSLAC, fieldValue)
                          @DecatErr_Field("@@slsb", "salesSub")          @dtw_assign(Err_PPSLSB, fieldValue)
                          @DecatErr_Field("@@c1ac", "cat1Acct")          @dtw_assign(Err_PPC1AC, fieldValue)
                          @DecatErr_Field("@@c1sb", "cat1Sub")           @dtw_assign(Err_PPC1SB, fieldValue)
                          @DecatErr_Field("@@c2ac", "cat2Acct")          @dtw_assign(Err_PPC2AC, fieldValue)
                          @DecatErr_Field("@@c2sb", "cat2Sub")           @dtw_assign(Err_PPC2SB, fieldValue)
                          @DecatErr_Field("@@c3ac", "cat3Acct")          @dtw_assign(Err_PPC3AC, fieldValue)
                          @DecatErr_Field("@@c3sb", "cat3Sub")           @dtw_assign(Err_PPC3SB, fieldValue)
                          @DecatErr_Field("@@c4ac", "cat4Acct")          @dtw_assign(Err_PPC4AC, fieldValue)
                          @DecatErr_Field("@@c4sb", "cat4Sub")           @dtw_assign(Err_PPC4SB, fieldValue)
                          @DecatErr_Field("@@c5ac", "cat5Acct")          @dtw_assign(Err_PPC5AC, fieldValue)
                          @DecatErr_Field("@@c5sb", "cat5Sub")           @dtw_assign(Err_PPC5SB, fieldValue)
						  %if ($(accountsByProdClass) == "Y")
						      @DecatErr_Field("@@fsia", "flrStkInvAcct")        @dtw_assign(Err_CAFSIA, fieldValue)
                              @DecatErr_Field("@@fsis", "flrStkInvSub")         @dtw_assign(Err_CAFSIS, fieldValue)
                              @DecatErr_Field("@@vsva", "vndSvcVarAcct")        @dtw_assign(Err_CAVSVA, fieldValue)
                              @DecatErr_Field("@@vsvs", "vndSvcVarSub")         @dtw_assign(Err_CAVSVS, fieldValue)
                              @DecatErr_Field("@@uvra", "unvRcptAcct")          @dtw_assign(Err_CAUVRA, fieldValue)
                              @DecatErr_Field("@@uvrs", "unvRcptSub")           @dtw_assign(Err_CAUVRS, fieldValue)
						      @DecatErr_Field("@@wp1a", "wipCost1Acct")         @dtw_assign(Err_CAWP1A, fieldValue)
                              @DecatErr_Field("@@wp1s", "wipCost1Sub")          @dtw_assign(Err_CAWP1S, fieldValue)
                              @DecatErr_Field("@@wp2a", "wipCost2Acct")         @dtw_assign(Err_CAWP2A, fieldValue)
                              @DecatErr_Field("@@wp2s", "wipCost2Sub")          @dtw_assign(Err_CAWP2S, fieldValue)
                              @DecatErr_Field("@@wp3a", "wipCost3Acct")         @dtw_assign(Err_CAWP3A, fieldValue)
                              @DecatErr_Field("@@wp3s", "wipCost3Sub")          @dtw_assign(Err_CAWP3S, fieldValue)
                              @DecatErr_Field("@@wp4a", "wipCost4Acct")         @dtw_assign(Err_CAWP4A, fieldValue)
                              @DecatErr_Field("@@wp4s", "wipCost4Sub")          @dtw_assign(Err_CAWP4S, fieldValue)
                              @DecatErr_Field("@@wp5a", "wipCost5Acct")         @dtw_assign(Err_CAWP5A, fieldValue)
                              @DecatErr_Field("@@wp5s", "wipCost5Sub")          @dtw_assign(Err_CAWP5S, fieldValue)
							  @DecatErr_Field("@@wv1a", "wipVar1Acct")          @dtw_assign(Err_CAWV1A, fieldValue)
                              @DecatErr_Field("@@wv1s", "wipVar1Sub")           @dtw_assign(Err_CAWV1S, fieldValue)
                              @DecatErr_Field("@@wv2a", "wipVar2Acct")          @dtw_assign(Err_CAWV2A, fieldValue)
                              @DecatErr_Field("@@wv2s", "wipVar2Sub")           @dtw_assign(Err_CAWV2S, fieldValue)
                              @DecatErr_Field("@@wv3a", "wipVar3Acct")          @dtw_assign(Err_CAWV3A, fieldValue)
                              @DecatErr_Field("@@wv3s", "wipVar3Sub")           @dtw_assign(Err_CAWV3S, fieldValue)
                              @DecatErr_Field("@@wv4a", "wipVar4Acct")          @dtw_assign(Err_CAWV4A, fieldValue)
                              @DecatErr_Field("@@wv4s", "wipVar4Sub")           @dtw_assign(Err_CAWV4S, fieldValue)
                              @DecatErr_Field("@@wv5a", "wipVar5Acct")          @dtw_assign(Err_CAWV5A, fieldValue)
                              @DecatErr_Field("@@wv5s", "wipVar5Sub")           @dtw_assign(Err_CAWV5S, fieldValue)
						      @DecatErr_Field("@@ma1a", "mfgAbs1Acct")          @dtw_assign(Err_CAMA1A, fieldValue)
                              @DecatErr_Field("@@ma1s", "mfgAbs1Sub")           @dtw_assign(Err_CAMA1S, fieldValue)
                              @DecatErr_Field("@@ma2a", "mfgAbs2Acct")          @dtw_assign(Err_CAMA2A, fieldValue)
                              @DecatErr_Field("@@ma2s", "mfgAbs2Sub")           @dtw_assign(Err_CAMA2S, fieldValue)
                              @DecatErr_Field("@@ma3a", "mfgAbs3Acct")          @dtw_assign(Err_CAMA3A, fieldValue)
                              @DecatErr_Field("@@ma3s", "mfgAbs3Sub")           @dtw_assign(Err_CAMA3S, fieldValue)
                              @DecatErr_Field("@@ma4a", "mfgAbs4Acct")          @dtw_assign(Err_CAMA4A, fieldValue)
                              @DecatErr_Field("@@ma4s", "mfgAbs4Sub")           @dtw_assign(Err_CAMA4S, fieldValue)
                              @DecatErr_Field("@@ma5a", "mfgAbs5Acct")          @dtw_assign(Err_CAMA5A, fieldValue)
                              @DecatErr_Field("@@ma5s", "mfgAbs5Sub")           @dtw_assign(Err_CAMA5S, fieldValue)
							  @DecatErr_Field("@@pa1a", "purAbs1Acct")          @dtw_assign(Err_CAPA1A, fieldValue)
                              @DecatErr_Field("@@pa1s", "purAbs1Sub")           @dtw_assign(Err_CAPA1S, fieldValue)
                              @DecatErr_Field("@@pa2a", "purAbs2Acct")          @dtw_assign(Err_CAPA2A, fieldValue)
                              @DecatErr_Field("@@pa2s", "purAbs2Sub")           @dtw_assign(Err_CAPA2S, fieldValue)
                              @DecatErr_Field("@@pa3a", "purAbs3Acct")          @dtw_assign(Err_CAPA3A, fieldValue)
                              @DecatErr_Field("@@pa3s", "purAbs3Sub")           @dtw_assign(Err_CAPA3S, fieldValue)
                              @DecatErr_Field("@@pa4a", "purAbs4Acct")          @dtw_assign(Err_CAPA4A, fieldValue)
                              @DecatErr_Field("@@pa4s", "purAbs4Sub")           @dtw_assign(Err_CAPA4S, fieldValue)
                              @DecatErr_Field("@@pa5a", "purAbs5Acct")          @dtw_assign(Err_CAPA5A, fieldValue)
                              @DecatErr_Field("@@pa5s", "purAbs5Sub")           @dtw_assign(Err_CAPA5S, fieldValue)
					      %endif		  
                      %endif

                      @Decat_Field("@@plt@")   @dtw_assign(V_PPPLT,  fieldValue)
                      @Decat_Field("@@slac")   @dtw_assign(V_PPSLAC, fieldValue)
                      @Decat_Field("@@slsb")   @dtw_assign(V_PPSLSB, fieldValue)
                      @Decat_Field("@@c1ac")   @dtw_assign(V_PPC1AC, fieldValue)
                      @Decat_Field("@@c1sb")   @dtw_assign(V_PPC1SB, fieldValue)
                      @Decat_Field("@@c2ac")   @dtw_assign(V_PPC2AC, fieldValue)
                      @Decat_Field("@@c2sb")   @dtw_assign(V_PPC2SB, fieldValue)
                      @Decat_Field("@@c3ac")   @dtw_assign(V_PPC3AC, fieldValue)
                      @Decat_Field("@@c3sb")   @dtw_assign(V_PPC3SB, fieldValue)
                      @Decat_Field("@@c4ac")   @dtw_assign(V_PPC4AC, fieldValue)
                      @Decat_Field("@@c4sb")   @dtw_assign(V_PPC4SB, fieldValue)
                      @Decat_Field("@@c5ac")   @dtw_assign(V_PPC5AC, fieldValue)
                      @Decat_Field("@@c5sb")   @dtw_assign(V_PPC5SB, fieldValue)
					  %if ($(accountsByProdClass) == "Y")
					      @Decat_Field("@@fsia")   @dtw_assign(V_CAFSIA, fieldValue)
                          @Decat_Field("@@fsis")   @dtw_assign(V_CAFSIS, fieldValue)
                          @Decat_Field("@@vsva")   @dtw_assign(V_CAVSVA, fieldValue)
                          @Decat_Field("@@vsvs")   @dtw_assign(V_CAVSVS, fieldValue)
                          @Decat_Field("@@uvra")   @dtw_assign(V_CAUVRA, fieldValue)
                          @Decat_Field("@@uvrs")   @dtw_assign(V_CAUVRS, fieldValue)
						  @Decat_Field("@@wp1a")   @dtw_assign(V_CAWP1A, fieldValue)
                          @Decat_Field("@@wp1s")   @dtw_assign(V_CAWP1S, fieldValue)
                          @Decat_Field("@@wp2a")   @dtw_assign(V_CAWP2A, fieldValue)
                          @Decat_Field("@@wp2s")   @dtw_assign(V_CAWP2S, fieldValue)
                          @Decat_Field("@@wp3a")   @dtw_assign(V_CAWP3A, fieldValue)
                          @Decat_Field("@@wp3s")   @dtw_assign(V_CAWP3S, fieldValue)
                          @Decat_Field("@@wp4a")   @dtw_assign(V_CAWP4A, fieldValue)
                          @Decat_Field("@@wp4s")   @dtw_assign(V_CAWP4S, fieldValue)
                          @Decat_Field("@@wp5a")   @dtw_assign(V_CAWP5A, fieldValue)
                          @Decat_Field("@@wp5s")   @dtw_assign(V_CAWP5S, fieldValue)
						  @Decat_Field("@@wv1a")   @dtw_assign(V_CAWV1A, fieldValue)
                          @Decat_Field("@@wv1s")   @dtw_assign(V_CAWV1S, fieldValue)
                          @Decat_Field("@@wv2a")   @dtw_assign(V_CAWV2A, fieldValue)
                          @Decat_Field("@@wv2s")   @dtw_assign(V_CAWV2S, fieldValue)
                          @Decat_Field("@@wv3a")   @dtw_assign(V_CAWV3A, fieldValue)
                          @Decat_Field("@@wv3s")   @dtw_assign(V_CAWV3S, fieldValue)
                          @Decat_Field("@@wv4a")   @dtw_assign(V_CAWV4A, fieldValue)
                          @Decat_Field("@@wv4s")   @dtw_assign(V_CAWV4S, fieldValue)
                          @Decat_Field("@@wv5a")   @dtw_assign(V_CAWV5A, fieldValue)
                          @Decat_Field("@@wv5s")   @dtw_assign(V_CAWV5S, fieldValue)
					      @Decat_Field("@@ma1a")   @dtw_assign(V_CAMA1A, fieldValue)
                          @Decat_Field("@@ma1s")   @dtw_assign(V_CAMA1S, fieldValue)
                          @Decat_Field("@@ma2a")   @dtw_assign(V_CAMA2A, fieldValue)
                          @Decat_Field("@@ma2s")   @dtw_assign(V_CAMA2S, fieldValue)
                          @Decat_Field("@@ma3a")   @dtw_assign(V_CAMA3A, fieldValue)
                          @Decat_Field("@@ma3s")   @dtw_assign(V_CAMA3S, fieldValue)
                          @Decat_Field("@@ma4a")   @dtw_assign(V_CAMA4A, fieldValue)
                          @Decat_Field("@@ma4s")   @dtw_assign(V_CAMA4S, fieldValue)
                          @Decat_Field("@@ma5a")   @dtw_assign(V_CAMA5A, fieldValue)
                          @Decat_Field("@@ma5s")   @dtw_assign(V_CAMA5S, fieldValue)
						  @Decat_Field("@@pa1a")   @dtw_assign(V_CAPA1A, fieldValue)
                          @Decat_Field("@@pa1s")   @dtw_assign(V_CAPA1S, fieldValue)
                          @Decat_Field("@@pa2a")   @dtw_assign(V_CAPA2A, fieldValue)
                          @Decat_Field("@@pa2s")   @dtw_assign(V_CAPA2S, fieldValue)
                          @Decat_Field("@@pa3a")   @dtw_assign(V_CAPA3A, fieldValue)
                          @Decat_Field("@@pa3s")   @dtw_assign(V_CAPA3S, fieldValue)
                          @Decat_Field("@@pa4a")   @dtw_assign(V_CAPA4A, fieldValue)
                          @Decat_Field("@@pa4s")   @dtw_assign(V_CAPA4S, fieldValue)
                          @Decat_Field("@@pa5a")   @dtw_assign(V_CAPA5A, fieldValue)
                          @Decat_Field("@@pa5s")   @dtw_assign(V_CAPA5S, fieldValue)
                      %endif
					  
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "plantNumber")
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(V_PPPLT,  "")
                      @dtw_assign(focusField, "plantNumber")
                  %else
                      @dtw_assign(focusField, "salesAcct")
                  %endif

                  @SetTextOvr(Err_PPPLT)
                  %if (plantNumber=="0" && maintenanceCode != "Z")
                      @dtw_assign(fieldDesc, "Product Class Default")
                  %else
                      %if (V_PPPLT > "0")
                          @RtvFldDesc("PLPLNT=$(V_PPPLT)", "HDPLNT", "PLNAME", fieldDesc)
                      %endif
                  %endif
                  <tr><td class="dsphdr"><span $(textOvr)>Plant Number</span></td>
                      %if (maintenanceCode == "A" && plantNumber != "000" || maintenanceCode == "Z")
                           <td class="inputnmbr"><input name="plantNumber" value="$(V_PPPLT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=plantNumber&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a> <input disabled name="plantName" value="$(fieldDesc)" type="text" size="30"></td>
                      %else
                          %if (V_PPPLT == "" && plantNumber == "000")
                              @dtw_assign(V_PPPLT, "000")
                              @Format_Code(plantNumber, F_PPPLT)
                              @dtw_assign(focusField, "salesAcct")
                          %else
                              @Format_Code(V_PPPLT, F_PPPLT)
                          %endif
                          <td class="inputnmbr"><input name="plantName" value="$(fieldDesc)" type="hidden"><input name="plantNumber" type="hidden" value="$(V_PPPLT)" size="3" maxlength="3">$(fieldDesc) &nbsp; $(F_PPPLT)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_PPPLT)

                  @Default_Zero(V_PPSLAC)
                  @Default_Zero(V_PPSLSB)
