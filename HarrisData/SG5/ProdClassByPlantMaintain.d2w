                          <tr><td class="dsphdr"><span $(textOvr)>$(mfgAbs3Desc)</span></td>
                              <td class="inputnmbr"><input name="mfgAbs3Acct" value="$(V_CAMA3A)" type="text" size="4" maxlength="4"> - <input name="mfgAbs3Sub" value="$(V_CAMA3S)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=mfgAbs3Acct&amp;subFld=mfgAbs3Sub&amp;descFld=mfgAbs3AcctDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="mfgAbs3AcctDesc" value="$(acctDesc)" type="text" size="30"></td>
                          </tr>
                          @DspErrMsg(Err_CAMA3A)
                      %endif

                      %if (mfgAbs4Desc!="")
                          @Default_Zero(V_CAMA4A)
                          @Default_Zero(V_CAMA4S)
                          @RtvFldDesc("CHACCT=$(V_CAMA4A) and CHSUB=$(V_CAMA4S) ", "HDCHRT", "CHCHDS", acctDesc)
                          @SetTextOvr(Err_CAMA4A)
                          <tr><td class="dsphdr"><span $(textOvr)>$(mfgAbs4Desc)</span></td>
                              <td class="inputnmbr"><input name="mfgAbs4Acct" value="$(V_CAMA4A)" type="text" size="4" maxlength="4"> - <input name="mfgAbs4Sub" value="$(V_CAMA4S)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=mfgAbs4Acct&amp;subFld=mfgAbs4Sub&amp;descFld=mfgAbs4AcctDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="mfgAbs4AcctDesc" value="$(acctDesc)" type="text" size="30"></td>
                          </tr>
                          @DspErrMsg(Err_CAMA4A)
                      %endif
					   
					  %if (mfgAbs5Desc!="")
                          @Default_Zero(V_CAMA5A)
                          @Default_Zero(V_CAMA5S)
                          @RtvFldDesc("CHACCT=$(V_CAMA5A) and CHSUB=$(V_CAMA5S) ", "HDCHRT", "CHCHDS", acctDesc)
                          @SetTextOvr(Err_CAMA5A)
                          <tr><td class="dsphdr"><span $(textOvr)>$(mfgAbs5Desc)</span></td>
                              <td class="inputnmbr"><input name="mfgAbs5Acct" value="$(V_CAMA5A)" type="text" size="4" maxlength="4"> - <input name="mfgAbs5Sub" value="$(V_CAMA5S)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=mfgAbs5Acct&amp;subFld=mfgAbs5Sub&amp;descFld=mfgAbs5AcctDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="mfgAbs5AcctDesc" value="$(acctDesc)" type="text" size="30"></td>
                          </tr>
                          @DspErrMsg(Err_CAMA5A)
                      %endif 
					  
					  <tr><td class="dsphdr">Pur Cost Absorption Account:</td></tr>
					  @dtw_assign(purAbs1Desc, cat1Desc)
                      @dtw_assign(purAbs2Desc, cat2Desc)
                      @dtw_assign(purAbs3Desc, cat3Desc)
                      @dtw_assign(purAbs4Desc, cat4Desc)
                      @dtw_assign(purAbs5Desc, cat5Desc)
					  
					  %if (purAbs1Desc!="")
                          @Default_Zero(V_CAPA1A)
                          @Default_Zero(V_CAPA1S)
                          @RtvFldDesc("CHACCT=$(V_CAPA1A) and CHSUB=$(V_CAPA1S) ", "HDCHRT", "CHCHDS", acctDesc)
                          @SetTextOvr(Err_CAPA1A)
                          <tr><td class="dsphdr"><span $(textOvr)>$(purAbs1Desc)</span></td>
                              <td class="inputnmbr"><input name="purAbs1Acct" value="$(V_CAPA1A)" type="text" size="4" maxlength="4"> - <input name="purAbs1Sub" value="$(V_CAPA1S)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=purAbs1Acct&amp;subFld=purAbs1Sub&amp;descFld=purAbs1AcctDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="purAbs1AcctDesc" value="$(acctDesc)" type="text" size="30"></td>
                          </tr>
                          @DspErrMsg(Err_CAPA1A)
                      %endif

                      %if (purAbs2Desc!="")
                          @Default_Zero(V_CAPA2A)
                          @Default_Zero(V_CAPA2S)
                          @RtvFldDesc("CHACCT=$(V_CAPA2A) and CHSUB=$(V_CAPA2S) ", "HDCHRT", "CHCHDS", acctDesc)
                          @SetTextOvr(Err_CAPA2A)
                          <tr><td class="dsphdr"><span $(textOvr)>$(purAbs2Desc)</span></td>
                              <td class="inputnmbr"><input name="purAbs2Acct" value="$(V_CAPA2A)" type="text" size="4" maxlength="4"> - <input name="purAbs2Sub" value="$(V_CAPA2S)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=purAbs2Acct&amp;subFld=purAbs2Sub&amp;descFld=purAbs2AcctDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="purAbs2AcctDesc" value="$(acctDesc)" type="text" size="30"></td>
                          </tr>
                          @DspErrMsg(Err_CAPA2A)
                      %endif
					   
					  %if (purAbs3Desc!="")
                          @Default_Zero(V_CAPA3A)
                          @Default_Zero(V_CAPA3S)
                          @RtvFldDesc("CHACCT=$(V_CAPA3A) and CHSUB=$(V_CAPA3S) ", "HDCHRT", "CHCHDS", acctDesc)
                          @SetTextOvr(Err_CAPA3A)
                          <tr><td class="dsphdr"><span $(textOvr)>$(purAbs3Desc)</span></td>
                              <td class="inputnmbr"><input name="purAbs3Acct" value="$(V_CAPA3A)" type="text" size="4" maxlength="4"> - <input name="purAbs3Sub" value="$(V_CAPA3S)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=purAbs3Acct&amp;subFld=purAbs3Sub&amp;descFld=purAbs3AcctDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="purAbs3AcctDesc" value="$(acctDesc)" type="text" size="30"></td>
                          </tr>
                          @DspErrMsg(Err_CAPA3A)
                      %endif

                      %if (purAbs4Desc!="")
                          @Default_Zero(V_CAPA4A)
                          @Default_Zero(V_CAPA4S)
                          @RtvFldDesc("CHACCT=$(V_CAPA4A) and CHSUB=$(V_CAPA4S) ", "HDCHRT", "CHCHDS", acctDesc)
                          @SetTextOvr(Err_CAPA4A)
                          <tr><td class="dsphdr"><span $(textOvr)>$(purAbs4Desc)</span></td>
                              <td class="inputnmbr"><input name="purAbs4Acct" value="$(V_CAPA4A)" type="text" size="4" maxlength="4"> - <input name="purAbs4Sub" value="$(V_CAPA4S)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=purAbs4Acct&amp;subFld=purAbs4Sub&amp;descFld=purAbs4AcctDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="purAbs4AcctDesc" value="$(acctDesc)" type="text" size="30"></td>
                          </tr>
                          @DspErrMsg(Err_CAPA4A)
                      %endif
					   
					  %if (purAbs5Desc!="")
                          @Default_Zero(V_CAPA5A)
                          @Default_Zero(V_CAPA5S)
                          @RtvFldDesc("CHACCT=$(V_CAPA5A) and CHSUB=$(V_CAPA5S) ", "HDCHRT", "CHCHDS", acctDesc)
                          @SetTextOvr(Err_CAPA5A)
                          <tr><td class="dsphdr"><span $(textOvr)>$(purAbs5Desc)</span></td>
                              <td class="inputnmbr"><input name="purAbs5Acct" value="$(V_CAPA5A)" type="text" size="4" maxlength="4"> - <input name="purAbs5Sub" value="$(V_CAPA5S)" type="text" size="4" maxlength="4"> <a href="$(homeURL)$(phpPath)AccountSearch.php$(altVarBase)&amp;docName=Chg&amp;acctFld=purAbs5Acct&amp;subFld=purAbs5Sub&amp;descFld=purAbs5AcctDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input disabled name="purAbs5AcctDesc" value="$(acctDesc)" type="text" size="30"></td>
                          </tr>
                          @DspErrMsg(Err_CAPA5A)
                      %endif 
				  %endif
              %}
          </table>
	
          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HHDPCP_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  @dtw_mUPPERCASE(productClass)

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@pcls", productClass)
  @Concat_Field("@@plt@", plantNumber)
  @Concat_Field("@@slac", salesAcct)
  @Concat_Field("@@slsb", salesSub)
  @Concat_Field("@@c1ac", cat1Acct)
  @Concat_Field("@@c1sb", cat1Sub)
  @Concat_Field("@@c2ac", cat2Acct)
  @Concat_Field("@@c2sb", cat2Sub)
  @Concat_Field("@@c3ac", cat3Acct)
  @Concat_Field("@@c3sb", cat3Sub)
  @Concat_Field("@@c4ac", cat4Acct)
  @Concat_Field("@@c4sb", cat4Sub)
  @Concat_Field("@@c5ac", cat5Acct)
  @Concat_Field("@@c5sb", cat5Sub)
  @Concat_Field("@@aflg", $(accountsByProdClass))
  %if ($(accountsByProdClass) == "Y")
      @Concat_Field("@@fsia", flrStkInvAcct)
      @Concat_Field("@@fsis", flrStkInvSub) 
      @Concat_Field("@@vsva", vndSvcVarAcct) 
      @Concat_Field("@@vsvs", vndSvcVarSub)  
      @Concat_Field("@@uvra", unvRcptAcct) 
      @Concat_Field("@@uvrs", unvRcptSub) 
	  @Concat_Field("@@wp1a", wipCost1Acct)  
      @Concat_Field("@@wp1s", wipCost1Sub)
      @Concat_Field("@@wp2a", wipCost2Acct)
      @Concat_Field("@@wp2s", wipCost2Sub)
      @Concat_Field("@@wp3a", wipCost3Acct)
      @Concat_Field("@@wp3s", wipCost3Sub)
      @Concat_Field("@@wp4a", wipCost4Acct)
      @Concat_Field("@@wp4s", wipCost4Sub)
      @Concat_Field("@@wp5a", wipCost5Acct)
      @Concat_Field("@@wp5s", wipCost5Sub)
	  @Concat_Field("@@wv1a", wipVar1Acct)
      @Concat_Field("@@wv1s", wipVar1Sub)
      @Concat_Field("@@wv2a", wipVar2Acct)
      @Concat_Field("@@wv2s", wipVar2Sub) 
      @Concat_Field("@@wv3a", wipVar3Acct)
      @Concat_Field("@@wv3s", wipVar3Sub)
      @Concat_Field("@@wv4a", wipVar4Acct)
      @Concat_Field("@@wv4s", wipVar4Sub) 
      @Concat_Field("@@wv5a", wipVar5Acct)
      @Concat_Field("@@wv5s", wipVar5Sub)
	  @Concat_Field("@@ma1a", mfgAbs1Acct)
      @Concat_Field("@@ma1s", mfgAbs1Sub)  
      @Concat_Field("@@ma2a", mfgAbs2Acct)
      @Concat_Field("@@ma2s", mfgAbs2Sub) 
      @Concat_Field("@@ma3a", mfgAbs3Acct)
      @Concat_Field("@@ma3s", mfgAbs3Sub)
      @Concat_Field("@@ma4a", mfgAbs4Acct) 
      @Concat_Field("@@ma4s", mfgAbs4Sub) 
      @Concat_Field("@@ma5a", mfgAbs5Acct)
      @Concat_Field("@@ma5s", mfgAbs5Sub)
	  @Concat_Field("@@pa1a", purAbs1Acct) 
      @Concat_Field("@@pa1s", purAbs1Sub)
      @Concat_Field("@@pa2a", purAbs2Acct)
      @Concat_Field("@@pa2s", purAbs2Sub)
      @Concat_Field("@@pa3a", purAbs3Acct)
      @Concat_Field("@@pa3s", purAbs3Sub)
      @Concat_Field("@@pa4a", purAbs4Acct)
      @Concat_Field("@@pa4s", purAbs4Sub) 
      @Concat_Field("@@pa5a", purAbs5Acct) 
      @Concat_Field("@@pa5s", purAbs5Sub) 
  %endif	  
      @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, $(plantName), $(plantNumber), "", "", "", "", confMessage)
      %if (backURL != "" && caller == "Accounts")
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)ProdClassByPlant.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif 
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@pcls", "productClass")
	  @Format_ConfMsg_Desc("", $(productClassDesc), $(productClass), "<br>$(fieldValue)", "", "", "", confMessage)
	  %if (backURL != "" && caller == "Accounts")
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)ProdClassByPlant.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif 
  %else
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}

