%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "State Reportable Earnings"
  d2wName                 = "StateEarningsReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  programName             = "HPRCHI"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  %INCLUDE "SelEmplActiveTerm.icl"
                  if (
                      editNum(document.Chg.fromCompany, 2, 0) &&
                      editNum(document.Chg.toCompany, 2, 0) &&
                      editNum(document.Chg.fromFacility, 4, 0) &&
                      editNum(document.Chg.toFacility, 4, 0) &&
                      editNum(document.Chg.fromPrEmpl, 5, 0) &&
                      editNum(document.Chg.toPrEmpl, 5, 0) &&
                      editNum(document.Chg.fromHrEmpl, 9, 0) &&
                      editNum(document.Chg.toHrEmpl, 9, 0) &&
                      editdate(document.Chg.fromCheckDate) &&
                      editdate(document.Chg.toCheckDate) &&
                      editFromToAll(document.Chg.fromCompany, document.Chg.toCompany, document.Chg.allCompany,2) &&
                      editFromToAll(document.Chg.fromFacility, document.Chg.toFacility, document.Chg.allFacility,4) &&
                      editFromToAll(document.Chg.fromLocation, document.Chg.toLocation, document.Chg.allLocation,"A") &&
                      editFromToAll(document.Chg.fromDepartment, document.Chg.toDepartment, document.Chg.allDepartment,"A") &&
                      editFromToAll(document.Chg.fromPrEmpl, document.Chg.toPrEmpl, document.Chg.allPrEmpl,5) &&
                      editFromToAll(document.Chg.fromHrEmpl, document.Chg.toHrEmpl, document.Chg.allHrEmpl,9) &&
                      editFromToAll(document.Chg.fromCheckDate, document.Chg.toCheckDate, document.Chg.allCheckDate,"D") &&
                      editFromToAll(document.Chg.fromHistDept, document.Chg.toHistDept, document.Chg.allHistDept,"A") &&
                      editFromToAll(document.Chg.fromStateId, document.Chg.toStateId, document.Chg.allStateId,"A") &&
                      editFromToAll(document.Chg.fromSuiId, document.Chg.toSuiId, document.Chg.allSuiId,"A") &&
                      editFromToAll(document.Chg.fromSdiId, document.Chg.toSdiId, document.Chg.allSdiId,"A") &&
                      editFromToAll(document.Chg.fromSwcId, document.Chg.toSwcId, document.Chg.allSwcId,"A"))
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "STATEEARNRP")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                     <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                         <table $(contentTable)>
                             @dtw_assign(focusField, "fromCompany")
                             %if (errFound != "" || scheduleJobSwitch == "Y")
                                 @EdtVarErr(profileHandle, typeValue, edtVar)
                                 @dtw_assign(focusField, "")
                                 @ErrVarErr(profileHandle, typeError, errVar)
                                 @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)

                                 @DecatErr_Field("@@rpcn", "reportContent")    @dtw_assign(Err_SLRPCN,  fieldValue)

                                 %INCLUDE "SelEmplDecatErr.icl"   %{ Decat Employee Report Selection Errors %}

                                 @DecatErr_Field("@@fdat", "fromCheckDate")    @dtw_assign(Err_SLFDAT,  fieldValue)
                                 @DecatErr_Field("@@tdat", "toCheckDate")      @dtw_assign(Err_SLTDAT,  fieldValue)
                                 @DecatErr_Field("@@adat", "allCheckDate")     @dtw_assign(Err_SLADAT,  fieldValue)

                                 @DecatErr_Field("@@fhdp", "fromHistDept")     @dtw_assign(Err_SLFHDP,  fieldValue)
                                 @DecatErr_Field("@@thdp", "toHistDept")       @dtw_assign(Err_SLTHDP,  fieldValue)
                                 @DecatErr_Field("@@ahdp", "allHistDept")      @dtw_assign(Err_SLAHDP,  fieldValue)

                                 @DecatErr_Field("@@fsit", "fromStateId")      @dtw_assign(Err_SLFSIT,  fieldValue)
                                 @DecatErr_Field("@@tsit", "toStateId")        @dtw_assign(Err_SLTSIT,  fieldValue)
                                 @DecatErr_Field("@@asit", "allStateId")       @dtw_assign(Err_SLASIT,  fieldValue)

                                 @DecatErr_Field("@@fsui", "fromSuiId")        @dtw_assign(Err_SLFSUI,  fieldValue)
                                 @DecatErr_Field("@@tsui", "toSuiId")          @dtw_assign(Err_SLTSUI,  fieldValue)
                                 @DecatErr_Field("@@asui", "allSuiId")         @dtw_assign(Err_SLASUI,  fieldValue)

                                 @DecatErr_Field("@@fsdi", "fromSdiId")        @dtw_assign(Err_SLFSDI,  fieldValue)
                                 @DecatErr_Field("@@tsdi", "toSdiId")          @dtw_assign(Err_SLTSDI,  fieldValue)
                                 @DecatErr_Field("@@asdi", "allSdiId")         @dtw_assign(Err_SLASDI,  fieldValue)

                                 @DecatErr_Field("@@fswc", "fromSwcId")        @dtw_assign(Err_SLFSWC,  fieldValue)
                                 @DecatErr_Field("@@tswc", "toSwcId")          @dtw_assign(Err_SLTSWC,  fieldValue)
                                 @DecatErr_Field("@@aswc", "allSwcId")         @dtw_assign(Err_SLASWC,  fieldValue)

                                 %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}

                                 @Decat_Field("@@rpcn")   @dtw_assign(V_SLRPCN,  fieldValue)

                                 %INCLUDE "SelEmplDecatSel.icl"   %{ Decat Employee Report Selections %}

                                 @Decat_Field("@@fdat")   @dtw_assign(V_SLFDAT,  fieldValue)
                                 @Decat_Field("@@tdat")   @dtw_assign(V_SLTDAT,  fieldValue)
                                 @Decat_Field("@@adat")   @dtw_assign(V_SLADAT,  fieldValue)

                                 @Decat_Field("@@fhdp")   @dtw_assign(V_SLFHDP,  fieldValue)
                                 @Decat_Field("@@thdp")   @dtw_assign(V_SLTHDP,  fieldValue)
                                 @Decat_Field("@@ahdp")   @dtw_assign(V_SLAHDP,  fieldValue)

                                 @Decat_Field("@@fsit")   @dtw_assign(V_SLFSIT,  fieldValue)
                                 @Decat_Field("@@tsit")   @dtw_assign(V_SLTSIT,  fieldValue)
                                 @Decat_Field("@@asit")   @dtw_assign(V_SLASIT,  fieldValue)

                                 @Decat_Field("@@fsui")   @dtw_assign(V_SLFSUI,  fieldValue)
                                 @Decat_Field("@@tsui")   @dtw_assign(V_SLTSUI,  fieldValue)
                                 @Decat_Field("@@asui")   @dtw_assign(V_SLASUI,  fieldValue)

                                 @Decat_Field("@@fsdi")   @dtw_assign(V_SLFSDI,  fieldValue)
                                 @Decat_Field("@@tsdi")   @dtw_assign(V_SLTSDI,  fieldValue)
                                 @Decat_Field("@@asdi")   @dtw_assign(V_SLASDI,  fieldValue)

                                 @Decat_Field("@@fswc")   @dtw_assign(V_SLFSWC,  fieldValue)
                                 @Decat_Field("@@tswc")   @dtw_assign(V_SLTSWC,  fieldValue)
                                 @Decat_Field("@@aswc")   @dtw_assign(V_SLASWC,  fieldValue)

                                 %INCLUDE "ScheduleJobValue.icl"  %{ Schedule Entries Values %}
                                 %if (V_SLRPCN == "02")
                                     @dtw_assign(byDept, "")
                                     @dtw_assign(byStateId, "CHECKED")
                                     @dtw_assign(bySuiId, "")
                                     @dtw_assign(bySdiId, "")
                                     @dtw_assign(bySwcId, "")
                                     @dtw_assign(byEmployee, "")
                                 %elif (V_SLRPCN == "03")
                                     @dtw_assign(byDept, "")
                                     @dtw_assign(byStateId, "")
                                     @dtw_assign(bySuiId, "CHECKED")
                                     @dtw_assign(bySdiId, "")
                                     @dtw_assign(bySwcId, "")
                                     @dtw_assign(byEmployee, "")
                                 %elif (V_SLRPCN == "04")
                                     @dtw_assign(byDept, "")
                                     @dtw_assign(byStateId, "")
                                     @dtw_assign(bySuiId, "")
                                     @dtw_assign(bySdiId, "CHECKED")
                                     @dtw_assign(bySwcId, "")
                                     @dtw_assign(byEmployee, "")
                                 %elif (V_SLRPCN == "05")
                                     @dtw_assign(byDept, "")
                                     @dtw_assign(byStateId, "")
                                     @dtw_assign(bySuiId, "")
                                     @dtw_assign(bySdiId, "")
                                     @dtw_assign(bySwcId, "CHECKED")
                                     @dtw_assign(byEmployee, "")
                                 %elif (V_SLRPCN == "06")
                                     @dtw_assign(byDept, "")
                                     @dtw_assign(byStateId, "")
                                     @dtw_assign(bySuiId, "")
                                     @dtw_assign(bySdiId, "")
                                     @dtw_assign(bySwcId, "")
                                     @dtw_assign(byEmployee, "CHECKED")
                                 %else
                                     @dtw_assign(byDept, "CHECKED")
                                     @dtw_assign(byStateId, "")
                                     @dtw_assign(bySuiId, "")
                                     @dtw_assign(bySdiId, "")
                                     @dtw_assign(bySwcId, "")
                                     @dtw_assign(byEmployee, "")
                                 %endif
                                 %if (V_SLASIT == "ALL")
                                     @dtw_assign(checkedStateId, "CHECKED")
                                 %else
                                     @dtw_assign(checkedStateId, "")
                                 %endif
                                 %if (V_SLASUI == "ALL")
                                     @dtw_assign(checkedSuiId, "CHECKED")
                                 %else
                                     @dtw_assign(checkedSuiId, "")
                                 %endif
                                 %if (V_SLASDI == "ALL")
                                     @dtw_assign(checkedSdiId, "CHECKED")
                                 %else
                                     @dtw_assign(checkedSdiId, "")
                                 %endif
                                 %if (V_SLASWC == "ALL")
                                     @dtw_assign(checkedSwcId, "CHECKED")
                                 %else
                                     @dtw_assign(checkedSwcId, "")
                                 %endif
                                 %if (V_SLADAT == "ALL")
                                     @dtw_assign(checkedCheckDate, "CHECKED")
                                 %else
                                     @dtw_assign(checkedCheckDate, "")
                                 %endif
                                 %if (V_SLAHDP == "ALL")
                                     @dtw_assign(checkedHistDept, "CHECKED")
                                 %else
                                     @dtw_assign(checkedHistDept, "")
                                 %endif
                             %else
                                 @dtw_assign(byDept, "CHECKED")
                                 @dtw_assign(byStateId, "")
                                 @dtw_assign(bySuiId, "")
                                 @dtw_assign(bySdiId, "")
                                 @dtw_assign(bySwcId, "")
                                 @dtw_assign(byEmployee, "")
                                 @dtw_assign(checkedStateId, "CHECKED")
                                 @dtw_assign(checkedSuiId, "CHECKED")
                                 @dtw_assign(checkedSdiId, "CHECKED")
                                 @dtw_assign(checkedSwcId, "CHECKED")
                                 @dtw_assign(checkedCheckDate, "CHECKED")
                                 @dtw_assign(checkedHistDept, "CHECKED")
                             %endif

                             @SetTextOvr(Err_SLRPCN)
                             <tr><td class="dsphdr"><span $(textOvr)>Report Sequence Selection</span></td>
                                 <td class="inputnmbr"><input name="reportContent" type="radio" VALUE='01' $(byDept)>Department</td>
                             </tr>
                             @DspErrMsg(Err_SLRPSQ)

                             <tr><td>&nbsp;</td>
                                 <td class="inputnmbr"><input name="reportContent" type="radio" VALUE='02' $(byStateId)>State ID</td>
                             </tr>

                             <tr><td>&nbsp;</td>
                                 <td class="inputnmbr"><input name="reportContent" type="radio" VALUE='03' $(bySuiId)>SUI ID</td>
                             </tr>

                             <tr><td>&nbsp;</td>
                                 <td class="inputnmbr"><input name="reportContent" type="radio" VALUE='04' $(bySdiId)>SDI ID</td>
                             </tr>

                             <tr><td>&nbsp;</td>
                                 <td class="inputnmbr"><input name="reportContent" type="radio" VALUE='05' $(bySwcId)>SWC ID</td>
                             </tr>

                             <tr><td>&nbsp;</td>
                                 <td class="inputnmbr"><input name="reportContent" type="radio" VALUE='06' $(byEmployee)>Employee</td>
                             </tr>

                              %INCLUDE "SelEmplCheckBoxes.icl"     %{ Set Employee Report Selection Check Box Values %}

                              @dtw_assign(scheduleJobSwitch, "")
                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>

                              %INCLUDE "SelEmplSetText.icl"       %{ Employee Report Selection Fields %}

                              @SetTextOvr(Err_SLFSIT)
                              %if (textOvr == "") @SetTextOvr(Err_SLTSIT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_SLASIT) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>State ID</span></td>
                                  <td class="inputalph"><input name="fromStateId" VALUE="$(V_SLFSIT)"type="text" size="5" maxlength="2"> <a href="$(homeURL)$(phpPath)StateSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromStateId&amp;fldDesc=stateDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="stateDesc" value="$(fieldDesc)" type="hidden" size="35" disabled></td>
                                  <td class="inputalph"><input name="toStateId" VALUE="$(V_SLTSIT)" type="text" size="5" maxlength="2"> <a href="$(homeURL)$(phpPath)StateSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toStateId&amp;fldDesc=stateDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="stateDesc" value="$(fieldDesc)" type="hidden" size="35" disabled></td>
                                  <td class="inputalph"><input name="allStateId" VALUE='ALL' $(checkedStateId) type="checkbox" onClick="if (this.checked) this.form.fromStateId.value='', this.form.toStateId.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_SLFSIT)
                              @DspErrMsg(Err_SLTSIT)
                              @DspErrMsg(Err_SLASIT)

                              @SetTextOvr(Err_SLFSUI)
                              %if (textOvr == "") @SetTextOvr(Err_SLTSUI) %endif
                              %if (textOvr == "") @SetTextOvr(Err_SLASUI) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>SUI ID</span></td>
                                  <td class="inputalph"><input name="fromSuiId" VALUE="$(V_SLFSUI)"type="text" size="5" maxlength="2"> <a href="$(homeURL)$(phpPath)StateSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromSuiId&amp;fldDesc=stateDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="stateDesc" value="$(fieldDesc)" type="hidden" size="35" disabled></td>
                                  <td class="inputalph"><input name="toSuiId" VALUE="$(V_SLTSUI)" type="text" size="5" maxlength="2"> <a href="$(homeURL)$(phpPath)StateSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toSuiId&amp;fldDesc=stateDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="stateDesc" value="$(fieldDesc)" type="hidden" size="35" disabled></td>
                                  <td class="inputalph"><input name="allSuiId" VALUE='ALL' $(checkedSuiId) type="checkbox" onClick="if (this.checked) this.form.fromSuiId.value='', this.form.toSuiId.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_SLFSUI)
                              @DspErrMsg(Err_SLTSUI)
                              @DspErrMsg(Err_SLASUI)

                              @SetTextOvr(Err_SLFSDI)
                              %if (textOvr == "") @SetTextOvr(Err_SLTSDI) %endif
                              %if (textOvr == "") @SetTextOvr(Err_SLASDI) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>SDI ID</span></td>
                                  <td class="inputalph"><input name="fromSdiId" VALUE="$(V_SLFSDI)"type="text" size="5" maxlength="2"> <a href="$(homeURL)$(phpPath)StateSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromSdiId&amp;fldDesc=stateDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="stateDesc" value="$(fieldDesc)" type="hidden" size="35" disabled></td>
                                  <td class="inputalph"><input name="toSdiId" VALUE="$(V_SLTSDI)" type="text" size="5" maxlength="2"> <a href="$(homeURL)$(phpPath)StateSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toSdiId&amp;fldDesc=stateDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="stateDesc" value="$(fieldDesc)" type="hidden" size="35" disabled></td>
                                  <td class="inputalph"><input name="allSdiId" VALUE='ALL' $(checkedSdiId) type="checkbox" onClick="if (this.checked) this.form.fromSdiId.value='', this.form.toSdiId.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_SLFSDI)
                              @DspErrMsg(Err_SLTSDI)
                              @DspErrMsg(Err_SLASDI)

                              @SetTextOvr(Err_SLFSWC)
                              %if (textOvr == "") @SetTextOvr(Err_SLTSWC) %endif
                              %if (textOvr == "") @SetTextOvr(Err_SLASWC) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>SWC ID</span></td>
                                  <td class="inputalph"><input name="fromSwcId" VALUE="$(V_SLFSWC)"type="text" size="5" maxlength="2"> <a href="$(homeURL)$(phpPath)StateSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromSwcId&amp;fldDesc=stateDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="stateDesc" value="$(fieldDesc)" type="hidden" size="35" disabled></td>
                                  <td class="inputalph"><input name="toSwcId" VALUE="$(V_SLTSWC)" type="text" size="5" maxlength="2"> <a href="$(homeURL)$(phpPath)StateSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toSwcId&amp;fldDesc=stateDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="stateDesc" value="$(fieldDesc)" type="hidden" size="35" disabled></td>
                                  <td class="inputalph"><input name="allSwcId" VALUE='ALL' $(checkedSwcId) type="checkbox" onClick="if (this.checked) this.form.fromSwcId.value='', this.form.toSwcId.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_SLFSWC)
                              @DspErrMsg(Err_SLTSWC)
                              @DspErrMsg(Err_SLASWC)

                              @SetTextOvr(Err_SLFDAT)
                              %if (textOvr == "") @SetTextOvr(Err_SLTDAT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_SLADAT) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Check Date</span></td>
                                  <td class="inputnmbr"><input type="text" name="fromCheckDate" VALUE="$(V_SLFDAT)" size="5" maxlength="6"> 		
                                      <a href="javascript:calWindow('fromCheckDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input type="text" name="toCheckDate" VALUE="$(V_SLTDAT)" size="5" maxlength="6"> 		
                                      <a href="javascript:calWindow('toCheckDate');">$(calendarImage)</a></td>
                                  <td class="inputnmbr"><input name="allCheckDate" VALUE='ALL' $(checkedCheckDate) type="checkbox" onClick="if (this.checked) this.form.fromCheckDate.value='', this.form.toCheckDate.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_SLFDAT)
                              @DspErrMsg(Err_SLTDAT)
                              @DspErrMsg(Err_SLADAT)

                              @SetTextOvr(Err_SLFHDP)
                              %if (textOvr == "") @SetTextOvr(Err_SLTHDP) %endif
                              %if (textOvr == "") @SetTextOvr(Err_SLAHDP) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Check History Department</span></td>
                                  <td class="inputalph"><input name="fromHistDept" value="$(V_SLFHDP)" type="text" size="5" maxlength="5"> <a href="$(homeURL)$(phpPath)DepartmentSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromHistDept&amp;fldDesc=fromDeptDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input  name="fromDeptDesc" value="$(fromDeptDesc)"  type="hidden" size="20" maxlength="20"></td>
                                  <td class="inputalph"><input name="toHistDept"   value="$(V_SLTHDP)" type="text" size="5" maxlength="5"> <a href="$(homeURL)$(phpPath)DepartmentSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toHistDept&amp;fldDesc=toDeptDesc" onclick="$(searchWinVar)"> $(searchImage) </a> <input  name="toDeptDesc" value="$(toDeptDesc)"  type="hidden" size="20" maxlength="20"></td>
                                  <td class="inputalph"><input name="allHistDept" VALUE='ALL' $(checkedHistDept) type="checkbox" onClick="if (this.checked) this.form.fromHistDept.value='', this.form.toHistDept.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_SLFHDP)
                              @DspErrMsg(Err_SLTHDP)
                              @DspErrMsg(Err_SLAHDP)

                          </table>
                          @dtw_assign(envProgram, "HPRSRR")
                          @dtw_assign(envPrinter, "QSYSPRT ")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HPRSRC_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if ((sec_05 == "N") || (sec_06 == "N") || (sec_07 == "N"))
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL()
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  %if (byDept != "1")
      @dtw_assign(byDept, "0")
  %endif
  %if (byStateId != "1")
      @dtw_assign(byStateId, "0")
  %endif

  %INCLUDE "SelEmplEdit.icl"       %{ Prepare Employee Report Selections For Edit %}

  @dtw_mUPPERCASE(fromStateId)
  @dtw_mUPPERCASE(toStateId)
  @dtw_mUPPERCASE(allStateId)
  %if (allStateId != "ALL")
      @dtw_assign(allStateId, "")
  %endif

  @dtw_mUPPERCASE(fromSuiId)
  @dtw_mUPPERCASE(toSuiId)
  @dtw_mUPPERCASE(allSuiId)
  %if (allSuiId != "ALL")
      @dtw_assign(allSuiId, "")
  %endif

  @dtw_mUPPERCASE(fromSdiId)
  @dtw_mUPPERCASE(toSdiId)
  @dtw_mUPPERCASE(allSdiId)
  %if (allSdiId != "ALL")
      @dtw_assign(allSdiId, "")
  %endif

  @dtw_mUPPERCASE(fromSwcId)
  @dtw_mUPPERCASE(toSwcId)
  @dtw_mUPPERCASE(allSwcId)
  %if (allSwcId != "ALL")
      @dtw_assign(allSwcId, "")
  %endif

  @dtw_mUPPERCASE(allCheckDate)
  @dtw_assign(fromCheckDate,@dtw_rstrip(fromCheckDate))
  @dtw_assign(toCheckDate,@dtw_rstrip(toCheckDate))
  %if (allCheckDate != "ALL")
      @dtw_assign(allCheckDate, "")
  %endif

  @dtw_mUPPERCASE(fromHistDept)
  @dtw_mUPPERCASE(toHistDept)
  @dtw_mUPPERCASE(allHistDept)
  %if (allHistDept != "ALL")
      @dtw_assign(allHistDept, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@rpcn", reportContent)

  %INCLUDE "SelEmplConcat.icl"       %{ Concat Employee Report Selections For Edit %}

  @Concat_Field("@@fsit", fromStateId)
  @Concat_Field("@@tsit", toStateId)
  @Concat_Field("@@asit", allStateId)

  @Concat_Field("@@fsui", fromSuiId)
  @Concat_Field("@@tsui", toSuiId)
  @Concat_Field("@@asui", allSuiId)

  @Concat_Field("@@fsdi", fromSdiId)
  @Concat_Field("@@tsdi", toSdiId)
  @Concat_Field("@@asdi", allSdiId)

  @Concat_Field("@@fswc", fromSwcId)
  @Concat_Field("@@tswc", toSwcId)
  @Concat_Field("@@aswc", allSwcId)

  @Concat_Field("@@fdat", fromCheckDate)
  @Concat_Field("@@tdat", toCheckDate)
  @Concat_Field("@@adat", allCheckDate)

  @Concat_Field("@@fhdp", fromHistDept)
  @Concat_Field("@@thdp", toHistDept)
  @Concat_Field("@@ahdp", allHistDept)

  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)
  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}