%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "YNFlagTable.icl"

%Define {
  page_title              = "Period Begin/End Dates Maintenance"
  d2wName                 = "PeriodBeginEndDatesMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;periodNumber=@dtw_rurlescseq(periodNumber)&amp;maintenanceCode=D"
  programName             = "HGLPDU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "dateedit.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              function confirmDelete() {return confirm("$(delRecordConf)")}
              function validate(searchForm) {
                  if (document.Chg.periodNumber.value =="" ||
                      document.Chg.beginDate.value =="" ||
                      document.Chg.endDate.value =="")
                         {alert("$(reqFieldError)"); return false;}
                  if (editNum(document.Chg.periodNumber, 4, 0) &&
                      editdate(document.Chg.beginDate) &&
                      editdate(document.Chg.endDate) &&
                      editNum(document.Chg.workingDays, 2, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "PERIODBEGENDMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, "Select * From HDPBED Where PDPER#=$(periodNumber)", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          @dtw_assign(backURL, "$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=117")
      %endif
      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"
			
      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                          @dtw_assign(focusField, "periodNumber")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @DecatErr_Field("@@per#", "periodNumber")  @dtw_assign(Err_PDPER#, fieldValue)
                          @DecatErr_Field("@@bdat", "beginDate")     @dtw_assign(Err_PDBDAT, fieldValue)
                          @DecatErr_Field("@@edat", "endDate")       @dtw_assign(Err_PDEDAT, fieldValue)
                          @DecatErr_Field("@@wkdy", "workingDays")   @dtw_assign(Err_PDWKDY, fieldValue)
                      %endif

                      @Decat_Field("@@per#")   @dtw_assign(V_PDPER#, fieldValue)
                      @Decat_Field("@@bdat")   @dtw_assign(V_PDBDAT, fieldValue)
                      @Decat_Field("@@edat")   @dtw_assign(V_PDEDAT, fieldValue)
                      @Decat_Field("@@wkdy")   @dtw_assign(V_PDWKDY, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(focusField, "periodNumber")
                          @dtw_assign(V_PDWKDY,  "22")
                      %endif

                      @dtw_assign(errFound, "")

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(V_PDPER#,  "")
                      @dtw_assign(focusField, "periodNumber")
                      @dtw_assign(F_PDPER#,  V_PDPER#)
                      @PeriodFromCYP(F_PDPER#)
                      @PeriodInputFromCYP(V_PDPER#)
                      @DateInputFromCYMD(V_PDBDAT)
                      @DateInputFromCYMD(V_PDEDAT)
                  %else
                      @dtw_assign(focusField, "beginDate")
                      @dtw_assign(F_PDPER#,  V_PDPER#)
                      @PeriodFromCYP(F_PDPER#)
                      @PeriodInputFromCYP(V_PDPER#)
                      @DateInputFromCYMD(V_PDBDAT)
                      @DateInputFromCYMD(V_PDEDAT)
                  %endif

                  @SetTextOvr(Err_PDPER#)
                  <tr><td class="dsphdr"><span $(textOvr)>Period Number</span></td>
                      %if (maintenanceCode == "A" || maintenanceCode == "Z")
                          <td class="inputalph"><input name="periodNumber" type="text" value="$(V_PDPER#)" size="4" maxlength="4">$(reqFieldChar)</td>
                      %else
                          <td class="inputalph"><input name="periodNumber" type="hidden" value="$(V_PDPER#)" size="4" maxlength="4">$(F_PDPER#)</td>
                      %endif
                  </tr>
                  @DspErrMsg(Err_PDPER#)

                  @SetTextOvr(Err_PDBDAT)
	           <tr><td class="dsphdr"><span $(textOvr)>Begin Date</span></td>
                      <td class="inputnmbr"><input type="text" name="beginDate" value="$(V_PDBDAT)" size="6" maxlength="6"> 		
                          <a href="javascript:calWindow('beginDate');">$(reqFieldChar)$(calendarImage)</a></td>
                  </tr>
                  @DspErrMsg(Err_PDBDAT)

                  @SetTextOvr(Err_PDEDAT)
	                 <tr><td class="dsphdr"><span $(textOvr)>End Date</span></td>
                      <td class="inputnmbr"><input type="text" name="endDate" value="$(V_PDEDAT)" size="6" maxlength="6"> 		
                          <a href="javascript:calWindow('endDate');">$(reqFieldChar)$(calendarImage)</a></td>
                  </tr>
                  @DspErrMsg(Err_PDEDAT)

                  @SetTextOvr(Err_PDWKDY)
                  <tr><td class="dsphdr"><span $(textOvr)>Working Days</span></td>
                      <td class="inputnmbr"><input name="workingDays" type="text" value="$(V_PDWKDY)" size="6" maxlength="2"></td>
                  </tr>
                  @DspErrMsg(Err_PDWKDY)
              %}
          </table>
	
          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>

      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HGLPDU_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %elif (maintenanceCode == "D")
      @PeriodInputFromCYP(periodNumber)
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@per#", periodNumber)
  @Concat_Field("@@bdat", beginDate)
  @Concat_Field("@@edat", endDate)
  @Concat_Field("@@wkdy", workingDays)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" || maintenanceCode == "D")
      %if (errFound == "")
          @Format_ConfMsg_Desc(maintenanceCode, "Period Number", $(periodNumber), "", "", "", "", confMessage)
      %else
          @DecatErr_Field("@@per#", "periodNumber")
          @Format_ConfMsg_Desc("", "Period Number", $(periodNumber), "<br>$(fieldValue)", "", "", "", confMessage)
      %endif
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(phpPath)hdList.php$(altVarBase)&amp;tblID=117&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      @PeriodToCYP(periodNumber)
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;periodNumber=@dtw_rurlescseq(periodNumber)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}