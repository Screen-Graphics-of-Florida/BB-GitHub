%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Cost Element Category List"
  d2wName                 = "CostElementCategoryList.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;apid=@dtw_rurlescseq(apid)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                      if  (editNum(document.Chg.fromPlantNumber, 3, 0) &&
                           editNum(document.Chg.toPlantNumber, 3, 0) &&
                           editNum(document.Chg.fromCostSet, 2, 0) &&
                           editNum(document.Chg.toCostSet, 2, 0) &&
                           editFromToAll(document.Chg.fromPlantNumber, document.Chg.toPlantNumber, document.Chg.allPlantNumber, 3) &&
                           editFromToAll(document.Chg.fromCostSet, document.Chg.toCostSet, document.Chg.allCostSet, 2) &&
                           editFromToAll(document.Chg.fromCostElementCategory, document.Chg.toCostElementCategory, document.Chg.allCostElementCategory, "A")
                      )
                      return true;
              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "COSTELEMENTCATEGORYLIST")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
            			
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromPlantNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@fplt", "fromPlantNumber")        @dtw_assign(Err_N1FPLT,  fieldValue)
                                  @DecatErr_Field("@@tplt", "toPlantNumber")        @dtw_assign(Err_N1TPLT,  fieldValue)
                                  @DecatErr_Field("@@aplt", "allPlantNumber")        @dtw_assign(Err_N1APLT,  fieldValue)
                                  @DecatErr_Field("@@fset", "fromCostSet")        @dtw_assign(Err_N1FCSET,  fieldValue)
                                  @DecatErr_Field("@@tset", "toCostSet")        @dtw_assign(Err_N1TCSET,  fieldValue)
                                  @DecatErr_Field("@@aset", "allCostSet")        @dtw_assign(Err_N1ACSET,  fieldValue)
                                  @DecatErr_Field("@@fcat", "fromCostElementCategory")        @dtw_assign(Err_N1FCECT,  fieldValue)
                                  @DecatErr_Field("@@tcat", "toCostElementCategory")        @dtw_assign(Err_N1TCECT,  fieldValue)
                                  @DecatErr_Field("@@acat", "allCostElementCategory")        @dtw_assign(Err_N1ACECT,  fieldValue)
                                  %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  @Decat_Field("@@fplt")  @dtw_assign(V_N1FPLT, fieldValue)
                                  @Decat_Field("@@tplt")  @dtw_assign(V_N1TPLT, fieldValue)
                                  @Decat_Field("@@aplt")  @dtw_assign(V_N1APLT, fieldValue)
                                  @Decat_Field("@@fset")  @dtw_assign(V_N1FCSET, fieldValue)
                                  @Decat_Field("@@tset")  @dtw_assign(V_N1TCSET, fieldValue)
                                  @Decat_Field("@@aset")  @dtw_assign(V_N1ACSET, fieldValue)
                                  @Decat_Field("@@fcat")  @dtw_assign(V_N1FCECT, fieldValue)
                                  @Decat_Field("@@tcat")  @dtw_assign(V_N1TCECT, fieldValue)
                                  @Decat_Field("@@acat")  @dtw_assign(V_N1ACECT, fieldValue)

                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}

                                  %if (V_N1APLT == "ALL")
                                      @dtw_assign(checkedallPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallPlantNumber, "")
                                  %endif
                                  %if (V_N1ACSET == "ALL")
                                      @dtw_assign(checkedallCostSet, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallCostSet, "")
                                  %endif
                                  %if (V_N1ACECT == "ALL")
                                      @dtw_assign(checkedallCostElementCategory, "CHECKED")
                                  %else
                                      @dtw_assign(checkedallCostElementCategory, "")
                                  %endif

                              %else

                                  @RtvDftPlant(plantNumber, plantName)
                                  %if (plantNumber == "0")
                                      @dtw_assign(checkedallPlantNumber, "CHECKED")
                                  %else
                                      @dtw_assign(V_N1FPLT, plantNumber)
                                      @dtw_assign(V_N1TPLT, plantNumber)
                                      @dtw_assign(checkedallPlantNumber, "")
                                      @dtw_assign(focusField, "fromCostSet")
                                  %endif
                                  @dtw_assign(checkedallCostSet, "CHECKED")
                                  @dtw_assign(checkedallCostElementCategory, "CHECKED")
                              %endif
                          </table>

                          <table $(contentTable)>

                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                              </tr>

                              @SetTextOvr(Err_N1FPLT)
                              %if (textOvr == "") @SetTextOvr(Err_N1TPLT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1APLT) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Plant Number</span></td>
                                  <td class="inputnmbr"><input name="fromPlantNumber" value="$(V_N1FPLT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromPlantNumber&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="plantName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toPlantNumber" value="$(V_N1TPLT)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)PlantSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toPlantNumber&amp;fldDesc=plantName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="plantName" type="hidden"></td>
                                  <td class="inputalph"><input name="allPlantNumber" value='ALL' $(checkedallPlantNumber) type="checkbox" onClick="if (this.checked) this.form.fromPlantNumber.value='', this.form.toPlantNumber.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FPLT)
                              @DspErrMsg(Err_N1TPLT)
                              @DspErrMsg(Err_N1APLT)

                              @SetTextOvr(Err_N1FCSET)
                              %if (textOvr == "") @SetTextOvr(Err_N1TCSET) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1ACSET) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Cost Set</span></td>
                                  <td class="inputnmbr"><input name="fromCostSet" value="$(V_N1FCSET)" type="text" size="2" maxlength="2"><a href="$(homeURL)$(cGIPath)CostSetDefinitionSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromCostSet&amp;fldDesc=fcostSetDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fcostSetDesc" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toCostSet" value="$(V_N1TCSET)" type="text" size="2" maxlength="2"><a href="$(homeURL)$(cGIPath)CostSetDefinitionSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toCostSet&amp;fldDesc=tcostSetDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="tcostSetDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="allCostSet" value='ALL' $(checkedallCostSet) type="checkbox" onClick="if (this.checked) this.form.fromCostSet.value='', this.form.toCostSet.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FCSET)
                              @DspErrMsg(Err_N1TCSET)
                              @DspErrMsg(Err_N1ACSET)

                              @SetTextOvr(Err_N1FCECT)
                              %if (textOvr == "") @SetTextOvr(Err_N1TCECT) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N1ACECT) %endif
                              <tr><td  class="dsphdr"><span $(textOvr)>Cost Element Category </span></td>
                                  <td class="inputnmbr"><input name="fromCostElementCategory" value="$(V_N1FCECT)" type="text" size="7" maxlength="5"><a href="$(homeURL)$(cGIPath)CostElemCatSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;fldcat=fromCostElementCategory&amp;fldlongDesc=longDesc" onclick="$(searchWinVar)">  $(searchImage) </a> <input name="longDesc" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toCostElementCategory" value="$(V_N1TCECT)" type="text" size="7" maxlength="5"><a href="$(homeURL)$(cGIPath)CostElemCatSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;plantNumber=@dtw_rurlescseq(plantNumber)&amp;fldcat=toCostElementCategory&amp;fldlongDesc=longDesc" onclick="$(searchWinVar)">  $(searchImage) </a> <input name="longDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="allCostElementCategory" value='ALL' $(checkedallCostElementCategory) type="checkbox" onClick="if (this.checked) this.form.fromCostElementCategory.value='', this.form.toCostElementCategory.value='';"></td>
                              </tr>
                              @DspErrMsg(Err_N1FCECT)
                              @DspErrMsg(Err_N1TCECT)
                              @DspErrMsg(Err_N1ACECT)

                          </table>

                          @dtw_assign(envProgram, "HSCECL")
                          @dtw_assign(envPrinter, "HSCECLPF")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HSCCCS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()
%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(allPlantNumber)
  @dtw_mUPPERCASE(allCostSet)
  @dtw_mUPPERCASE(fromCostElementCategory)
  @dtw_mUPPERCASE(toCostElementCategory)
  @dtw_mUPPERCASE(allCostElementCategory)

  @dtw_assign(fromPlantNumber,@dtw_rstrip(fromPlantNumber))
  @dtw_assign(toPlantNumber,@dtw_rstrip(toPlantNumber))
  @dtw_assign(fromCostSet,@dtw_rstrip(fromCostSet))
  @dtw_assign(toCostSet,@dtw_rstrip(toCostSet))

  %if (allPlantNumber != "ALL")
      @dtw_assign(allPlantNumber, "")
  %endif
  %if (allCostSet != "ALL")
      @dtw_assign(allCostSet, "")
  %endif
  %if (allCostElementCategory != "ALL")
      @dtw_assign(allCostElementCategory, "")
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@fplt", fromPlantNumber)
  @Concat_Field("@@tplt", toPlantNumber)
  @Concat_Field("@@aplt", allPlantNumber)
  @Concat_Field("@@fset", fromCostSet)
  @Concat_Field("@@tset", toCostSet)
  @Concat_Field("@@aset", allCostSet)
  @Concat_Field("@@fcat", fromCostElementCategory)
  @Concat_Field("@@tcat", toCostElementCategory)
  @Concat_Field("@@acat", allCostElementCategory)


  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}