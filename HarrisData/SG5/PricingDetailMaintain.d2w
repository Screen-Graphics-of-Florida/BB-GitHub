%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "PricingDetailFunctions.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Customer Pricing Detail Maintenance"
  d2wName                 = "PricingDetailMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;pricingLevel=@dtw_rurlescseq(pricingLevel)&amp;levelDesc=@dtw_rurlescseq(levelDesc)"
  deleteURL               = "$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;detailKey=@dtw_rurlescseq(detailKey)&amp;contractStart=@dtw_rurlescseq(contractStart)&amp;maintenanceCode=D"
  programName             = "HOEPLM_E"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "1"
  START_ROW_NUM           = "1"
%}

%MACRO_FUNCTION DspBktMsg (IN CHAR(100) inputField) {
  %if (inputField != "")
      <tr><td class="error" colspan="10">$(inputField)</td></tr>
  %endif
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"

  @dtw_assign(requiredFields, "")
  @dtw_assign(editVariables,  "")
  @dtw_assign(i, "1")
  %while (i <= @dtw_Tb_rRows(mdCol)) {
      @dtw_assign(curdType, @dtw_Tb_rGetV(mdCol, i, @dtw_Tb_rQueryColNOnJ(mdCol, "PWDTYP")))
      @dtw_assign(curfType, @dtw_Tb_rGetV(mdCol, i, @dtw_Tb_rQueryColNOnJ(mdCol, "PWFTYP")))
      @dtw_assign(curName,  @dtw_Tb_rGetV(mdCol, i, @dtw_Tb_rQueryColNOnJ(mdCol, "PWCOLN")))
      @dtw_assign(curSize,  @dtw_Tb_rGetV(mdCol, i, @dtw_Tb_rQueryColNOnJ(mdCol, "PWFLEN")))
      @dtw_assign(curDecm,  @dtw_Tb_rGetV(mdCol, i, @dtw_Tb_rQueryColNOnJ(mdCol, "PWFDEC")))

      @dtw_replace(curName, "#", "_", curName)
      %if (requiredFields != "")
          @dtw_concat(requiredFields, " ||", requiredFields)
      %endif
      @dtw_concat(requiredFields, " document.Chg.chg$(curName).value =="""" ", requiredFields)
      %if (curdType == "NUMERIC" || curdType == "DECIMAL")
          %if (editVariables != "")
              @dtw_concat(editVariables, " &&", editVariables)
          %endif
          %if (curfType == "CYMD" || curfType == "ISO")
              @dtw_concat(editVariables, " editdate(document.Chg.chg$(curName)) ", editVariables)
          %else
              @dtw_concat(editVariables, " editNum(document.Chg.", editVariables)
              @dtw_concat(editVariables, "chg$(curName),$(curSize),$(curDecm)) ", editVariables)
          %endif
      %endif
      @dtw_add(i, "1", i)
  %}
  %if (contract == "Y")
      %if (requiredFields != "")
          @dtw_concat(requiredFields, " ||", requiredFields)
      %endif
      @dtw_concat(requiredFields, " document.Chg.contractStart.value =="""" ", requiredFields)
      @dtw_concat(requiredFields, " || document.Chg.contractExpire.value =="""" ", requiredFields)
      %if (editVariables != "")
          @dtw_concat(editVariables, " &&", editVariables)
      %endif
      @dtw_concat(editVariables, " editdate(document.Chg.contractStart)", editVariables)
      @dtw_concat(editVariables, " && editdate(document.Chg.contractExpire)", editVariables)
  %endif
  %if (bracketQty == "Y" || bracketAmt == "Y")
      %if (editVariables != "")
          @dtw_concat(editVariables, " &&", editVariables)
      %endif
      @dtw_concat(editVariables, " editNum(document.Chg.bracketLimit1,9,4)", editVariables)
      @dtw_concat(editVariables, " && editNum(document.Chg.bracketLimit2,9,4)", editVariables)
      @dtw_concat(editVariables, " && editNum(document.Chg.bracketLimit3,9,4)", editVariables)
      @dtw_concat(editVariables, " && editNum(document.Chg.bracketLimit4,9,4)", editVariables)
      @dtw_concat(editVariables, " && editNum(document.Chg.bracketLimit5,9,4)", editVariables)
      @dtw_concat(editVariables, " && editNum(document.Chg.bracketLimit6,9,4)", editVariables)
      @dtw_concat(editVariables, " && editNum(document.Chg.bracketLimit7,9,4)", editVariables)
      @dtw_concat(editVariables, " && editNum(document.Chg.bracketLimit8,9,4)", editVariables)
      %if (usePercent == "Y")
          @dtw_concat(editVariables, " && editNum(document.Chg.bracketPercent1,3,4)", editVariables)
          @dtw_concat(editVariables, " && editNum(document.Chg.bracketPercent2,3,4)", editVariables)
          @dtw_concat(editVariables, " && editNum(document.Chg.bracketPercent3,3,4)", editVariables)
          @dtw_concat(editVariables, " && editNum(document.Chg.bracketPercent4,3,4)", editVariables)
          @dtw_concat(editVariables, " && editNum(document.Chg.bracketPercent5,3,4)", editVariables)
          @dtw_concat(editVariables, " && editNum(document.Chg.bracketPercent6,3,4)", editVariables)
          @dtw_concat(editVariables, " && editNum(document.Chg.bracketPercent7,3,4)", editVariables)
          @dtw_concat(editVariables, " && editNum(document.Chg.bracketPercent8,3,4)", editVariables)
      %else
          @dtw_concat(editVariables, " && editNum(document.Chg.bracketPrice1,8,5)", editVariables)
          @dtw_concat(editVariables, " && editNum(document.Chg.bracketPrice2,8,5)", editVariables)
          @dtw_concat(editVariables, " && editNum(document.Chg.bracketPrice3,8,5)", editVariables)
          @dtw_concat(editVariables, " && editNum(document.Chg.bracketPrice4,8,5)", editVariables)
          @dtw_concat(editVariables, " && editNum(document.Chg.bracketPrice5,8,5)", editVariables)
          @dtw_concat(editVariables, " && editNum(document.Chg.bracketPrice6,8,5)", editVariables)
          @dtw_concat(editVariables, " && editNum(document.Chg.bracketPrice7,8,5)", editVariables)
          @dtw_concat(editVariables, " && editNum(document.Chg.bracketPrice8,8,5)", editVariables)
      %endif
      %if (commission == "Y" || commission == "L")
          @dtw_concat(editVariables, " && editNum(document.Chg.bracketComm1,3,4)", editVariables)
          @dtw_concat(editVariables, " && editNum(document.Chg.bracketComm2,3,4)", editVariables)
          @dtw_concat(editVariables, " && editNum(document.Chg.bracketComm3,3,4)", editVariables)
          @dtw_concat(editVariables, " && editNum(document.Chg.bracketComm4,3,4)", editVariables)
          @dtw_concat(editVariables, " && editNum(document.Chg.bracketComm5,3,4)", editVariables)
          @dtw_concat(editVariables, " && editNum(document.Chg.bracketComm6,3,4)", editVariables)
          @dtw_concat(editVariables, " && editNum(document.Chg.bracketComm7,3,4)", editVariables)
          @dtw_concat(editVariables, " && editNum(document.Chg.bracketComm8,3,4)", editVariables)
      %endif
  %else
      %if (editVariables != "")
          @dtw_concat(editVariables, " &&", editVariables)
      %endif
      %if (usePercent == "Y")
          @dtw_concat(editVariables, " editNum(document.Chg.llCpPercent,3,4)", editVariables)
      %else
          @dtw_concat(editVariables, " editNum(document.Chg.llCpAmount,8,5)", editVariables)
      %endif
      %if (commission == "Y" || commission == "L")
          %if (editVariables != "")
              @dtw_concat(editVariables, " &&", editVariables)
          %endif
          @dtw_concat(editVariables, " editNum(document.Chg.commPercent,3,4)", editVariables)
      %endif
  %endif

  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "dateedit.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "NewWindowOpen.icl"
              function validate(chgForm) {
                  if ($(requiredFields))
                     {alert("$(reqFieldError)"); return false;}
                  if ($(editVariables))
                      return true;
              }
              function confirmDelete() {return confirm("$(delRecordConf)")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "PRICINGDETAILMAINT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @dtw_assign(stmtSQL, "")
                      %if (maintenanceCode == "A")
                          %INCLUDE "AddRecordSQL.icl"
                      %else
                          @dtw_concat(stmtSQL, " Select * From HDPRCD Where PMPMLV=$(pricingLevel) and PMPMKY='$(detailKey)' and PMSTDT=$(contractStart)", stmtSQL)
                      %endif
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @pgmOptSecurity(profileHandle, daataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %INCLUDE "MaintainTop.icl"
      <table $(contentTable)>
          @Format_Header_URL("Pricing Level", $(levelDesc), $(pricingLevel), "")

          %if (listLess == "Y")
              @dtw_assign(structureDefn, "List Less")
          %endif
          %if (costPlus == "Y")
              @dtw_assign(structureDefn, "Cost Plus")
          %endif
          %if (dollarAmt == "Y")
              @dtw_assign(structureDefn, "Dollar")
          %endif
          %if (usePercent == "Y")
              @dtw_concat(structureDefn, " Percentage", structureDefn)
          %else
              @dtw_concat(structureDefn, " Amount", structureDefn)
          %endif
          <tr><td class="hdrtitl">Definition:</td>
              %if (contract == "Y")
                  <td class="hdrdata">Contract</td></tr>
                  <tr><td>&nbsp;</td><td class="hdrdata">$(structureDefn)</td>
              %else
                  <td class="hdrdata">$(structureDefn)</td>
              %endif
          </tr>

          %if (bracketQty == "Y")
              <tr><td>&nbsp;</td><td class="hdrdata">Bracket By Quantity</td></tr>
          %elif (bracketAmt == "Y")
              <tr><td>&nbsp;</td><td class="hdrdata">Bracket By Amount</td></tr>
          %endif

          %if (commission != "")
              <tr><td>&nbsp;</td><td class="hdrdata">
                  %if (commission == "Y")
                      Commissionable
                  %elif (commission == "N")
                      Non-Commissionable
                  %elif (commission == "L")
                      Limited Commission
                  %endif
              </td></tr>
          %endif
      </table>
      $(hrTagAttr)
      %INCLUDE "RequiredField.icl"
      %INCLUDE "ErrorDisplay.icl"

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)">
          <table $(contentTable)>
              %ROW {
                  %if (errFound != "" || maintenanceCode == "A")
                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(edtVar, "")
                      %else
                          @dtw_assign(focusField, "")
                          @EdtVarErr(profileHandle, typeValue, edtVar)
                          @ErrVarErr(profileHandle, typeError, errVar)
                          @dtw_assign(curName,  @dtw_Tb_rGetV(mdCol, "1", @dtw_Tb_rQueryColNOnJ(mdCol, "PWCOLN")))
                          @dtw_replace(curName, "#", "_", curName)
                          @DecatErr_Field("@@gerr", "chg$(curName)")   @dtw_assign(Err_General,  fieldValue)
                          @DecatErr_Field("@@stdt", "contractStart")   @dtw_assign(Err_PMSTDT,  fieldValue)
                          @DecatErr_Field("@@exdt", "contractExpire")  @dtw_assign(Err_PMEXDT,  fieldValue)
                          @DecatErr_Field("@@lcam", "llCpAmount")      @dtw_assign(Err_PMLCAM,  fieldValue)
                          @DecatErr_Field("@@lcpc", "llCpPercent")     @dtw_assign(Err_PMLCPC,  fieldValue)
                          @DecatErr_Field("@@cmpc", "commPercent")     @dtw_assign(Err_PMCMPC,  fieldValue)
                          @DecatErr_Field("@@bkl1", "bracketLimit1")   @dtw_assign(Err_PMBKL1,  fieldValue)
                          @DecatErr_Field("@@bkp1", "bracketPrice1")   @dtw_assign(Err_PMBKP1,  fieldValue)
                          @DecatErr_Field("@@bkc1", "bracketPercent1") @dtw_assign(Err_PMBKC1,  fieldValue)
                          @DecatErr_Field("@@cmp1", "bracketComm1")    @dtw_assign(Err_PMCMP1,  fieldValue)
                          @DecatErr_Field("@@bkl2", "bracketLimit2")   @dtw_assign(Err_PMBKL2,  fieldValue)
                          @DecatErr_Field("@@bkp2", "bracketPrice2")   @dtw_assign(Err_PMBKP2,  fieldValue)
                          @DecatErr_Field("@@bkc2", "bracketPercent2") @dtw_assign(Err_PMBKC2,  fieldValue)
                          @DecatErr_Field("@@cmp2", "bracketComm2")    @dtw_assign(Err_PMCMP2,  fieldValue)
                          @DecatErr_Field("@@bkl3", "bracketLimit3")   @dtw_assign(Err_PMBKL3,  fieldValue)
                          @DecatErr_Field("@@bkp3", "bracketPrice3")   @dtw_assign(Err_PMBKP3,  fieldValue)
                          @DecatErr_Field("@@bkc3", "bracketPercent3") @dtw_assign(Err_PMBKC3,  fieldValue)
                          @DecatErr_Field("@@cmp3", "bracketComm3")    @dtw_assign(Err_PMCMP3,  fieldValue)
                          @DecatErr_Field("@@bkl4", "bracketLimit4")   @dtw_assign(Err_PMBKL4,  fieldValue)
                          @DecatErr_Field("@@bkp4", "bracketPrice4")   @dtw_assign(Err_PMBKP4,  fieldValue)
                          @DecatErr_Field("@@bkc4", "bracketPercent4") @dtw_assign(Err_PMBKC4,  fieldValue)
                          @DecatErr_Field("@@cmp4", "bracketComm4")    @dtw_assign(Err_PMCMP4,  fieldValue)
                          @DecatErr_Field("@@bkl5", "bracketLimit5")   @dtw_assign(Err_PMBKL5,  fieldValue)
                          @DecatErr_Field("@@bkp5", "bracketPrice5")   @dtw_assign(Err_PMBKP5,  fieldValue)
                          @DecatErr_Field("@@bkc5", "bracketPercent5") @dtw_assign(Err_PMBKC5,  fieldValue)
                          @DecatErr_Field("@@cmp5", "bracketComm5")    @dtw_assign(Err_PMCMP5,  fieldValue)
                          @DecatErr_Field("@@bkl6", "bracketLimit6")   @dtw_assign(Err_PMBKL6,  fieldValue)
                          @DecatErr_Field("@@bkp6", "bracketPrice6")   @dtw_assign(Err_PMBKP6,  fieldValue)
                          @DecatErr_Field("@@bkc6", "bracketPercent6") @dtw_assign(Err_PMBKC6,  fieldValue)
                          @DecatErr_Field("@@cmp6", "bracketComm6")    @dtw_assign(Err_PMCMP6,  fieldValue)
                          @DecatErr_Field("@@bkl7", "bracketLimit7")   @dtw_assign(Err_PMBKL7,  fieldValue)
                          @DecatErr_Field("@@bkp7", "bracketPrice7")   @dtw_assign(Err_PMBKP7,  fieldValue)
                          @DecatErr_Field("@@bkc7", "bracketPercent7") @dtw_assign(Err_PMBKC7,  fieldValue)
                          @DecatErr_Field("@@cmp7", "bracketComm7")    @dtw_assign(Err_PMCMP7,  fieldValue)
                          @DecatErr_Field("@@bkl8", "bracketLimit8")   @dtw_assign(Err_PMBKL8,  fieldValue)
                          @DecatErr_Field("@@bkp8", "bracketPrice8")   @dtw_assign(Err_PMBKP8,  fieldValue)
                          @DecatErr_Field("@@bkc8", "bracketPercent8") @dtw_assign(Err_PMBKC8,  fieldValue)
                          @DecatErr_Field("@@cmp8", "bracketComm8")    @dtw_assign(Err_PMCMP8,  fieldValue)
                      %endif

                      @Decat_Field("@@pmky")   @dtw_assign(V_PMPMKY, fieldValue)
                      @Decat_Field("@@stdt")   @dtw_assign(V_PMSTDT, fieldValue)
                      @Decat_Field("@@exdt")   @dtw_assign(V_PMEXDT, fieldValue)
                      @Decat_Field("@@lcam")   @dtw_assign(V_PMLCAM, fieldValue)
                      @Decat_Field("@@lcpc")   @dtw_assign(V_PMLCPC, fieldValue)
                      @Decat_Field("@@cmpc")   @dtw_assign(V_PMCMPC, fieldValue)
                      @Decat_Field("@@bkl1")   @dtw_assign(V_PMBKL1, fieldValue)
                      @Decat_Field("@@bkp1")   @dtw_assign(V_PMBKP1, fieldValue)
                      @Decat_Field("@@bkc1")   @dtw_assign(V_PMBKC1, fieldValue)
                      @Decat_Field("@@cmp1")   @dtw_assign(V_PMCMP1, fieldValue)
                      @Decat_Field("@@bkl2")   @dtw_assign(V_PMBKL2, fieldValue)
                      @Decat_Field("@@bkp2")   @dtw_assign(V_PMBKP2, fieldValue)
                      @Decat_Field("@@bkc2")   @dtw_assign(V_PMBKC2, fieldValue)
                      @Decat_Field("@@cmp2")   @dtw_assign(V_PMCMP2, fieldValue)
                      @Decat_Field("@@bkl3")   @dtw_assign(V_PMBKL3, fieldValue)
                      @Decat_Field("@@bkp3")   @dtw_assign(V_PMBKP3, fieldValue)
                      @Decat_Field("@@bkc3")   @dtw_assign(V_PMBKC3, fieldValue)
                      @Decat_Field("@@cmp3")   @dtw_assign(V_PMCMP3, fieldValue)
                      @Decat_Field("@@bkl4")   @dtw_assign(V_PMBKL4, fieldValue)
                      @Decat_Field("@@bkp4")   @dtw_assign(V_PMBKP4, fieldValue)
                      @Decat_Field("@@bkc4")   @dtw_assign(V_PMBKC4, fieldValue)
                      @Decat_Field("@@cmp4")   @dtw_assign(V_PMCMP4, fieldValue)
                      @Decat_Field("@@bkl5")   @dtw_assign(V_PMBKL5, fieldValue)
                      @Decat_Field("@@bkp5")   @dtw_assign(V_PMBKP5, fieldValue)
                      @Decat_Field("@@bkc5")   @dtw_assign(V_PMBKC5, fieldValue)
                      @Decat_Field("@@cmp5")   @dtw_assign(V_PMCMP5, fieldValue)
                      @Decat_Field("@@bkl6")   @dtw_assign(V_PMBKL6, fieldValue)
                      @Decat_Field("@@bkp6")   @dtw_assign(V_PMBKP6, fieldValue)
                      @Decat_Field("@@bkc6")   @dtw_assign(V_PMBKC6, fieldValue)
                      @Decat_Field("@@cmp6")   @dtw_assign(V_PMCMP6, fieldValue)
                      @Decat_Field("@@bkl7")   @dtw_assign(V_PMBKL7, fieldValue)
                      @Decat_Field("@@bkp7")   @dtw_assign(V_PMBKP7, fieldValue)
                      @Decat_Field("@@bkc7")   @dtw_assign(V_PMBKC7, fieldValue)
                      @Decat_Field("@@cmp7")   @dtw_assign(V_PMCMP7, fieldValue)
                      @Decat_Field("@@bkl8")   @dtw_assign(V_PMBKL8, fieldValue)
                      @Decat_Field("@@bkp8")   @dtw_assign(V_PMBKP8, fieldValue)
                      @Decat_Field("@@bkc8")   @dtw_assign(V_PMBKC8, fieldValue)
                      @Decat_Field("@@cmp8")   @dtw_assign(V_PMCMP8, fieldValue)

                      %if (errFound == "" && maintenanceCode == "A")
                          @dtw_assign(curName,  @dtw_Tb_rGetV(mdCol, "1", @dtw_Tb_rQueryColNOnJ(mdCol, "PWCOLN")))
                          @dtw_replace(curName, "#", "_", curName)
                          @dtw_assign(focusField, "chg$(curName)")
                      %endif

                  %elif (maintenanceCode == "Z")
                      @dtw_assign(curName,  @dtw_Tb_rGetV(mdCol, "1", @dtw_Tb_rQueryColNOnJ(mdCol, "PWCOLN")))
                      @dtw_replace(curName, "#", "_", curName)
                      @dtw_assign(focusField, "chg$(curName)")
                      @dtw_assign(V_PMWHS , "")
                      @dtw_assign(V_PMITEM, "")
                      @dtw_assign(V_PMCUST, "")
                      @dtw_assign(V_PMCCLS, "")
                      @dtw_assign(V_PMPCLS, "")
                      @dtw_assign(V_PMCRGN, "")
                      @dtw_assign(V_PMPGRP, "")
                      @dtw_assign(V_PMSTDT, "")
                      @dtw_assign(V_PMEXDT, "")
                      @dtw_assign(V_PMLCPC, "@dtw_rformat(@dtw_rmultiply(V_PMLCPC, "100"),"","4")")
                      @dtw_assign(V_PMCMPC, "@dtw_rformat(@dtw_rmultiply(V_PMCMPC, "100"),"","4")")
                      @dtw_assign(V_PMBKC1, "@dtw_rformat(@dtw_rmultiply(V_PMBKC1, "100"),"","4")")
                      @dtw_assign(V_PMCMP1, "@dtw_rformat(@dtw_rmultiply(V_PMCMP1, "100"),"","4")")
                      @dtw_assign(V_PMBKC2, "@dtw_rformat(@dtw_rmultiply(V_PMBKC2, "100"),"","4")")
                      @dtw_assign(V_PMCMP2, "@dtw_rformat(@dtw_rmultiply(V_PMCMP2, "100"),"","4")")
                      @dtw_assign(V_PMBKC3, "@dtw_rformat(@dtw_rmultiply(V_PMBKC3, "100"),"","4")")
                      @dtw_assign(V_PMCMP3, "@dtw_rformat(@dtw_rmultiply(V_PMCMP3, "100"),"","4")")
                      @dtw_assign(V_PMBKC4, "@dtw_rformat(@dtw_rmultiply(V_PMBKC4, "100"),"","4")")
                      @dtw_assign(V_PMCMP4, "@dtw_rformat(@dtw_rmultiply(V_PMCMP4, "100"),"","4")")
                      @dtw_assign(V_PMBKC5, "@dtw_rformat(@dtw_rmultiply(V_PMBKC5, "100"),"","4")")
                      @dtw_assign(V_PMCMP5, "@dtw_rformat(@dtw_rmultiply(V_PMCMP5, "100"),"","4")")
                      @dtw_assign(V_PMBKC6, "@dtw_rformat(@dtw_rmultiply(V_PMBKC6, "100"),"","4")")
                      @dtw_assign(V_PMCMP6, "@dtw_rformat(@dtw_rmultiply(V_PMCMP6, "100"),"","4")")
                      @dtw_assign(V_PMBKC7, "@dtw_rformat(@dtw_rmultiply(V_PMBKC7, "100"),"","4")")
                      @dtw_assign(V_PMCMP7, "@dtw_rformat(@dtw_rmultiply(V_PMCMP7, "100"),"","4")")
                      @dtw_assign(V_PMBKC8, "@dtw_rformat(@dtw_rmultiply(V_PMBKC8, "100"),"","4")")
                      @dtw_assign(V_PMCMP8, "@dtw_rformat(@dtw_rmultiply(V_PMCMP8, "100"),"","4")")
                  %else
                      %if (contract == "Y")
                          @dtw_assign(focusField, "contractExpire")
                      %elif (bracketQty == "Y" || bracketAmt == "Y")
                          @dtw_assign(focusField, "bracketLimit1")
                      %elif (usePercent == "Y")
                          @dtw_assign(focusField, "llCpPercent")
                      %else
                          @dtw_assign(focusField, "llCpAmount")
                      %endif
                      @dtw_assign(F_PMSTDT,  V_PMSTDT)
                      @DateFromCYMD(F_PMSTDT)
                      @DateInputFromCYMD(V_PMSTDT)
                      @DateInputFromCYMD(V_PMEXDT)
                      @dtw_assign(V_PMLCPC, "@dtw_rformat(@dtw_rmultiply(V_PMLCPC, "100"),"","4")")
                      @dtw_assign(V_PMCMPC, "@dtw_rformat(@dtw_rmultiply(V_PMCMPC, "100"),"","4")")
                      @dtw_assign(V_PMBKC1, "@dtw_rformat(@dtw_rmultiply(V_PMBKC1, "100"),"","4")")
                      @dtw_assign(V_PMCMP1, "@dtw_rformat(@dtw_rmultiply(V_PMCMP1, "100"),"","4")")
                      @dtw_assign(V_PMBKC2, "@dtw_rformat(@dtw_rmultiply(V_PMBKC2, "100"),"","4")")
                      @dtw_assign(V_PMCMP2, "@dtw_rformat(@dtw_rmultiply(V_PMCMP2, "100"),"","4")")
                      @dtw_assign(V_PMBKC3, "@dtw_rformat(@dtw_rmultiply(V_PMBKC3, "100"),"","4")")
                      @dtw_assign(V_PMCMP3, "@dtw_rformat(@dtw_rmultiply(V_PMCMP3, "100"),"","4")")
                      @dtw_assign(V_PMBKC4, "@dtw_rformat(@dtw_rmultiply(V_PMBKC4, "100"),"","4")")
                      @dtw_assign(V_PMCMP4, "@dtw_rformat(@dtw_rmultiply(V_PMCMP4, "100"),"","4")")
                      @dtw_assign(V_PMBKC5, "@dtw_rformat(@dtw_rmultiply(V_PMBKC5, "100"),"","4")")
                      @dtw_assign(V_PMCMP5, "@dtw_rformat(@dtw_rmultiply(V_PMCMP5, "100"),"","4")")
                      @dtw_assign(V_PMBKC6, "@dtw_rformat(@dtw_rmultiply(V_PMBKC6, "100"),"","4")")
                      @dtw_assign(V_PMCMP6, "@dtw_rformat(@dtw_rmultiply(V_PMCMP6, "100"),"","4")")
                      @dtw_assign(V_PMBKC7, "@dtw_rformat(@dtw_rmultiply(V_PMBKC7, "100"),"","4")")
                      @dtw_assign(V_PMCMP7, "@dtw_rformat(@dtw_rmultiply(V_PMCMP7, "100"),"","4")")
                      @dtw_assign(V_PMBKC8, "@dtw_rformat(@dtw_rmultiply(V_PMBKC8, "100"),"","4")")
                      @dtw_assign(V_PMCMP8, "@dtw_rformat(@dtw_rmultiply(V_PMCMP8, "100"),"","4")")
                  %endif

                  %if (Err_General != "")
                      <tr><td>&nbsp;</td><td class="error" colspan="10">$(Err_General)</td></tr>
                  %endif

                  @dtw_assign(i, "1")
                  %while (i <= @dtw_Tb_rRows(mdCol)) {
                      @dtw_assign(curdCol,   @dtw_Tb_rGetV(mdCol, i, @dtw_Tb_rQueryColNOnJ(mdCol, "PWDCOL")))
                      @dtw_assign(curdKey,   @dtw_Tb_rGetV(mdCol, i, @dtw_Tb_rQueryColNOnJ(mdCol, "PWDKEY")))
                      @dtw_assign(curdTbl,   @dtw_Tb_rGetV(mdCol, i, @dtw_Tb_rQueryColNOnJ(mdCol, "PWDTBL")))
                      @dtw_assign(curdType,  @dtw_Tb_rGetV(mdCol, i, @dtw_Tb_rQueryColNOnJ(mdCol, "PWDTYP")))
                      @dtw_assign(curName,   @dtw_Tb_rGetV(mdCol, i, @dtw_Tb_rQueryColNOnJ(mdCol, "PWCOLN")))
                      @dtw_assign(curText,   @dtw_Tb_rGetV(mdCol, i, @dtw_Tb_rQueryColNOnJ(mdCol, "PWCTXT")))
                      @dtw_assign(maxWidth,  @dtw_Tb_rGetV(mdCol, i, @dtw_Tb_rQueryColNOnJ(mdCol, "PWFLEN")))
                      @dtw_assign(curSearch, @dtw_Tb_rGetV(mdCol, i, @dtw_Tb_rQueryColNOnJ(mdCol, "PWSD2W")))
                      @dtw_replace(curName, "#", "_", curName)
                      %if (errFound != "")
                          @dtw_assign(curShort,  @dtw_rconcat("@@", "@dtw_rsubstr(@dtw_rlowercase(curName), "3", "4", "@")"))
                          @DecatErr_Field("$(curShort)", "chg$(curName)")
                          @dtw_assign(Err_Message, "$(fieldValue)")
                          @Decat_Field("$(curShort)")
                      %else
                          @dtw_assign(Err_Message, "")
                          @dtw_assign(fieldValue, "$(V_$(curName))")
                      %endif
                      %if (curdType == "NUMERIC" || curdType == "DECIMAL")
                          @dtw_assign(cssClass, "inputnmbr")
                          @RtvFldDesc("$(curdKey)=$(fieldValue)", "$(curdTbl)", "$(curdCol)", fieldDesc)
                      %else
                          @dtw_assign(cssClass, "inputalph")
                          @RtvFldDesc("$(curdKey)='$(fieldValue)'", "$(curdTbl)", "$(curdCol)", fieldDesc)
                      %endif
                      %if (fieldValue == "")
                          @dtw_assign(fieldDesc, "")
                      %endif

                      @SetTextOvr(Err_Message)
                      <tr><td class="dsphdr"><span $(textOvr)>$(curText)</span></td>
                          %if (maintenanceCode == "A" || maintenanceCode == "Z")
                              %if (curSearch == "ProdClassSearch" || curSearch == "ProductGroupSearch")
                                  @dtw_assign(srch, "$(cGIPath)$(curSearch).d2w/ENTRY$(genericVarBase)")
                              %else
                                  @dtw_assign(srch, "$(phpPath)$(curSearch).php$(altVarBase)")
                              %endif
                              <td class="$(cssClass)"><input name="chg$(curName)" type="text" value="$(fieldValue)" size="12" maxlength="$(maxWidth)"><a href="$(homeURL)$(srch)&amp;docName=Chg&amp;fldName=chg$(curName)&amp;fldDesc=desc$(curName)" onclick="$(searchWinVar)"> $(reqFieldChar) $(searchImage) </a><input disabled name="desc$(curName)" value="$(fieldDesc)" type="text" size="25"></td>
                          %else
                              <td class="$(cssClass)"><input name="chg$(curName)" type="hidden" value="$(fieldValue)" size="12">$(fieldValue)</td><td class="$(cssClass)"> &nbsp; $(fieldDesc)</td>
                          %endif
                      </tr>
                      @DspErrMsg(Err_Message)

                      @dtw_add(i, "1", i)
                  %}

                  @dtw_assign(errFound, "")

                  %if (contract == "Y")
                      @SetTextOvr(Err_PMSTDT)
                      <tr><td class="dsphdr"><span $(textOvr)>Contract Start Date</span></td>
                          %if (maintenanceCode == "A" || maintenanceCode == "Z")
                              <td class="inputnmbr"><input name="contractStart" type="text" value="$(V_PMSTDT)" size="6" maxlength="6"> $(reqFieldChar) <a href="javascript:calWindow('contractStart');">$(calendarImage)</a></td>
                          %else
                              <td class="inputnmbr"><input name="contractStart" type="hidden" value="$(V_PMSTDT)" size="6">$(F_PMSTDT)</td>
                          %endif
                      </tr>
                      @DspErrMsg(Err_PMSTDT)

                      @SetTextOvr(Err_PMEXDT)
                      <tr><td class="dsphdr"><span $(textOvr)>Expiration Date</span></td>
                          <td class="inputnmbr"><input name="contractExpire" type="text" value="$(V_PMEXDT)" size="6" maxlength="6"> $(reqFieldChar) <a href="javascript:calWindow('contractExpire');">$(calendarImage)</a></td>
                      </tr>
                      @DspErrMsg(Err_PMEXDT)
                  %endif

                  %if (bracketQty == "Y" || bracketAmt == "Y")
                      <tr><td>&nbsp;</td></tr>
                      <tr><td>&nbsp;</td>
                          <td colspan="10">
                              <table $(contentTable)>
                                  <tr>
                                      %if (bracketQty == "Y")
                                          <td class="colhdr">Quantity Limit</td>
                                      %else
                                          <td class="colhdr">Amount Limit</td>
                                      %endif
                                      <td class="colhdr">$(structureDefn)</td>
                                      %if (commission == "Y" || commission == "L")
                                          <td class="colhdr">Commission<br>Percent</td>
                                      %endif
                                  </tr>

                                  @SetTextOvr(Err_PMBKL1)
                                  @SetTextOvr(Err_PMBKC1)
                                  @SetTextOvr(Err_PMBKP1)
                                  @SetTextOvr(Err_PMCMP1)
                                  <tr><td class="inputnmbr"><input name="bracketLimit1" type="text" value="$(V_PMBKL1)" size="12" maxlength="15"></td>
                                      %if (usePercent == "Y")
                                          <td class="inputnmbr"><input name="bracketPercent1" type="text" value="$(V_PMBKC1)" size="12" maxlength="9"></td>
                                      %else
                                          <td class="inputnmbr"><input name="bracketPrice1" type="text" value="$(V_PMBKP1)" size="12" maxlength="15"></td>
                                      %endif
                                      %if (commission == "Y" || commission == "L")
                                          <td class="inputnmbr"><input name="bracketComm1" type="text" value="$(V_PMCMP1)" size="12" maxlength="9"></td>
                                      %endif
                                  </tr>
                                  @DspBktMsg(Err_PMBKL1)
                                  @DspBktMsg(Err_PMBKC1)
                                  @DspBktMsg(Err_PMBKP1)
                                  @DspBktMsg(Err_PMCMP1)

                                  @SetTextOvr(Err_PMBKL2)
                                  @SetTextOvr(Err_PMBKC2)
                                  @SetTextOvr(Err_PMBKP2)
                                  @SetTextOvr(Err_PMCMP2)
                                  <tr><td class="inputnmbr"><input name="bracketLimit2" type="text" value="$(V_PMBKL2)" size="12" maxlength="15"></td>
                                      %if (usePercent == "Y")
                                          <td class="inputnmbr"><input name="bracketPercent2" type="text" value="$(V_PMBKC2)" size="12" maxlength="9"></td>
                                      %else
                                          <td class="inputnmbr"><input name="bracketPrice2" type="text" value="$(V_PMBKP2)" size="12" maxlength="15"></td>
                                      %endif
                                      %if (commission == "Y" || commission == "L")
                                          <td class="inputnmbr"><input name="bracketComm2" type="text" value="$(V_PMCMP2)" size="12" maxlength="9"></td>
                                      %endif
                                  </tr>
                                  @DspBktMsg(Err_PMBKL2)
                                  @DspBktMsg(Err_PMBKC2)
                                  @DspBktMsg(Err_PMBKP2)
                                  @DspBktMsg(Err_PMCMP2)

                                  @SetTextOvr(Err_PMBKL3)
                                  @SetTextOvr(Err_PMBKC3)
                                  @SetTextOvr(Err_PMBKP3)
                                  @SetTextOvr(Err_PMCMP3)
                                  <tr><td class="inputnmbr"><input name="bracketLimit3" type="text" value="$(V_PMBKL3)" size="12" maxlength="15"></td>
                                      %if (usePercent == "Y")
                                          <td class="inputnmbr"><input name="bracketPercent3" type="text" value="$(V_PMBKC3)" size="12" maxlength="9"></td>
                                      %else
                                          <td class="inputnmbr"><input name="bracketPrice3" type="text" value="$(V_PMBKP3)" size="12" maxlength="15"></td>
                                      %endif
                                      %if (commission == "Y" || commission == "L")
                                          <td class="inputnmbr"><input name="bracketComm3" type="text" value="$(V_PMCMP3)" size="12" maxlength="9"></td>
                                      %endif
                                  </tr>
                                  @DspBktMsg(Err_PMBKL3)
                                  @DspBktMsg(Err_PMBKC3)
                                  @DspBktMsg(Err_PMBKP3)
                                  @DspBktMsg(Err_PMCMP3)

                                  @SetTextOvr(Err_PMBKL4)
                                  @SetTextOvr(Err_PMBKC4)
                                  @SetTextOvr(Err_PMBKP4)
                                  @SetTextOvr(Err_PMCMP4)
                                  <tr><td class="inputnmbr"><input name="bracketLimit4" type="text" value="$(V_PMBKL4)" size="12" maxlength="15"></td>
                                      %if (usePercent == "Y")
                                          <td class="inputnmbr"><input name="bracketPercent4" type="text" value="$(V_PMBKC4)" size="12" maxlength="9"></td>
                                      %else
                                          <td class="inputnmbr"><input name="bracketPrice4" type="text" value="$(V_PMBKP4)" size="12" maxlength="15"></td>
                                      %endif
                                      %if (commission == "Y" || commission == "L")
                                          <td class="inputnmbr"><input name="bracketComm4" type="text" value="$(V_PMCMP4)" size="12" maxlength="9"></td>
                                      %endif
                                  </tr>
                                  @DspBktMsg(Err_PMBKL4)
                                  @DspBktMsg(Err_PMBKC4)
                                  @DspBktMsg(Err_PMBKP4)
                                  @DspBktMsg(Err_PMCMP4)

                                  @SetTextOvr(Err_PMBKL5)
                                  @SetTextOvr(Err_PMBKC5)
                                  @SetTextOvr(Err_PMBKP5)
                                  @SetTextOvr(Err_PMCMP5)
                                  <tr><td class="inputnmbr"><input name="bracketLimit5" type="text" value="$(V_PMBKL5)" size="12" maxlength="15"></td>
                                      %if (usePercent == "Y")
                                          <td class="inputnmbr"><input name="bracketPercent5" type="text" value="$(V_PMBKC5)" size="12" maxlength="9"></td>
                                      %else
                                          <td class="inputnmbr"><input name="bracketPrice5" type="text" value="$(V_PMBKP5)" size="12" maxlength="15"></td>
                                      %endif
                                      %if (commission == "Y" || commission == "L")
                                          <td class="inputnmbr"><input name="bracketComm5" type="text" value="$(V_PMCMP5)" size="12" maxlength="9"></td>
                                      %endif
                                  </tr>
                                  @DspBktMsg(Err_PMBKL5)
                                  @DspBktMsg(Err_PMBKC5)
                                  @DspBktMsg(Err_PMBKP5)
                                  @DspBktMsg(Err_PMCMP5)

                                  @SetTextOvr(Err_PMBKL6)
                                  @SetTextOvr(Err_PMBKC6)
                                  @SetTextOvr(Err_PMBKP6)
                                  @SetTextOvr(Err_PMCMP6)
                                  <tr><td class="inputnmbr"><input name="bracketLimit6" type="text" value="$(V_PMBKL6)" size="12" maxlength="15"></td>
                                      %if (usePercent == "Y")
                                          <td class="inputnmbr"><input name="bracketPercent6" type="text" value="$(V_PMBKC6)" size="12" maxlength="9"></td>
                                      %else
                                          <td class="inputnmbr"><input name="bracketPrice6" type="text" value="$(V_PMBKP6)" size="12" maxlength="15"></td>
                                      %endif
                                      %if (commission == "Y" || commission == "L")
                                          <td class="inputnmbr"><input name="bracketComm6" type="text" value="$(V_PMCMP6)" size="12" maxlength="9"></td>
                                      %endif
                                  </tr>
                                  @DspBktMsg(Err_PMBKL6)
                                  @DspBktMsg(Err_PMBKC6)
                                  @DspBktMsg(Err_PMBKP6)
                                  @DspBktMsg(Err_PMCMP6)

                                  @SetTextOvr(Err_PMBKL7)
                                  @SetTextOvr(Err_PMBKC7)
                                  @SetTextOvr(Err_PMBKP7)
                                  @SetTextOvr(Err_PMCMP7)
                                  <tr><td class="inputnmbr"><input name="bracketLimit7" type="text" value="$(V_PMBKL7)" size="12" maxlength="15"></td>
                                      %if (usePercent == "Y")
                                          <td class="inputnmbr"><input name="bracketPercent7" type="text" value="$(V_PMBKC7)" size="12" maxlength="9"></td>
                                      %else
                                          <td class="inputnmbr"><input name="bracketPrice7" type="text" value="$(V_PMBKP7)" size="12" maxlength="15"></td>
                                      %endif
                                      %if (commission == "Y" || commission == "L")
                                          <td class="inputnmbr"><input name="bracketComm7" type="text" value="$(V_PMCMP7)" size="12" maxlength="9"></td>
                                      %endif
                                  </tr>
                                  @DspBktMsg(Err_PMBKL7)
                                  @DspBktMsg(Err_PMBKC7)
                                  @DspBktMsg(Err_PMBKP7)
                                  @DspBktMsg(Err_PMCMP7)

                                  @SetTextOvr(Err_PMBKL8)
                                  @SetTextOvr(Err_PMBKC8)
                                  @SetTextOvr(Err_PMBKP8)
                                  @SetTextOvr(Err_PMCMP8)
                                  <tr><td class="inputnmbr"><input name="bracketLimit8" type="text" value="$(V_PMBKL8)" size="12" maxlength="15"></td>
                                      %if (usePercent == "Y")
                                          <td class="inputnmbr"><input name="bracketPercent8" type="text" value="$(V_PMBKC8)" size="12" maxlength="9"></td>
                                      %else
                                          <td class="inputnmbr"><input name="bracketPrice8" type="text" value="$(V_PMBKP8)" size="12" maxlength="15"></td>
                                      %endif
                                      %if (commission == "Y" || commission == "L")
                                          <td class="inputnmbr"><input name="bracketComm8" type="text" value="$(V_PMCMP8)" size="12" maxlength="9"></td>
                                      %endif
                                  </tr>
                                  @DspBktMsg(Err_PMBKL8)
                                  @DspBktMsg(Err_PMBKC8)
                                  @DspBktMsg(Err_PMBKP8)
                                  @DspBktMsg(Err_PMCMP8)
                              </table>
                          </td>
                      </tr>
                  %else
                      %if (usePercent == "Y")
                          @SetTextOvr(Err_PMLCPC)
                          <tr><td class="dsphdr"><span $(textOvr)>$(structureDefn)</span></td>
                              <td class="inputnmbr"><input name="llCpPercent" type="text" value="$(V_PMLCPC)" size="12" maxlength="9"></td>
                          </tr>
                          @DspErrMsg(Err_PMLCPC)
                      %else
                          @SetTextOvr(Err_PMLCAM)
                          <tr><td class="dsphdr"><span $(textOvr)>$(structureDefn)</span></td>
                              <td class="inputnmbr"><input name="llCpAmount" type="text" value="$(V_PMLCAM)" size="12" maxlength="15"></td>
                          </tr>
                          @DspErrMsg(Err_PMLCAM)
                      %endif
                      %if (commission == "Y" || commission == "L")
                          @SetTextOvr(Err_PMCMPC)
                          <tr><td class="dsphdr"><span $(textOvr)>Commission Percent</span></td>
                              <td class="inputnmbr"><input name="commPercent" type="text" value="$(V_PMCMPC)" size="12" maxlength="9"></td>
                          </tr>
                          @DspErrMsg(Err_PMCMPC)
                      %endif
                  %endif

              %}
          </table>
          <script TYPE="text/javascript">
              document.Chg.$(focusField).focus();
          </script>
      </form>
      %INCLUDE "MaintainBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(10)    userProfile,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HOEPRM_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "ProgSecurityTest.icl"
  %if (pgmOptAuth=="F")
      %INCLUDE "ProgSecurityError.icl"
  %else
      %if (errFound != "")
          @dtw_assign(savedtVar, edtVar)
      %endif
      %INCLUDE "PricingDetail.icl"
      %if (errFound != "")
          @dtw_assign(edtVar, savedtVar)
      %endif
      @Set_SQL(stmtSQL)
  %endif
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "PricingDetail.icl"

  @dtw_mUPPERCASE(detailKey)

  @dtw_assign(pricingLevel,    @dtw_rstrip(pricingLevel))
  @dtw_assign(contractStart,   @dtw_rstrip(contractStart))
  @dtw_assign(contractExpire,  @dtw_rstrip(contractExpire))
  @dtw_assign(llCpAmount,      @dtw_rstrip(llCpAmount))
  @dtw_assign(llCpPercent,     @dtw_rstrip(llCpPercent))
  @dtw_assign(commPercent,     @dtw_rstrip(commPercent))
  @dtw_assign(bracketLimit1,   @dtw_rstrip(bracketLimit1))
  @dtw_assign(bracketPrice1,   @dtw_rstrip(bracketPrice1))
  @dtw_assign(bracketPercent1, @dtw_rstrip(bracketPercent1))
  @dtw_assign(bracketComm1,    @dtw_rstrip(bracketComm1))
  @dtw_assign(bracketLimit2,   @dtw_rstrip(bracketLimit2))
  @dtw_assign(bracketPrice2,   @dtw_rstrip(bracketPrice2))
  @dtw_assign(bracketPercent2, @dtw_rstrip(bracketPercent2))
  @dtw_assign(bracketComm2,    @dtw_rstrip(bracketComm2))
  @dtw_assign(bracketLimit3,   @dtw_rstrip(bracketLimit3))
  @dtw_assign(bracketPrice3,   @dtw_rstrip(bracketPrice3))
  @dtw_assign(bracketPercent3, @dtw_rstrip(bracketPercent3))
  @dtw_assign(bracketComm3,    @dtw_rstrip(bracketComm3))
  @dtw_assign(bracketLimit4,   @dtw_rstrip(bracketLimit4))
  @dtw_assign(bracketPrice4,   @dtw_rstrip(bracketPrice4))
  @dtw_assign(bracketPercent4, @dtw_rstrip(bracketPercent4))
  @dtw_assign(bracketComm4,    @dtw_rstrip(bracketComm4))
  @dtw_assign(bracketLimit5,   @dtw_rstrip(bracketLimit5))
  @dtw_assign(bracketPrice5,   @dtw_rstrip(bracketPrice5))
  @dtw_assign(bracketPercent5, @dtw_rstrip(bracketPercent5))
  @dtw_assign(bracketComm5,    @dtw_rstrip(bracketComm5))
  @dtw_assign(bracketLimit6,   @dtw_rstrip(bracketLimit6))
  @dtw_assign(bracketPrice6,   @dtw_rstrip(bracketPrice6))
  @dtw_assign(bracketPercent6, @dtw_rstrip(bracketPercent6))
  @dtw_assign(bracketComm6,    @dtw_rstrip(bracketComm6))
  @dtw_assign(bracketLimit7,   @dtw_rstrip(bracketLimit7))
  @dtw_assign(bracketPrice7,   @dtw_rstrip(bracketPrice7))
  @dtw_assign(bracketPercent7, @dtw_rstrip(bracketPercent7))
  @dtw_assign(bracketComm7,    @dtw_rstrip(bracketComm7))
  @dtw_assign(bracketLimit8,   @dtw_rstrip(bracketLimit8))
  @dtw_assign(bracketPrice8,   @dtw_rstrip(bracketPrice8))
  @dtw_assign(bracketPercent8, @dtw_rstrip(bracketPercent8))
  @dtw_assign(bracketComm8,    @dtw_rstrip(bracketComm8))

  %if (maintenanceCode == "Z")
      @dtw_assign(maintenanceCode, "A")
  %elif (maintenanceCode == "D")
      @DateInputFromCYMD(contractStart)
  %endif

  @dtw_assign(edtVar, "")
  @Concat_Field("@@pmlv", pricingLevel)
  @Concat_Field("@@pmky", detailKey)

  @dtw_assign(i, "1")
  %while (i <= @dtw_Tb_rRows(mdCol)) {
      @dtw_assign(curName,  @dtw_Tb_rGetV(mdCol, i, @dtw_Tb_rQueryColNOnJ(mdCol, "PWCOLN")))
      @dtw_assign(curdType, @dtw_Tb_rGetV(mdCol, i, @dtw_Tb_rQueryColNOnJ(mdCol, "PWDTYP")))
      @dtw_assign(curSize,  @dtw_Tb_rGetV(mdCol, i, @dtw_Tb_rQueryColNOnJ(mdCol, "PWFLEN")))
      @dtw_replace(curName, "#", "_", curName)
      @Concat_Field("@@nam$(i)", curName)
      %while(@dtw_rlength(curSize) != "5") {@dtw_insert("0", curSize, curSize)%}
      @Concat_Field("@@len$(i)", curSize)
      @dtw_assign(curShort,  @dtw_rconcat("@@", "@dtw_rsubstr(@dtw_rlowercase(curName), "3", "4", "@")"))
      %if (curdType == "NUMERIC" || curdType == "DECIMAL")
          @Concat_Field(curShort, @dtw_rstrip($(chg$(curName))))
      %else
          @Concat_Field(curShort, @dtw_ruppercase($(chg$(curName))))
      %endif
      @dtw_add(i, "1", i)
  %}

  %if (contract == "Y")
      @Concat_Field("@@stdt", contractStart)
      @Concat_Field("@@exdt", contractExpire)
  %endif
  %if (bracketQty == "Y" || bracketAmt == "Y")
      @Concat_Field("@@bkl1", bracketLimit1)
      @Concat_Field("@@bkl2", bracketLimit2)
      @Concat_Field("@@bkl3", bracketLimit3)
      @Concat_Field("@@bkl4", bracketLimit4)
      @Concat_Field("@@bkl5", bracketLimit5)
      @Concat_Field("@@bkl6", bracketLimit6)
      @Concat_Field("@@bkl7", bracketLimit7)
      @Concat_Field("@@bkl8", bracketLimit8)
      %if (usePercent == "Y")
          @Concat_Field("@@bkc1", bracketPercent1)
          @Concat_Field("@@bkc2", bracketPercent2)
          @Concat_Field("@@bkc3", bracketPercent3)
          @Concat_Field("@@bkc4", bracketPercent4)
          @Concat_Field("@@bkc5", bracketPercent5)
          @Concat_Field("@@bkc6", bracketPercent6)
          @Concat_Field("@@bkc7", bracketPercent7)
          @Concat_Field("@@bkc8", bracketPercent8)
      %else
          @Concat_Field("@@bkp1", bracketPrice1)
          @Concat_Field("@@bkp2", bracketPrice2)
          @Concat_Field("@@bkp3", bracketPrice3)
          @Concat_Field("@@bkp4", bracketPrice4)
          @Concat_Field("@@bkp5", bracketPrice5)
          @Concat_Field("@@bkp6", bracketPrice6)
          @Concat_Field("@@bkp7", bracketPrice7)
          @Concat_Field("@@bkp8", bracketPrice8)
      %endif
      %if (commission == "Y" || commission == "L")
          @Concat_Field("@@cmp1", bracketComm1)
          @Concat_Field("@@cmp2", bracketComm2)
          @Concat_Field("@@cmp3", bracketComm3)
          @Concat_Field("@@cmp4", bracketComm4)
          @Concat_Field("@@cmp5", bracketComm5)
          @Concat_Field("@@cmp6", bracketComm6)
          @Concat_Field("@@cmp7", bracketComm7)
          @Concat_Field("@@cmp8", bracketComm8)
      %endif
  %else
      %if (usePercent == "Y")
          @Concat_Field("@@lcpc", llCpPercent)
      %else
          @Concat_Field("@@lcam", llCpAmount)
      %endif
      %if (commission == "Y" || commission == "L")
          @Concat_Field("@@cmpc", commPercent)
      %endif
  %endif

  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(userProfile, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "")
      @Format_ConfMsg_Desc(maintenanceCode, $(levelDesc), $(pricingLevel), "", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)PricingDetail.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %elif (maintenanceCode == "D")
      @DecatErr_Field("@@pmlv", "pricingLevel")
      @Format_ConfMsg_Desc("", $(levelDesc), $(pricingLevel), "<br>$(fieldValue)", "", "", "", confMessage)
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)PricingDetail.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
  %else
      @DateToCYMD(contractStart)
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;detailKey=@dtw_rurlescseq(detailKey)&amp;contractStart=@dtw_rurlescseq(contractStart)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
