%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {
  page_title              = "Audit View Employee"
  d2wName                 = "AuditFileViewEmployee.d2w"
  d2wVarBase              = "$(genericVarBase)$(employeeVarBase)&amp;inclCommon=@dtw_rurlescseq(inclCommon)&amp;inclHR=@dtw_rurlescseq(inclHR)&amp;inclPayroll=@dtw_rurlescseq(inclPayroll)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = ""
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  inclCommon              = ""
  inclHR                  = ""
  inclPayroll             = ""
  edtVar2                 = ""
%}

%MACRO_FUNCTION Decat_Field2 (IN CHAR(6) fieldName) {
  @dtw_assign(fieldValue, "")
  @dtw_pos("$(fieldName)", edtVar2, pos)
  %if (pos > "0")
      @dtw_pos("}{", edtVar2, @dtw_radd(pos, "1"), posNext)
      @dtw_substr(edtVar2, @dtw_radd(pos, "6"), @dtw_rsubtract(posNext, @dtw_radd(pos, "6")), fieldValue)
  %endif
%}


%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script type="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchCo, 2, 0) &&
                      editNum(document.Search.srchFac, 4, 0) &&
                      editNum(document.Search.srchPREmpl, 5, 0) &&
                      editNum(document.Search.srchHREmpl, 9, 0) &&
                      editNum(document.Search.srchDate, 6, 0))
                      return true;
              }
           </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "AUDITFILEVIEWEMPL")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      @dtw_assign(uv_CompanyName, "AUCO#")
                      @dtw_assign(uv_FacilityName, "AUFAC#")
                      @dtw_assign(uv_HRCompanyName, "AUPECO")
                      @dtw_assign(uv_HRLocationName, "AUPELC")
                      @dtw_assign(uv_HomeDepartmentName, "AUDEPT")
                      @dtw_assign(uv_PayTypeName, "AUPAYT")
                      @dtw_assign(uv_SalaryControlName, "AUPAYD")
                      @dtw_assign(uv_PREmployeeName, "AUPREM")
                      @dtw_assign(uv_HREmployeeName, "AUPEEM")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " HDAUDT ", fileSQL)
                      @dtw_concat(selectSQL, "AUGRP='EMPLOYEE' and AUSEQ < 2 ", selectSQL)
                      %INCLUDE "AuditFileChecked.icl"
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @AUDITFILEVIEWEMPL_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) AUDITFILEVIEWEMPL_Query (IN CHAR(64)    profileHandle,
                                               CHAR(2)     dataBaseID,
                                               CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
          <table $(contentTable)>
              <colgroup>
                  <col width="85%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  %if (formatToPrint != "Y")
                      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                      <td class="toolbar">
                          %INCLUDE "XMLFormat.icl"
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"

          $(hrTagAttr)

          %if (formatToPrint != "Y")
              <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
                  <table $(quickSearchTable)>
                      <tr><th class="colhdr">Activity <br> Code</th>
                          <th class="colhdr">Co / Fac</th>
                          <th class="colhdr">PR Empl</th>
                          <th class="colhdr">HR Empl</th>
                          <th class="colhdr">User</th>
                          <th class="colhdr">Date</th>
                      </tr>
                      <tr><td><input type="text" class="inputalph" name="srchCode" size="1" maxlength="1">
                              <input type="hidden" name="operCode" value="LIKE">
                              <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=AUDACTCODE&amp;flagSrchHdr=@dtw_rurlescseq("Audit Activity Code")&amp;docName=Search&amp;fldName=srchCode&amp;fldDesc=srchCalcDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="srchCalcDesc" value="$(fieldDesc)" type="text" size="10" disabled>
                          </td>
                          <td class="inputnmbr"><input name="srchCo" type="text" size="2" maxlength="2"> / <input name="srchFac" type="text" size="4" maxlength="4">
                              <input type="hidden" name="operCo" value="=">
                              <input type="hidden" name="operFac" value="=">
                          </td>
                          <td><input type="text" class="inputnmbr" name="srchPREmpl" size="5" maxlength="5">
                              <input type="hidden" name="operPREmpl" value="=">
                          </td>
                          <td><input type="text" class="inputnmbr" name="srchHREmpl" size="9" maxlength="9">
                              <input type="hidden" name="operHREmpl" value="=">
                          </td>
                          <td><input type="text" class="inputalph" name="srchUser" size="10" maxlength="10">
                              <input type="hidden" name="operUser" value="LIKE">
                          </td>
                          <td><input type="text" class="inputnmbr" name="srchDate" size="6" maxlength="6">
                              <input type="hidden" name="operDate" value="=">
                          </td>
                          <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                      </tr>
                  </table>
                  <script TYPE="text/javascript">
                      document.Search.srchCode.focus();
                  </script>
              </form>

              %if (inclCommon == "Y")
                  @dtw_assign(commonChecked, "CHECKED")
              %else
                  @dtw_assign(commonChecked, "")
              %endif
              %if (inclHR == "Y")
                  @dtw_assign(hrChecked, "CHECKED")
              %else
                  @dtw_assign(hrChecked, "")
              %endif
              %if (inclPayroll == "Y")
                  @dtw_assign(payrollChecked, "CHECKED")
              %else
                  @dtw_assign(payrollChecked, "")
              %endif


              @dtw_assign(viewCheckBox, "AuditEmpl")
              %INCLUDE "WildCardPage.icl"
          %endif

          <table $(contentTable)>
              <tr>
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("AUCODE", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Code" title="Sequence By Activity Code">Activity <br>Code</a></th>
                  @OrderBy_Sort("AUFILE", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Table" title="Sequence By Table">Table</a></th>
                  @OrderBy_Sort("AUCO#", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=CoFac" title="Sequence By Co/Fac">Co / Fac</a></th>
                  @OrderBy_Sort("AUPREM", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=PREmpl" title="Sequence By PR Empl">PR<br> Empl</a></th>
                  @OrderBy_Sort("AUPEEM", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=HREmpl" title="Sequence By HR Empl">HR<br> Empl</a></th>
                  <th class="colhdr">Report Name</th>
                  @OrderBy_Sort("AUUSER", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=User" title="Sequence By User">User</a></th>
                  @OrderBy_Sort("AUTSTP", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Timestamp" title="Sequence By Timestamp">Timestamp</a></th>
              </tr>
              %INCLUDE "NoRecordsFound.icl"

              %ROW{
                  @dtw_assign(maintainVar, "$(genericVarBase)&amp;grouping=@dtw_rurlescseq(V_AUGRP)&amp;fromD2w=@dtw_rurlescseq(d2wName)")

                      %INCLUDE "SetRowClass.icl"

                      @Format_Confirm_Desc("$(V_AUGRP)","", "", "", "", "", confirmDesc)
                      <tr class="$(rowClass)">
                          @RtvFldDesc("FLTYPE='AUDACTCODE' and FLVALU='$(V_AUCODE)'", "SYFLAG", "FLDESC", actCodeDesc)
                          %if (V_AUFILE == "HREMPL")
                              @dtw_assign(F_File, "Common")
                          %elseif (V_AUFILE == "PEEMPL")
                              @dtw_assign(F_File, "HR")
                          %elseif (V_AUFILE == "PREMPL")
                              @dtw_assign(F_File, "Payroll")
                          %endif
                          @Format_HRCoFac("$(V_AUCO#)", "$(V_AUFAC#)", "", F_CoFac)
                          @dtw_assign(edtVar,V_AUDATA)
                          %if (V_AUCODE=="C" && V_AUFILE=="HREMPL")
                              @dtw_assign(edtVar2,"")
                              @RtvFldDesc("AUGRP='EMPLOYEE' and AUTSTP='$(V_AUTSTP)' and AUSEQ='2'", "HDAUDT", "AUDATA", edtVar2)
                              @Decat_Field2("@@rnam")   @dtw_assign(V_RNAME, fieldValue)
                          %else
                              @Decat_Field("@@rnam")   @dtw_assign(V_RNAME, fieldValue)
                          %endif
                          @RtvFldDesc("USUSER='$(V_AUUSER)'", "SYUSER", "USDESC", userProfileDesc)
                          %if (V_AUCODE == "C")
                              @dtw_assign(inclChgOnly,"Y")
                          %else
                              @dtw_assign(inclChgOnly,"")
                          %endif
                          <td class="colalph"><a href="$(homeURL)$(cGIPath)AuditEmployee.d2w/REPORT$(genericVarBase)&amp;prCompany=@dtw_rurlescseq(V_AUCO#)&amp;prFacility=@dtw_rurlescseq(V_AUFAC#)&amp;prEmployee=@dtw_rurlescseq(V_AUPREM)&amp;hrCompany=@dtw_rurlescseq(V_AUPECO)&amp;hrEmployee=@dtw_rurlescseq(V_AUPEEM)&amp;grouping=@dtw_rurlescseq(V_AUGRP)&amp;timestamp=@dtw_rurlescseq(V_AUTSTP)&amp;inclChgOnly=@dtw_rurlescseq(inclChgOnly)&amp;backHome=$(d2wName)/REPORT" title="View Audit Info">$(actCodeDesc)</a></td>
                          <td class="colalph" $(helpCursor)><span title="$(V_AUFILE)">$(F_File)</td>
                          <td class="colalph">$(F_CoFac)</td>
                          <td class="colalph">$(V_AUPREM)</td>
                          <td class="colalph">$(V_AUPEEM)</td>
                          <td class="colalph">$(V_RNAME)</td>
                          <td class="colalph" $(helpCursor)><span title="$(userProfileDesc)">$(V_AUUSER)</span></td>
                          <td class="colalph">$(V_AUTSTP)</td>
                      </tr>

              %}
          </table>
          %if (sql_Record_Count != "1")
              %INCLUDE "PageBottom.icl"
              %INCLUDE "WildCardPrint.icl"
              $(hrTagAttr)
              %INCLUDE "Copyright.icl"
          %endif
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  @dtw_assign(uv_CompanyName, "AUCO#")
  @dtw_assign(uv_FacilityName, "AUFAC#")
  @dtw_assign(uv_HRCompanyName, "AUPECO")
  @dtw_assign(uv_HRLocationName, "AUPELC")
  @dtw_assign(uv_HomeDepartmentName, "AUDEPT")
  @dtw_assign(uv_PayTypeName, "AUPAYT")
  @dtw_assign(uv_SalaryControlName, "AUPAYD")
  @dtw_assign(uv_PREmployeeName, "AUPREM")
  @dtw_assign(uv_HREmployeeName, "AUPEEM")
  %INCLUDE "userview.icl"

  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select AUCODE, AUFILE, AUCO#, AUFAC#, AUPREM, AUPEEM, AUUSER, AUTSTP, AUSSNO ", stmtSQL)
  @dtw_concat(fileSQL, " HDAUDT ", fileSQL)
  @dtw_concat(selectSQL, "AUGRP='EMPLOYEE' and AUSEQ < 2 ", selectSQL)
  %INCLUDE "AuditFileChecked.icl"
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"

  @EmplAuditView_XMLQuery(profileHandle, dataBaseID, stmtSQL)

%}

%FUNCTION(dtw_sql) EmplAuditView_XMLQuery (IN CHAR(64)    profileHandle,
			                       CHAR(2)     dataBaseID,
                                              CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      @XMLBeginTag("EmplAuditList")
          %ROW{
              @XMLIDTag(V_AUTSTP, "employee ID")
                  @XMLTag(V_AUCODE, "Actcode")
                  @XMLTag(V_AUFILE, "Table")
                  @XMLTag(V_AUCO#,  "Co")
                  @XMLTag(V_AUFAC#, "Fac")
                  @XMLTag(V_AUPREM, "PayrollEmpl")
                  @XMLTag(V_AUPEEM, "HREmpl")
                  @XMLTag(V_AUUSER, "User")
                  @XMLTag(V_AUTSTP, "Timestamp")
              @XMLEndTag("employee")
	   %}

      @XMLEndTag("EmplAuditList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "AUTSTP")
          @DTW_ASSIGN(orderByDisplay, "Timestamp")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %elseif (chgCommon == "Y" && inclCommon == "Y")
          @dtw_assign(inclCommon, "")
      %elseif (chgCommon == "Y")
          @dtw_assign(inclCommon, "Y")
      %elseif (chgHR == "Y" && inclHR == "Y")
          @dtw_assign(inclHR, "")
      %elseif (chgHR == "Y")
          @dtw_assign(inclHR, "Y")
      %elseif (chgPayroll == "Y" && inclPayroll == "Y")
          @dtw_assign(inclPayroll, "")
      %elseif (chgPayroll == "Y")
          @dtw_assign(inclPayroll, "Y")
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %if (inclCommon == "" && inclHR == "" && inclPayroll == "" && chgCommon != "Y" && chgHR != "Y" && chgPayroll != "Y")
      @dtw_assign(inclCommon, "Y")
      @dtw_assign(inclHR, "Y")
      @dtw_assign(inclPayroll, "Y")
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Code")
      %if (orderBy == "AUCODE")
          @DTW_ASSIGN(orderBy, "AUCODE DESC")
          @DTW_ASSIGN(orderByDisplay, "Activity Code (descending)")
      %else
          @DTW_ASSIGN(orderBy, "AUCODE")
          @DTW_ASSIGN(orderByDisplay, "Activity Code")
      %endif
  %elseif (sequence == "Table")
      %if (orderBy == "AUFILE")
          @DTW_ASSIGN(orderBy, "AUFILE DESC")
          @DTW_ASSIGN(orderByDisplay, "Table (descending)")
      %else
          @DTW_ASSIGN(orderBy, "AUFILE")
          @DTW_ASSIGN(orderByDisplay, "Table")
      %endif
  %elseif (sequence == "CoFac")
      %if (orderBy == "AUCO#, AUFAC#")
          @DTW_ASSIGN(orderBy, "AUCO# DESC, AUFAC#")
          @DTW_ASSIGN(orderByDisplay, "Co/Fac (descending)")
      %else
          @DTW_ASSIGN(orderBy, "AUCO#, AUFAC#")
          @DTW_ASSIGN(orderByDisplay, "Co/Fac")
      %endif
  %elseif (sequence == "PREmpl")
      %if (orderBy == "AUPREM")
          @DTW_ASSIGN(orderBy, "AUPREM DESC")
          @DTW_ASSIGN(orderByDisplay, "PR Empl (descending)")
      %else
          @DTW_ASSIGN(orderBy, "AUPREM")
          @DTW_ASSIGN(orderByDisplay, "PR Empl")
      %endif
  %elseif (sequence == "HREmpl")
      %if (orderBy == "AUPEEM")
          @DTW_ASSIGN(orderBy, "AUPEEM DESC")
          @DTW_ASSIGN(orderByDisplay, "HR Empl (descending)")
      %else
          @DTW_ASSIGN(orderBy, "AUPEEM")
          @DTW_ASSIGN(orderByDisplay, "HR Empl")
      %endif
  %elseif (sequence == "User")
      %if (orderBy == "AUUSER")
          @DTW_ASSIGN(orderBy, "AUUSER DESC")
          @DTW_ASSIGN(orderByDisplay, "User (descending)")
      %else
          @DTW_ASSIGN(orderBy, "AUUSER")
          @DTW_ASSIGN(orderByDisplay, "User")
      %endif
  %elseif (sequence == "Timestamp")
      %if (orderBy == "AUTSTP")
          @DTW_ASSIGN(orderBy, "AUTSTP DESC")
          @DTW_ASSIGN(orderByDisplay, "Timestamp (descending)")
      %else
          @DTW_ASSIGN(orderBy, "AUTSTP")
          @DTW_ASSIGN(orderByDisplay, "Timestamp")
      %endif
  %endif

  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Search")
          <script TYPE="text/javascript">
              %INCLUDE "dateedit.icl"
	       %INCLUDE "numedit.icl"
              %INCLUDE "calendar.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchCo, 2, 0) &&
                      editNum(document.Search.srchFac, 4, 0) &&
                      editNum(document.Search.srchPREmpl, 5, 0) &&
                      editNum(document.Search.srchHREmpl, 9, 0) &&
                      editNum(document.Search.srchDate, 6, 0))
                  return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "GRPSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Activity Code</td>
                              @dtw_assign(operNbr, "operCode")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchCode" size="1" maxlength="1">                              <a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=AUDACTCODE&amp;flagSrchHdr=@dtw_rurlescseq("Audit Activity Code")&amp;docName=Search&amp;fldName=srchCode&amp;fldDesc=srchCalcDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="srchCalcDesc" value="$(fieldDesc)" type="text" size="10" disabled></td>
                          </tr>

                          <tr><td class="dsphdr">Company</td>
                              @dtw_assign(operNbr, "operCo")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchCo" size="2" maxlength="2"></td>
                          </tr>

                          <tr><td class="dsphdr">Facility</td>
                              @dtw_assign(operNbr, "operFac")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchFac" size="4" maxlength="4"></td>
                          </tr>

                          <tr><td class="dsphdr">PR Employee</td>
                              @dtw_assign(operNbr, "operPREmpl")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchPREmpl" size="5" maxlength="5"></td>
                          </tr>

                          <tr><td class="dsphdr">HR Employee</td>
                              @dtw_assign(operNbr, "operHREmpl")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchHREmpl" size="9" maxlength="9"></td>
                          </tr>

                          <tr><td class="dsphdr">User</td>
                              @dtw_assign(operNbr, "operUser")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchUser" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Date</td>
                              @dtw_assign(operNbr, "operDate")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchDate" size="6" maxlength="6">
                              <a href="javascript:calWindow('srchDate');">$(calendarImage)</a></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchCode.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("upper(AUCODE)", "Code", $(srchCode), "U", operCode, "A")
  @Build_WildCard ("AUCO#", "Company", $(srchCo), "", operCo, "N")
  @Build_WildCard ("AUFAC#", "Facility", $(srchFac), "", operFac, "N")
  @Build_WildCard ("AUPREM", "PR Employee", $(srchPREmpl), "", operPREmpl, "N")
  @Build_WildCard ("AUPEEM", "HR Employee", $(srchHREmpl), "", operHREmpl, "N")
  @Build_WildCard ("upper(AUUSER)", "User", $(srchUser), "U", operUser, "A")
  @Build_WildCard ("date(AUTSTP)", "Date", $(srchDate), "", operDate, "I")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}