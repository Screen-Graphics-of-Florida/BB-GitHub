%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {	
  page_title              = "Salesman"
  d2wName                 = "Salesman.d2w"
  d2wVarBase              = "$(genericVarBase)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HHDSLU"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"	
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\r" + "\r" + text);}
	       %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchNumber, 3, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "SALESMAN")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      @dtw_assign(uv_SalesmanName, "SMSLSM")
                      %INCLUDE "userview.icl"

                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select SMSLSM, SMSNA1, SMSNA2, SMSNA3, SMSNA4, SMSCTY, SMST, SMZIP, SMPHON,", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(SMSNA1) as SMSNA1U, upper(SMSNA2) as SMSNA2U, upper(SMSNA3) as SMSNA3U, ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(SMSNA4) as SMSNA4U, upper(SMSCTY) as SMSCTYU ", stmtSQL)
                      @dtw_concat(fileSQL, " HDSLSM ", fileSQL)
                      %if (wildCardSearch!="" || uv_Sql != "")
                          @dtw_concat(selectSQL, "SMSLSM>0 ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Salesman_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Salesman_Query (IN  CHAR(64)    profileHandle,
				        CHAR(2)     dataBaseID,
                                       CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %if (sql_Record_Count != "1")
          <table $(contentTable)>
              <colgroup>
                  <col width="80%">
                  <col width="15%">
              <tr><td><h1>$(page_title)</h1></td>
                  %if (formatToPrint =="")
                      @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                      <td class="toolbar">
                          %if (sec_01 == "Y")
                              <a href="$(homeURL)$(cGIPath)SalesmanMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                          %endif
                          %INCLUDE "XMLFormat.icl"
                          %INCLUDE "FormatToPrint.icl"
                          %INCLUDE "HelpPage.icl"
                      </td>
                  %endif
              </tr>
          </table>
          %INCLUDE "ConfMessageDisplay.icl"
	
          $(hrTagAttr)

          %if (formatToPrint != "Y")
              <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
                  <table $(quickSearchTable)>
                      <tr>
                          <th class="colhdr">Name</th>
                          <th class="colhdr">Number</th>
                      </tr>
                      <tr><td><input type="text" class="inputalph" name="srchName" size="26" maxlength="26">
                              <input type="hidden" name="operName" value="LIKE">
                          </td>
                          <td><input type="text" class="inputnmbr" name="srchNumber" size="7" maxlength="3">
                              <input type="hidden" name="operNumber" value="=">
                          </td>
                          <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                      </tr>
                  </table>
                  <script TYPE="text/javascript">
                      document.Search.srchName.focus();
                  </script>
              </form>

              %INCLUDE "WildCardPage.icl"
          %endif
	   		
          <table $(contentTable)>
              <tr>
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y" || sec_05 == "Y"))
                      <th class="colhdr">$(optionHeading)</th>
                  %endif
                  @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
                  @OrderBy_Sort("SMSLSM", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Number" title="Sequence By Number">  Number</a></th>
                  @OrderBy_Sort("SMSNA1U", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Name" title="Sequence By Name">  Name</a></th>
                  @OrderBy_Sort("SMSNA2U", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Address" title="Sequence By Address, City, Number">  Address</a></th>
                  @OrderBy_Sort("SMSCTYU", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=City" title="Sequence By City, Name">  City</a></th>
                  @OrderBy_Sort("SMST", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=State" title="Sequence By State, Name">  State</a></th>
                  @OrderBy_Sort("SMZIP", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Zip" title="Sequence By Zip, Name">  Zip</a></th>
                  @OrderBy_Sort("SMPHON", sortVar)
                  <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Phone" title="Sequence By Phone Number">  Phone Number</a></th>
              </tr>
              %INCLUDE "NoRecordsFound.icl"
      %endif

              %ROW{
                  %if (sql_Record_Count == "1")
                      @Save_WebReg(webRegCurFile, profileHandle, d2wName, "", orderBy, orderByDisplay, "")
                      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)SalesmanSelect.d2w/REPORT$(d2wVarBase)&amp;salesmanNumber=@dtw_rurlescseq(V_SMSLSM)&amp;salesmanName=@dtw_rurlescseq(V_SMSNA1)">
                  %else
                      @dtw_assign(maintainVar, "$(d2wVarBase)&amp;salesmanNumber=@dtw_rurlescseq(V_SMSLSM)&amp;salesmanName=@dtw_rurlescseq(V_SMSNA1)&amp;fromD2w=@dtw_rurlescseq(d2wName)")
                      @EditPhoneNumber(V_SMPHON)
                      %INCLUDE "SetRowClass.icl"
                      @Format_Confirm_Desc($(V_SMSNA1), $(V_SMSLSM), "", "", "", "", confirmDesc)
           		
                      <tr class="$(rowClass)">
                          %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y" || sec_05 == "Y"))
                              <td class="opticon">
                                  %if (sec_05 == "Y" && sec_02 != "Y")
                                      <a href="$(homeURL)$(cGIPath)SalesmanMaintainBasic.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                                  %elseif (sec_02 == "Y" || sec_03 == "Y")
                                      <a href="$(homeURL)$(cGIPath)SalesmanMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                                  %endif
                                  %if (sec_04 == "Y")
                                      <a href="$(homeURL)$(cGIPath)SalesmanMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                                  %endif
                                  %if (sec_03 == "Y")
                                      <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)SalesmanMaintain.d2w/Edit_Data$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                                  %endif
                              </td>
                          %endif
                          <td class="colnmbr">$(V_SMSLSM)</td>
                          <td class="colalph"><a href="$(homeURL)$(cGIPath)SalesmanSelect.d2w/REPORT$(maintainVar)" title="View Salesman">$(V_SMSNA1)</a></td>
                          <td class="colalph">$(V_SMSNA2)</td>
                          <td class="colalph">$(V_SMSCTY)</td>
                          <td class="colcode">$(V_SMST)</td>
                          <td class="colalph">$(V_SMZIP)</td>
                          <td class="colnmbr">$(V_SMPHON)</td>
                      </tr>
                  %endif
              %}
          </table>
          %if (sql_Record_Count != "1")
              %INCLUDE "PageBottom.icl"
              %INCLUDE "WildCardPrint.icl"
              $(hrTagAttr)
              %INCLUDE "Copyright.icl"
          %endif
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  @dtw_assign(uv_SalesmanName, "SMSLSM")
  %INCLUDE "userview.icl"

  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select SMSLSM, SMSNA1, SMSNA2, SMSNA3, SMSNA4, SMSCTY, SMST, SMZIP, SMPHON,", stmtSQL)
  @dtw_concat(stmtSQL, " upper(SMSNA1) as SMSNA1U, upper(SMSNA2) as SMSNA2U, upper(SMSNA3) as SMSNA3U, ", stmtSQL)
  @dtw_concat(stmtSQL, " upper(SMSNA4) as SMSNA4U, upper(SMSCTY) as SMSCTYU ", stmtSQL)
  @dtw_concat(fileSQL, " HDSLSM ", fileSQL)
  %if (wildCardSearch!="" || uv_Sql != "")
    @dtw_concat(selectSQL, "SMSLSM>0 ", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @Salesman_XMLQuery(profileHandle, dataBaseID, stmtSQL)

%}

%FUNCTION(dtw_sql) Salesman_XMLQuery (IN  CHAR(64)    profileHandle,
				           CHAR(2)     dataBaseID,
                                          CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("SalesmanList")
          %ROW{
              @EditPhoneNumber(V_SMPHON)

              @XMLIDTag(V_SMSLSM, "Salesman ID")
                  @XMLTag(V_SMSLSM, "Number")
                  @XMLTag(V_SMSNA1, "Name")
                  @XMLTag(V_SMSNA2, "Address1")
                  @XMLTag(V_SMSNA3, "Address2")
                  @XMLTag(V_SMSCTY, "City")
                  @XMLTag(V_SMST, "State")
                  @XMLTag(V_SMZIP, "Zip")
                  @XMLTag(V_SMPHON, "PhoneNumber")
              @XMLEndTag("Salesman")
          %}
      @XMLEndTag("SalesmanList")
  %}
%}
%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "SMSNA1U")
          @DTW_ASSIGN(orderByDisplay, "Name")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Number")
      %if (orderBy == "SMSLSM")
          @DTW_ASSIGN(orderBy, "SMSLSM DESC")
          @DTW_ASSIGN(orderByDisplay, "Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "SMSLSM")
          @DTW_ASSIGN(orderByDisplay, "Number")
      %endif
  %elseif (sequence == "Name")
      %if (orderBy == "SMSNA1U")
          @DTW_ASSIGN(orderBy, "SMSNA1U DESC")
          @DTW_ASSIGN(orderByDisplay, "Name (descending)")
      %else
          @DTW_ASSIGN(orderBy, "SMSNA1U")
          @DTW_ASSIGN(orderByDisplay, "Name")
      %endif
  %elseif (sequence == "Address")
      %if (orderBy == "SMSNA2U,SMSNA3U,SMSNA4U,SMSCTYU,SMSLSM")
          @DTW_ASSIGN(orderBy, "SMSNA2U DESC,SMSNA3U,SMSNA4U,SMSCTYU,SMSLSM")
          @DTW_ASSIGN(orderByDisplay, "Address (descending), City, Number")
      %else
          @DTW_ASSIGN(orderBy, "SMSNA2U,SMSNA3U,SMSNA4U,SMSCTYU,SMSLSM")
          @DTW_ASSIGN(orderByDisplay, "Address, City, Number")
      %endif
  %elseif (sequence == "City")
      %if (orderBy == "SMSCTYU,SMSNA1U")
          @DTW_ASSIGN(orderBy, "SMSCTYU DESC,SMSNA1U")
          @DTW_ASSIGN(orderByDisplay, "City (descending), Name")
      %else
          @DTW_ASSIGN(orderBy, "SMSCTYU,SMSNA1U")
          @DTW_ASSIGN(orderByDisplay, "City, Name")
      %endif
  %elseif (sequence == "State")
      %if (orderBy == "SMST,SMSNA1U")
          @DTW_ASSIGN(orderBy, "SMST DESC,SMSNA1U")
          @DTW_ASSIGN(orderByDisplay, "State (descending), Name")
      %else
          @DTW_ASSIGN(orderBy, "SMST,SMSNA1U")
          @DTW_ASSIGN(orderByDisplay, "State, Name")
      %endif
  %elseif (sequence == "Zip")
      %if (orderBy == "SMZIP,SMSNA1U")
          @DTW_ASSIGN(orderBy, "SMZIP DESC,SMSNA1U")
          @DTW_ASSIGN(orderByDisplay, "Zip (descending), Name")
      %else
          @DTW_ASSIGN(orderBy, "SMZIP,SMSNA1U")
          @DTW_ASSIGN(orderByDisplay, "Zip, Name")
      %endif
  %elseif (sequence == "Phone")
      %if (orderBy == "SMPHON")
          @DTW_ASSIGN(orderBy, "SMPHON DESC")
          @DTW_ASSIGN(orderByDisplay, "Phone Number (descending)")
      %else
          @DTW_ASSIGN(orderBy, "SMPHON")
          @DTW_ASSIGN(orderByDisplay, "Phone Number")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          @dtw_assign(formName, "Search")
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchNumber, 3, 0) &&
                      editNum(document.Search.srchPhone, 11, 0))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "SALESMANSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)
                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Number</td>
                              @dtw_assign(operNbr, "operNumber")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"> <input type="text" name="srchNumber" size="3" maxlength="3"></td>
                          </tr>

                          <tr><td class="dsphdr">Name</td>
                              @dtw_assign(operNbr, "operName")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchName" size="26" maxlength="26"></td>
                          </tr>

                          <tr><td class="dsphdr">Address</td>
                              <td>&nbsp;</td>
                              <td class="inputalph"><input type="text" name="srchAddress" size="26" maxlength="26"></td>	
                          </tr>

                          <tr><td class="dsphdr">State</td>
                              @dtw_assign(operNbr, "operState")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchState" size="4" maxlength="2"><a href="$(homeURL)$(cGIPath)StateSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Search&amp;fldName=srchState&amp;fldDesc=stateDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="stateDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                          </tr>

                          <tr><td class="dsphdr">Zip</td>
                              @dtw_assign(operNbr, "operZip")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchZip" size="14" maxlength="14"></td>
                          </tr>

                          <tr><td class="dsphdr">Phone Number</td>
                              <td>&nbsp;</td>
                              <td class="inputnmbr"><input type="text" name="srchPhone" size="14" maxlength="11"></td>
                          </tr>

                          <tr><td class="dsphdr">Customer Region</td>
                              @dtw_assign(operNbr, "operRegion")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"> <input type="text" name="srchRegion" size="4" maxlength="5"><a href="$(homeURL)$(cGIPath)RegionSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Search&amp;fldName=srchRegion&amp;fldDesc=regionDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="regionDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                          </tr>

                          <tr><td class="dsphdr">Country</td>
                              @dtw_assign(operNbr, "operCountry")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchCountry" size="4" maxlength="3"><a href="$(homeURL)$(cGIPath)CountrySearch.d2w/ENTRY$(genericVarBase)&amp;docName=Search&amp;fldName=srchCountry&amp;fldDesc=countryDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="countryDesc" value="$(fieldDesc)" type="text" size="35" disabled></td>
                          </tr>

                          <tr><td class="dsphdr">Commission Type</td>
                              @dtw_assign(operNbr, "operComm")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchComm" size="1" maxlength="1"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchNumber.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("SMSLSM", "Number", $(srchNumber), "", operNumber, "N")
  @Build_WildCard ("upper(SMSNA1)", "Name", $(srchName), "U", operName, "A")

  @dtw_assign(salesmanAddress,@dtw_rstrip(srchAddress))
  %if (srchAddress != "")
      @Build_WildCard ("SMSNA2", "Address", $(salesmanAddress), "U", "LIKE", "V")
      @dtw_mUPPERCASE(srchAddress)
      @dtw_replace(srchAddress, "?", "_", "1", "a", srchAddress)
      @dtw_replace(srchAddress, "*", "%", "1", "a", srchAddress)
      @dtw_concat(wildCardTemp, " (trim(upper(SMSNA2)) LIKE '$(srchAddress)'", wildCardTemp)
      @dtw_concat(wildCardTemp, " OR   trim(upper(SMSNA3)) LIKE '$(srchAddress)'", wildCardTemp)
      @dtw_concat(wildCardTemp, " OR   trim(upper(SMSCTY)) LIKE '$(srchAddress)')", wildCardTemp)
  %endif
		
  @Build_WildCard ("SMST", "State", $(srchState), "U", operState, "A")
  @Build_WildCard ("SMZIP", "Zip", $(srchZip), "U", operZip, "A")
  @Build_WildCard ("SMPHON", "Phone Number", $(srchPhone), "", "", "P")
  @Build_WildCard ("SMREGN", "Region", $(srchRegion), "U", operRegion, "A")
  @Build_WildCard ("SMCTRY", "Country", $(srchCountry), "U", operCountry, "A")
  @Build_WildCard ("SMSCPT", "Commission Type", $(srchComm), "U", operComm, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}