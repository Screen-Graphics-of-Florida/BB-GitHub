%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {
  page_title              = "Table Column Maintenance"
  d2wName                 = "TableColumnMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;tblID=@dtw_rurlescseq(tblID)&amp;tableName=@dtw_rurlescseq(tableName)&amp;tableDesc=@dtw_rurlescseq(tableDesc)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  editVariables           = ""
  tableLibrary            = ""
  refreshDefn             = ""
  dspAlt                  = ""
%}

@dtw_assign(customTable, "")
%if (tblID >= "5000")
  @dtw_assign(customTable, "Custom")
%endif

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  @RtvFldDesc("TWXHND='$(profileHandle)' and TWTBLN='$(tableName)' ", "SYTBLW", "char(count(*))", recCount)	
  %if (recCount <= "0")
    %if (refreshDefn == "Y")
      @RtvFldDesc("TNTBLN='$(tableName)'", "SYTBLN", "TNTBID", tableID)	
      @RtvFileLib(tableName, tableLibrary)
      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Insert Into SYTBLW (TWXHND,TWTBLN,TWTBID,TWCOLN,TWDSEQ,TWSDFT,TWDTYP,TWFTYP,TWFLGT,TWLENG,TWSCAL, ", stmtSQL)
      @dtw_concat(stmtSQL, "                     TWDPOS,TWREQF,TWUPCS,TWCNID,TWRFTB,TWALWN,TWALWU, ", stmtSQL)
      @dtw_concat(stmtSQL, "                     TWDFTF,TWDFTV,TWCTXT,TWCHDG,TWSTOR,TWPREC,TWCSID, ", stmtSQL)
      @dtw_concat(stmtSQL, "                     TWDTPR,TWSURL,TWSRTN,TWUVFN) ", stmtSQL)
      @dtw_concat(stmtSQL, " Select '$(profileHandle)','$(tableName)',$(tableID),coalesce(COLUMN_NAME,' '),coalesce(TCDSEQ,0),' ',coalesce(DATA_TYPE,' '),coalesce(TCFTYP,' '),coalesce(TCFLGT,' '),coalesce(LENGTH,0),coalesce(NUMERIC_SCALE,0), ", stmtSQL)
      @dtw_concat(stmtSQL, "                     coalesce(ORDINAL_POSITION,0),coalesce(TCREQF,' '),coalesce(TCUPCS,' '),coalesce(TCCNID,' '),coalesce(TCRFTB,' '),coalesce(IS_NULLABLE,' '),coalesce(IS_UPDATABLE,' '), ", stmtSQL)
      @dtw_concat(stmtSQL, "                     coalesce(HAS_DEFAULT,' '),coalesce(TCDFTV,nullif(COLUMN_DEFAULT,''' '''),' '),coalesce(TCCTXT,COLUMN_TEXT,LABELTEXT,' '), ", stmtSQL)
      @dtw_concat(stmtSQL, "                     case when TCCHDG is null and COLUMN_HEADING is null then coalesce(COLUMN_TEXT,LABELTEXT,' ') ", stmtSQL)
      @dtw_concat(stmtSQL, "                      when TCCHDG is null then concat(trim(substr(COLUMN_HEADING,1,20)),concat(' ',concat(trim(substr(COLUMN_HEADING,21,20)),concat(' ',trim(substr(COLUMN_HEADING,41,20)))))) ", stmtSQL)
      @dtw_concat(stmtSQL, "                      else TCCHDG end, ", stmtSQL)
      @dtw_concat(stmtSQL, "                     coalesce(STORAGE,0),coalesce(NUMERIC_PRECISION,0),coalesce(CCSID,0), ", stmtSQL)
      @dtw_concat(stmtSQL, "                     coalesce(DATETIME_PRECISION,0),coalesce(TCSURL,' '),coalesce(TCSRTN,' '),coalesce(TCUVFN,' ') ", stmtSQL)
      @dtw_concat(stmtSQL, " From QSYS2/SYSCOLUMNS ", stmtSQL)
      @dtw_concat(stmtSQL, " left join SYTBLC on TABLE_NAME=TCTBLN and COLUMN_NAME=TCCOLN ", stmtSQL)
      @dtw_concat(stmtSQL, " Where TABLE_NAME='$(tableName)' and SYSTEM_TABLE_SCHEMA='$(tableLibrary)' ", stmtSQL)
    %else
      @RtvFileLib(tableName, tableLibrary)
      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Insert Into SYTBLW (TWXHND,TWTBLN,TWTBID,TWCOLN,TWDSEQ,TWSDFT,TWDTYP,TWFTYP,TWFLGT,TWLENG,TWSCAL, ", stmtSQL)
      @dtw_concat(stmtSQL, "                     TWDPOS,TWREQF,TWUPCS,TWCNID,TWRFTB,TWALWN,TWALWU, ", stmtSQL)
      @dtw_concat(stmtSQL, "                     TWDFTF,TWDFTV,TWCTXT,TWCHDG,TWSTOR,TWPREC,TWCSID, ", stmtSQL)
      @dtw_concat(stmtSQL, "                     TWDTPR,TWSURL,TWSRTN,TWUVFN) ", stmtSQL)
      @dtw_concat(stmtSQL, " Select '$(profileHandle)','$(tableName)',TCTBID,TCCOLN,TCDSEQ,Case When TCSDFT='Y' Then TCCOLN Else ' ' End,TCDTYP,TCFTYP,TCFLGT,TCLENG,TCSCAL, ", stmtSQL)
      @dtw_concat(stmtSQL, "                     TCDPOS,TCREQF,TCUPCS,TCCNID,TCRFTB,TCALWN,TCALWU, ", stmtSQL)
      @dtw_concat(stmtSQL, "                     TCDFTF,TCDFTV,TCCTXT,TCCHDG,TCSTOR,TCPREC,TCCSID, ", stmtSQL)
      @dtw_concat(stmtSQL, "                     TCDTPR,TCSURL,TCSRTN,TCUVFN ", stmtSQL)
      @dtw_concat(stmtSQL, " From SYTBLC ", stmtSQL)
      @dtw_concat(stmtSQL, " Where TCTBLN='$(tableName)' ", stmtSQL)
    %endif
    @dtw_concat(stmtSQL, " @@endsql ", stmtSQL)
    @SQL_Update(stmtSQL, status)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
 	   %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NoFormValidate.icl"
              %INCLUDE "numedit.icl"
              function confirmRefresh() { return confirm("Confirm refresh of columns")}
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "TABLECOLUMNMAINTAIN")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select *  ", stmtSQL)
                      @dtw_concat(stmtSQL, " From SYTBLW ", stmtSQL)
                      @dtw_concat(stmtSQL, " Where TWXHND='$(profileHandle)' and TWTBLN='$(tableName)' ", stmtSQL)
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @Maintain_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Maintain_Query (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1>$(page_title)</h1></td>
              <td class="toolbar">
                  <a href="javascript:document.Chg.updateOption.value='U'; check(document.Chg)">$(acceptImageMed)</a>
                  <a href="$(homeURL)$(cGIPath)$(customTable)Table.d2w/REPORT$(d2wVarBase)">$(cancelImageMed)</a>
                  <a onClick="return confirmRefresh()" href="$(homeURL)$(cGIPath)$(d2wName)/REFRESH$(d2wVarBase)&amp;refreshDefn=Y">$(selectResetImage)</a>
                  @dtw_assign(medIcon, "Y")
                  %INCLUDE "HelpPage.icl"
              </td>
          </tr>
      </table>

      <table $(contentTable)>
          @Format_Header("Table", $(tableDesc), $(tableName))
      </table>

      $(hrTagAttr)
      %INCLUDE "ErrorDisplay.icl"

      %if (dspAlt == "Y")
          @dtw_assign(dspAltChecked, "CHECKED")
      %else
          @dtw_assign(dspAltChecked, "")
      %endif
      <div class="page">
          <input type="checkbox" name="dspAlt" $(dspAltChecked) onClick="javascript:document.Chg.chgFields.value='Y'; check(document.Chg);">Alternate Columns
      </div>

      <form class="formClass" METHOD=POST NAME="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;dspAlt=@dtw_rurlescseq(dspAlt)">
          <table $(contentTable)>
              <tr><td><input type="hidden" name="updateOption">
                      <input type="hidden" name="chgFields">
                  </td>
              </tr>

              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)&amp;dspAlt=@dtw_rurlescseq(dspAlt)")
              %if (dspAlt == "Y")
                  <tr>
                      @OrderBy_Sort("TWCOLN", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=column" title="Sequence By Column">Column</a></th>
                      @OrderBy_Sort("TWCTXT", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=desc" title="Sequence By Description, Column">Description</a></th>
                      @OrderBy_Sort("TWFLGT", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=flagtype" title="Sequence By Flag Type, Column">Flag Type</a></th>
                      @OrderBy_Sort("TWRFTB", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=reference" title="Sequence By Reference Table, Column">Reference Table</a></th>
                      @OrderBy_Sort("TWDFTV", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=default" title="Sequence By Default Value, Column">Default Value</a></th>
                      @OrderBy_Sort("TWCNID", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=condition" title="Sequence By Condition, Column">Condition</a></th>
                      @OrderBy_Sort("TWREQF", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=required" title="Sequence By Required, Column">Required</a></th>
                      @OrderBy_Sort("TWUPCS", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=upper" title="Sequence By Uppercase, Column">Uppercase</a></th>
                      @OrderBy_Sort("TWDTYP", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=datatype" title="Sequence By Data Type, Size, Column">Data Type</a></th>
                      @OrderBy_Sort("TWDPOS", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=seq" title="Sequence By Sequence">Seq</a></th>
                  </tr>
              %else
                  <tr>
                      @OrderBy_Sort("TWCOLN", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=column" title="Sequence By Column">Column</a></th>
                      @OrderBy_Sort("TWCTXT", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=desc" title="Sequence By Description, Column">Description</a></th>
                      @OrderBy_Sort("TWCHDG", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=heading" title="Sequence By Column Heading, Column">Column Heading</a></th>
                      @OrderBy_Sort("TWDSEQ", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=dftseq" title="Sequence By Default Sequence, Column">Dft Seq</a></th>
                      @OrderBy_Sort("TWSDFT", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=srchdft" title="Sequence By Search Default, Column">Search<br>Default</a></th>
                      @OrderBy_Sort("TWFTYP", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=fieldtype" title="Sequence By Column Type, Column">Column Type</a></th>
                      @OrderBy_Sort("TWSRTN", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=altsort" title="Sequence By Alternate Sort, Column">Alternate Sort</a></th>
                      @OrderBy_Sort("TWUVFN", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=uvfield" title="Sequence By User View Column, Column">User View</a></th>
                      @OrderBy_Sort("TWDTYP", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=datatype" title="Sequence By Data Type, Size, Column">Data Type</a></th>
                      @OrderBy_Sort("TWDPOS", sortVar)
                      <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=seq" title="Sequence By Sequence">Seq</a></th>
                  </tr>
              %endif

              %ROW {
                  %INCLUDE "SetRowClass.icl"
                  @dtw_assign(recNbr, $(ROW_NUM))
                  %while(@dtw_rlength(recNbr) != "4") {@dtw_insert("0", recNbr, recNbr)%}
                  @Field_Checked(V_TWUPCS, "Y", ucChecked)
                  @Field_Checked(V_TWREQF, "Y", rqChecked)
                  %if (V_TWDTYP == "CHAR")
                      @dtw_assign(V_TWSCAL, "")
                  %endif
                  %if (V_TWSCAL == "")
                      @dtw_assign(dataType, "$(V_TWDTYP) ($(V_TWLENG))")
                  %else
                      @dtw_assign(dataType, "$(V_TWDTYP) ($(V_TWLENG),$(V_TWSCAL))")
                  %endif
                  @Format_Nbr(V_TWDSEQ, F_TWDSEQ, "3", "4", "", "", "")

                  @Field_Checked(V_TWSDFT, V_TWCOLN, sdChecked)

                  %if (dspAlt == "Y")
                      <tr class="$(rowClass)">
                          <td class="inputalph"><input type="hidden" name="co$(recNbr)" value="$(V_TWCOLN)">$(V_TWCOLN)</td>
                          <td class="inputalph"><input type="text"   name="tx$(recNbr)" value="$(V_TWCTXT)" size="35" maxlength="52"></td>
                          <td class="inputalph"><input type="text"   name="fl$(recNbr)" value="$(V_TWFLGT)" size="10" maxlength="10"><a href="$(homeURL)$(phpPath)FlagTypeSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fl$(recNbr)" onclick="$(searchWinVar)"> $(searchImage) &nbsp; </a></td>
                          <td class="inputalph"><input type="text"   name="rt$(recNbr)" value="$(V_TWRFTB)" size="10" maxlength="130"><a href="$(homeURL)$(phpPath)TableSearch.php$(altVarBase)&amp;tag=REPORT&amp;docName=Chg&amp;fldName=rt$(recNbr)&amp;fldDesc=rt$(recNbr)Desc" onclick="$(searchWinVar)"> $(searchImage) &nbsp; </a><input name="rt$(recNbr)Desc" type="hidden"></td>
                          <td class="inputalph"><input type="text"   name="dv$(recNbr)" value="$(V_TWDFTV)" size="15" maxlength="2002"></td>
                          <td class="inputalph"><input type="text"   name="cn$(recNbr)" value="$(V_TWCNID)" size="10" maxlength="10"><a href="$(homeURL)$(cGIPath)ColumnConditionSearch.d2w/REPORT$(genericVarBase)&amp;docName=Chg&amp;fldName=cn$(recNbr)&amp;fldDesc=cn$(recNbr)Desc" onclick="$(searchWinVar)"> $(searchImage) &nbsp; </a><input name="cn$(recNbr)Desc" type="hidden"></td>
                          <td class="colcode"><input type="checkbox" name="rq$(recNbr)" value='Y' $(rqChecked)></td>
                          <td class="colcode"><input type="checkbox" name="uc$(recNbr)" value='Y' $(ucChecked)></td>
                          <td class="colalph">$(dataType)</td>
                          <td class="colnmbr">$(V_TWDPOS)</td>
                          <td><input type="hidden" name="hd$(recNbr)" value="$(V_TWCHDG)"></td>
                          <td><input type="hidden" name="ds$(recNbr)" value="$(F_TWDSEQ)"></td>
                          <td><input type="hidden" name="srchDft"     value="$(V_TWSDFT)"></td>
                          <td><input type="hidden" name="sn$(recNbr)" value="$(V_TWSRTN)"></td>
                          <td><input type="hidden" name="uv$(recNbr)" value="$(V_TWUVFN)"></td>
                          <td><input type="hidden" name="ft$(recNbr)" value="$(V_TWFTYP)"></td>
                      </tr>
                  %else
                      <tr class="$(rowClass)">
                          <td class="inputalph"><input type="hidden" name="co$(recNbr)" value="$(V_TWCOLN)">$(V_TWCOLN)</td>
                          <td class="inputalph"><input type="text"   name="tx$(recNbr)" value="$(V_TWCTXT)" size="35" maxlength="52" style="background:$(rowClass)"></td>
                          <td class="inputalph"><input type="text"   name="hd$(recNbr)" value="$(V_TWCHDG)" size="35" maxlength="52" style="background:$(rowClass)"></td>
                          <td class="inputalph"><input type="text"   name="ds$(recNbr)" value="$(F_TWDSEQ)" size="5" maxlength="7" style="background:$(rowClass)"></td>
                          <td class="colcode"><input type="radio"    name="srchDft" value="$(V_TWCOLN)" $(sdChecked) style="background:$(rowClass)"></td>
                          <td class="inputalph"><input type="text"   name="ft$(recNbr)" value="$(V_TWFTYP)" size="10" maxlength="10" style="background:$(rowClass)"><a href="$(homeURL)$(phpPath)FlagSearch.php$(altVarBase)&amp;flagType=FLDTYPE&amp;flagSrchHdr=@dtw_rurlescseq("Column Type")&amp;docName=Chg&amp;fldName=ft$(recNbr)&amp;fldDesc=ft$(recNbr)Desc" onclick="$(searchWinVar)"> $(searchImage) &nbsp; </a><input name="ft$(recNbr)Desc" type="hidden"></td>
                          <td class="inputalph"><input type="text"   name="sn$(recNbr)" value="$(V_TWSRTN)" size="10" maxlength="130" style="background:$(rowClass)"><a href="$(homeURL)$(cGIPath)TableColumnSearch.d2w/REPORT$(d2wVarBase)&amp;docName=Chg&amp;fldName=sn$(recNbr)&amp;fldDesc=sn$(recNbr)Desc" onclick="$(searchWinVar)"> $(searchImage) </a> <input name="sn$(recNbr)Desc" value="$(fieldDesc)" type="hidden"></td>
                          <td class="inputalph"><input type="text"   name="uv$(recNbr)" value="$(V_TWUVFN)" size="10" maxlength="10" style="background:$(rowClass)"><a href="$(homeURL)$(phpPath)UserViewFieldSearch.php$(altVarBase)&amp;tag=REPORT&amp;docName=Chg&amp;fldName=uv$(recNbr)&amp;fldDesc=uv$(recNbr)Desc" onclick="$(searchWinVar)"> $(searchImage) &nbsp; </a><input name="uv$(recNbr)Desc" type="hidden"></td>
                          <td class="colalph">$(dataType)</td>
                          <td class="colnmbr">$(V_TWDPOS)</td>
                          <td><input type="hidden" name="rt$(recNbr)" value="$(V_TWRFTB)"></td>
                          <td><input type="hidden" name="cn$(recNbr)" value="$(V_TWCNID)"></td>
                          <td><input type="hidden" name="rq$(recNbr)" value="$(V_TWREQF)"></td>
                          <td><input type="hidden" name="uc$(recNbr)" value="$(V_TWUPCS)"></td>
                          <td><input type="hidden" name="fl$(recNbr)" value="$(V_TWFLGT)"></td>
                          <td><input type="hidden" name="dv$(recNbr)" value="$(V_TWDFTV)"></td>
                      </tr>
                  %endif
                  %if (V_TWMSG# != "")
                      @Ret_Error_Msg(profileHandle, dataBaseID, $(V_TWMSG#), errorMessage)
                      <tr><td>&nbsp;</td>
                          <td class="error" colspan="9">$(errorMessage)</td>		
                      </tr>
                  %endif
              %}
          </table>
      </form>
      <table $(contentTable)>
          <tr>
              <td class="toolbar">
                  <a href="javascript:document.Chg.updateOption.value='U'; check(document.Chg)">$(acceptImageMed)</a>
                  <a href="$(homeURL)$(cGIPath)$(customTable)Table.d2w/REPORT$(d2wVarBase)">$(cancelImageMed)</a>
                  <a onClick="return confirmRefresh()" href="$(homeURL)$(cGIPath)$(d2wName)/REFRESH$(d2wVarBase)&amp;refreshDefn=Y">$(selectResetImage)</a>
                  @dtw_assign(medIcon, "Y")
                  %INCLUDE "HelpPage.icl"
              </td>
          </tr>
      </table>
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     maintenanceCode,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,                             	
                                        INOUT CHAR(32000) errVar)
{%EXEC {HSYTBC_W.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}

%HTML(REFRESH) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "TWDPOS")
      @DTW_ASSIGN(orderByDisplay, "Sequence")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif

  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Delete From SYTBLW Where TWXHND='$(profileHandle)' and TWTBLN='$(tableName)' ", stmtSQL)
  @dtw_concat(stmtSQL, " @@endsql ", stmtSQL)
  @SQL_Update(stmtSQL, status)

  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "column")
      %if (orderBy == "TWCOLN")
          @DTW_ASSIGN(orderBy, "TWCOLN DESC")
          @DTW_ASSIGN(orderByDisplay, "Column (descending)")
      %else
          @DTW_ASSIGN(orderBy, "TWCOLN")
          @DTW_ASSIGN(orderByDisplay, "Column")
      %endif
  %elif (sequence == "desc")
      %if (orderBy == "TWCTXT,TWCOLN")
          @DTW_ASSIGN(orderBy, "TWCTXT DESC,TWCOLN")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Column")
      %else
          @DTW_ASSIGN(orderBy, "TWCTXT,TWCOLN")
          @DTW_ASSIGN(orderByDisplay, "Description, Column")
      %endif
  %elif (sequence == "heading")
      %if (orderBy == "TWCHDG,TWCOLN")
          @DTW_ASSIGN(orderBy, "TWCHDG DESC,TWCOLN")
          @DTW_ASSIGN(orderByDisplay, "Column Heading (descending), Column")
      %else
          @DTW_ASSIGN(orderBy, "TWCHDG,TWCOLN")
          @DTW_ASSIGN(orderByDisplay, "Column Heading, Column")
      %endif
  %elif (sequence == "dftseq")
      %if (orderBy == "TWDSEQ,TWCOLN")
          @DTW_ASSIGN(orderBy, "TWDSEQ DESC,TWCOLN")
          @DTW_ASSIGN(orderByDisplay, "Default Sequence (descending), Column")
      %else
          @DTW_ASSIGN(orderBy, "TWDSEQ,TWCOLN")
          @DTW_ASSIGN(orderByDisplay, "Default Sequence, Column")
      %endif
  %elif (sequence == "srchDft")
      %if (orderBy == "TWSDFT,TWCOLN")
          @DTW_ASSIGN(orderBy, "TWSDFT DESC,TWCOLN")
          @DTW_ASSIGN(orderByDisplay, "Search Default (descending), Column")
      %else
          @DTW_ASSIGN(orderBy, "TWSDFT,TWCOLN")
          @DTW_ASSIGN(orderByDisplay, "Search Default, Column")
      %endif
  %elif (sequence == "flagtype")
      %if (orderBy == "TWFLGT,TWCOLN")
          @DTW_ASSIGN(orderBy, "TWFLGT DESC,TWCOLN")
          @DTW_ASSIGN(orderByDisplay, "Flag Type (descending), Column")
      %else
          @DTW_ASSIGN(orderBy, "TWFLGT,TWCOLN")
          @DTW_ASSIGN(orderByDisplay, "Flag Type, Column")
      %endif
  %elif (sequence == "reference")
      %if (orderBy == "TWRFTB,TWCOLN")
          @DTW_ASSIGN(orderBy, "TWRFTB DESC,TWCOLN")
          @DTW_ASSIGN(orderByDisplay, "Reference (descending), Column")
      %else
          @DTW_ASSIGN(orderBy, "TWRFTB,TWCOLN")
          @DTW_ASSIGN(orderByDisplay, "Reference, Column")
      %endif
  %elif (sequence == "default")
      %if (orderBy == "TWDFTV,TWCOLN")
          @DTW_ASSIGN(orderBy, "TWDFTV DESC,TWCOLN")
          @DTW_ASSIGN(orderByDisplay, "Default Value (descending), Column")
      %else
          @DTW_ASSIGN(orderBy, "TWDFTV,TWCOLN")
          @DTW_ASSIGN(orderByDisplay, "Default Value, Column")
      %endif
  %elif (sequence == "condition")
      %if (orderBy == "TWCNID,TWCOLN")
          @DTW_ASSIGN(orderBy, "TWCNID DESC,TWCOLN")
          @DTW_ASSIGN(orderByDisplay, "Condition (descending), Column")
      %else
          @DTW_ASSIGN(orderBy, "TWCNID,TWCOLN")
          @DTW_ASSIGN(orderByDisplay, "Condition, Column")
      %endif
  %elif (sequence == "required")
      %if (orderBy == "TWREQF,TWCOLN")
          @DTW_ASSIGN(orderBy, "TWREQF DESC,TWCOLN")
          @DTW_ASSIGN(orderByDisplay, "Required (descending), Column")
      %else
          @DTW_ASSIGN(orderBy, "TWREQF,TWCOLN")
          @DTW_ASSIGN(orderByDisplay, "Required, Column")
      %endif
  %elif (sequence == "upper")
      %if (orderBy == "TWUPCS,TWCOLN")
          @DTW_ASSIGN(orderBy, "TWUPCS DESC,TWCOLN")
          @DTW_ASSIGN(orderByDisplay, "Uppercase (descending), Column")
      %else
          @DTW_ASSIGN(orderBy, "TWUPCS,TWCOLN")
          @DTW_ASSIGN(orderByDisplay, "Uppercase, Column")
      %endif
  %elif (sequence == "datatype")
      %if (orderBy == "TWDTYP,TWLENG,TWCOLN")
          @DTW_ASSIGN(orderBy, "TWDTYP DESC,TWLENG,TWCOLN")
          @DTW_ASSIGN(orderByDisplay, "Data Type (descending), Size, Column")
      %else
          @DTW_ASSIGN(orderBy, "TWDTYP,TWLENG,TWCOLN")
          @DTW_ASSIGN(orderByDisplay, "Data Type, Size, Column")
      %endif
  %elif (sequence == "fieldtype")
      %if (orderBy == "TWFTYP,TWCOLN")
          @DTW_ASSIGN(orderBy, "TWFTYP DESC,TWCOLN")
          @DTW_ASSIGN(orderByDisplay, "Column Type (descending), Column")
      %else
          @DTW_ASSIGN(orderBy, "TWFTYP,TWCOLN")
          @DTW_ASSIGN(orderByDisplay, "Column Type, Column")
      %endif
  %elif (sequence == "altsort")
      %if (orderBy == "TWSRTN,TWCOLN")
          @DTW_ASSIGN(orderBy, "TWSRTN DESC,TWCOLN")
          @DTW_ASSIGN(orderByDisplay, "Alternate Sort (descending), Column")
      %else
          @DTW_ASSIGN(orderBy, "TWSRTN,TWCOLN")
          @DTW_ASSIGN(orderByDisplay, "Alternate Sort, Column")
      %endif
  %elif (sequence == "uvfield")
      %if (orderBy == "TWUVFN,TWCOLN")
          @DTW_ASSIGN(orderBy, "TWUVFN DESC,TWCOLN")
          @DTW_ASSIGN(orderByDisplay, "User View Column (descending), Column")
      %else
          @DTW_ASSIGN(orderBy, "TWUVFN,TWCOLN")
          @DTW_ASSIGN(orderByDisplay, "User View Column, Column")
      %endif
  %elif (sequence == "seq")
      %if (orderBy == "TWDPOS,TWCOLN")
          @DTW_ASSIGN(orderBy, "TWDPOS DESC,TWCOLN")
          @DTW_ASSIGN(orderByDisplay, "Sequence (descending)")
      %else
          @DTW_ASSIGN(orderBy, "TWDPOS,TWCOLN")
          @DTW_ASSIGN(orderByDisplay, "Sequence")
      %endif
  %endif
		
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(Edit_Data) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"

  @RtvFldDesc("TWXHND='$(profileHandle)' and TWTBLN='$(tableName)' ", "SYTBLW", "char(count(*))", recCount)	
  @dtw_assign(ux, "1")
  %while(ux <= recCount){
      @dtw_assign(recNbr, ux)
      %while(@dtw_rlength(recNbr) != "4") {@dtw_insert("0", recNbr, recNbr)%}
      @dtw_assign(coln, $(co$(recNbr)))
      @dtw_assign(text, @DTW_rHTMLENCODE($(tx$(recNbr))))
      @dtw_assign(chdg, @DTW_rHTMLENCODE($(hd$(recNbr))))
      @dtw_assign(dseq, $(ds$(recNbr)))
      @dtw_assign(sdft, "")
      %if (srchDft == coln) @dtw_assign(sdft, coln) %endif
      %if (dseq == "") @dtw_assign(dseq, "0") %endif
      @dtw_assign(fldt, $(ft$(recNbr)))   @dtw_mUPPERCASE(fldt)
      @dtw_assign(flgt, $(fl$(recNbr)))   @dtw_mUPPERCASE(flgt)
      @dtw_assign(dftv, $(dv$(recNbr)))
      @dtw_assign(rftb, $(rt$(recNbr)))   @dtw_mUPPERCASE(rftb)
      @dtw_assign(reqf, $(rq$(recNbr)))
      @dtw_assign(upcs, $(uc$(recNbr)))
      @dtw_assign(cnid, $(cn$(recNbr)))
      @dtw_assign(srtn, $(sn$(recNbr)))   @dtw_mUPPERCASE(srtn)
      @dtw_assign(uvfn, $(uv$(recNbr)))
      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Update SYTBLW Set TWFTYP='$(fldt)', TWCTXT='$(text)', TWCHDG='$(chdg)', TWDSEQ=$(dseq), TWSDFT='$(sdft)',", stmtSQL)
      @dtw_concat(stmtSQL, "               TWFILN='$(filn)', TWFLGT='$(flgt)', TWDFTV='$(dftv)', TWRFTB='$(rftb)', ", stmtSQL)
      @dtw_concat(stmtSQL, "               TWREQF='$(reqf)', TWUPCS='$(upcs)', TWCNID='$(cnid)', TWSRTN='$(srtn)', TWUVFN='$(uvfn)' ", stmtSQL)
      @dtw_concat(stmtSQL, " Where TWXHND='$(profileHandle)' and TWTBLN='$(tableName)' and TWCOLN='$(coln)' ", stmtSQL)
      @dtw_concat(stmtSQL, " @@endsql ", stmtSQL)
      @SQL_Update(stmtSQL, status)

      @dtw_add(ux, "1", ux)
  %}

  @dtw_assign(maintenanceCode, updateOption)
  @dtw_assign(edtVar, "")
  @Concat_Field("@@tbln", tableName)
  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, maintenanceCode, errFound, edtVar, errVar)

  %if (errFound == "" && updateOption=="U")
      @Format_ConfMsg_Desc("C", $(tableDesc), "$(tableName)", "", "", "", "", confMessage)
      @RtvFldDesc("ERXHND='$(profileHandle)' and ERTYPE='U'", "SYEERR", "EREERR", backURL)
      %if (backURL == "")
          <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)$(customTable)Table.d2w/REPORT$(d2wVarBase)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %else
          <meta http-equiv="refresh" content="1; URL=$(backURL)&amp;confMessage=@dtw_rurlescseq(confMessage)">
      %endif
  %else
      %if (chgFields == "Y" && dspAlt == "Y")
          @dtw_assign(dspAlt, "")
      %elif (chgFields == "Y")
          @dtw_assign(dspAlt, "Y")
      %endif
      @EdtVarErr(profileHandle, typeValue, edtVar)
      @ErrVarErr(profileHandle, typeError, errVar)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;maintenanceCode=@dtw_rurlescseq(maintenanceCode)&amp;dspAlt=@dtw_rurlescseq(dspAlt)$(searchVarBase)&amp;errFound=@dtw_rurlescseq(errFound)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}
