%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "VarBase.icl"

%Define {	
  page_title              = "Order Shipping - Kit Options"
  d2wName                 = "OrderShipKitOption.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)&amp;lineNumber=@dtw_rurlescseq(lineNumber)&amp;orderNumber=@dtw_rurlescseq(orderNumber)&amp;vendCustItemsFound=@dtw_rurlescseq(vendCustItemsFound)&amp;reliefCode=@dtw_rurlescseq(reliefCode)&amp;addToOrder=@dtw_rurlescseq(addToOrder)&amp;orderTypeDesc=@dtw_rurlescseq(orderTypeDesc)"
  nextPrevVar             = "$(d2wVarBase)&amp;optError=@dtw_rurlescseq(optError)&amp;kitPrice=@dtw_rurlescseq(kitPrice)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "10"
  rowIndexNext            = "1"
  totalPages              = "0"
  optError                = ""
  itemNumber              = ""
  itemDesc                = ""
  releaseNumber           = "000"
  qtyOrdered              = "0"
  qtyShipped              = "0"
  pricedByKit             = ""
  kitPrice                = "0"
  qtyOpen                 = "0"
  relQty                  = "0"
  relErr                  = ""
  maintCode               = ""
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@customerName", "@dtw_rurlescseq(customerName)", "1", "a", workURL)
  @dtw_replace(workURL, "@@customerNumber", "@dtw_rurlescseq(customerNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@orderControlNumber", "@dtw_rurlescseq(orderControlNumber)", "1", "a", workURL)
  @dtw_replace(workURL, "@@lineNumber", "@dtw_rurlescseq(lineNumber)", "1", "a", workURL)
%}

%FUNCTION(DTW_directcall) Update_Misc_Charges (INOUT CHAR(64)  profileHandle,
				      		      CHAR(2)   dataBaseID,
				      	 	      DEC(8,0)  orderControlNumber,
				      	 	      DEC(9,2)  freightCharge,
				      		      DEC(9,2)  specialCharge,
				      		      CHAR(1)   updateTotal)
						
{%EXEC {HOEUMC_W.PGM %}
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"	
  <html>
      <head>
	   %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmNoUpdate() { return confirm("Confirm No Update Of Kit Options")}
              %INCLUDE "Menu.js"
              %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  var rows = 1;
                  if (typeof document.Chg.totrows.value == 'undefined') {rows = document.Chg.totrows[0].value;}
                  var ok = true;
                  if (rows >= 1)  {if (editNum(document.Chg.qty1, 9, 4) == false) {ok = false};}
                  if (rows >= 2)  {if (editNum(document.Chg.qty2, 9, 4) == false) {ok = false};}
                  if (rows >= 3)  {if (editNum(document.Chg.qty3, 9, 4) == false) {ok = false};}
                  if (rows >= 4)  {if (editNum(document.Chg.qty4, 9, 4) == false) {ok = false};}
                  if (rows >= 5)  {if (editNum(document.Chg.qty5, 9, 4) == false) {ok = false};}
                  if (rows >= 6)  {if (editNum(document.Chg.qty6, 9, 4) == false) {ok = false};}
                  if (rows >= 7)  {if (editNum(document.Chg.qty7, 9, 4) == false) {ok = false};}
                  if (rows >= 8)  {if (editNum(document.Chg.qty8, 9, 4) == false) {ok = false};}
                  if (rows >= 9)  {if (editNum(document.Chg.qty9, 9, 4) == false) {ok = false};}
                  if (rows >= 10) {if (editNum(document.Chg.qty10, 9, 4)== false) {ok = false};}
                  if (ok == true) {return true;}
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- Start Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "OEKITOPTIONS")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      @Get_Detail_Line(profileHandle, dataBaseID, orderControlNumber, lineNumber, dropShipNumber, itemNumber, itemDesc, qtyOrdered, qtyShipped, pricedByKit, qtyOpen, relQty, relErr, maintCode)
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select * ", stmtSQL)
                      @dtw_concat(fileSQL, " OEKTWW ", fileSQL)
                      @dtw_concat(selectSQL, "W2OCTL=$(orderControlNumber) and W2ORL#=$(lineNumber) ", selectSQL)
                      %INCLUDE "stmtSQLSelect.icl"
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Kit_Option_Line_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Kit_Option_Line_Query (IN  CHAR(64) profileHandle,
                                              CHAR(2)    dataBaseID,
                                              CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="50%">
              <col width="45%">
          <tr><td><h1>$(page_title)</h1></td>
              <td align="right">
                  %if (optError == "")
                      <a href="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)">$(orderAcceptImage)</a>
                  %endif
                  <a onClick="return confirmNoUpdate()" href="$(homeURL)$(cGIPath)$(d2wName)/NOUPDATE$(d2wVarBase)">$(orderNoUpdateImage)</a>
              </td>
          </tr>
      </table>

      %INCLUDE "OrderEntryHeader.icl"

      $(hrTagAttr)

      <table $(contentTable)>
          <tr>
              <td class="colhdr">Item Number</td>
              <td class="colhdr">Description</td>
              <td class="colhdr">Quantity Shipped</td>
              %if (pricedByKit == "O")
                  <td class="colhdr">Kit Price</td>
              %endif
          </tr>
          <tr class="evenrow">
              <td class="colalph">$(itemNumber)</td>		
              <td class="colalph">$(itemDesc)</td>		
              <td class="colnmbr">$(qtyShipped)</td>
              %if (pricedByKit == "O")
                  <td class="colnmbr">$(kitPrice)</td>
              %endif
          </tr>
      </table>
      <table $(contentTable)>
          <tr><td>%INCLUDE "AssignPageValue.icl"</td></tr>
      </table>
			
      <form class="formClass" METHOD=POST name="Chg" ACTION="$(homeURL)$(cGIPath)$(d2wName)/UPDATE$(d2wVarBase)&amp;updateRowNum=@dtw_rurlescseq($(START_ROW_NUM))">
          <table $(contentTable)>
              <tr>
                  <td class="colhdr">Component/Option</td>
                  <td class="colhdr">Description</td>
                  <td class="colhdr">Man</td>
                  <td class="colhdr">Mult</td>
                  <td class="colhdr">Required<br>Quantity</td>
                  <td class="colhdr">Open<br>Quantity</td>
                  <td class="colhdr">Quantity<br>Shipped</td>
                  %if (pricedByKit == "O")
                      <td class="colhdr">Price</td>
                      <td class="colhdr">Extra<br>Charge</td>
                  %endif
                  <td><a href="javascript:check(document.Chg)">$(orderUpdateImage)</a></td>
              </tr>
    		
              %ROW{
                  %INCLUDE "SetRowClass.icl"
          	
                  %if (V_W2ER# != "")
                      @Ret_Error_Msg(profileHandle, dataBaseID, $(V_W2ER#), errorMessage)
                  %endif

                  @Format_Nbr("@dtw_rmultiply(V_W2IMQT, qtyShipped)", optionOrdered, $(qtyNbrDec), $(qtyEditCode), "Y", "", "")
                  @dtw_subtract(V_W2QORD, V_W2QSTD, openQty)
                  @Format_Nbr(openQty, F_openQty, $(qtyNbrDec), $(qtyEditCode), "", "", "")

                  <tr class="$(rowClass)">
                      %if (V_W2OITM == "")
                          <td class="colalph">$(V_W2CITM)</td>
                          <td class="colalph">$(V_W2CIDS)</td>
                          <td class="colcode">$(V_W2MAND)</td>
                          <td class="colcode">$(V_W2MULT)</td>
                          <td class="colnmbr">$(optionOrdered)</td>
                      %else
                          <td class="colalph">$(V_W2OITM)</td>
                          <td class="colalph">$(V_W2OIDS)</td>
                          <td>&nbsp;</td>
                          <td>&nbsp;</td>
                          <td>&nbsp;</td>
                      %endif
                      %if (V_W2HASO != "Y" || V_W2OITM != "" || V_W2NS != "N")
                          <td class="colnmbr">$(F_openQty)</td>		
                      %else
                          <td>&nbsp;</td>
                      %endif
                      %if (V_W2NS != "N" && (V_W2MAND != "Y" || V_W2MULT == "Y") && openQty != "0")
                          <td class="inputnmbr"><input type="text" name="qty$(ROW_NUM)" value="$(V_W2QSTC)" size="15" maxlength="15"></td>		
                      %elif (V_W2HASO != "Y" || V_W2OITM != "" || V_W2NS != "N")
                          <td class="colnmbr"><input type="hidden" name="qty$(ROW_NUM)" value="$(V_W2QSTC)" size="13" maxlength="13">$(V_W2QSTC)</td>
                      %else
                          <td class="colnmbr"><input type="hidden" name="qty$(ROW_NUM)" value="$(V_W2QSTC)" size="13" maxlength="13"></td>
                      %endif
                      %if (V_W2NS !="N" && pricedByKit == "O")
                          @Format_Nbr(V_W2SLPR, F_W2SLPR, "5", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_W2SLPR)</td>		
                      %else
                          <td>&nbsp;</td>
                      %endif
                      %if (V_W2NS != "N" && V_W2OITM != "" && pricedByKit == "O")
                          @Format_Nbr(V_W2XCHG, F_W2XCHG, "5", $(amtEditCode), "", "", "")
                          <td class="colnmbr">$(F_W2XCHG)</td>
                      %else
                          <td>&nbsp;</td>
                      %endif
                      %if (V_W2ER# != "")
                          <td class="error">$(errorMessage)</td>		
                      %endif

                      <td class="colicon"><input type="hidden" name="citm$(ROW_NUM)" value="@dtw_rqhtmlencode($(V_W2CITM))">		
                          <input type="hidden" name="oitm$(ROW_NUM)" value="@dtw_rqhtmlencode($(V_W2OITM))">		
                          <input type="hidden" name="totrows" value="@dtw_radd(@dtw_rsubtract(sql_Record_Count, START_ROW_NUM), "1")">
                      </td>
                  </tr>
              %}
          </table>
      </form>
      %INCLUDE "PageBottom.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%FUNCTION(DTW_directcall) Get_Detail_Line (INOUT CHAR(64)  profileHandle,
                                                 CHAR(2)   dataBaseID,
                                                 DEC(8,0)  orderControlNumber,
                                                 DEC(3,0)  lineNumber,
                                                 DEC(7,0)  dropShipNumber,
                                                 CHAR(15)  itemNumber,
                                                 CHAR(30)  itemDesc,
                                                 DEC(13,4) qtyOrdered,
                                                 DEC(13,4) qtyShipped,
                                                 CHAR(1)   pricedByKit,
                                                 DEC(13,4) qtyOpen,
                                                 DEC(13,4) relQty,
                                                 CHAR(1)   relErr,
                                                 CHAR(1)   maintCode)
{%EXEC {HOEDWR_W.PGM %}
%}

%FUNCTION(dtw_directcall) Update_Kit_Option (IN    CHAR(64)  profileHandle,
                                                   CHAR(2)   dataBaseID,
                                                   DEC(8,0)  orderControlNumber,
                                                   DEC(3,0)  lineNumber,
                                                   CHAR(1)   updCode,
                                                   CHAR(32000) edtVar,                             	
                                             INOUT CHAR(1)   optError,
                                             INOUT DEC(13,5) kitPrice)
{%EXEC {HOEKSU_W.PGM %}
%}

%HTML(UPDATE) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(qty1,@dtw_rstrip(qty1))
  @dtw_assign(qty2,@dtw_rstrip(qty2))
  @dtw_assign(qty3,@dtw_rstrip(qty3))
  @dtw_assign(qty4,@dtw_rstrip(qty4))
  @dtw_assign(qty5,@dtw_rstrip(qty5))
  @dtw_assign(qty6,@dtw_rstrip(qty6))
  @dtw_assign(qty7,@dtw_rstrip(qty7))
  @dtw_assign(qty8,@dtw_rstrip(qty8))
  @dtw_assign(qty9,@dtw_rstrip(qty9))
  @dtw_assign(qty10,@dtw_rstrip(qty10))

  @dtw_assign(updCode, "")
  @dtw_assign(edtVar, "")
  @Concat_Field("@@ci01", citm1)
  @Concat_Field("@@ci02", citm2)
  @Concat_Field("@@ci03", citm3)
  @Concat_Field("@@ci04", citm4)
  @Concat_Field("@@ci05", citm5)
  @Concat_Field("@@ci06", citm6)
  @Concat_Field("@@ci07", citm7)
  @Concat_Field("@@ci08", citm8)
  @Concat_Field("@@ci09", citm9)
  @Concat_Field("@@ci10", citm10)
  @Concat_Field("@@oi01", oitm1)
  @Concat_Field("@@oi02", oitm2)
  @Concat_Field("@@oi03", oitm3)
  @Concat_Field("@@oi04", oitm4)
  @Concat_Field("@@oi05", oitm5)
  @Concat_Field("@@oi06", oitm6)
  @Concat_Field("@@oi07", oitm7)
  @Concat_Field("@@oi08", oitm8)
  @Concat_Field("@@oi09", oitm9)
  @Concat_Field("@@oi10", oitm10)
  @Concat_Field("@@qt01", qty1)
  @Concat_Field("@@qt02", qty2)
  @Concat_Field("@@qt03", qty3)
  @Concat_Field("@@qt04", qty4)
  @Concat_Field("@@qt05", qty5)
  @Concat_Field("@@qt06", qty6)
  @Concat_Field("@@qt07", qty7)
  @Concat_Field("@@qt08", qty8)
  @Concat_Field("@@qt09", qty9)
  @Concat_Field("@@qt10", qty10)
  @dtw_concat(edtVar, "}{", edtVar)

  @Update_Kit_Option (profileHandle, dataBaseID, orderControlNumber, lineNumber, updCode, edtVar, optError, kitPrice)

  @dtw_assign(START_ROW_NUM,  "$(updateRowNum)")
  @Set_SQL(stmtSQL)
%}

%HTML(ACCEPT) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(updCode, "U")
  @dtw_assign(edtVar, "")
  @Update_Kit_Option (profileHandle, dataBaseID, orderControlNumber, lineNumber,
                      updCode, edtVar, optError, kitPrice)
  %if (reliefCode == "E" || reliefCode == "D")
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)OrderShipKitOptionError.d2w/DISPLAY$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)&amp;turnaround=@dtw_rurlescseq(turnaround)&amp;reliefCode=@dtw_rurlescseq(reliefCode)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %else
      @DTW_ASSIGN(updateTotal, "Y")
      @Update_Misc_Charges (profileHandle, dataBaseID, orderControlNumber, freightCharge, specialCharge, updateTotal)
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)OrderShippingReview.d2w/DISPLAY$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)&amp;orderNumber=@dtw_rurlescseq(orderNumber)&amp;turnaround=@dtw_rurlescseq(turnaround)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}

%HTML(NOUPDATE) {
  %INCLUDE "setLibraryList.icl"
  %if (reliefCode == "D")
      <meta http-equiv="refresh" content="1; URL=$(homeURL)$(cGIPath)OrderShipKitOptionError.d2w/DISPLAY$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)&amp;turnaround=@dtw_rurlescseq(turnaround)&amp;reliefCode=@dtw_rurlescseq(reliefCode)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %else
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)OrderShippingReview.d2w/DISPLAY$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)&amp;orderNumber=@dtw_rurlescseq(orderNumber)&amp;turnaround=@dtw_rurlescseq(turnaround)&amp;timeStamp=@dtw_rurlescseq(@dtw_rconcat(@dtw_rdate(),@dtw_rtime("X")))">
  %endif
%}

%HTML(DISPLAY) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(updCode, "L")
  @dtw_assign(edtVar, "")
  @Update_Kit_Option (profileHandle, dataBaseID, orderControlNumber, lineNumber,
                      updCode, edtVar, optError, kitPrice)
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}