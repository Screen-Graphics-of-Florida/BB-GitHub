%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Customer Contact Search"
  d2wName                 = "CustomerContactSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;fileName=@dtw_rurlescseq(fileName)&amp;fileDesc=@dtw_rurlescseq(fileDesc)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;docName=@dtw_rurlescseq(docName)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  fldName                 = ""
  fldDesc                 = ""
  advanceSearch           = "N"
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function selectContact(contact, desc){
                  window.opener.document.$(docName).$(fldName).value = contact;
		          if (window.opener.document.$(docName).$(fldDesc))
	 	             {window.opener.document.$(docName).$(fldDesc).value = desc;} 
		          else if (window.opener.document.getElementById('$(fldDesc)'))
		                  {window.opener.document.getElementById('$(fldDesc)').innerHTML = desc;}
                  window.opener.document.$(docName).$(fldName).focus();
                  window.close();
              }
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select CRCONT, CRLNAM, CRFNAM, CRCNAM, CRTITL, ", stmtSQL)
                      @dtw_concat(stmtSQL, " CRLNAMU, CRFNAMU, CRCNAMU, CRTITLU ", stmtSQL)
                      @dtw_concat(fileSQL, " CRCNTM ", fileSQL)
                      %if (customerNumber > "0")
                          @dtw_concat(selectSQL, " CRCUST=$(customerNumber) ", selectSQL)
                      %elif (wildCardSearch!="")
                          @dtw_concat(selectSQL, " CRCONT>0  ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @Contact_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Contact_Search (IN CHAR(64)    profileHandle,
				       CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"
      $(searchhrTagAttr)
      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
          <table $(quickSearchTable)>
              <tr><th class="colhdr">Last Name</th>
              </tr>
              <tr><td class="inputalph">
                      <input type="text" name="lastName" size="15" maxlength="30">
                      <input type="hidden" name="operLast" value="LIKE">
                  </td>
                  <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
              </tr>
          </table>
          <script TYPE="text/javascript">
              document.Search.lastName.focus();
          </script>
      </form>	

      %INCLUDE "WildCardPage.icl"

      <table $(contentTable)>
          <tr>
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("CRLNAMU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=last" title="Sequence By Last Name, First Name">Last Name</a></th>
              @OrderBy_Sort("CRFNAMU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=first" title="Sequence By First Name, Last Name">First Name</a></th>
              @OrderBy_Sort("CRCNAMU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=company" title="Sequence By Company, Last Name">Company</a></th>
              @OrderBy_Sort("CRTITLU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=title" title="Sequence By Title, Last Name">Title</a></th>
          </tr>
		
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              %INCLUDE "SetRowClass.icl"
              @Format_Quote(V_CRLNAM, F_CRLNAM)
              @Format_Quote(V_CRFNAM, F_CRFNAM)

              <tr class="$(rowClass)">
                  <td class="colalph"><a href="javascript:selectContact($(V_CRCONT),'$(F_CRLNAM), $(F_CRFNAM)')" title="Select Contact">$(V_CRLNAM)</a></td>
                  <td class="colalph">$(V_CRFNAM)</td>
                  <td class="colalph">$(V_CRCNAM)</td>
                  <td class="colalph">$(V_CRTITL)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "CRLNAMU,CRFNAMU")
      @DTW_ASSIGN(orderByDisplay, "Last Name, First Name")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "last")
      %if (orderBy == "CRLNAMU,CRFNAMU")
          @DTW_ASSIGN(orderBy, "CRLNAMU DESC,CRFNAMU")
          @DTW_ASSIGN(orderByDisplay, "Last Name (descending), First Name")
      %else
          @DTW_ASSIGN(orderBy, "CRLNAMU,CRFNAMU")
          @DTW_ASSIGN(orderByDisplay, "Last Name, First Name")
      %endif
  %elif (sequence == "first")
      %if (orderBy == "CRFNAMU,CRLNAMU")
          @DTW_ASSIGN(orderBy, "CRFNAMU DESC,CRLNAMU")
          @DTW_ASSIGN(orderByDisplay, "First Name (descending), Last Name")
      %else
          @DTW_ASSIGN(orderBy, "CRFNAMU,CRLNAMU")
          @DTW_ASSIGN(orderByDisplay, "First Name, Last Name")
      %endif
  %elif (sequence == "company")
      %if (orderBy == "CRCNAMU,CRLNAMU,CRFNAMU")
          @DTW_ASSIGN(orderBy, "CRCNAMU DESC,CRLNAMU,CRFNAMU")
          @DTW_ASSIGN(orderByDisplay, "Company Name (descending), Last Name, First Name")
      %else
          @DTW_ASSIGN(orderBy, "CRCNAMU,CRLNAMU,CRFNAMU")
          @DTW_ASSIGN(orderByDisplay, "Company Name, Last Name, First Name")
      %endif
  %elif (sequence == "title")
      %if (orderBy == "CRTITLU,CRLNAMU,CRFNAMU")
          @DTW_ASSIGN(orderBy, "CRTITLU DESC,CRLNAMU,CRFNAMU")
          @DTW_ASSIGN(orderByDisplay, "Title (descending), Last Name, First Name")
      %else
          @DTW_ASSIGN(orderBy, "CRTITLU,CRLNAMU,CRFNAMU")
          @DTW_ASSIGN(orderByDisplay, "Title, Last Name, First Name")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
  @Build_WildCard ("CRLNAMU", "Last Name", $(lastName), "U", operLast, "A")
  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
