%}

%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {	
  page_title              = "Order Entry Comments Maintain"
  d2wName                 = "OrderEntryCommentsMaintain.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;customerNumber=@dtw_rurlescseq(customerNumber)&amp;customerName=@dtw_rurlescseq(customerName)&amp;orderControlNumber=@dtw_rurlescseq(orderControlNumber)&amp;itemNumber=@dtw_rurlescseq(itemNumber)&amp;itemDescription=@dtw_rurlescseq(itemDescription)&amp;detailLine=@dtw_rurlescseq(detailLine)&amp;documentType=@dtw_rurlescseq(documentType)&amp;docDescription=@dtw_rurlescseq(docDescription)&amp;clearOnClose=@dtw_rurlescseq(clearOnClose)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_HTML_TABLE          = "YES"
  DTW_PAD_PGM_PARMS       = "YES"
%}

%MACRO_FUNCTION Display_Comments () {
  %INCLUDE "$(docType)"	
  <html>
      <head>
          %INCLUDE "headcmt.icl"
          <script TYPE="text/javascript">
              function confirmClear()  {return confirm("Confirm clear of order comments");}
              %INCLUDE "CheckEnterChg.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
      </head>

      <body $(bodyTagAttr)>
          <!-- Start Of Banner Code -->
          %INCLUDE "$(cmtBanner)"
          <!-- End Of Banner Code -->
          <table $(contentTable)>
              <tr valign="top">
                  <td>
                      @Get_Order_Comments(profileHandle, dataBaseID, documentType, orderControlNumber, detailLine, comment)
                      @dtw_assign(comments, "")
                      @dtw_assign(defaultComments, "Y")
                      %if (detailLine == "000")
                          @dtw_assign(headerTrailer, "H")
                          @dtw_assign(commentType, "Header")
                      %elif (detailLine == "999")
                          @dtw_assign(headerTrailer, "T")
                          @dtw_assign(commentType, "Trailer")
                      %else
                          @dtw_assign(headerTrailer, "")
                          @dtw_assign(commentType, "Detail")
                      %endif

                      @dtw_assign(vcf, "C")
                      @Check_Item_Comments(profileHandle, dataBaseID, itemNumber, vcf, customerNumber, documentType, headerTrailer, defaultComments)
                      <table $(contentTable)>
                          <tr><td><h1>Order Entry $(commentType) Comments &nbsp; &nbsp;</h1></td>
                              <td>
        		           %if (headerTrailer != "")
                                      <a href="$(homeURL)$(cGIPath)CommentSearch.d2w/REPORT$(d2wVarBase)&amp;headerTrailer=@dtw_rurlescseq(headerTrailer)&amp;commentType=@dtw_rurlescseq(commentType)&amp;commentFile=HDCCMT&amp;lineNumber=@dtw_rurlescseq(detailLine)" onclick="$(searchWinVar)"> $(searchDesc)</a>
                                  %endif
                                  <a href="$(homeURL)$(cGIPath)SpecificationSearch.d2w/REPORT$(d2wVarBase)&amp;lineNumber=@dtw_rurlescseq(detailLine)" onclick="$(searchWinVar)"> $(searchSpecLrg)</a>
                                  <a href="javascript:document.Chg.cmtSelection.value='A'; check(document.Chg)">$(commentAcceptImage)</a>
                                  <a href="$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)" onclick="$(commentWinVar)">$(commentResetImage)</a>
                                  <a onClick="return confirmClear()" href="javascript:document.Chg.cmtSelection.value='C'; check(document.Chg)">$(commentClearImage)</a>
        		           %if (defaultComments != "")
                                      <a href="javascript:document.Chg.cmtSelection.value='Y'; check(document.Chg)">$(commentDftImage)</a>
                                  %endif
                                  <a href="$(homeURL)$(cGIPath)$(d2wName)/CLOSE$(d2wVarBase)">$(closeImageMed)</a>
                              </td>
                          </tr>
                      </table>

                      <table $(contentTable)>
                          @Format_Header("Customer", $(customerName), $(customerNumber))
                          @Format_Header("Document", $(docDescription), $(documentType))
                          %if (itemNumber != "")
                              @Format_Header("Item", $(itemDescription), $(itemNumber))
                          %endif
                      </table>

                      <form class="formClass" METHOD=POST NAME=Chg ACTION="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)">
            	           <table $(contentTable)>
                              <tr><td><input type="hidden" name="cmtSelection"></td>
                                  <td>
                                      %if ("$(comment)" != "")
                                          <textarea name="comments" ROWS=20 COLS=60 WRAP="hard">$(comment)</textarea>
                                      %else
            	                           <textarea name="comments" ROWS=20 COLS=60 WRAP="hard"></textarea>
                                      %endif
                                  </td>
                              </tr>
                          </table>
                          <script TYPE="text/javascript">
                              document.Chg.comments.focus();
                          </script>
                      </form>

            	       <table $(contentTable)>
                          <tr>
                              <td valign="top">
        		           %if (headerTrailer != "")
                                      <a href="$(homeURL)$(cGIPath)CommentSearch.d2w/REPORT$(d2wVarBase)&amp;headerTrailer=@dtw_rurlescseq(headerTrailer)&amp;commentType=@dtw_rurlescseq(commentType)&amp;commentFile=HDCCMT&amp;lineNumber=@dtw_rurlescseq(detailLine)" onclick="$(searchWinVar)"> $(searchDesc)</a>
                                  %endif
                                  <a href="$(homeURL)$(cGIPath)SpecificationSearch.d2w/REPORT$(d2wVarBase)&amp;lineNumber=@dtw_rurlescseq(detailLine)" onclick="$(searchWinVar)"> $(searchSpecLrg)</a>
                                  <a href="javascript:document.Chg.cmtSelection.value='A'; check(document.Chg)">$(commentAcceptImage)</a>
                                  <a href="$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)" onclick="$(commentWinVar)">$(commentResetImage)</a>
                                  <a onClick="return confirmClear()" href="javascript:document.Chg.cmtSelection.value='C'; check(document.Chg)">$(commentClearImage)</a>
        		           %if (defaultComments != "")
                                      <a href="javascript:document.Chg.cmtSelection.value='Y'; check(document.Chg)">$(commentDftImage)</a>
                                  %endif
                                  <a href="$(homeURL)$(cGIPath)$(d2wName)/CLOSE$(d2wVarBase)">$(closeImageMed)</a>
                              </td>
                          </tr>
                      </table>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(cmtTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(DTW_directcall) Update_Comments (INOUT   CHAR(64)    profileHandle,
				      		    CHAR(2)     dataBaseID,
				                    CHAR(3)     documentType,
				      		    DEC(8,0)    orderControlNumber,
				      		    CHAR(15)    itemNumber,
				      		    DEC(3,0)    detailLine,
				      		    CHAR(1)     cmtSelection,
				      		    char(32000) comments)

{%EXEC {HOEOCU_W.PGM %}
%}

%FUNCTION(DTW_directcall) Get_Order_Comments(INOUT CHAR(64)    profileHandle,
				                    CHAR(2)     dataBaseID,
				                    CHAR(3)     documentType,
				                    DEC(8,0)    orderControlNumber,	
				      	            DEC(3,0)    detailLine,
				      	            char(32000) comment)

{%EXEC {HOEOCU_P.PGM %}
%}

%HTML(MAINTAIN) {
  %INCLUDE "setLibraryList.icl"
  %if (cmtSelection != "")
      @Update_Comments(profileHandle, dataBaseID, documentType, orderControlNumber, itemNumber, detailLine, cmtSelection, comments)
  %endif
  <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)">
%}

%HTML(DISPLAY) {
  %INCLUDE "setLibraryList.icl"
  @Display_Comments ()
%}

%HTML(ACCEPT) {
  %INCLUDE "setLibraryList.icl"
  @Update_Comments(profileHandle, dataBaseID, documentType, orderControlNumber, itemNumber, detailLine, cmtSelection, comments)

  %if (cmtSelection != "A")
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/DISPLAY$(d2wVarBase)">
  %else
      <script TYPE="text/javascript">
          opener.location.href=opener.location.href;
          window.close()
      </script>
  %endif
%}

%HTML(CLOSE) {
  %if (clearOnClose == "Y")
      %INCLUDE "setLibraryList.icl"
      %INCLUDE "stmtSQLClear.icl"
      @dtw_concat(stmtSQL, " Delete From OECMWK Where O4OCTL=$(orderControlNumber) and O4ORL#=$(detailLine) ", stmtSQL)
      @dtw_concat(stmtSQL, "  and O4DOCT='$(documentType)' @@endsql ", stmtSQL)
      @SQL_Update(stmtSQL, status)
  %endif

  <script TYPE="text/javascript">
      opener.location.href=opener.location.href;
      window.close();
  </script>
%}