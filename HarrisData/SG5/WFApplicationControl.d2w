%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"
%INCLUDE "XMLProcess.icl"

%Define {	
  page_title              = "Application Control"
  d2wName                 = "WFApplicationControl.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;backHome=@dtw_rurlescseq(backHome)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "REPORT$(d2wVarBase)"
  programName             = "HWFAPM"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_PRINT_HEADER        = "NO"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  prtMaxRows              = "$(prtMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  noMsg                   = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
  @dtw_replace(workURL, "@@backHome", "@dtw_rurlescseq(backHome)", "1", "a", workURL)
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function confirmDelete(text) {return confirm("$(delRecordConf)" + "\r" + "\r" + text);}
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  %if (formatToPrint == "")
                      @dtw_assign(pageID, "WFAPPLICATIONCONTROL")
                      <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  %endif
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select WFAPCT.*, ", stmtSQL)
                      @dtw_concat(stmtSQL, " ifnull(PRDESC,' ') as PRDESC, ifnull(PRDESCU,' ') as PRDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " ifnull(FLDESC,' ') as FLDESC, upper(ifnull(FLDESC,' ')) as FLDESCU, ", stmtSQL)
                      @dtw_concat(stmtSQL, " ifnull(PDDESC,' ') as PDDESC, ifnull(PDDESCU,' ') as PDDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " WFAPCT ", fileSQL)
                      @dtw_concat(fileSQL, " left join WFPRHD on PRPROC=ACPROC ", fileSQL)
                      @dtw_concat(fileSQL, " left join SYFLAG on FLTYPE='WFAPPLSTAT' and FLVALU=ACSTAT ", fileSQL)
                      @dtw_concat(fileSQL, " left join WFPRDT on PDPROC=ACPROC and PDPONT=ACPONT and PDSEQ=ACSEQ ", fileSQL)
                      %if (wildCardSearch!="")
                          @dtw_concat(selectSQL, " ACPROC>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @List_Query(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) List_Query (IN  CHAR(64)    profileHandle,
                                   CHAR(2)     dataBaseID,
                                   CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      <table $(contentTable)>
          <colgroup>
              <col width="80%">
              <col width="15%">
          <tr><td><h1> $(page_title)</h1></td>
              %if (formatToPrint != "Y")
                  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
                  <td class="toolbar">
                      %if (backHome != "$(d2wName)/report" && backHome != "")
                          <a href="$(homeURL)$(cGIPath)$(backHome)$(d2wVarBase)" title="Back Home">$(portalHome)</a>
                      %endif
                      %if (sec_01 == "Y")
                          <a href="$(homeURL)$(cGIPath)WFApplicationControlMaintain.d2w/MAINTAIN$(d2wVarBase)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;maintenanceCode=A">$(addImageLrg)</a>
                      %endif
                      %INCLUDE "XMLFormat.icl"
                      %INCLUDE "FormatToPrint.icl"
                      %INCLUDE "HelpPage.icl"
                  </td>
              %endif
          </tr>
      </table>

      %INCLUDE "ConfMessageDisplay.icl"

      $(hrTagAttr)

      %if (formatToPrint == "")
          <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
              <table $(quickSearchTable)>
                  <tr>
                      <th class="colhdr">Description</th>
                      <th class="colhdr">Program</th>
                      <th class="colhdr">Process</th>
                  </tr>
                  <tr><td><input type="text" class="inputalph" name="srchDesc" size="15" maxlength="50">
                          <input type="hidden" name="operDesc" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchProgram" size="10" maxlength="10">
                          <input type="hidden" name="operProgram" value="LIKE">
                      </td>
                      <td><input type="text" class="inputalph" name="srchProcess" size="15" maxlength="50">
                          <input type="hidden" name="operProcess" value="LIKE">
                      </td>
                      <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
                  </tr>
              </table>
              <script TYPE="text/javascript">
                  document.Search.srchDesc.focus();
              </script>
          </form>

          %INCLUDE "WildCardPage.icl"
      %endif

      <table $(contentTable)>
          <tr>
              %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                  <th class="colhdr">$(optionHeading)</th>
              %endif
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("ACDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Description"  title="Sequence By Description, Program, Process">Description</a></th>
              @OrderBy_Sort("ACPGM", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Program"      title="Sequence By Program, Process">Program</a></th>
              @OrderBy_Sort("PRDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Process"      title="Sequence By Process, Program">Process</a></th>
              @OrderBy_Sort("FLDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=Status"       title="Sequence By Status, Program, Process">Status</a></th>
              @OrderBy_Sort("PDDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=DetailPoint"  title="Sequence By Entry Detail Point, Program, Process">Entry Detail Point</a></th>
              @OrderBy_Sort("ACEFFF", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=EffectiveFrom" title="Sequence By Effective From, Program, Process">Effective From</a></th>
              @OrderBy_Sort("ACEFFT", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=EffectiveTo"   title="Sequence By Effective To, Program, Process">Effective To</a></th>
          </tr>

          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @dtw_assign(maintainVar, "$(d2wVarBase)&amp;applProgram=@dtw_rurlescseq(V_ACPGM)&amp;applProcess=@dtw_rurlescseq(V_ACPROC)&amp;fromD2w=@dtw_rurlescseq(d2wName)&amp;updRecNbr=@dtw_rurlescseq(START_ROW_NUM)")
              %INCLUDE "SetRowClass.icl"
              @Format_Confirm_Desc($(V_ACDESC), "$(V_ACPGM)-$(V_ACPROC)", "", "", "", "", confirmDesc)

              <tr class="$(rowClass)">
                  %if (formatToPrint != "Y" && (sec_02 == "Y" || sec_03 == "Y" || sec_04 == "Y"))
                      <td class="opticon">
                          %if (sec_02 == "Y" || sec_03 == "Y")
                              <a href="$(homeURL)$(cGIPath)WFApplicationControlMaintain.d2w/MAINTAIN$(maintainVar)&amp;maintenanceCode=C">$(changeImageSml)</a>
                          %endif
                          %if (sec_04 == "Y")
                              <a href="$(homeURL)$(cGIPath)WFApplicationControlMaintain.d2w/MAINTAIN$(maintainVar)&amp;fromApplProgram=@dtw_rurlescseq(V_ACPGM)&amp;fromApplProcess=@dtw_rurlescseq(V_ACPROC)&amp;maintenanceCode=Z">$(copyImageSml)</a>
                          %endif
                          %if (sec_03 == "Y")
                              <a onClick="return confirmDelete('$(confirmDesc)')" href="$(homeURL)$(cGIPath)WFApplicationControlMaintain.d2w/EDIT_DATA$(maintainVar)&amp;maintenanceCode=D">$(deleteImageSml)</a>
                          %endif
                      </td>
                  %endif
                  <td class="colalph">$(V_ACDESC)</td>                                      	
                  <td class="colalph">$(V_ACPGM)</td>                                      	
                  <td class="colalph" $(helpCursor)><span title="$(V_ACPROC)">$(V_PRDESC)</span></td>                                      	
                  <td class="colalph" $(helpCursor)><span title="$(V_ACSTAT)">$(V_FLDESC)</span></td>                                      	
                  <td class="colalph" $(helpCursor)><span title="$(V_ACPONT)-$(V_ACSEQ)">$(V_PDDESC)</span></td>                                      	
                  <td class="colalph">$(V_ACEFFF)</td>                                      	
                  <td class="colalph">$(V_ACEFFT)</td>                                      	
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(hrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%MACRO_FUNCTION Set_XMLSQL (INOUT stmtSQL) {
  %INCLUDE "stmtSQLClear.icl"
  @dtw_concat(stmtSQL, " Select WFAPCT.*, ", stmtSQL)
  @dtw_concat(stmtSQL, " ifnull(PRDESC,' ') as PRDESC, ifnull(PRDESCU,' ') as PRDESCU, ", stmtSQL)
  @dtw_concat(stmtSQL, " ifnull(FLDESC,' ') as FLDESC, upper(ifnull(FLDESC,' ')) as FLDESCU, ", stmtSQL)
  @dtw_concat(stmtSQL, " ifnull(PDDESC,' ') as PDDESC, ifnull(PDDESCU,' ') as PDDESCU ", stmtSQL)
  @dtw_concat(fileSQL, " WFAPCT ", fileSQL)
  @dtw_concat(fileSQL, " left join WFPRHD on PRPROC=ACPROC ", fileSQL)
  @dtw_concat(fileSQL, " left join SYFLAG on FLTYPE='WFAPPLSTAT' and FLVALU=ACSTAT ", fileSQL)
  @dtw_concat(fileSQL, " left join WFPRDT on PDPROC=ACPROC and PDPONT=ACPONT and PDSEQ=ACSEQ ", fileSQL)
  %if (wildCardSearch!="")
      @dtw_concat(selectSQL, " ACPROC>' ' ", selectSQL)
  %endif
  %INCLUDE "stmtSQLSelect.icl"
  @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
  %INCLUDE "stmtSQLEnd.icl"
  @List_XMLQuery(profileHandle, dataBaseID, stmtSQL)
%}

%FUNCTION(dtw_sql) List_XMLQuery (IN  CHAR(64)    profileHandle,
                                      CHAR(2)     dataBaseID,
                                      CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W
  %REPORT{
      @XMLBeginTag("WFApplicationControlList")
          %ROW{
              @XMLIDTag("$(V_ACPGM)-$(V_ACPROC)", "Entry ID")
                  @XMLTag(V_ACPGM,  "Program")
                  @XMLTag(V_ACPROC, "Process")
                  @XMLTag(V_ACDESC, "Description")
                  @XMLTag(V_ACSTAT, "Status")
                  @XMLTag(V_ACPONT, "EntryPoint")
                  @XMLTag(V_ACSEQ,  "EntrySequence")
                  @XMLTag(V_ACEFFF, "EffectiveFromTimestamp")
                  @XMLTag(V_ACEFFT, "EffectiveToTimestamp")
              @XMLEndTag("Entry")
          %}
      @XMLEndTag("WFApplicationControlList")
  %}
%}

%HTML(REPORT) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (formatToPrint != "")
      @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  %else
      %if (orderBy == "")
          @DTW_ASSIGN(orderBy, "ACDESCU,ACPGM,PRDESCU")
          @DTW_ASSIGN(orderByDisplay, "Description, Program, Process")
          @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
      %endif
      @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  %endif
  %if (updRecNbr > "0")
      @dtw_assign(START_ROW_NUM, updRecNbr)
      @dtw_assign(updRecNbr, "")
  %endif
  %INCLUDE "SearchReturn.icl"
%}

%HTML(EXPORT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @XMLInit()
  @DTW_ASSIGN(RPT_MAX_ROWS, prtMaxRows)
  @Set_XMLSQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "Description")
      %if (orderBy == "ACDESCU,ACPGM,PRDESCU")
          @DTW_ASSIGN(orderBy, "ACDESCU DESC,ACPGM,PRDESCU")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Program, Process")
      %else
          @DTW_ASSIGN(orderBy, "ACDESCU,ACPGM,PRDESCU")
          @DTW_ASSIGN(orderByDisplay, "Description, Program, Process")
      %endif
  %elseif (sequence == "Program")
      %if (orderBy == "ACPGM,PRDESCU")
          @DTW_ASSIGN(orderBy, "ACPGM DESC,PRDESCU")
          @DTW_ASSIGN(orderByDisplay, "Program (descending), Process")
      %else
          @DTW_ASSIGN(orderBy, "ACPGM,PRDESCU")
          @DTW_ASSIGN(orderByDisplay, "Program, Process")
      %endif
  %elseif (sequence == "Process")
      %if (orderBy == "PRDESCU,ACPGM")
          @DTW_ASSIGN(orderBy, "PRDESCU DESC,ACPGM")
          @DTW_ASSIGN(orderByDisplay, "Process (descending), Program")
      %else
          @DTW_ASSIGN(orderBy, "PRDESCU,ACPGM")
          @DTW_ASSIGN(orderByDisplay, "Process, Program")
      %endif
  %elseif (sequence == "Status")
      %if (orderBy == "FLDESCU,ACPGM,PRDESCU")
          @DTW_ASSIGN(orderBy, "FLDESCU DESC,ACPGM,PRDESCU")
          @DTW_ASSIGN(orderByDisplay, "Status (descending), Program, Process")
      %else
          @DTW_ASSIGN(orderBy, "FLDESCU,ACPGM,PRDESCU")
          @DTW_ASSIGN(orderByDisplay, "Status, Program, Process")
      %endif
  %elseif (sequence == "DetailPoint")
      %if (orderBy == "PDDESCU,ACPGM,PRDESCU")
          @DTW_ASSIGN(orderBy, "PDDESCU DESC,ACPGM,PRDESCU")
          @DTW_ASSIGN(orderByDisplay, "Entry Detail Point (descending), Program, Process")
      %else
          @DTW_ASSIGN(orderBy, "PDDESCU,ACPGM,PRDESCU")
          @DTW_ASSIGN(orderByDisplay, "Entry Detail Point, Program, Process")
      %endif
  %elseif (sequence == "EffectiveFrom")
      %if (orderBy == "ACEFFF,ACPGM,PRDESCU")
          @DTW_ASSIGN(orderBy, "ACEFFF DESC,ACPGM,PRDESCU")
          @DTW_ASSIGN(orderByDisplay, "Effective From (descending), Program, Process")
      %else
          @DTW_ASSIGN(orderBy, "ACEFFF,ACPGM,PRDESCU")
          @DTW_ASSIGN(orderByDisplay, "Effective From, Program, Process")
      %endif
  %elseif (sequence == "EffectiveTo")
      %if (orderBy == "ACEFFT,ACPGM,PRDESCU")
          @DTW_ASSIGN(orderBy, "ACEFFT DESC,ACPGM,PRDESCU")
          @DTW_ASSIGN(orderByDisplay, "Effective To (descending), Program, Process")
      %else
          @DTW_ASSIGN(orderBy, "ACEFFT,ACPGM,PRDESCU")
          @DTW_ASSIGN(orderByDisplay, "Effective To, Program, Process")
      %endif
  %endif
	
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(MASTERSEARCH) {
  %INCLUDE "setLibraryList.icl"
  %if (defaultSearch == "Y")
      @DTW_ASSIGN(defaultSearch, "")
      @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  %endif
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
	       %INCLUDE "numedit.icl"
              %INCLUDE "CheckEnterSearch.icl"
              function validate(searchForm) {
                  if (editNum(document.Search.srchPoint, 4, 3) &&
                      editNum(document.Search.srchSequence, 4, 3))
                      return true;
              }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "WFAPPLCONTROLSEARCH")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SearchPageTitle.icl"
                      $(hrTagAttr)

                      @dtw_assign(wildCardResetURL, "$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=&amp;updateSearch=Y")
                      %INCLUDE "WildCardReset.icl"

                      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" action="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)$(wildCardVarBase)">
                          %INCLUDE "SearchTop.icl"

                          <tr><td class="dsphdr">Description</td>
                              @dtw_assign(operNbr, "operDesc")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDesc" size="15" maxlength="50"></td>
                          </tr>

                          <tr><td class="dsphdr">Program</td>
                              @dtw_assign(operNbr, "operProgram")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchProgram" size="10" maxlength="10"></td>
                          </tr>

                          <tr><td class="dsphdr">Process</td>
                              @dtw_assign(operNbr, "operProcess")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchProcess" size="15" maxlength="50"></td>
                          </tr>

                          <tr><td class="dsphdr">Status</td>
                              @dtw_assign(operNbr, "operStatus")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchStatus" size="15" maxlength="30"></td>
                          </tr>

                          <tr><td class="dsphdr">Entry Detail Point</td>
                              @dtw_assign(operNbr, "operDtlPoint")
                              <td>%INCLUDE "opersel_alph_short.icl"</td>
                              <td class="inputalph"><input type="text" name="srchDtlPoint" size="15" maxlength="50"></td>
                          </tr>

                          <tr><td class="dsphdr">Entry Point</td>
                              @dtw_assign(operNbr, "operPoint")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchPoint" size="8" maxlength="8"></td>
                          </tr>

                          <tr><td class="dsphdr">Entry Sequence</td>
                              @dtw_assign(operNbr, "operSequence")
                              <td>%INCLUDE "opersel_num_short.icl"</td>
                              <td class="inputnmbr"><input type="text" name="srchSequence" size="8" maxlength="8"></td>
                          </tr>

                          %INCLUDE "SearchBottom.icl"
                          <script TYPE="text/javascript">
                              document.Search.srchDesc.focus();
                          </script>
                      </form>
                      $(hrTagAttr)
                      %INCLUDE "Copyright.icl"
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")
		
  @Build_WildCard ("ACDESCU", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("ACPGM",   "Program", $(srchProgram), "U", operProgram, "A")
  @Build_WildCard ("PRDESCU", "Process", $(srchProcess), "U", operProcess, "A")
  @Build_WildCard ("upper(FLDESC)", "Status", $(srchStatus), "U", operStatus, "A")
  @Build_WildCard ("PDDESCU", "Entry Detail Point", $(srchDtlPoint), "U", operDtlPoint, "A")
  @Build_WildCard ("ACPONT",  "Entry Point", $(srchPoint), "", operPoint, "N")
  @Build_WildCard ("ACSEQ",   "Entry Sequence", $(srchSequence), "", operSequence, "N")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}
