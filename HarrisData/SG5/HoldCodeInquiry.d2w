%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "InventoryControl$(dataBaseID).icl"
%INCLUDE "NumFormat.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"

%Define {	
  page_title              = "Hold Code Inquiry"
  d2wName                 = "HoldCodeInquiry.d2w"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
%}
	
%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onLoad="window.focus()" onBlur="window.close()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(inquiryBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td>
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, "Select * From HDHLCD Where HCHLCD='$(holdCode)' and HCTYPE='$(type)'", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      @Hold_Code_Inquiry(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(inquiryTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) Hold_Code_Inquiry (IN CHAR(64)    profileHandle,
				          CHAR(2)     dataBaseID,
                                         CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"

      $(inquiryhrTagAttr)

      %ROW{
          <table $(contentTable)>
              %if (type=="M")
                  @dtw_assign(typeDesc, "Manufacturing")
              %else
                  @dtw_assign(typeDesc, "Order Management")
              %endif
	       <tr><td class="dsphdr">Type</td>
                  <td class="dspalph">$(typeDesc)</td>
              </tr>

              @Format_Code(V_HCHLCD, F_HCHLCD)
	       <tr><td class="dsphdr">Hold Code</td>
                  <td class="dspalph">$(V_HCDESC)</td>
                  <td class="dspalph">$(F_HCHLCD)</td>
              </tr>

              %if (V_HCICON != "")
    	           <tr><td class="dsphdr">Icon Name</td>
                      <td class="dspalph">$(V_HCICON)</td>
                  </tr>
              %endif

              %if (V_HDPDRL>"0" && type=="O")
                  @Format_Code(V_HCMHLD, F_HCMHLD)
                  @RtvFldDesc("HCTYPE='M' and HCHLCD='$(V_HCMHLD)'", "HDHLCD", "HCDESC", fieldDesc)
	      	   <tr><td class="dsphdr">Mfg Hold Code</td>
                      <td class="dspalph">$(fieldDesc)</td>
                      <td class="dspalph">$(F_HCMHLD)</td>
                  </tr>
              %endif

              %if (type=="M")
                  @RtvYNDesc($(V_HCPRTO), fieldDesc)
                  <tr><td class="dsphdr">Print Order</td>
                       <td class="dspalph">$(fieldDesc)</td>
                  </tr>

                  @RtvYNDesc($(V_HCISSC), fieldDesc)
                  <tr><td class="dsphdr">Issue Components</td>
                       <td class="dspalph">$(fieldDesc)</td>
                  </tr>

                  @RtvYNDesc($(V_HCRPTL), fieldDesc)
                  <tr><td class="dsphdr">Report Labor</td>
                       <td class="dspalph">$(fieldDesc)</td>
                  </tr>

                  @RtvYNDesc($(V_HCORDR), fieldDesc)
                  <tr><td class="dsphdr">Order Receipt</td>
                       <td class="dspalph">$(fieldDesc)</td>
                  </tr>

                  @RtvYNDesc($(V_HCORDC), fieldDesc)
                  <tr><td class="dsphdr">Order Close</td>
                       <td class="dspalph">$(fieldDesc)</td>
                  </tr>

                  @RtvYNDesc($(V_HCPMAT), fieldDesc)
                  <tr><td class="dsphdr">Plan Material</td>
                       <td class="dspalph">$(fieldDesc)</td>
                  </tr>

                  @RtvYNDesc($(V_HCPCAP), fieldDesc)
                  <tr><td class="dsphdr">Plan Capacity</td>
                       <td class="dspalph">$(fieldDesc)</td>
                  </tr>

                  @RtvYNDesc($(V_HCSCHL), fieldDesc)
                  <tr><td class="dsphdr">Schedule Labor</td>
                       <td class="dspalph">$(fieldDesc)</td>
                  </tr>

                  @RtvYNDesc($(V_HCHAEO), fieldDesc)
                  <tr><td class="dsphdr">Hold Auto-Explode Orders</td>
                       <td class="dspalph">$(fieldDesc)</td>
                  </tr>
              %endif
          </table>
      %}
      $(inquiryhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(DISPLAY) {
  %INCLUDE "setLibraryList.icl"
  @Set_SQL(stmtSQL)
%}