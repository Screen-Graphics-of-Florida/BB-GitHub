%INCLUDE "$(baseVar)"
%INCLUDE "BuildSortSeqSel.icl"
%INCLUDE "EditRoutines.icl"
%INCLUDE "EdtVar.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "InventoryControl$(dataBaseID).icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "SubmitScheduleVar.icl"
%INCLUDE "StoredProcedureVariables.icl"
%INCLUDE "SystemControl$(dataBaseID).icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Whs/Inventory Valuation Report"
  d2wName                 = "WarehouseInventoryValuationReport.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;stockLocActive=@dtw_rurlescseq(stockLocActive)&amp;lotActive=@dtw_rurlescseq(lotActive)&amp;reportSelType=@dtw_rurlescseq(reportSelType)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  sortSeqMax              = "6"
  stockLocActive          = ""
  lotActive               = ""
  V_N2SEL                 = ""
  V_N3SET                 = ""
%}

%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL () {
  %INCLUDE "$(docType)"	
  %if (V_CISTKL=="Y")		
      @dtw_assign(stockLocActive, "Y")
  %endif
  %if (V_CILTUS=="Y")		
      @dtw_assign(lotActive, "Y")
  %endif
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          @dtw_assign(formName, "Chg")
          <script TYPE="text/javascript">
              %INCLUDE "Calendar.icl"
              %INCLUDE "DateEdit.icl"
              %INCLUDE "EditFromToAll.icl"
              %INCLUDE "Menu.js"
              %INCLUDE "NumEdit.icl"
              %INCLUDE "CheckEnterChg.icl"
              function validate(chgForm) {
                  if (editNum(document.Chg.fromWarehouse, 3, 0) &&
                      editNum(document.Chg.toWarehouse, 3, 0) &&
                      editNum(document.Chg.fromBuyer, 7, 0) &&
                      editNum(document.Chg.toBuyer, 7, 0) &&
                      editFromToAll(document.Chg.fromItemNumber, document.Chg.toItemNumber, document.Chg.allItemNumber, "A") &&
                      editFromToAll(document.Chg.fromWarehouse, document.Chg.toWarehouse, document.Chg.allWarehouse, 3) &&
                      editFromToAll(document.Chg.fromProductClass, document.Chg.toProductClass, document.Chg.allProductClass, "A") &&
                      editFromToAll(document.Chg.fromInventoryType, document.Chg.toInventoryType, document.Chg.allInventoryType, "A") &&
                      editFromToAll(document.Chg.fromABCClassCode, document.Chg.toABCClassCode, document.Chg.allABCClassCode, "A") &&
                      editFromToAll(document.Chg.fromBuyer, document.Chg.toBuyer, document.Chg.allBuyer, 7)
                      %if (stockLocActive == "Y" )
                          && editFromToAll(document.Chg.fromStockroom, document.Chg.toStockroom, document.Chg.allStockroom, "A")
                          && editFromToAll(document.Chg.fromAisle, document.Chg.toAisle, document.Chg.allAisle, "A")
                          && editFromToAll(document.Chg.fromLocation, document.Chg.toLocation, document.Chg.allLocation, "A")
                      %endif
                     )
                     return true;

              }
              function returndate9() {
                       document.Chg.schDate.value = '' + padout(month - 0 + 1) + padout(day) + yr2(year);
                       date9win.close();
               }
          </script>
          %INCLUDE "$(genericHead)"
      </head>
      <body $(bodyTagAttr) onKeyPress="checkEnterChg()">
          <!-- Start Of Banner Code -->
          %INCLUDE "Banner.icl"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  @dtw_assign(pageID, "WAREHOUSEINVENTORYVALUATIONREPORT")
                  <td class="menu">@Menu_Query(profileHandle, dataBaseID, portal, pageID)</td>
                  <td class="content">
                      %INCLUDE "SubmitScheduleTop.icl"
                      %INCLUDE "ConfMessageDisplayNoTable.icl"
                      $(hrTagAttr)
                      <form class="formClass" METHOD=POST NAME="Chg"  onSubmit="return validate(document.Chg)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/Edit_Data$(d2wVarBase)">
                          <table $(contentTable)>
                              @dtw_assign(focusField, "fromItemNumber")
                              %if (errFound != "" || scheduleJobSwitch == "Y")
                                  @dtw_assign(scheduleJobSwitch, "")
                                  @EdtVarErr(profileHandle, typeValue, edtVar)
                                  @dtw_assign(focusField, "")
                                  @ErrVarErr(profileHandle, typeError, errVar)
                                  @Decat_Field("@@sbjb")   @dtw_assign(submitSchedule,  fieldValue)
                                  @DecatErr_Field("@@sel1", "reportUM")            @dtw_assign(Err_N1SEL,  fieldValue)
                                  %if (V_HDPDRL == "0" || (V_HDPDRL > "0" && V_HDTCV == "A"))
                                     @DecatErr_Field("@@sel2", "costMethod")      @dtw_assign(Err_N2SEL,  fieldValue)
                                  %else
                                     @DecatErr_Field("@@set3", "costSet")      @dtw_assign(Err_N3SET,  fieldValue)
                                  %endif
                                  @DecatErr_Field("@@sel4", "stockLocations")      @dtw_assign(Err_N4SEL,  fieldValue)
                                  @DecatErr_Field("@@hneg", "negativeOH")          @dtw_assign(Err_N5HNEG,  fieldValue)
                                  @DecatErr_Field("@@hpos", "positiveOH")          @dtw_assign(Err_N5HPOS,  fieldValue)
                                  @DecatErr_Field("@@hzro", "zeroOH")              @dtw_assign(Err_N5HZRO,  fieldValue)
                                  @DecatErr_Field("@@hrcv", "inReceiving")             @dtw_assign(Err_N5HRCV,  fieldValue)
                                  @DecatErr_Field("@@fitm", "fromItemNumber")      @dtw_assign(Err_N6FR01,  fieldValue)
                                  @DecatErr_Field("@@titm", "toItemNumber")        @dtw_assign(Err_N6TO01,  fieldValue)
                                  @DecatErr_Field("@@aitm", "allItemNumber")       @dtw_assign(Err_N6AL01,  fieldValue)
                                  @DecatErr_Field("@@sitm", "sortItemNumber")      @dtw_assign(Err_N6SQ01,  fieldValue)
                                  @DecatErr_Field("@@pitm", "totalItemNumber")     @dtw_assign(Err_N6PT01,  fieldValue)
                                  @DecatErr_Field("@@fwhs", "fromWarehouse")       @dtw_assign(Err_N6FR02,  fieldValue)
                                  @DecatErr_Field("@@twhs", "toWarehouse")         @dtw_assign(Err_N6TO02,  fieldValue)
                                  @DecatErr_Field("@@awhs", "allWarehouse")        @dtw_assign(Err_N6AL02,  fieldValue)
                                  @DecatErr_Field("@@swhs", "sortWarehouse")       @dtw_assign(Err_N6SQ02,  fieldValue)
                                  @DecatErr_Field("@@pwhs", "totalWarehouse")      @dtw_assign(Err_N6PT02,  fieldValue)
                                  @DecatErr_Field("@@fpcl", "fromProductClass")    @dtw_assign(Err_N6FR03,  fieldValue)
                                  @DecatErr_Field("@@tpcl", "toProductClass")      @dtw_assign(Err_N6TO03,  fieldValue)
                                  @DecatErr_Field("@@apcl", "allProductClass")     @dtw_assign(Err_N6AL03,  fieldValue)
                                  @DecatErr_Field("@@spcl", "sortProductClass")    @dtw_assign(Err_N6SQ03,  fieldValue)
                                  @DecatErr_Field("@@ppcl", "totalProductClass")   @dtw_assign(Err_N6PT03,  fieldValue)
                                  @DecatErr_Field("@@finv", "fromInventoryType")   @dtw_assign(Err_N6FR04,  fieldValue)
                                  @DecatErr_Field("@@tinv", "toInventoryType")     @dtw_assign(Err_N6TO04,  fieldValue)
                                  @DecatErr_Field("@@ainv", "allInventoryType")    @dtw_assign(Err_N6AL04,  fieldValue)
                                  @DecatErr_Field("@@sinv", "sortInventoryType")   @dtw_assign(Err_N6SQ04,  fieldValue)
                                  @DecatErr_Field("@@pinv", "totalInventoryType")  @dtw_assign(Err_N6PT04,  fieldValue)
                                  @DecatErr_Field("@@fabc", "fromABCClassCode")    @dtw_assign(Err_N6FR05,  fieldValue)
                                  @DecatErr_Field("@@tabc", "toABCClassCode")      @dtw_assign(Err_N6TO05,  fieldValue)
                                  @DecatErr_Field("@@aabc", "allABCClassCode")     @dtw_assign(Err_N6AL05,  fieldValue)
                                  @DecatErr_Field("@@sabc", "sortABCClassCode")    @dtw_assign(Err_N6SQ05,  fieldValue)
                                  @DecatErr_Field("@@pabc", "totalABCClassCode")   @dtw_assign(Err_N6PT05,  fieldValue)
                                  @DecatErr_Field("@@fbyr", "fromBuyer")   @dtw_assign(Err_N6FR06,  fieldValue)
                                  @DecatErr_Field("@@tbyr", "toBuyer")     @dtw_assign(Err_N6TO06,  fieldValue)
                                  @DecatErr_Field("@@abyr", "allBuyer")    @dtw_assign(Err_N6AL06,  fieldValue)
                                  @DecatErr_Field("@@sbyr", "sortBuyer")   @dtw_assign(Err_N6SQ06,  fieldValue)
                                  @DecatErr_Field("@@pbyr", "totalBuyer")  @dtw_assign(Err_N6PT06,  fieldValue)
                                  %if (stockLocActive == "Y")
                                     @DecatErr_Field("@@fstk", "fromStockroom")    @dtw_assign(Err_N6FR07,  fieldValue)
                                     @DecatErr_Field("@@tstk", "toStockroom")      @dtw_assign(Err_N6TO07,  fieldValue)
                                     @DecatErr_Field("@@astk", "allStockroom")     @dtw_assign(Err_N6AL07,  fieldValue)
                                     @DecatErr_Field("@@fisl", "fromAisle")        @dtw_assign(Err_N6FR08,  fieldValue)
                                     @DecatErr_Field("@@tisl", "toAisle")          @dtw_assign(Err_N6TO08,  fieldValue)
                                     @DecatErr_Field("@@aisl", "allAisle")         @dtw_assign(Err_N6AL08,  fieldValue)
                                     @DecatErr_Field("@@floc", "fromLocation")     @dtw_assign(Err_N6FR09,  fieldValue)
                                     @DecatErr_Field("@@tloc", "toLocation")       @dtw_assign(Err_N6TO09,  fieldValue)
                                     @DecatErr_Field("@@aloc", "allLocation")      @dtw_assign(Err_N6AL09,  fieldValue)
                                  %endif

                                  %if (submitSchedule != "")
                                      %INCLUDE "ScheduleJobErr.icl"    %{ Schedule Entries Errors %}
                                  %endif

                                  @Decat_Field("@@sel1")  @dtw_assign(V_N1SEL,  fieldValue)
                                  @Decat_Field("@@sel2")  @dtw_assign(V_N2SEL,   fieldValue)
                                  @Decat_Field("@@set3")  @dtw_assign(V_N3SET,   fieldValue)
                                  @Decat_Field("@@sel4")  @dtw_assign(V_N4SEL,   fieldValue)
                                  @Decat_Field("@@hneg")  @dtw_assign(V_N5HNEG,  fieldValue)
                                  @Decat_Field("@@hpos")  @dtw_assign(V_N5HPOS,  fieldValue)
                                  @Decat_Field("@@hzro")  @dtw_assign(V_N5HZRO,  fieldValue)
                                  @Decat_Field("@@hrcv")  @dtw_assign(V_N5HRCV,  fieldValue)
                                  @Decat_Field("@@fitm")  @dtw_assign(V_N6FR01,  fieldValue)
                                  @Decat_Field("@@titm")  @dtw_assign(V_N6TO01,  fieldValue)
                                  @Decat_Field("@@aitm")  @dtw_assign(V_N6AL01,  fieldValue)
                                  @Decat_Field("@@sitm")  @dtw_assign(V_N6SQ01,  fieldValue)
                                  @Decat_Field("@@pitm")  @dtw_assign(V_N6PT01,  fieldValue)
                                  @Decat_Field("@@fwhs")  @dtw_assign(V_N6FR02,  fieldValue)
                                  @Decat_Field("@@twhs")  @dtw_assign(V_N6TO02,  fieldValue)
                                  @Decat_Field("@@awhs")  @dtw_assign(V_N6AL02,  fieldValue)
                                  @Decat_Field("@@swhs")  @dtw_assign(V_N6SQ02,  fieldValue)
                                  @Decat_Field("@@pwhs")  @dtw_assign(V_N6PT02,  fieldValue)
                                  @Decat_Field("@@fpcl")  @dtw_assign(V_N6FR03,  fieldValue)
                                  @Decat_Field("@@tpcl")  @dtw_assign(V_N6TO03,  fieldValue)
                                  @Decat_Field("@@apcl")  @dtw_assign(V_N6AL03,  fieldValue)
                                  @Decat_Field("@@spcl")  @dtw_assign(V_N6SQ03,  fieldValue)
                                  @Decat_Field("@@ppcl")  @dtw_assign(V_N6PT03,  fieldValue)
                                  @Decat_Field("@@finv")  @dtw_assign(V_N6FR04,  fieldValue)
                                  @Decat_Field("@@tinv")  @dtw_assign(V_N6TO04,  fieldValue)
                                  @Decat_Field("@@ainv")  @dtw_assign(V_N6AL04,  fieldValue)
                                  @Decat_Field("@@sinv")  @dtw_assign(V_N6SQ04,  fieldValue)
                                  @Decat_Field("@@pinv")  @dtw_assign(V_N6PT04,  fieldValue)
                                  @Decat_Field("@@fabc")  @dtw_assign(V_N6FR05,  fieldValue)
                                  @Decat_Field("@@tabc")  @dtw_assign(V_N6TO05,  fieldValue)
                                  @Decat_Field("@@aabc")  @dtw_assign(V_N6AL05,  fieldValue)
                                  @Decat_Field("@@sabc")  @dtw_assign(V_N6SQ05,  fieldValue)
                                  @Decat_Field("@@pabc")  @dtw_assign(V_N6PT05,  fieldValue)
                                  @Decat_Field("@@fbyr")  @dtw_assign(V_N6FR06,  fieldValue)
                                  @Decat_Field("@@tbyr")  @dtw_assign(V_N6TO06,  fieldValue)
                                  @Decat_Field("@@abyr")  @dtw_assign(V_N6AL06,  fieldValue)
                                  @Decat_Field("@@sbyr")  @dtw_assign(V_N6SQ06,  fieldValue)
                                  @Decat_Field("@@pbyr")  @dtw_assign(V_N6PT06,  fieldValue)

                                  %if (stockLocActive == "Y")
                                     @Decat_Field("@@fstk")  @dtw_assign(V_N6FR07,  fieldValue)
                                     @Decat_Field("@@tstk")  @dtw_assign(V_N6TO07,  fieldValue)
                                     @Decat_Field("@@astk")  @dtw_assign(V_N6AL07,  fieldValue)
                                     @Decat_Field("@@fisl")  @dtw_assign(V_N6FR08,  fieldValue)
                                     @Decat_Field("@@tisl")  @dtw_assign(V_N6TO08,  fieldValue)
                                     @Decat_Field("@@aisl")  @dtw_assign(V_N6AL08,  fieldValue)
                                     @Decat_Field("@@floc")  @dtw_assign(V_N6FR09,  fieldValue)
                                     @Decat_Field("@@tloc")  @dtw_assign(V_N6TO09,  fieldValue)
                                     @Decat_Field("@@aloc")  @dtw_assign(V_N6AL09,  fieldValue)
                                  %endif

                                  %INCLUDE "ScheduleJobValue.icl"    %{ Schedule Entries Values %}
                                  %if (V_N1SEL == "02")
                                      @dtw_assign(StockingUM, "")
                                      @dtw_assign(PurchasingUM, "CHECKED")
                                  %else
                                      @dtw_assign(StockingUM, "CHECKED")
                                      @dtw_assign(PurchasingUM, "")
                                  %endif
                                  %if (V_HDPDRL == "0" || (V_HDPDRL > "0" && V_HDTCV == "A"))
                                     %if (V_N2SEL == "01")
                                         @dtw_assign(standardCost, "CHECKED")
                                         @dtw_assign(averageCost, "")
                                         @dtw_assign(replacementCost, "")
                                         @dtw_assign(baseyearCost, "")
                                     %elif (V_N2SEL == "02")
                                         @dtw_assign(averageCost, "CHECKED")
                                         @dtw_assign(standardCost, "")
                                         @dtw_assign(replacementCost, "")
                                         @dtw_assign(baseyearCost, "")
                                     %elif (V_N2SEL == "03")
                                         @dtw_assign(replacementCost, "CHECKED")
                                         @dtw_assign(standardCost, "")
                                         @dtw_assign(averageCost, "")
                                         @dtw_assign(baseyearCost, "")
                                     %elif (V_N2SEL == "04")
                                         @dtw_assign(baseyearCost, "CHECKED")
                                         @dtw_assign(standardCost, "")
                                         @dtw_assign(averageCost, "")
                                         @dtw_assign(replacementCost, "")
                                     %endif
                                  %endif

                                  %if (V_N4SEL == "02")
                                      @dtw_assign(stockLocationsNo, "")
                                      @dtw_assign(stockLocationsYes, "CHECKED")
                                  %else
                                      @dtw_assign(stockLocationsNo, "CHECKED")
                                      @dtw_assign(stockLocationsYes, "")
                                  %endif
                                  %if (V_N5HNEG == "01")
                                      @dtw_assign(checkedNegativeOH, "CHECKED")
                                  %else
                                      @dtw_assign(checkedNegativeOH, "")
                                  %endif
                                  %if (V_N5HPOS == "01")
                                      @dtw_assign(checkedPositiveOH, "CHECKED")
                                  %else
                                      @dtw_assign(checkedPositiveOH, "")
                                  %endif
                                  %if (V_N5HZRO == "01")
                                      @dtw_assign(checkedZeroOH, "CHECKED")
                                  %else
                                      @dtw_assign(checkedZeroOH, "")
                                  %endif
                                  %if (V_N5HRCV == "01")
                                      @dtw_assign(checkedInReceiving, "CHECKED")
                                  %else
                                      @dtw_assign(checkedInReceiving, "")
                                  %endif
                                  %if (V_N6AL01 == "ALL")
                                      @dtw_assign(checkedAllItemNumber, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllItemNumber, "")
                                  %endif
                                  %if (V_N6AL02 == "ALL")
                                      @dtw_assign(checkedAllWarehouse, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllWarehouse, "")
                                  %endif
                                  %if (V_N6AL03 == "ALL")
                                      @dtw_assign(checkedAllProductClass, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllProductClass, "")
                                  %endif
                                  %if (V_N6AL04 == "ALL")
                                      @dtw_assign(checkedAllInventoryType, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllInventoryType, "")
                                  %endif
                                  %if (V_N6AL05 == "ALL")
                                      @dtw_assign(checkedAllABCClassCode, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllABCClassCode, "")
                                  %endif
                                  %if (V_N6AL06 == "ALL")
                                      @dtw_assign(checkedAllBuyer, "CHECKED")
                                  %else
                                      @dtw_assign(checkedAllBuyer, "")
                                  %endif
                                  %if (stockLocActive == "Y")
                                     %if (V_N6AL07 == "ALL")
                                         @dtw_assign(checkedAllStockroom, "CHECKED")
                                     %else
                                          @dtw_assign(checkedAllStockroom, "")
                                     %endif
                                     %if (V_N6AL08 == "ALL")
                                         @dtw_assign(checkedAllAisle, "CHECKED")
                                     %else
                                         @dtw_assign(checkedAllAisle, "")
                                     %endif
                                     %if (V_N6AL09 == "ALL")
                                         @dtw_assign(checkedAllLocation, "CHECKED")
                                     %else
                                         @dtw_assign(checkedAllLocation, "")
                                     %endif
                                  %endif

                                  %if (V_N6PT01 == "Y")
                                      @dtw_assign(checkedItemNumberTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedItemNumberTotals, "")
                                  %endif
                                  %if (V_N6PT02 == "Y")
                                      @dtw_assign(checkedWarehouseTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedWarehouseTotals, "")
                                  %endif
                                  %if (V_N6PT03 == "Y")
                                      @dtw_assign(checkedProductClassTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedProductClassTotals, "")
                                  %endif
                                  %if (V_N6PT04 == "Y")
                                      @dtw_assign(checkedInventoryTypeTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedInventoryTypeTotals, "")
                                  %endif
                                  %if (V_N6PT05 == "Y")
                                      @dtw_assign(checkedABCClassCodeTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedABCClassCodeTotals, "")
                                  %endif
                                  %if (V_N6PT06 == "Y")
                                      @dtw_assign(checkedBuyerTotals, "CHECKED")
                                  %else
                                      @dtw_assign(checkedBuyerTotals, "")
                                  %endif
                              %else
                                  @dtw_assign(StockingUM, "CHECKED")
                                  @dtw_assign(PurchasingUM, "")
                                  %if (V_HDPDRL == "0" || (V_HDPDRL > "0" && V_HDTCV == "A"))
                                     %if (V_HDTCV == "S")
                                         @dtw_assign(standardCost, "CHECKED")
                                         @dtw_assign(averageCost, "")
                                     %else
                                         @dtw_assign(averageCost, "CHECKED")
                                         @dtw_assign(standardCost, "")
                                     %endif
                                     @dtw_assign(replacementCost, "")
                                     @dtw_assign(baseyearCost, "")
                                  %else
                                     @dtw_assign(V_N3SET, "1")
                                  %endif
                                  @dtw_assign(stockLocationsNo, "CHECKED")
                                  @dtw_assign(stockLocationsYes, "")
                                  @dtw_assign(checkedNegativeOH, "")
                                  @dtw_assign(checkedPositiveOH, "CHECKED")
                                  @dtw_assign(checkedZeroOH, "")
                                  @dtw_assign(checkedInReceiving, "")
                                  @dtw_assign(checkedAllItemNumber, "CHECKED")
                                  @dtw_assign(checkedAllWarehouse, "CHECKED")
                                  @dtw_assign(checkedAllProductClass, "CHECKED")
                                  @dtw_assign(checkedAllInventoryType, "CHECKED")
                                  @dtw_assign(checkedAllABCClassCode, "CHECKED")
                                  @dtw_assign(checkedAllBuyer, "CHECKED")
                                  %if (stockLocActive == "Y" )
                                     @dtw_assign(checkedAllStockroom, "CHECKED")
                                     @dtw_assign(checkedAllAisle, "CHECKED")
                                     @dtw_assign(checkedAllLocation, "CHECKED")
                                  %endif
                                  @dtw_assign(checkedItemNumberTotals, "")
                                  @dtw_assign(checkedWarehouseTotals, "")
                                  @dtw_assign(checkedProductClassTotals, "")
                                  @dtw_assign(checkedInventoryTypeTotals, "")
                                  @dtw_assign(checkedABCClassCodeTotals, "")
                                  @dtw_assign(checkedBuyerTotals, "")
                              %endif

                              @SetTextOvr(Err_N1SEL)
                              <tr><td class="dsphdr"><span $(textOvr)>Report U/M Selection</span></td>
                                  <td class="inputnmbr"><input name="reportUM" type="radio" VALUE='01' $(StockingUM)>Stocking</td>
                              </tr>
                              @DspErrMsg(Err_N1SLCT)

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="reportUM" type="radio" VALUE='02' $(PurchasingUM)>Purchasing</td>
                              </tr>

                              %if (V_HDPDRL == "0" || (V_HDPDRL > "0" && V_HDTCV == "A"))
                                 @SetTextOvr(Err_N2SEL)
                                 <tr><td class="dsphdr"><span $(textOvr)>Cost Method</span></td>
                                     <td class="inputnmbr"><input name="costMethod" type="radio" VALUE='01' $(standardCost)>Standard Cost</td>
                                 </tr>
                                 @DspErrMsg(Err_N2SEL)

                                 <tr><td>&nbsp;</td>
                                     <td class="inputnmbr"><input name="costMethod" type="radio" VALUE='02' $(averageCost)>Average Cost</td>
                                 </tr>

                                 <tr><td>&nbsp;</td>
                                     <td class="inputnmbr"><input name="costMethod" type="radio" VALUE='03' $(replacementCost)>Replacement Cost</td>
                                 </tr>

                                 <tr><td>&nbsp;</td>
                                     <td class="inputnmbr"><input name="costMethod" type="radio" VALUE='04' $(baseyearCost)>Base Year Cost</td>
                                 </tr>
                              %else
                                 @RtvFldDesc("STCSET=$(V_N3SET)", "SCMSTM", "(STCSLD)", fldDesc)
                                 @SetTextOvr(Err_N3SET)
                                 <tr><td class="dsphdr"><span $(textOvr)>Cost Set</span></td>
                                     <td class="inputnmbr"><input name="costSet" value="$(V_N3SET)" type="text" size="2" maxlength="2"><a href="$(homeURL)$(cGIPath)CostSetDefinitionSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=costSet&amp;fldDesc=tcostSetDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="tcostSetDesc" value="$(fldDesc)" type="text"  size="25" disabled></td>
                                 </tr>
                                 @DspErrMsg(Err_N3SET)

                              %endif

                              %if (stockLocActive == "Y" || lotActive == "Y")
                                 @SetTextOvr(Err_N4SEL)
                                 <tr>
                                 %if (stockLocActive == "Y" && lotActive == "N")
                                     <td class="dsphdr"><span $(textOvr)>Print Stock Locations</span></td>
                                 %elif (stockLocActive == "N" && lotActive == "Y")
                                     <td class="dsphdr"><span $(textOvr)>Print Lots</span></td>
                                 %elif (stockLocActive == "Y" && lotActive == "Y")
                                     <td class="dsphdr"><span $(textOvr)>Print Stock Locations/Lots</span></td>
                                 %endif
                                     <td class="inputnmbr"><input name="stockLocations" type="radio" VALUE='01' $(stockLocationsNo)>No</td>
                                 </tr>

                                 @DspErrMsg(Err_N4SEL)
                                 <tr><td>&nbsp;</td>
                                     <td class="inputnmbr"><input name="stockLocations" type="radio" VALUE='02' $(stockLocationsYes)>Yes</td>
                                 </tr>
                              %endif

                              @SetTextOvr(Err_N5HNEG)
                              <tr><td class="dsphdr"><span $(textOvr)>Include On Hand Items</span></td>
                                  <td class="inputnmbr"><input name="negativeOH" type="checkbox" VALUE='01' $(checkedNegativeOH)>Negative On Hand</td>
                              </tr>
                              @DspErrMsg(Err_N5HNEG)

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="positiveOH" type="checkbox" VALUE='01' $(checkedPositiveOH)>Positive On Hand</td>
                              </tr>

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="zeroOH" type="checkbox" VALUE='01' $(checkedZeroOH)>Zero On Hand</td>
                              </tr>

                              <tr><td>&nbsp;</td>
                                  <td class="inputnmbr"><input name="inReceiving" type="checkbox" VALUE='01' $(checkedInReceiving)>On Order</td>
                              </tr>

                          </table>

                          <table $(contentTable)>
                              <tr><td>&nbsp;</td>
                                  <td class="colhdr">From</td>
                                  <td class="colhdr">To</td>
                                  <td class="colhdr">All</td>
                                  <td class="colhdr">Sort<br>Sequence</td>
                                  <td class="colhdr">Print<br>Totals</td>
                              </tr>

                              @SetTextOvr(Err_N6FR01)
                              %if (textOvr == "") @SetTextOvr(Err_N6TO01) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N6AL01) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N6SQ01) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N6PT01) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Item Number</span></td>
                                  <td class="inputalph"><input name="fromItemNumber" value="$(V_N6FR01)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromItemNumber&amp;fldDesc=fitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="toItemNumber" value="$(V_N6TO01)" type="text" size="15" maxlength="15"><a href="$(homeURL)$(phpPath)ItemSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toItemNumber&amp;fldDesc=toitemDescription" onclick="$(searchWinVar)"> $(searchImage) </a><input name="toitemDescription" type="hidden"></td>
                                  <td class="inputalph"><input name="allItemNumber" value='ALL' $(checkedAllItemNumber) type="checkbox" onClick="if (this.checked) this.form.fromItemNumber.value='', this.form.toItemNumber.value='';"></td>
                                  @Build_Sort_Select("sortItemNumber", "$(V_N6SQ01)")
                                  <td align=center ><input name="totalItemNumber" type="checkbox" $(checkedItemNumberTotals) VALUE='Y'></td>
                              </tr>
                              @DspErrMsg(Err_N6FR01)
                              @DspErrMsg(Err_N6TO01)
                              @DspErrMsg(Err_N6AL01)
                              @DspErrMsg(Err_N6SQ01)
                              @DspErrMsg(Err_N6PT01)

                              @SetTextOvr(Err_N6FR02)
                              %if (textOvr == "") @SetTextOvr(Err_N6TO02) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N6AL02) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N6SQ02) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N6PT02) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Warehouse</span></td>
                                  <td class="inputnmbr"><input name="fromWarehouse" value="$(V_N6FR02)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)WarehouseSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=fromWarehouse&amp;fldDesc=fwarehouseName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fwarehouseName" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toWarehouse" value="$(V_N6TO02)" type="text" size="3" maxlength="3"><a href="$(homeURL)$(phpPath)WarehouseSearch.php$(altVarBase)&amp;docName=Chg&amp;fldName=toWarehouse&amp;fldDesc=twarehouseName" onclick="$(searchWinVar)"> $(searchImage) </a><input name="twarehouseName" type="hidden"></td>
                                  <td class="inputalph"><input name="allWarehouse" value='ALL' $(checkedAllWarehouse) type="checkbox" onClick="if (this.checked) this.form.fromWarehouse.value='', this.form.toWarehouse.value='';"></td>
                                  @Build_Sort_Select("sortWarehouse", "$(V_N6SQ02)")
                                  <td align=center ><input name="totalWarehouse" type="checkbox" $(checkedWarehouseTotals) VALUE='Y'></td>
                              </tr>
                              @DspErrMsg(Err_N6FR02)
                              @DspErrMsg(Err_N6TO02)
                              @DspErrMsg(Err_N6AL02)
                              @DspErrMsg(Err_N6SQ02)
                              @DspErrMsg(Err_N6PT02)

                              @SetTextOvr(Err_N6FR03)
                              %if (textOvr == "") @SetTextOvr(Err_N6TO03) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N6AL03) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N6SQ03) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N6PT03) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Product Class</span></td>
                                  <td class="inputalph"><input name="fromProductClass" value="$(V_N6FR03)" type="text" size="8" maxlength="4"><a href="$(homeURL)$(cGIPath)ProdClassSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromProductClass&amp;fldDesc=fproductClassDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="fproductClassDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="toProductClass" value="$(V_N6TO03)" type="text" size="8" maxlength="4"><a href="$(homeURL)$(cGIPath)ProdClassSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toProductClass&amp;fldDesc=tproductClassDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="tproductClassDesc" type="hidden"></td>
                                  <td class="inputalph"><input name="allProductClass" value='ALL' $(checkedAllProductClass) type="checkbox" onClick="if (this.checked) this.form.fromProductClass.value='', this.form.toProductClass.value='';"></td>
                                  @Build_Sort_Select("sortProductClass", "$(V_N6SQ03)")
                                  <td align=center ><input name="totalProductClass" type="checkbox" $(checkedProductClassTotals) VALUE='Y'></td>
                              </tr>
                              @DspErrMsg(Err_N6FR03)
                              @DspErrMsg(Err_N6TO03)
                              @DspErrMsg(Err_N6AL03)
                              @DspErrMsg(Err_N6SQ03)
                              @DspErrMsg(Err_N6PT03)

                              @SetTextOvr(Err_N6FR04)
                              %if (textOvr == "") @SetTextOvr(Err_N6TO04) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N6AL04) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N6SQ04) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N6PT04) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Inventory Type</span></td>
                                  <td class="inputalph"><input name="fromInventoryType" value="$(V_N6FR04)" type="text" size="6" maxlength="4"><a href="$(homeURL)$(cGIPath)invtypesearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromInventoryType&amp;fldDesc=finventoryTypeDesc" onclick="$(searchWinVar)"> $(searchImage) </a><input name="finventoryTypeDesc"  type="hidden"></td>
                                  <td class="inputalph"><input name="toInventoryType" value="$(V_N6TO04)" type="text" size="6" maxlength="4"><a href="$(homeURL)$(cGIPath)invtypesearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toInventoryType&amp;fldDesc=tinventoryTypeDesc" onclick="$(searchWinVar)">$(searchImage) </a><input name="tinventoryTypeDesc"  type="hidden"></td>
                                  <td class="inputalph"><input name="allInventoryType" value='ALL' $(checkedAllInventoryType) type="checkbox" onClick="if (this.checked) this.form.fromInventoryType.value='', this.form.toInventoryType.value='';"></td>
                                  @Build_Sort_Select("sortInventoryType", "$(V_N6SQ04)")
                                  <td align=center ><input name="totalInventoryType" type="checkbox" $(checkedInventoryTypeTotals) VALUE='Y'></td>
                              </tr>
                              @DspErrMsg(Err_N6FR04)
                              @DspErrMsg(Err_N6TO04)
                              @DspErrMsg(Err_N6AL04)
                              @DspErrMsg(Err_N6SQ04)
                              @DspErrMsg(Err_N6PT04)

                              @SetTextOvr(Err_N6FR05)
                              %if (textOvr == "") @SetTextOvr(Err_N6TO05) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N6AL05) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N6SQ05) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N6PT05) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>ABC Class Code</span></td>
                                  <td class="inputalph"><input name="fromABCClassCode" value="$(V_N6FR05)" type="text" size="1" maxlength="1"></td>
                                  <td class="inputalph"><input name="toABCClassCode" value="$(V_N6TO05)" type="text" size="1" maxlength="1"></td>
                                  <td class="inputalph"><input name="allABCClassCode" value='ALL' $(checkedAllABCClassCode) type="checkbox" onClick="if (this.checked) this.form.fromABCClassCode.value='', this.form.toABCClassCode.value='';"></td>
                                  @Build_Sort_Select("sortABCClassCode", "$(V_N6SQ05)")
                                  <td align=center ><input name="totalABCClassCode" type="checkbox" $(checkedABCClassCodeTotals) VALUE='Y'></td>
                              </tr>
                              @DspErrMsg(Err_N6FR05)
                              @DspErrMsg(Err_N6TO05)
                              @DspErrMsg(Err_N6AL05)
                              @DspErrMsg(Err_N6SQ05)
                              @DspErrMsg(Err_N6PT05)

                              @SetTextOvr(Err_N6FR06)
                              %if (textOvr == "") @SetTextOvr(Err_N6TO06) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N6AL06) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N6SQ06) %endif
                              %if (textOvr == "") @SetTextOvr(Err_N6PT06) %endif
                              <tr><td class="dsphdr"><span $(textOvr)>Buyer</span></td>
                                  <td class="inputnmbr"><input name="fromBuyer" value="$(V_N6FR06)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(cGIPath)BuyerSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=fromBuyer&amp;fldDesc=analystName&amp;buyerAnalyst=Analyst" onclick="$(searchWinVar)"> $(searchImage) </a><input name="analystName" type="hidden"><input name="Analyst" type="hidden"></td>
                                  <td class="inputnmbr"><input name="toBuyer" value="$(V_N6TO06)" type="text" size="7" maxlength="7"><a href="$(homeURL)$(cGIPath)BuyerSearch.d2w/ENTRY$(genericVarBase)&amp;docName=Chg&amp;fldName=toBuyer&amp;fldDesc=analystName&amp;buyerAnalyst=Analyst" onclick="$(searchWinVar)"> $(searchImage) </a><input name="analystName" type="hidden"><input name="Analyst" type="hidden"></td>
                                  <td class="inputalph"><input name="allBuyer" value='ALL' $(checkedAllBuyer) type="checkbox" onClick="if (this.checked) this.form.fromBuyer.value='', this.form.toBuyer.value='';"></td>
                                  @Build_Sort_Select("sortBuyer", "$(V_N6SQ06)")
                                  <td align=center ><input name="totalBuyer" type="checkbox" $(checkedBuyer) VALUE='Y'></td>
                              </tr>
                              @DspErrMsg(Err_N6FR06)
                              @DspErrMsg(Err_N6TO06)
                              @DspErrMsg(Err_N6AL06)
                              @DspErrMsg(Err_N6SQ06)
                              @DspErrMsg(Err_N6PT06)


                              %if (stockLocActive == "Y" )

                                 @SetTextOvr(Err_N6FR07)
                                 %if (textOvr == "") @SetTextOvr(Err_N6TO07) %endif
                                 %if (textOvr == "") @SetTextOvr(Err_N6AL07) %endif
                                 <tr><td class="dsphdr"><span $(textOvr)>Stockroom</span></td>
                                     <td class="inputalph"><input name="fromStockroom" value="$(V_N6FR07)" type="text" size="5" maxlength="3"><a href="$(homeURL)$(phpPath)StockLocSearch.php$(altVarBase)&amp;docName=Chg&amp;forWhs=@dtw_rurlescseq(warehouseNumber)&amp;fldStkr=fromStockroom&amp;fldAisle=fromAisle&amp;fldLoc=fromLocation&amp;fldStkID=stockLocId" onclick="$(searchWinVar)"> $(searchImage) </a><input name="stockLocId" type="hidden"></td>
                                     <td class="inputalph"><input name="toStockroom" value="$(V_N6TO07)" type="text" size="5" maxlength="3"><a href="$(homeURL)$(phpPath)StockLocSearch.php$(altVarBase)&amp;docName=Chg&amp;forWhs=@dtw_rurlescseq(warehouseNumber)&amp;fldStkr=toStockroom&amp;fldAisle=toAisle&amp;fldLoc=toLocation&amp;fldStkID=stockLocId" onclick="$(searchWinVar)"> $(searchImage) </a></td>
                                     <td class="inputalph"><input name="allStockroom" value='ALL' $(checkedAllStockroom) type="checkbox" onClick="if (this.checked) this.form.fromStockroom.value='', this.form.toStockroom.value='';"></td>
                                 </tr>
                                 @DspErrMsg(Err_N6FR07)
                                 @DspErrMsg(Err_N6TO07)
                                 @DspErrMsg(Err_N6AL07)

                                 @SetTextOvr(Err_N6FR08)
                                 %if (textOvr == "") @SetTextOvr(Err_N6TO08) %endif
                                 %if (textOvr == "") @SetTextOvr(Err_N6AL08) %endif
                                 <tr><td class="dsphdr"><span $(textOvr)>Aisle</span></td>
                                     <td class="inputalph"><input name="fromAisle" value="$(V_N6FR08)" type="text" size="6" maxlength="4"><a href="$(homeURL)$(phpPath)StockLocSearch.php$(altVarBase)&amp;docName=Chg&amp;forWhs=@dtw_rurlescseq(warehouseNumber)&amp;fldStkr=fromStockroom&amp;fldAisle=fromAisle&amp;fldLoc=fromLocation&amp;fldStkID=stockLocId" onclick="$(searchWinVar)"> $(searchImage) </a><input name="stockLocId" type="hidden"></td>
                                     <td class="inputalph"><input name="toAisle" value="$(V_N6TO08)" type="text" size="6" maxlength="4"><a href="$(homeURL)$(phpPath)StockLocSearch.php$(altVarBase)&amp;docName=Chg&amp;forWhs=@dtw_rurlescseq(warehouseNumber)&amp;fldStkr=toStockroom&amp;fldAisle=toAisle&amp;fldLoc=toLocation&amp;fldStkID=stockLocId" onclick="$(searchWinVar)"> $(searchImage) </a></td>
                                     <td class="inputalph"><input name="allAisle" value='ALL' $(checkedAllAisle) type="checkbox" onClick="if (this.checked) this.form.fromAisle.value='', this.form.toAisle.value='';"></td>
                                 </tr>
                                 @DspErrMsg(Err_N6FR08)
                                 @DspErrMsg(Err_N6TO08)
                                 @DspErrMsg(Err_N6AL08)

                                 @SetTextOvr(Err_N6FR09)
                                 %if (textOvr == "") @SetTextOvr(Err_N6TO09) %endif
                                 %if (textOvr == "") @SetTextOvr(Err_N6AL09) %endif
                                 <tr><td class="dsphdr"><span $(textOvr)>Location</span></td>
                                     <td class="inputalph"><input name="fromLocation" value="$(V_N6FR09)" type="text" size="12" maxlength="8"><a href="$(homeURL)$(phpPath)StockLocSearch.php$(altVarBase)&amp;docName=Chg&amp;forWhs=@dtw_rurlescseq(warehouseNumber)&amp;fldStkr=fromStockroom&amp;fldAisle=fromAisle&amp;fldLoc=fromLocation&amp;fldStkID=stockLocId" onclick="$(searchWinVar)"> $(searchImage) </a><input name="stockLocId" type="hidden"></td>
                                     <td class="inputalph"><input name="toLocation" value="$(V_N6TO09)" type="text" size="12" maxlength="8"><a href="$(homeURL)$(phpPath)StockLocSearch.php$(altVarBase)&amp;docName=Chg&amp;forWhs=@dtw_rurlescseq(warehouseNumber)&amp;fldStkr=toStockroom&amp;fldAisle=toAisle&amp;fldLoc=toLocation&amp;fldStkID=stockLocId" onclick="$(searchWinVar)"> $(searchImage) </a></td>
                                     <td class="inputalph"><input name="allLocation" value='ALL' $(checkedAllLocation) type="checkbox" onClick="if (this.checked) this.form.fromLocation.value='', this.form.toLocation.value='';"></td>
                                 </tr>
                                 @DspErrMsg(Err_N6FR09)
                                 @DspErrMsg(Err_N6TO09)
                                 @DspErrMsg(Err_N6AL09)

                              %endif
                          </table>

                          @dtw_assign(envProgram, "HIVIVR")
                          @dtw_assign(envPrinter, "QSYSPRT")
                          %INCLUDE "ScheduleJob.icl"
                          %INCLUDE "SubmitScheduleBottom.icl"
                          $(hrTagAttr)
                          %INCLUDE "Copyright.icl"

                          %if (focusField !="")
                              <script TYPE="text/javascript">
                                  document.Chg.$(focusField).focus();
                              </script>
                          %endif
                      </form>
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "Trailer.icl"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_directcall) Validate_Data(INOUT CHAR(64)    profileHandle,
                                        INOUT CHAR(2)     dataBaseID,
                                        INOUT CHAR(1)     submitSchedule,
                                        INOUT CHAR(1)     errFound,
                                        INOUT CHAR(32000) edtVar,            	
                                        INOUT CHAR(32000) errVar)
  {%EXEC {HIVIVS_W.PGM %}
%}

%HTML(REPORT) {
  %INCLUDE "SetLibraryList.icl"
  @Set_SQL()

%}

%HTML(Edit_Data) {
  %INCLUDE "SetLibraryList.icl"
  @dtw_mUPPERCASE(fromItemNumber)
  @dtw_mUPPERCASE(toItemNumber)
  @dtw_mUPPERCASE(allItemNumber)
  @dtw_mUPPERCASE(allWarehouse)
  @dtw_mUPPERCASE(fromProductClass)
  @dtw_mUPPERCASE(toProductClass)
  @dtw_mUPPERCASE(allProductClass)
  @dtw_mUPPERCASE(fromInventoryType)
  @dtw_mUPPERCASE(toInventoryType)
  @dtw_mUPPERCASE(allInventoryType)
  @dtw_mUPPERCASE(fromABCClassCode)
  @dtw_mUPPERCASE(toABCClassCode)
  @dtw_mUPPERCASE(allABCClassCode)
  @dtw_mUPPERCASE(allBuyer)
  %if (stockLocActive == "Y" &&  stockLocations == "02")
      @dtw_mUPPERCASE(fromStockroom)
      @dtw_mUPPERCASE(toStockroom)
      @dtw_mUPPERCASE(allStockroom)
      @dtw_mUPPERCASE(fromAisle)
      @dtw_mUPPERCASE(toAisle)
      @dtw_mUPPERCASE(allAisle)
      @dtw_mUPPERCASE(fromLocation)
      @dtw_mUPPERCASE(toLocation)
      @dtw_mUPPERCASE(allLocation)
  %endif

  @dtw_assign(sortItemNumber,@dtw_rstrip(sortItemNumber))
  @dtw_assign(fromWarehouse,@dtw_rstrip(fromWarehouse))
  @dtw_assign(toWarehouse,@dtw_rstrip(toWarehouse))
  @dtw_assign(sortWarehouse,@dtw_rstrip(sortWarehouse))
  @dtw_assign(sortInventoryType,@dtw_rstrip(sortInventoryType))
  @dtw_assign(sortABCClassCode,@dtw_rstrip(sortABCClassCode))
  @dtw_assign(fromBuyer,@dtw_rstrip(fromBuyer))
  @dtw_assign(toBuyer,@dtw_rstrip(toBuyer))
  @dtw_assign(sortBuyer,@dtw_rstrip(sortBuyer))
  %if (stockLocActive == "Y" &&  stockLocations == "02")
      @dtw_assign(sortStockroom,@dtw_rstrip(sortStockroom))
      @dtw_assign(sortAisle,@dtw_rstrip(sortAisle))
      @dtw_assign(sortLocation,@dtw_rstrip(sortLocation))
  %endif


  %if (allItemNumber != "ALL")
      @dtw_assign(allItemNumber, "")
  %endif
  %if (allWarehouse != "ALL")
      @dtw_assign(allWarehouse, "")
  %endif
  %if (allProductClass != "ALL")
      @dtw_assign(allProductClass, "")
  %endif
  %if (allInventoryType != "ALL")
      @dtw_assign(allInventoryType, "")
  %endif
  %if (allABCClassCode != "ALL")
      @dtw_assign(allABCClassCode, "")
  %endif
  %if (allBuyer != "ALL")
      @dtw_assign(allBuyer, "")
  %endif
  %if (stockLocActive == "Y" &&  stockLocations == "02")
      %if (allStockroom != "ALL")
          @dtw_assign(allStockroom, "")
      %endif
      %if (allAisle != "ALL")
          @dtw_assign(allAisle, "")
      %endif
      %if (allLocation != "ALL")
          @dtw_assign(allLocation, "")
      %endif
  %endif

  %if (totalItemNumber != "Y")
      @dtw_assign(totalItemNumber, "N")
  %endif
  %if (totalWarehouse != "Y")
      @dtw_assign(totalWarehouse, "N")
  %endif
  %if (totalProductClass != "Y")
      @dtw_assign(totalProductClass, "N")
  %endif
  %if (totalInventoryType != "Y")
      @dtw_assign(totalInventoryType, "N")
  %endif
  %if (totalABCClassCode != "Y")
      @dtw_assign(totalABCClassCode, "N")
  %endif
  %if (totalBuyer != "Y")
      @dtw_assign(totalBuyer, "N")
  %endif
  %if (stockLocActive != "Y" && lotActive != "Y" )
      @dtw_assign(stockLocations, "01")
  %endif


  @dtw_assign(edtVar, "")
  @Concat_Field("@@stkl", stockLocActive)
  @Concat_Field("@@ltus", lotActive)
  @Concat_Field("@@sel1", reportUM)
  %if (V_HDPDRL == "0" || (V_HDPDRL > "0" && V_HDTCV == "A"))
     @Concat_Field("@@sel2", costMethod)
  %else
     @Concat_Field("@@set3", costSet)
  %endif
  @Concat_Field("@@sel4", stockLocations)
  @Concat_Field("@@hneg", negativeOH)
  @Concat_Field("@@hpos", positiveOH)
  @Concat_Field("@@hzro", zeroOH)
  @Concat_Field("@@hrcv", inReceiving)
  @Concat_Field("@@fitm", fromItemNumber)
  @Concat_Field("@@titm", toItemNumber)
  @Concat_Field("@@aitm", allItemNumber)
  @Concat_Field("@@sitm", sortItemNumber)
  @Concat_Field("@@pitm", totalItemNumber)
  @Concat_Field("@@fwhs", fromWarehouse)
  @Concat_Field("@@twhs", toWarehouse)
  @Concat_Field("@@awhs", allWarehouse)
  @Concat_Field("@@swhs", sortWarehouse)
  @Concat_Field("@@pwhs", totalWarehouse)
  @Concat_Field("@@fpcl", fromProductClass)
  @Concat_Field("@@tpcl", toProductClass)
  @Concat_Field("@@apcl", allProductClass)
  @Concat_Field("@@spcl", sortProductClass)
  @Concat_Field("@@ppcl", totalProductClass)
  @Concat_Field("@@finv", fromInventoryType)
  @Concat_Field("@@tinv", toInventoryType)
  @Concat_Field("@@ainv", allInventoryType)
  @Concat_Field("@@sinv", sortInventoryType)
  @Concat_Field("@@pinv", totalInventoryType)
  @Concat_Field("@@fabc", fromABCClassCode)
  @Concat_Field("@@tabc", toABCClassCode)
  @Concat_Field("@@aabc", allABCClassCode)
  @Concat_Field("@@sabc", sortABCClassCode)
  @Concat_Field("@@pabc", totalABCClassCode)
  @Concat_Field("@@fbyr", fromBuyer)
  @Concat_Field("@@tbyr", toBuyer)
  @Concat_Field("@@abyr", allBuyer)
  @Concat_Field("@@sbyr", sortBuyer)
  @Concat_Field("@@pbyr", totalBuyer)
  %if (stockLocActive == "Y" &&  stockLocations == "02")
     @Concat_Field("@@fstk", fromStockroom)
     @Concat_Field("@@tstk", toStockroom)
     @Concat_Field("@@astk", allStockroom)
     @Concat_Field("@@fisl", fromAisle)
     @Concat_Field("@@tisl", toAisle)
     @Concat_Field("@@aisl", allAisle)
     @Concat_Field("@@floc", fromLocation)
     @Concat_Field("@@tloc", toLocation)
     @Concat_Field("@@aloc", allLocation)
  %else
     @Concat_Field("@@astk", "ALL")
     @Concat_Field("@@aisl", "ALL")
     @Concat_Field("@@aloc", "ALL")
  %endif

  %INCLUDE "ScheduleJobConcat.icl"    %{ Schedule Entries Values %}

  @dtw_concat(edtVar, "}{", edtVar)

  @Validate_Data(profileHandle, dataBaseID, submitSchedule, errFound, edtVar, errVar)

  %INCLUDE "SubmitScheduleUpdate.icl"
%}