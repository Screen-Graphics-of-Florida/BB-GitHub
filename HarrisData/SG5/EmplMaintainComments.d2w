%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"

%Define {
  page_title              = "Comment Maintenance"
  d2wName                 = "EmplMaintainComments.d2w"
  d2wVarBase              = "$(genericVarBase)$(employeeVarBase)&amp;fromDate=@dtw_rurlescseq(fromDate)&amp;fromSeq=@dtw_rurlescseq(fromSeq)&amp;backHome=@dtw_rurlescseq(backHome)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  DTW_HTML_TABLE          = "YES"
  DTW_PAD_PGM_PARMS       = "YES"
  programName             = "HHREMU"
%}

%MACRO_FUNCTION Display_Comments () {	

  <html>
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
      %if ((sec_02 == "N") || (sec_12 == "N"))
          %INCLUDE "ProgSecurityError.icl"
      %else
          <head>
              %INCLUDE "headcmt.icl"
              <script TYPE="text/javascript">
                  %INCLUDE "CheckEnterChg.icl"
                  %INCLUDE "NoFormValidate.icl"
              </script>
          </head>
          <body $(bodyTagAttr)>
              <!-- Start Of Banner Code -->
              %INCLUDE "$(cmtBanner)"
              <!-- End Of Banner Code -->
              <table $(contentTable)>
                  <tr valign="top">
                      <td>
                          @dtw_assign(comments, "")
                          @dtw_assign(comment, "")
                          %if (cmtSelection != "C")
                              @Get_Empl_Comments(profileHandle, dataBaseID, hrCompany, hrEmployee, fromDate, fromSeq, comment)
                          %endif

                          <table $(contentTable)>
                      	       <colgroup>
                      	           <col width="80%">
                      	           <col width="15%">
                              <tr><td><h1>$(page_title)</h1></td>
                                  <td class="toolbar">
                                      <a href="javascript:check(document.Chg)">$(commentAcceptImage)</a>
                                      <a href="javascript:document.Chg.cmtSelection.value='R'; check(document.Chg)">$(commentResetImage)</a>
                                      <a href="$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;cmtSelection=C">$(commentClearImage)</a>
                                      @dtw_assign(medIcon, "Y")
                                      %INCLUDE "HelpPage.icl"
                                  </td>
                              </tr>
                          </table>

                          <table $(contentTable)>
                              %if (hrEmployee > "0")
                                  @Ret_Format_EmplName(prCompany, prFacility, prEmployee, hrCompany, hrEmployee, "H", F_EmpName)
                                  @Format_Header("Employee", $(F_EmpName), "")
                              %else
                                  @RtvFldDesc("APCOMP=$(hrCompany) and APAPDT=$(fromDate) and APAPSQ=$(fromSeq)", "PEAPPL", "APRNAM", applicantName)
                                  @Format_Header("Applicant", $(applicantName), "")
                              %endif
                          </table>

                          <table $(contentTable)>
                              <form class="formClass" METHOD=POST NAME=Chg ACTION="$(homeURL)$(cGIPath)$(d2wName)/ACCEPT$(d2wVarBase)">
                                  <tr><td><input type="hidden" name="cmtSelection"></td>
                                      <td>
                                          %if ("$(comment)" != "")
                                              <textarea name="comments" ROWS=20 COLS=72 WRAP="hard">$(comment)</textarea>
                                          %else
                                              <textarea name="comments" ROWS=20 COLS=72 WRAP="hard"></textarea>
                                          %endif
                                      </td>
                                  </tr>
                          </table>
                	       <table $(contentTable)>
                              <tr>
                                  <td valign="top">
                                      <a href="javascript:check(document.Chg)">$(commentAcceptImage)</a>
                                      <a href="javascript:document.Chg.cmtSelection.value='R'; check(document.Chg)">$(commentResetImage)</a>
                                      <a href="$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)&amp;cmtSelection=C">$(commentClearImage)</a>
                                      %INCLUDE "HelpPage.icl"
                                  </td>
                              </tr>
                          </table>
                      </td>
                  </tr>
              </table>
              <!-- Start Of Trailer Code -->
              %INCLUDE "$(cmtTrailer)"
              <!-- End Of Trailer Code -->
          </body>
      </html>
  %endif
%}

%FUNCTION(DTW_directcall) Update_Comments (INOUT CHAR(64)     profileHandle,
				      		  CHAR(2)      dataBaseID,
					          DEC(2,0)     hrCompany,
					          DEC(9,0)     hrEmployee,
					          DEC(7,0)     fromDate,
					          DEC(4,0)     fromSeq,
				      		  char(32000)  comments)

{%EXEC {HHRECM_W.PGM %}
%}

%FUNCTION(DTW_directcall) Get_Empl_Comments(INOUT CHAR(64)     profileHandle,
				                   CHAR(2)      dataBaseID,
					           DEC(2,0)     hrCompany,
					           DEC(9,0)     hrEmployee,
					           DEC(7,0)     fromDate,
					           DEC(4,0)     fromSeq,
				                   char(32000)  comment)
{%EXEC {HHRECM_P.PGM %}
%}

%HTML(MAINTAIN) {
  @pgmOptSecurity(profileHandle, dataBaseID, programName, sec_01, sec_02, sec_03, sec_04, sec_05, sec_06, sec_07, sec_08, sec_09, sec_10, sec_11, sec_12, sec_13, sec_14, sec_15)
  %if ((sec_02 == "N") || (sec_12 == "N"))
      %INCLUDE "ProgSecurityError.icl"
  %else
      %INCLUDE "setLibraryList.icl"
      @Display_Comments ()
  %endif
%}

%HTML(ACCEPT) {
  %INCLUDE "setLibraryList.icl"
  %if (cmtSelection == "R")
      <meta http-equiv="refresh" content="0; URL=$(homeURL)$(cGIPath)$(d2wName)/MAINTAIN$(d2wVarBase)">
  %else
      @Update_Comments(profileHandle, dataBaseID, hrCompany, hrEmployee, fromDate, fromSeq, comments)
      @dtw_assign(confMessage, "Confirm Update Of Employee $(hrEmployee) comments")
      <script TYPE="text/javascript">
          opener.location.href=opener.location.href;
          opener.focus();
          window.close();
      </script>
  %endif
%}