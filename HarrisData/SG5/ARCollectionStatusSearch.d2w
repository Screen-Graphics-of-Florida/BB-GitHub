%INCLUDE "$(baseVar)"
%INCLUDE "EditRoutines.icl"
%INCLUDE "ErrorMessage.icl"
%INCLUDE "GenericDirectCallVariables.icl"
%INCLUDE "Menu.icl"
%INCLUDE "NewWindowVariables.icl"
%INCLUDE "VarBase.icl"
%INCLUDE "WildCard.icl"

%Define {	
  page_title              = "Collection Status Search"
  d2wName                 = "ARCollectionStatusSearch.d2w"
  d2wVarBase              = "$(genericVarBase)&amp;docName=@dtw_rurlescseq(docName)&amp;fldName=@dtw_rurlescseq(fldName)&amp;fldDesc=@dtw_rurlescseq(fldDesc)"
  nextPrevVar             = "$(d2wVarBase)"
  wildDftVar              = "ENTRY$(d2wVarBase)"
  DATABASE                = "*LOCAL"
  DTW_DEFAULT_REPORT      = "NO"
  RPT_MAX_ROWS            = "10"
  ROW_NUM                 = "0"
  START_ROW_NUM           = "1"
  dspMaxRows              = "$(dspMaxRowsDft)"
  rowIndexNext            = "1"
  totalPages              = "0"
  docName                 = ""
  fldName                 = ""
  fldDesc                 = ""
  advanceSearch           = "N"
%}
	
%MACRO_FUNCTION Set_URL (INOUT workURL) {
%}

%MACRO_FUNCTION Set_SQL (INOUT stmtSQL) {	
  %INCLUDE "$(docType)"
  <html>
      <head>
          %INCLUDE "$(headInclude)"
          <script TYPE="text/javascript">
              function selectCollectionStatus(collectionStatus, collectionStatusDesc){
                  window.opener.document.$(docName).$(fldName).value = collectionStatus;
                  window.opener.document.$(docName).$(fldDesc).value = collectionStatusDesc;
                  window.opener.document.$(docName).$(fldName).focus();
                  window.close();
              }
              %INCLUDE "CheckEnterSearch.icl"
              %INCLUDE "NoFormValidate.icl"
          </script>
          %INCLUDE "$(genericHead)"
      </head>

      <body $(bodyTagAttr) onKeyPress="checkEnterSearch()">
          <!-- Start Of Banner Code -->
          %INCLUDE "$(searchBanner)"
          <!-- End Of Banner Code -->
          <table $(baseTable)>
              <tr valign="top">
                  <td class="content">
                      %INCLUDE "stmtSQLClear.icl"
                      @dtw_concat(stmtSQL, " Select CSSTCD, CSDESC, ", stmtSQL)
                      @dtw_concat(stmtSQL, " upper(CSDESC) as CSDESCU ", stmtSQL)
                      @dtw_concat(fileSQL, " ARCSTM ", fileSQL)
                      %if (wildCardSearch!="")
                          @dtw_concat(selectSQL, "CSSTCD<>' ' ", selectSQL)
                      %endif
                      %INCLUDE "stmtSQLSelect.icl"
                      @dtw_concat(stmtSQL, " Order By $(orderBy) ", stmtSQL)
                      %INCLUDE "stmtSQLEnd.icl"
                      %INCLUDE "stmtSQLTotalRows.icl"
                      @CollectionStatus_Search(profileHandle, dataBaseID, stmtSQL)
                  </td>
              </tr>
          </table>
          <!-- Start Of Trailer Code -->
          %INCLUDE "$(searchTrailer)"
          <!-- End Of Trailer Code -->
      </body>
  </html>
%}

%FUNCTION(dtw_sql) CollectionStatus_Search (IN  CHAR(64) profileHandle,
				         CHAR(2)   dataBaseID,
                                        CHAR(32000) stmtSQL)
{CALL $(pgmLibrary)HSYSQL_W

  %REPORT{
      %INCLUDE "PageTitle.icl"
      $(searchhrTagAttr)
      <form class="formClass" METHOD=POST NAME="Search" onSubmit="return validate(document.Search)" ACTION="$(homeURL)$(cGIPath)$(d2wName)/WILDCARD$(d2wVarBase)$(orderByVarBase)&amp;wildCardSearch=">
          <table $(quickSearchTable)>
              <tr><th class="colhdr">Description</th>
                  <th class="colhdr">Collection<br>Status</th>
              </tr>
              <tr><td class="inputalph">
                      <input type="text" name="srchDesc" size="30" maxlength="30">
                      <input type="hidden" name="operDesc" value="LIKE">
                  </td>
                  <td class="inputalph">
                      <input type="text" name="srchStatus" size="3" maxlength="3">
                      <input type="hidden" name="operStatus" value="LIKE">
                  </td>
                  <td><a href="javascript:check(document.Search)">$(goSearchImage)</a></td>
              </tr>
          </table>
          <script TYPE="text/javascript">
              document.Search.srchDesc.focus();
          </script>
      </form>

      %INCLUDE "WildCardPage.icl"

      <table $(contentTable)>
          <tr>	
              @dtw_assign(orderByVar, "$(d2wVarBase)$(searchVarBase)")
              @OrderBy_Sort("CSDESCU", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=description" title="Sequence By Description, Collection Status">Description</a></th>
              @OrderBy_Sort("CSSTCD", sortVar)
              <th class="colhdr$(sortVar)"><a href="$(homeURL)$(cGIPath)$(d2wName)/ORDERBY$(orderByVar)&amp;sequence=collectionStatus" title="Sequence By Collection Status">Collection<br>Status</a></th>
          </tr>
          %INCLUDE "NoRecordsFound.icl"

          %ROW{
              @Format_Quote(V_CSSTCD, F_CSSTCD)
              @Format_Quote(V_CSDESC, F_CSDESC)
              %INCLUDE "SetRowClass.icl"

              <tr class="$(rowClass)">
                  <td class="colalph"><a href="javascript:selectCollectionStatus('$(F_CSSTCD)','$(F_CSDESC)')" title="Select Collection Status">$(V_CSDESC)</a></td>
                  <td class="colcode">$(V_CSSTCD)</td>
              </tr>
          %}
      </table>
      %INCLUDE "PageBottom.icl"
      %INCLUDE "WildCardPrint.icl"
      $(searchhrTagAttr)
      %INCLUDE "Copyright.icl"
  %}
%}

%HTML(ENTRY) {
  %INCLUDE "setLibraryList.icl"
  %INCLUDE "WebReg.icl"
  %if (orderBy == "")
      @DTW_ASSIGN(orderBy, "CSDESCU,CSSTCD")
      @DTW_ASSIGN(orderByDisplay, "Description, Collection Status")
      @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  %endif
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Set_SQL(stmtSQL)
%}

%HTML(INPUT) {
  %INCLUDE "setLibraryList.icl"
  @Retrieve_WebReg(webRegCurFile, profileHandle, d2wName, wildCardSearch, orderBy, orderByDisplay, wildCardDisplay)
  @Set_SQL(stmtSQL)
%}

%HTML(ORDERBY) {
  %INCLUDE "setLibraryList.icl"
  %if (sequence == "description")
      %if (orderBy == "CSDESCU,CSSTCD")
          @DTW_ASSIGN(orderBy, "CSDESCU DESC,CSSTCD")
          @DTW_ASSIGN(orderByDisplay, "Description (descending), Collection Status")
      %else
          @DTW_ASSIGN(orderBy, "CSDESCU,CSSTCD")
          @DTW_ASSIGN(orderByDisplay, "Description, Collection Status")
      %endif
  %elseif (sequence == "collectionStatus")
      %if (orderBy == "CSSTCD")
          @DTW_ASSIGN(orderBy, "CSSTCD DESC")
          @DTW_ASSIGN(orderByDisplay, "Collection Status (descending)")
      %else
          @DTW_ASSIGN(orderBy, "CSSTCD")
          @DTW_ASSIGN(orderByDisplay, "Collection Status")
      %endif
  %endif
		
  @DTW_ASSIGN(RPT_MAX_ROWS, dspMaxRows)
  @Save_WebReg_OrderBy(webRegCurFile, profileHandle, d2wName, orderBy, orderByDisplay)
  @Set_SQL(stmtSQL)
%}
		
%HTML(WILDCARD) {
  %INCLUDE "setLibraryList.icl"
  @dtw_assign(wildCardTemp, "")
  @dtw_assign(wildDisplayTemp, "")

  @Build_WildCard ("upper(CSDESC)", "Description", $(srchDesc), "U", operDesc, "A")
  @Build_WildCard ("CSSTCD", "Collection Status", $(srchStatus), "U", operStatus, "A")

  @dtw_assign(masterSearchVar, "$(homeURL)$(cGIPath)$(d2wName)/MASTERSEARCH$(d2wVarBase)")
  %INCLUDE "WildCardUpdate.icl"
%}